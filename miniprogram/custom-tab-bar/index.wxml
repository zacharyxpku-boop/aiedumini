<view class="yd-tabbar">
  <view
    class="yd-tab-item {{selected === 0 ? 'active' : ''}}"
    data-index="0"
    data-path="/pages/home/home"
    bindtap="switchTab"
  >
    <view class="yd-tab-icon-wrap"><view class="yd-tab-icon home"></view></view>
    <view class="yd-tab-text">今天</view>
  </view>
  <view
    class="yd-tab-item {{selected === 1 ? 'active' : ''}}"
    data-index="1"
    data-path="/pages/tutor/tutor"
    bindtap="switchTab"
  >
    <view class="yd-tab-icon-wrap"><view class="yd-tab-icon tutor"></view></view>
    <view class="yd-tab-text">原小点</view>
  </view>
  <view
    class="yd-tab-item {{selected === 2 ? 'active' : ''}}"
    data-index="2"
    data-path="/pages/arcade/arcade"
    bindtap="switchTab"
  >
    <view class="yd-tab-icon-wrap"><view class="yd-tab-icon island"></view></view>
    <view class="yd-tab-text">复习岛</view>
  </view>
  <view
    class="yd-tab-item {{selected === 3 ? 'active' : ''}}"
    data-index="3"
    data-path="/pages/profile/profile"
    bindtap="switchTab"
  >
    <view class="yd-tab-icon-wrap"><view class="yd-tab-icon parent"></view></view>
    <view class="yd-tab-text">家长</view>
  </view>
  <view
    class="yd-tab-item {{selected === 4 ? 'active' : ''}}"
    data-index="4"
    data-path="/pages/upload/upload"
    bindtap="switchTab"
  >
    <view class="yd-tab-icon-wrap"><view class="yd-tab-icon upload"></view></view>
    <view class="yd-tab-text">上传</view>
  </view>
</view>
