  grid-template-columns: 1fr 1.3fr;
  gap: 18rpx;
  margin-top: 18rpx;
}

.ux-kit-progress-row view {
  min-height: 58rpx;
  padding: 0 18rpx;
  border: 1rpx solid #f0dfbd;
  border-radius: 999rpx;
  color: #6b5a37;
  background: #fff6df;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.ux-kit-progress-row text {
  color: #e39a26;
  font-size: 34rpx;
  font-weight: 950;
}

.ux-kit-progress {
  height: 13rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ede8de;
}

.ux-kit-progress view {
  width: 34%;
  height: 100%;
  border-radius: 999rpx;
  background: #50b36b;
}

.ux-kit-quiz-card {
  min-height: 286rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #ede3d2;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.86)),
    radial-gradient(circle at 88% 88%, rgba(160, 197, 213, .36), transparent 34%);
  box-shadow: 0 14rpx 28rpx rgba(84, 59, 28, .065);
}

.ux-kit-quiz-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #1d764b;
  background: #e7f6e5;
  font-size: 22rpx;
  font-weight: 950;
}

.ux-kit-quiz-title {
  margin-top: 52rpx;
  color: #141a16;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.34;
  text-align: center;
}

.ux-kit-choice-scale {
  display: grid;
  grid-template-columns: 70rpx repeat(4, 1fr) 70rpx;
  gap: 20rpx;
  align-items: center;
  margin-top: 38rpx;
  color: #15724d;
  font-size: 23rpx;
  font-weight: 950;
}

.ux-kit-choice-scale text:not(:first-child):not(:last-child) {
  width: 22rpx;
  height: 22rpx;
  justify-self: center;
  border: 2rpx solid #d4d8d2;
  border-radius: 50%;
}

.ux-kit-choice-scale text:nth-child(2) {
  background: #50b36b;
  border-color: #50b36b;
}

.ux-kit-parent-card {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #eee2cf;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(84, 59, 28, .055);
}

.ux-kit-parent-card.light {
  background: #fff8e8;
}

.ux-kit-parent-head,
.ux-kit-task-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
}

.ux-kit-parent-head text:first-child {
  color: #1a211d;
  font-size: 27rpx;
  font-weight: 950;
}

.ux-kit-parent-head text:last-child {
  color: #8a7f6f;
  font-size: 21rpx;
  font-weight: 850;
}

.ux-kit-task-row {
  grid-template-columns: 36rpx minmax(0, 1fr) 108rpx;
  padding: 0 0 2rpx;
}

.ux-kit-task-row text:first-child {
  color: #394139;
  font-size: 23rpx;
  font-weight: 950;
}

.ux-kit-task-row text:nth-child(2) {
  color: #202720;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.3;
}

.ux-kit-task-row text:last-child {
  min-height: 38rpx;
  border-radius: 999rpx;
  color: #9c7627;
  background: #fff1ce;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 38rpx;
  text-align: center;
}

.ux-kit-quote {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  color: #4a3820;
  background: #fffdf6;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 1.45;
}

.ux-kit-segment {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: 20rpx;
  padding: 6rpx;
  border: 1rpx solid #eadfcd;
  border-radius: 999rpx;
  background: #fffef8;
}

.ux-kit-segment text {
  min-height: 58rpx;
  border-radius: 999rpx;
  color: #5f665f;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 58rpx;
  text-align: center;
}

.ux-kit-segment text:first-child {
  color: #ffffff;
  background: #10533f;
}

.ux-kit-upload-box {
  min-height: 188rpx;
  justify-items: center;
  align-content: center;
  border-style: dashed;
  background: #fffdfa;
}

.ux-kit-upload-icon {
  color: #c4bcae;
  font-size: 66rpx;
  line-height: 1;
}

.ux-kit-upload-box view:nth-child(2) {
  margin-top: 12rpx;
  color: #5b5b54;
  font-size: 27rpx;
  font-weight: 950;
}

.ux-kit-upload-box text {
  margin-top: 10rpx;
  color: #8a857b;
  font-size: 21rpx;
  font-weight: 760;
}

.ux-kit-safe-line {
  margin-top: 14rpx;
  color: #7d776c;
  font-size: 20rpx;
  font-weight: 760;
  text-align: center;
}

.ux-kit-output-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.ux-kit-output-grid view {
  min-height: 94rpx;
  padding: 16rpx;
  border: 1rpx solid #eee4d4;
  border-radius: 20rpx;
  background: #ffffff;
}

.ux-kit-output-grid text {
  display: block;
}

.ux-kit-output-grid text:first-child {
  color: #203a30;
  font-size: 25rpx;
  font-weight: 950;
}

.ux-kit-output-grid text:last-child {
  margin-top: 10rpx;
  color: #70776f;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1.35;
}

/*
 * Main tab contract: the first tab viewport is an entry screen, not a long
 * report. Detailed legacy panels stay in code for current tests and later
 * subpage extraction, but they do not render under the five primary tab
 * launch screens.
 */
.ux-kit-screen ~ view,
.ux-kit-screen ~ button,
.ux-kit-screen ~ form,
.ux-kit-screen ~ scroll-view,
.ux-kit-screen ~ swiper {
  display: none !important;
}

.ux-kit-screen ~ .ux-kit-subcheck {
  display: grid !important;
}

.ux-kit-subcheck {
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
  margin: 0 34rpx 20rpx;
}

.main-inner > .ux-kit-subcheck,
.profile-shell > .ux-kit-subcheck,
.upload-content > .ux-kit-subcheck {
  margin-right: 0;
  margin-left: 0;
}

.subcheck-main,
.subcheck-side > view {
  min-width: 0;
  border: 1rpx solid rgba(27, 67, 50, 0.12);
  border-radius: 26rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(27, 67, 50, 0.055);
}

.subcheck-main {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 116rpx;
  gap: 16rpx;
  align-items: center;
  min-height: 142rpx;
  padding: 18rpx 20rpx;
  background:
    radial-gradient(circle at 92% 18%, rgba(248, 198, 34, 0.26), transparent 34%),
    linear-gradient(145deg, #ffffff 0%, #f0fbef 100%);
}

.subcheck-copy {
  min-width: 0;
}

.subcheck-art {
  width: 116rpx;
  height: 104rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 12rpx 24rpx rgba(34, 85, 54, 0.10);
}

.subcheck-main text,
.subcheck-side text {
  display: block;
  max-width: 100%;
  overflow: hidden;
}

.subcheck-main text:first-child {
  color: #13251c;
  font-size: 27rpx;
  font-weight: 1000;
  line-height: 1.16;
}

.subcheck-main text:last-child {
  display: -webkit-box;
  margin-top: 8rpx;
  color: #59685f;
  font-size: 20rpx;
  font-weight: 780;
  line-height: 1.36;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.subcheck-side {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.subcheck-side > view {
  min-height: 76rpx;
  padding: 13rpx 14rpx;
  background: rgba(255, 255, 255, 0.92);
}

.subcheck-side > view:first-child {
  background: #fff8dd;
}

.subcheck-side text:first-child {
  color: #174c3d;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1.18;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.subcheck-side text:last-child {
  display: -webkit-box;
  margin-top: 6rpx;
  color: #68756d;
  font-size: 17rpx;
  font-weight: 760;
  line-height: 1.28;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
