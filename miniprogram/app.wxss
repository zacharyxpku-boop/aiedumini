page {
  min-height: 100vh;
  color: #10231c;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 242, 215, 0.92) 0%, rgba(255, 242, 215, 0) 520rpx),
    #fbf4e8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker,
canvas,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  color: inherit;
  line-height: 1.2;
  background: transparent;
  border: 0;
  border-radius: 0;
  font: inherit;
  transition: opacity 120ms ease, transform 120ms ease;
}

button:active {
  opacity: 0.86;
  transform: scale(0.985);
}

button::after {
  border: 0;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
}

.safe-bottom {
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
}

.v1-page,
.v1-shell {
  position: relative;
  min-height: 100vh;
}

.v1-brand {
  display: flex;
  align-items: center;
}

.v1-brand {
  min-width: 0;
  gap: 14rpx;
}

.v1-logo {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  background: #0c4a3b;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 18rpx rgba(12, 74, 59, 0.16);
}

.v1-logo::before {
  content: "";
  position: absolute;
  inset: 13rpx;
  background: #ffd96b;
  border-radius: 50%;
}

.v1-logo-core::before,
.v1-logo-core::after {
  content: "";
  position: absolute;
  top: 23rpx;
  z-index: 1;
  width: 5rpx;
  height: 5rpx;
  background: #0c4a3b;
  border-radius: 50%;
}

.v1-logo-core::before { left: 20rpx; }
.v1-logo-core::after { right: 20rpx; }

.v1-brand-copy {
  min-width: 0;
}

.v1-brand-name {
  color: #10231c;
  font-size: 34rpx;
  font-weight: 1000;
  line-height: 1.02;
}

.v1-brand-sub {
  max-width: 340rpx;
  margin-top: 4rpx;
  color: #6b665d;
  font-size: 20rpx;
  font-weight: 760;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.v1-pill {
  min-height: 48rpx;
  padding: 0 22rpx;
  flex: 0 0 auto;
  color: #705020;
  background: rgba(255, 253, 248, 0.88);
  border: 1rpx solid #eadbc3;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.v1-card,
.panel,
.panel-quiet,
.mini-card {
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid #eadfce;
  border-radius: 26rpx;
  box-shadow: 0 14rpx 30rpx rgba(65, 48, 28, 0.065);
}

.v1-card,
.panel,
.panel-quiet {
  padding: 22rpx;
}

.panel-quiet {
  background: #fbf4e8;
}

.v1-section-title,
.title-md {
  color: #10231c;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.2;
}

.v1-section-subtitle,
.muted {
  margin-top: 8rpx;
  color: #6b6257;
  font-size: 22rpx;
  font-weight: 740;
  line-height: 1.5;
}

.title-xl {
  color: #10231c;
  font-size: 54rpx;
  font-weight: 1000;
  line-height: 1.04;
  letter-spacing: 0;
}

.title-lg {
  color: #10231c;
  font-size: 38rpx;
  font-weight: 950;
  line-height: 1.14;
}

.body {
  color: #514c44;
  font-size: 25rpx;
  font-weight: 760;
  line-height: 1.55;
}

.eyebrow,
.v1-secondary-chip {
  display: inline-flex;
  min-height: 42rpx;
  align-items: center;
  padding: 0 16rpx;
  color: #0c4a3b;
  background: #eaf5ee;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.v1-primary,
.v1-secondary,
.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  min-height: 84rpx;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 27rpx;
  font-weight: 950;
  line-height: 1.1;
}

.v1-primary,
.primary-button {
  color: #fffdf8;
  background: linear-gradient(180deg, #155746 0%, #0c4a3b 100%);
  box-shadow: 0 16rpx 28rpx rgba(12, 74, 59, 0.18);
}

.v1-secondary,
.secondary-button,
.ghost-button {
  color: #0c4a3b;
  background: rgba(255, 253, 248, 0.92);
  border: 1rpx solid #e5d8c3;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  color: #423d36;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker-box {
  width: 100%;
  min-height: 80rpx;
  padding: 20rpx 22rpx;
  color: #10231c;
  background: #fffdf8;
  border: 1rpx solid #e5d8c3;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 760;
}

.textarea {
  min-height: 180rpx;
  line-height: 1.55;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section {
  margin-top: 20rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.bar {
  width: 100%;
  height: 12rpx;
  overflow: hidden;
  background: #eee7dc;
  border-radius: 999rpx;
}

.bar-fill {
  height: 100%;
  background: #4da66b;
  border-radius: 999rpx;
}

.divider {
  height: 1rpx;
  margin: 20rpx 0;
  background: #eadfce;
}

.v1-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.v1-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  color: #0c4a3b;
  background: #fffdf8;
  border: 1rpx solid #e5d8c3;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.positioning-kicker {
  color: #587064;
  font-size: 22rpx;
  font-weight: 800;
}

.positioning-title {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.positioning-flow {
  margin-top: 8rpx;
  color: #56665f;
  font-size: 24rpx;
  line-height: 1.55;
}

.positioning-actions,
.upload-flow-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.positioning-actions button,
.upload-flow-actions button {
  min-height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  color: #17342b;
  background: #fffaf0;
  border: 1rpx solid #e2cfad;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.ux-entry {
  position: relative;
  margin: 20rpx 24rpx 24rpx;
  padding: 34rpx 30rpx 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 96, 73, 0.1);
  border-radius: 36rpx;
  background: #FFFDF6;
  box-shadow: 0 18rpx 40rpx rgba(64, 53, 28, 0.08);
  box-sizing: border-box;
}

.ux-entry::before {
  content: "";
  position: absolute;
  right: -76rpx;
  top: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(244, 182, 63, 0.16);
}

.ux-entry::after {
  content: "";
  position: absolute;
  left: -58rpx;
  bottom: -74rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(82, 150, 111, 0.12);
}

.ux-entry-copy,
.ux-entry > .ux-kicker,
.ux-entry > .ux-title,
.ux-entry > .ux-subtitle,
.ux-mascot-card,
.ux-primary-button,
.ux-jump-row,
.ux-board,
.ux-island-map,
.ux-evidence-strip,
.ux-material-grid {
  position: relative;
  z-index: 1;
}

.ux-kicker {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #0F4F3D;
  background: #ECF6E8;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.ux-title {
  margin-top: 18rpx;
  color: #113F33;
  font-size: 46rpx;
  font-weight: 950;
  line-height: 1.12;
  letter-spacing: 0;
}

.ux-subtitle {
  max-width: 520rpx;
  margin-top: 14rpx;
  color: #635A4D;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.55;
}

.ux-primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  color: #173B2D;
  background: #F4B63F;
  box-shadow: 0 12rpx 22rpx rgba(183, 122, 20, 0.18);
  font-size: 29rpx;
  font-weight: 950;
}

.ux-jump-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.ux-jump-row.compact {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.ux-jump {
  min-height: 96rpx;
  padding: 16rpx 10rpx;
  border-radius: 24rpx;
  color: #19473A;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(30, 82, 61, 0.08);
  box-sizing: border-box;
}

.ux-jump text {
  display: block;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ux-jump text:first-child {
  font-size: 25rpx;
  font-weight: 950;
}

.ux-jump text:last-child {
  margin-top: 8rpx;
  color: #7D735F;
  font-size: 20rpx;
  font-weight: 800;
}

.ux-mascot-card {
  display: flex;
  justify-content: center;
  margin: 22rpx 0 6rpx;
}

.ux-mascot {
  position: relative;
  width: 180rpx;
  height: 160rpx;
}

.ux-ear {
  position: absolute;
  top: 8rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx 16rpx 6rpx;
  background: #2F7B5F;
}

.ux-ear.left {
  left: 26rpx;
  transform: rotate(-25deg);
}

.ux-ear.right {
  right: 26rpx;
  transform: rotate(25deg);
}

.ux-face {
  position: absolute;
  left: 25rpx;
  top: 34rpx;
  width: 130rpx;
  height: 112rpx;
  border-radius: 48rpx 48rpx 42rpx 42rpx;
  background: #2F7B5F;
  box-shadow: inset 0 -10rpx 0 rgba(0, 0, 0, 0.08);
}

.ux-eye {
  position: absolute;
  top: 42rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FFFDF6;
}

.ux-eye.left {
  left: 34rpx;
}

.ux-eye.right {
  right: 34rpx;
}

.ux-smile {
  position: absolute;
  left: 52rpx;
  top: 68rpx;
  width: 26rpx;
  height: 13rpx;
  border-bottom: 4rpx solid #FFFDF6;
  border-radius: 0 0 20rpx 20rpx;
}

.ux-scarf {
  position: absolute;
  left: 54rpx;
  bottom: 0;
  width: 72rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: #F4B63F;
}

.ux-board {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  color: #245042;
  background: #F7FBF1;
  box-shadow: inset 0 0 0 1rpx rgba(34, 82, 60, 0.08);
}

.ux-board-line {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.65;
}

.ux-board-line.strong {
  color: #123F32;
  font-size: 30rpx;
  font-weight: 950;
}

.ux-island-map {
  display: grid;
  grid-template-columns: 1fr 38rpx 1fr 38rpx 1fr;
  align-items: center;
  gap: 8rpx;
  margin-top: 26rpx;
}

.ux-map-node {
  display: flex;
  min-height: 108rpx;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
  border-radius: 28rpx;
  color: #255244;
  background: #FFFFFF;
  box-shadow: 0 10rpx 20rpx rgba(44, 86, 63, 0.08);
  font-size: 23rpx;
  font-weight: 950;
  text-align: center;
}

.ux-map-node.active {
  color: #143B2E;
  background: #F4B63F;
}

.ux-map-node.done {
  background: #E8F5E6;
}

.ux-map-path {
  height: 6rpx;
  border-radius: 999rpx;
  background: #BFD7C8;
}

.ux-evidence-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.ux-evidence-item {
  min-height: 100rpx;
  padding: 14rpx 10rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 20rpx rgba(44, 86, 63, 0.08);
  box-sizing: border-box;
}

.ux-evidence-item text {
  display: block;
  text-align: center;
}

.ux-evidence-item text:first-child {
  color: #113F33;
  font-size: 24rpx;
  font-weight: 950;
}

.ux-evidence-item text:last-child {
  margin-top: 8rpx;
  color: #7D735F;
  font-size: 20rpx;
  font-weight: 800;
}

.ux-material-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.ux-material-card {
  min-height: 126rpx;
  padding: 18rpx 14rpx;
  border: 0;
  border-radius: 26rpx;
  color: #1A4537;
  background: #FFFFFF;
  box-shadow: 0 10rpx 20rpx rgba(44, 86, 63, 0.08);
  line-height: 1.2;
  text-align: left;
}

.ux-material-card::after {
  border: 0;
}

.ux-material-card text {
  display: block;
}

.ux-material-card text:first-child {
  font-size: 27rpx;
  font-weight: 950;
}

.ux-material-card text:last-child {
  margin-top: 10rpx;
  color: #7D735F;
  font-size: 21rpx;
  font-weight: 800;
}

.global-depth-card {
  display: grid;
  gap: 12rpx;
  margin: 20rpx 24rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 248, 0.94);
  border: 1rpx solid rgba(229, 216, 195, 0.95);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.global-depth-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.global-depth-title {
  color: #17342b;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.25;
}

.global-depth-summary,
.global-depth-next,
.global-depth-note {
  color: #56665f;
  font-size: 22rpx;
  line-height: 1.45;
}

.global-depth-score {
  flex: 0 0 auto;
  color: #0f6b50;
  font-size: 22rpx;
  font-weight: 950;
}

.global-depth-next {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #fff7e1;
  color: #17342b;
  font-weight: 850;
}

.global-depth-grid {
  display: grid;
  gap: 10rpx;
}

.global-depth-chip {
  display: grid;
  gap: 4rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(229, 216, 195, 0.8);
}

.global-depth-chip.ready {
  background: #ecfdf5;
  border-color: #bbf7d0;
}

.global-depth-chip-title {
  color: #17342b;
  font-size: 21rpx;
  font-weight: 900;
}

.global-depth-chip-line {
  color: #69736e;
  font-size: 19rpx;
  line-height: 1.35;
}

/* Five-entry launch screens: compact, visual, and jump-first. */
.ux-stage-screen {
  min-height: 900rpx;
  margin: 16rpx 22rpx 26rpx;
  padding: 28rpx 28rpx 30rpx;
  border: 0;
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 231, 155, 0.78), transparent 28%),
    radial-gradient(circle at 88% 30%, rgba(162, 214, 149, 0.34), transparent 30%),
    linear-gradient(180deg, #fff7df 0%, #fffdf6 62%, #f2fbec 100%);
  box-shadow: 0 20rpx 46rpx rgba(47, 71, 50, 0.12);
}

.ux-stage-screen::before,
.ux-stage-screen::after {
  display: none;
}

.ux-brand-row,
.ux-title-stack,
.ux-hero-scene,
.ux-main-card,
.ux-report-scene,
.ux-upload-scene,
.ux-prize-strip,
.ux-choice-row,
.ux-status-strip {
  position: relative;
  z-index: 1;
}

.ux-brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.ux-brand-mark {
  color: #184333;
  font-size: 27rpx;
  font-weight: 950;
}

.ux-mini-badge {
  min-width: 118rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #295646;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: inset 0 0 0 1rpx rgba(38, 87, 64, 0.08);
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
}

.ux-title-stack {
  display: grid;
  justify-items: flex-start;
  gap: 10rpx;
}

.ux-stage-screen .ux-kicker {
  height: auto;
  padding: 0;
  color: #0f4f3d;
  background: transparent;
  font-size: 32rpx;
  line-height: 1;
}

.ux-stage-screen .ux-title {
  max-width: 560rpx;
  margin: 0;
  color: #113f33;
  font-size: 54rpx;
  line-height: 1.08;
}

.ux-underline {
  width: 132rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #f4b63f;
  transform: rotate(-2deg);
}

.ux-hero-scene,
.ux-upload-scene {
  display: grid;
  grid-template-columns: 1fr 240rpx;
  align-items: center;
  min-height: 270rpx;
  margin-top: 18rpx;
}

.ux-speech-card {
  position: relative;
  display: grid;
  gap: 8rpx;
  padding: 24rpx 28rpx;
  border: 4rpx solid #1f4d3c;
  border-radius: 32rpx;
  color: #163f31;
  background: #fffef8;
  box-shadow: 0 14rpx 26rpx rgba(55, 72, 50, 0.1);
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.28;
}

.ux-speech-card::after {
  content: "";
  position: absolute;
  right: -18rpx;
  bottom: 34rpx;
  width: 34rpx;
  height: 34rpx;
  border-top: 4rpx solid #1f4d3c;
  border-right: 4rpx solid #1f4d3c;
  background: #fffef8;
  transform: rotate(45deg);
}

.ux-mascot-card.big,
.ux-mascot-card.upload {
  margin: 0;
}

.ux-mascot-card.big .ux-mascot {
  width: 230rpx;
  height: 228rpx;
}

.ux-mascot.mini {
  width: 132rpx;
  height: 126rpx;
}

.ux-stage-screen .ux-ear {
  background: #287254;
  box-shadow: inset -8rpx -8rpx 0 rgba(0, 0, 0, 0.08);
}

.ux-stage-screen .ux-face {
  background: #2f8a63;
  box-shadow: inset 0 -12rpx 0 rgba(0, 0, 0, 0.08);
}

.ux-stage-screen .ux-glasses {
  position: absolute;
  left: 45rpx;
  top: 74rpx;
  z-index: 3;
  width: 90rpx;
  height: 34rpx;
  border-left: 5rpx solid #143c30;
  border-right: 5rpx solid #143c30;
  border-radius: 999rpx;
  box-shadow: inset 0 0 0 5rpx rgba(255, 255, 255, 0.42);
}

.ux-mascot.mini .ux-glasses {
  left: 28rpx;
  top: 54rpx;
  width: 70rpx;
  height: 26rpx;
  border-width: 4rpx;
}

.ux-mascot.mini .ux-face {
  left: 18rpx;
  top: 26rpx;
  width: 96rpx;
  height: 84rpx;
  border-radius: 36rpx;
}

.ux-mascot.mini .ux-ear {
  top: 4rpx;
  width: 42rpx;
  height: 42rpx;
}

.ux-mascot.mini .ux-ear.left {
  left: 18rpx;
}

.ux-mascot.mini .ux-ear.right {
  right: 18rpx;
}

.ux-mascot.mini .ux-eye {
  top: 31rpx;
}

.ux-mascot.mini .ux-scarf {
  left: 40rpx;
  width: 54rpx;
}

