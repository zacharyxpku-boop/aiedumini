<view class="page arcade-page safe-bottom">
  <view class="page-positioning arcade-positioning">
    <view class="positioning-kicker">游戏化轻练习</view>
    <view class="positioning-title">玩一小局，错的卡回到复习队列</view>
    <view class="positioning-flow">游戏负责让孩子愿意再练一下；错题和模糊点会回到修卡点，不做排行。</view>
  </view>
  <view class="arcade-topbar">
    <button class="nav-back" bindtap="goBack">‹</button>
    <view class="nav-title">轻练习</view>
    <button class="nav-home" bindtap="goHome">首页</button>
  </view>

  <scroll-view class="arcade-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="arcade-hero">
      <view class="hero-art">
        <view class="hero-orbit">
          <view class="hero-core"></view>
          <view class="hero-dot one"></view>
          <view class="hero-dot two"></view>
          <view class="hero-dot three"></view>
        </view>
      </view>
      <view class="hero-kicker">学科 × 知识类型 × 游戏类型</view>
      <view class="hero-title">今天把知识打一小关</view>
      <view class="hero-copy">不是把复习换皮，而是让短回忆、概念和步骤各自进入最合适的玩法。</view>
      <view class="hero-stats">
        <view class="hero-stat">
          <view class="hero-stat-num">{{cards.length || 0}}</view>
          <view class="hero-stat-label">可用卡片</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat-num">{{round.total || 0}}</view>
          <view class="hero-stat-label">本局题数</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat-num">{{score || 0}}</view>
          <view class="hero-stat-label">本局得分</view>
        </view>
      </view>
    </view>

    <view class="challenge-brief-card" wx:if="{{challengeBrief}}">
      <view class="challenge-brief-top">
        <view>
          <view class="challenge-brief-kicker">本局目标</view>
          <view class="challenge-brief-title">{{challengeBrief.modeLabel}}</view>
        </view>
        <view class="challenge-brief-pill">{{challengeBrief.roundSize}} 题 · {{challengeBrief.targetAccuracy}}%</view>
      </view>
      <view class="challenge-brief-line">{{challengeBrief.questTitle}} · {{challengeBrief.questProgress}}</view>
      <view class="challenge-brief-sub">{{challengeBrief.bossLine}}</view>
      <view class="challenge-brief-sub">{{challengeBrief.rewardLine}}</view>
      <view class="story-mission" wx:if="{{challengeBrief.storyTitle}}">
        <view class="story-mission-title">{{challengeBrief.storyTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.storyLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.storyRule}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.subjectDepthLine}}">
        <view class="story-mission-title">{{challengeBrief.subjectDepthLabel}}</view>
        <view class="story-mission-line">题型第一步：{{challengeBrief.subjectDepthLine}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.subjectDepthGameLine}}">本局练：{{challengeBrief.subjectDepthGameLine}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.subjectDepthEvidenceLine}}">留下证据：{{challengeBrief.subjectDepthEvidenceLine}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.curriculumLine}}">
        <view class="story-mission-title">{{challengeBrief.curriculumTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.curriculumLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.curriculumProgression}}" wx:key="id">{{item.order}}. {{item.label}}：{{item.evidence}}</view>
        <view class="story-mission-rule">{{challengeBrief.curriculumScaleLine}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.courseUnitTitle}}">
        <view class="story-mission-title">{{challengeBrief.courseUnitTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.courseUnitLine}}</view>
        <view class="story-mission-rule">错因谱：{{challengeBrief.courseUnitWrongCauseLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionTypes}}" wx:key="*this">本局题型：{{item}}</view>
        <view class="story-mission-rule">{{challengeBrief.courseUnitReportContract}}</view>
        <view class="story-mission-rule">{{challengeBrief.courseUnitShareContract}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.courseUnitPracticeDeckTitle}}">{{challengeBrief.courseUnitPracticeDeckTitle}}：{{challengeBrief.courseUnitPracticeDeckLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitPracticeDeck}}" wx:key="id">{{item.label}} · 掌握度 {{item.masteryScore}} · 风险 {{item.risk}} · {{item.action}} · {{item.nextEvidence}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.courseUnitQuestionBankTitle}}">{{challengeBrief.courseUnitQuestionBankTitle}}：{{challengeBrief.courseUnitQuestionBankLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">题库卡：{{item.label}}｜{{item.prompt}}｜{{item.evidenceRequired}}</view>
      </view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">样例：{{item.sampleStem}}｜第一步：{{item.firstStepHint}}｜近迁移：{{item.nearTransferStem}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">进阶路径：{{item.progression.entryTask}}｜明天：{{item.progression.nextDayRevisit}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">掌握门槛：{{item.progression.masteryGate}}</view>
      <view class="story-mission" wx:if="{{challengeBrief.commercialDepthRunwayTitle}}">
        <view class="story-mission-title">{{challengeBrief.commercialDepthRunwayTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.commercialDepthRunwayLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.commercialDepthRunwayBoundary}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.commercialDepthRunwayLanes}}" wx:key="id">{{item.label}}：{{item.evidenceLine}}｜下一步：{{item.nextAction}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.commercialDepthMemoryCadence}}" wx:key="id">{{item.label}}：{{item.action}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.sevenSubjectMasterySprintTitle}}">
        <view class="story-mission-title">{{challengeBrief.sevenSubjectMasterySprintTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.sevenSubjectMasterySprintLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.sevenSubjectMasterySprintLanes}}" wx:key="id">{{item.label}}：{{item.target}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.sevenSubjectMasterySprintSubjects}}" wx:key="id">{{item.label}}：{{item.memoryGameTarget}}</view>
        <view class="story-mission-rule">{{challengeBrief.sevenSubjectMasterySprintMoat}}</view>
      </view>
      <view class="challenge-brief-sub" wx:if="{{challengeBrief.evidenceBiasLine}}">为什么开这局：{{challengeBrief.evidenceBiasLine}}</view>
    </view>

    <view class="surface-depth-card arcade-surface-depth" wx:if="{{surfaceDepthPack}}">
      <view class="surface-depth-title">{{surfaceDepthPack.title}}</view>
      <view class="surface-depth-subtitle">{{surfaceDepthPack.summary}}</view>
      <view class="surface-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
      <view class="surface-depth-grid">
        <view class="surface-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
          <text class="surface-depth-chip-title">{{item.displayLabel}}</text>
          <text class="surface-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
        </view>
      </view>
      <view class="surface-depth-note">{{surfaceDepthPack.familyLine}}</view>
    </view>

    <view class="arcade-card compact">
      <view class="section-head">
        <view>
          <view class="section-title">推荐玩法</view>
          <view class="section-subtitle">四个精品关卡先露出，更多实验型玩法放到矩阵里。</view>
        </view>
        <button class="ghost-link" bindtap="toggleMatrix">{{expandedMatrix ? '收起' : '展开'}}</button>
      </view>
      <view class="game-reco-row">
        <button
          wx:for="{{visibleRecommendations}}"
          wx:key="id"
          class="game-chip {{item.id === selectedGame ? 'active' : ''}} {{!item.available ? 'disabled' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectGame"
        >
          <text class="game-chip-mascot">{{item.mascot}}</text>
          <text class="game-chip-title">{{item.shortName}}</text>
          <text class="game-chip-meta">{{item.available ? item.readyCount + ' 张可玩' : '先补材料'}}</text>
          <text class="game-chip-pitch">{{item.pitch}}</text>
          <text class="game-chip-lock" wx:if="{{!item.available}}">{{item.lockedReason}}</text>
        </button>
      </view>
    </view>

    <view class="mode-brief" wx:if="{{activeGame}}">
      <view>
        <view class="mode-brief-kicker">当前玩法</view>
        <view class="mode-brief-title">{{activeGame.name}}</view>
      </view>
      <view class="mode-brief-pill">{{activeGame.knowledgeType}}</view>
    </view>

    <view class="play-principle-card" wx:if="{{activeGame && expandedMatrix}}">
      <view class="play-principle-dot">{{activeGame.mascot}}</view>
      <view class="play-principle-copy">
        <view class="play-principle-title">{{activeGame.principleTitle}}</view>
        <view class="play-principle-body">{{activeGame.principleBody}} 答题结果会进入回访记录、错因和间隔复习。</view>
      </view>
    </view>

    <view class="matrix-card" wx:if="{{expandedMatrix}}">
      <view class="matrix-title">知识类型覆盖</view>
      <view class="type-row" wx:for="{{classifications}}" wx:key="id">
        <view class="type-name">{{item.name}}</view>
        <view class="type-count">{{item.count}} 张</view>
      </view>
    </view>

    <view class="whack-stage" wx:if="{{gameMode === 'whack' && currentQuestion && !result}}">
      <view class="stage-top">
        <view>
          <view class="stage-kicker">打地鼠速记关</view>
          <view class="stage-question">{{currentQuestion.question}}</view>
        </view>
        <view class="life-pill">生命 {{lives}}</view>
      </view>
      <view class="combo-row">
        <view>进度 {{currentIndex + 1}} / {{round.total}}</view>
        <view>Combo {{combo}}</view>
      </view>
      <view class="mole-grid">
        <button
          wx:for="{{moleHoles}}"
          wx:key="id"
          class="mole-hole {{item.active ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="tapHole"
        >
          <view class="mole" wx:if="{{item.active}}">
            <view class="mole-face"></view>
            <view class="mole-label">{{item.label}}</view>
          </view>
        </button>
      </view>
    </view>

    <view class="quest-stage" wx:if="{{gameMode === 'quiz' && currentQuestion && !result}}">
      <view class="quest-map">
        <view
          wx:for="{{round.questions}}"
          wx:key="id"
          class="quest-node {{index < currentIndex ? 'done' : ''}} {{index === currentIndex ? 'active' : ''}}"
        >{{index + 1}}</view>
      </view>
      <view class="quest-card">
        <view class="stage-top">
          <view>
            <view class="stage-kicker">轻练答题 · {{currentQuestion.knowledgeType}}</view>
            <view class="quest-checkpoint">{{currentQuestion.checkpoint}}</view>
          </view>
          <view class="life-pill">生命 {{lives}}</view>
        </view>
        <view class="quest-question">{{currentQuestion.question}}</view>
        <view class="quest-hint" wx:if="{{currentQuestion.hint}}">{{currentQuestion.hint}}</view>
        <button class="reveal-btn" wx:if="{{!revealed}}" bindtap="revealAnswer">我想好了，核对思路</button>
        <view class="quest-answer" wx:if="{{revealed}}">
          <view class="answer-review-title">参考思路</view>
          <view class="quest-answer-text">{{currentQuestion.answer}}</view>
          <view class="grade-row">
            <button class="grade-btn weak" data-rating="again" bindtap="gradeQuest">忘记</button>
            <button class="grade-btn mid" data-rating="good" bindtap="gradeQuest">模糊</button>
            <button class="grade-btn strong" data-rating="easy" bindtap="gradeQuest">记得</button>
          </view>
        </view>
      </view>
    </view>

    <view class="snake-stage" wx:if="{{gameMode === 'snake' && snakeTrack && !result}}">
      <view class="snake-board">
        <view class="stage-top">
          <view>
            <view class="stage-kicker">贪吃蛇顺序关 · {{snakeTrack.knowledgeType}}</view>
            <view class="snake-title">{{snakeTrack.question}}</view>
          </view>
          <view class="life-pill">生命 {{lives}}</view>
        </view>
        <view class="snake-path">
          <view
            wx:for="{{snakeTrack.correctOrder}}"
            wx:key="*this"
            class="snake-segment {{index < snakeNextOrder ? 'eaten' : ''}}"
          >{{index + 1}}</view>
        </view>
        <view class="snake-body" wx:if="{{snakeNextOrder > 0}}">
          <view class="snake-body-title">已经吃掉</view>
          <view class="snake-body-track">
            <text wx:for="{{snakeTiles}}" wx:key="id" wx:if="{{item.eaten}}" class="snake-body-chip">{{item.text}}</text>
          </view>
        </view>
        <view class="snake-prompt">下一口：第 {{snakeNextOrder + 1}} 步</view>
        <view class="snake-grid">
          <button
            wx:for="{{snakeTiles}}"
            wx:key="id"
            class="snake-tile {{item.eaten ? 'eaten' : ''}} {{item.missed ? 'missed' : ''}}"
            data-id="{{item.id}}"
            bindtap="tapSnakeTile"
          >
            {{item.text}}
          </button>
        </view>
      </view>
    </view>

    <view class="bubble-stage" wx:if="{{gameMode === 'match' && currentQuestion && !result}}">
      <view class="bubble-board">
        <view class="stage-top">
          <view>
            <view class="bubble-kicker">泡泡消消乐 · {{currentQuestion.knowledgeType}}</view>
            <view class="bubble-title">点一颗题泡泡，再点对应泡泡</view>
          </view>
          <view class="life-pill bubble-life">生命 {{lives}}</view>
        </view>
        <view class="bubble-progress">
          <view>已消 {{matchPairsDone}} / {{round.total}}</view>
          <view>Combo {{combo}}</view>
        </view>
        <view class="bubble-grid">
          <button
            wx:for="{{matchTiles}}"
            wx:key="id"
            class="bubble-tile side-{{item.side}} {{item.selected ? 'selected' : ''}} {{item.matched ? 'matched' : ''}} {{item.missed ? 'missed' : ''}}"
            disabled="{{item.matched}}"
            data-id="{{item.id}}"
            bindtap="tapMatchTile"
          >
            <view class="bubble-badge">{{item.sideLabel}}</view>
            <view class="bubble-text">{{item.text}}</view>
          </button>
        </view>
      </view>
    </view>

    <view class="arcade-card empty" wx:if="{{!currentQuestion && !result}}">
      <view class="empty-title">{{emptyGuide.title}}</view>
      <view class="empty-copy">{{emptyGuide.body}}</view>
      <button class="primary-btn" data-action="{{emptyGuide.action}}" bindtap="runGuideAction">{{emptyGuide.cta}}</button>
    </view>

    <view class="result-card" wx:if="{{result}}">
      <view class="result-kicker">{{result.passed ? '通关完成' : '继续练这一组'}}</view>
      <view class="result-title">{{result.correct}} / {{result.total}} 答对</view>
      <view class="result-grid">
        <view>
          <view class="result-num">{{result.accuracy}}%</view>
          <view class="result-label">正确率</view>
        </view>
        <view>
          <view class="result-num">{{result.xp}}</view>
          <view class="result-label">回访</view>
        </view>
        <view>
          <view class="result-num">{{result.bestCombo}}</view>
          <view class="result-label">最佳 Combo</view>
        </view>
      </view>
      <view class="answer-review" wx:if="{{wrongAnswers.length}}">
        <view class="answer-review-title">本局错题</view>
        <view class="answer-row" wx:for="{{wrongAnswers}}" wx:key="cardId">
          <view class="answer-selected">你选：{{item.selected}}</view>
          <view class="answer-correct">应选：{{item.answer}}</view>
        </view>
      </view>
      <view class="repair-focus-card" wx:if="{{repairFocus}}">
        <view class="repair-focus-kicker">先修这个断点</view>
        <view class="repair-focus-title">{{repairFocus.title}}</view>
        <view class="repair-focus-body">{{repairFocus.decision}}</view>
      </view>
      <view class="result-copy">{{feedbackText}}</view>
      <view class="retention-loop-card" wx:if="{{gameRetentionLoop}}">
        <view class="retention-loop-kicker">连续练习闭环</view>
        <view class="retention-loop-title">{{gameRetentionLoop.title}}</view>
        <view class="retention-loop-line">{{gameRetentionLoop.loopLine}}</view>
        <view class="retention-loop-step">{{gameRetentionLoop.nextRoundLine}}</view>
        <view class="retention-loop-step">{{gameRetentionLoop.wrongCauseReturnLine}}</view>
        <view class="retention-loop-step">{{gameRetentionLoop.tomorrowLine}}</view>
        <view class="retention-loop-foot">{{gameRetentionLoop.xpLine}} {{gameRetentionLoop.habitCue}}</view>
      </view>
      <view class="retention-loop-card high-frequency-card" wx:if="{{highFrequencyPracticeLoop}}">
        <view class="retention-loop-kicker">高频回忆计划</view>
        <view class="retention-loop-title">{{highFrequencyPracticeLoop.title}}</view>
        <view class="retention-loop-line">{{highFrequencyPracticeLoop.summaryLine}}</view>
        <view class="high-frequency-section">
          <view class="high-frequency-label">主动回忆卡</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.recallCards}}" wx:key="id">
            <text>{{item.order}}. {{item.prompt}}</text>
            <text>{{item.firstStep}}</text>
          </view>
        </view>
        <view class="high-frequency-section">
          <view class="high-frequency-label">间隔回访</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.spacedReviewPlan}}" wx:key="id">
            <text>{{item.label}}：{{item.action}}</text>
          </view>
        </view>
        <view class="retention-loop-step">{{highFrequencyPracticeLoop.xpRule}}</view>
        <view class="retention-loop-step">{{highFrequencyPracticeLoop.leechRule}}</view>
        <view class="memory-feedback-card" wx:if="{{highFrequencyPracticeLoop.memoryFeedbackController}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.memoryFeedbackController.title}}</view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.memoryFeedbackController.triggerSignals}}" wx:key="*this">{{item}}</view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.memoryFeedbackController.interventionSteps}}" wx:key="*this">{{item}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryFeedbackController.xpThrottle}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryFeedbackController.nextReview}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.recallIntensityPlan}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.recallIntensityPlan.title}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.recallIntensityPlan.rounds}}" wx:key="id">
            <text>{{item.label}} · {{item.size}} 张</text>
            <text>{{item.rule}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.recallIntensityPlan.stopRule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.recallIntensityPlan.releaseRule}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.wrongCauseReplayDeck}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.wrongCauseReplayDeck.title}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.wrongCauseReplayDeck.cards}}" wx:key="id">
            <text>{{item.order}}. {{item.label}}</text>
            <text>{{item.repairMove}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.wrongCauseReplayDeck.rule}}</view>
        </view>
        <view class="memory-feedback-card" wx:if="{{highFrequencyPracticeLoop.xpFeedbackPolicy}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.xpFeedbackPolicy.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.xpFeedbackPolicy.rewardLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.xpFeedbackPolicy.throttleLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.xpFeedbackPolicy.parentLine}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.questArcRunway}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.questArcRunway.title}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.questArcRunway.stages}}" wx:key="id">
            <text>{{item.order}}. {{item.label}} · {{item.status}}</text>
            <text>{{item.nextAction}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.questArcRunway.bossLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.questArcRunway.completionRule}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.parentContract.line}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.dailyMinimumRounds}}" wx:key="id">
            <text>{{item.label}} · {{item.target}}</text>
            <text>{{item.rule}}</text>
          </view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.returnWindows}}" wx:key="id">
            <text>{{item.label}}</text>
            <text>{{item.action}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.antiCramThrottle.xpRule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.leechEscalation.rule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.gizmoLikeMemoryProtocol.shareSafeChallenge.line}}</view>
        </view>
        <view class="retention-loop-foot">{{highFrequencyPracticeLoop.parentShareLine}}</view>
      </view>
      <view class="next-action-card" wx:if="{{challengeBrief.resultLine}}">
        <view class="next-action-title">目标回看</view>
        <view class="next-action-body">{{challengeBrief.resultLine}}</view>
      </view>
      <view class="next-action-card" wx:if="{{resultAdvice}}">
        <view class="next-action-title">{{resultAdvice.title}}</view>
        <view class="next-action-body">{{resultAdvice.body}}</view>
      </view>
      <view class="arcade-result-bridge" wx:if="{{arcadeResultActionBridge}}">
        <view class="bridge-kicker">{{arcadeResultActionBridge.title}}</view>
        <view class="bridge-title">{{arcadeResultActionBridge.headline}}</view>
        <view class="bridge-line">{{arcadeResultActionBridge.evidenceLine}}</view>
        <view class="bridge-line">{{arcadeResultActionBridge.tomorrowLine}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.masteryGateLine}}">{{arcadeResultActionBridge.masteryGateLine}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.parentEvidenceLine}}">{{arcadeResultActionBridge.parentEvidenceLine}}</view>
        <view class="bridge-share">{{arcadeResultActionBridge.shareLine}}</view>
        <view class="bridge-action-grid">
          <button
            class="bridge-action"
            wx:for="{{arcadeResultActionBridge.actions}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-label="{{item.label}}"
            data-route="{{item.route}}"
            data-reason="{{item.reason}}"
            data-capability-id="{{item.capabilityId}}"
            bindtap="runArcadeResultBridgeAction"
          >{{item.label}}</button>
        </view>
      </view>
      <view class="result-actions">
        <button class="primary-btn" bindtap="restartRound">{{resultAdvice.primary}}</button>
        <button class="secondary-btn" bindtap="runResultSecondary">{{resultAdvice.secondary}}</button>
      </view>
    </view>

    <view class="feedback-line" wx:if="{{feedbackText && !result}}">{{feedbackText}}</view>
  </scroll-view>
</view>
