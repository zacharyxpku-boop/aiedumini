        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.dailyMemorySprintDeck}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.dailyMemorySprintDeck.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySprintDeck.summary}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.dailyMemorySprintDeck.sprintCards}}" wx:key="id">
            <text>{{item.label}} · {{item.minutes}} 分钟</text>
            <text>{{item.action}}</text>
            <text>证据：{{item.proof}}</text>
          </view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.dailyMemorySprintDeck.lockRules}}" wx:key="*this">锁定规则：{{item}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.dailyMemorySprintDeck.streakMeters}}" wx:key="id">
            <text>{{item.label}}：{{item.current}} / {{item.target}}</text>
            <text>{{item.rule}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySprintDeck.xpLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySprintDeck.parentLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySprintDeck.shareBoundary}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.adaptiveRecallScheduler}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.adaptiveRecallScheduler.title}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.adaptiveRecallScheduler.schedulerBoxes}}" wx:key="id">
            <text>{{item.label}} 路 {{item.window}}</text>
            <text>{{item.unlockRule}}</text>
          </view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.adaptiveRecallScheduler.reviewQueue}}" wx:key="id">
            <text>{{item.label}}：{{item.dueWindow}}</text>
            <text>{{item.action}}</text>
            <text>放行证据：{{item.releaseEvidence}}</text>
          </view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.adaptiveRecallScheduler.unlockRules}}" wx:key="*this">放行规则：{{item}}</view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.adaptiveRecallScheduler.leechRules}}" wx:key="*this">急救规则：{{item}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.adaptiveRecallScheduler.xpGate}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.adaptiveRecallScheduler.parentLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.adaptiveRecallScheduler.shareBoundary}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.memoryRiskReleaseModel}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.memoryRiskReleaseModel.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryRiskReleaseModel.summary}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.memoryRiskReleaseModel.riskSignals}}" wx:key="id">
            <text>{{item.label}} 路 {{item.level}}</text>
            <text>{{item.evidence}}</text>
          </view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.memoryRiskReleaseModel.forgettingWarnings}}" wx:key="id">
            <text>{{item.label}}遗忘预警</text>
            <text>{{item.warning}}</text>
            <text>{{item.action}}</text>
          </view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.memoryRiskReleaseModel.variantReleaseGates}}" wx:key="id">变式放行：{{item.label}}｜{{item.status}}｜{{item.rule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryRiskReleaseModel.parentDecisionLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryRiskReleaseModel.xpReleaseLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.memoryRiskReleaseModel.shareBoundary}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.peerMemoryRelayLeague}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.peerMemoryRelayLeague.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.peerMemoryRelayLeague.parentLine}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.peerMemoryRelayLeague.lanes}}" wx:key="id">
            <text>{{item.label}} · {{item.locked ? '先锁定' : '可执行'}}</text>
            <text>{{item.action}}</text>
            <text>{{item.proof}}</text>
          </view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.peerMemoryRelayLeague.relayWindows}}" wx:key="id">接力窗口：{{item.label}}｜{{item.action}}</view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.peerMemoryRelayLeague.scoreboardReplacement}}" wx:key="id">接力证据：{{item.label}}｜{{item.value}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.peerMemoryRelayLeague.shareLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.peerMemoryRelayLeague.aiBoundary}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.dailyMemorySeasonPlan}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.retentionLine}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.missions}}" wx:key="id">
            <text>{{item.label}} · {{item.locked ? '先锁住' : '可执行'}}</text>
            <text>{{item.action}}</text>
            <text>证据：{{item.proof}}</text>
          </view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.nonRankingBoard}}" wx:key="id">
            <text>{{item.label}}：{{item.value}}</text>
            <text>{{item.rule}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.parentLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.sharePayload.receiverRule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyMemorySeasonPlan.aiBoundary}}</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.dailyComebackDecisionEngine}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.decisionLine}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.rewardGate}}</view>
          <view class="high-frequency-item" wx:if="{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.primaryCard}}">
            <text>{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.primaryCard.label}}</text>
            <text>{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.primaryCard.action}}</text>
            <text>证据：{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.primaryCard.proof}}</text>
          </view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.stopRule}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.parentLine}}</view>
          <view class="retention-loop-step">每日上限：{{highFrequencyPracticeLoop.dailyComebackDecisionEngine.antiAddictionPolicy.maxMinutes}} 分钟，不做比较展示，不无限下滑。</view>
        </view>
        <view class="high-frequency-section" wx:if="{{highFrequencyPracticeLoop.healthyCommercialReturnGuard}}">
          <view class="high-frequency-label">{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.title}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.parentDecisionLine}}</view>
          <view class="retention-loop-step" wx:for="{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.stopRules}}" wx:key="*this">停止条件：{{item}}</view>
          <view class="retention-loop-step">{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.serviceHandoffLine}}</view>
          <view class="high-frequency-item" wx:for="{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.actionCards}}" wx:key="id">
            <text>{{item.label}}</text>
            <text>放行：{{item.releaseGate}}</text>
          </view>
          <view class="retention-loop-step">禁止奖励：{{highFrequencyPracticeLoop.healthyCommercialReturnGuard.blockedRewards.length}} 项。</view>
        </view>
        <view class="retention-loop-foot">{{highFrequencyPracticeLoop.parentShareLine}}</view>
      </view>
      <view class="next-action-card" wx:if="{{challengeBrief.resultLine}}">
        <view class="next-action-title">目标回看</view>
        <view class="next-action-body">{{challengeBrief.resultLine}}</view>
      </view>
      <view class="next-action-card" wx:if="{{resultAdvice}}">
        <view class="next-action-title">{{resultAdvice.title}}</view>
        <view class="next-action-body">{{resultAdvice.body}}</view>
      </view>
      <view class="arcade-result-bridge" wx:if="{{arcadeResultActionBridge}}">
        <view class="bridge-kicker">{{arcadeResultActionBridge.title}}</view>
        <view class="bridge-title">{{arcadeResultActionBridge.headline}}</view>
        <view class="bridge-line">{{arcadeResultActionBridge.evidenceLine}}</view>
        <view class="bridge-line">{{arcadeResultActionBridge.tomorrowLine}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.masteryGateLine}}">{{arcadeResultActionBridge.masteryGateLine}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.parentEvidenceLine}}">{{arcadeResultActionBridge.parentEvidenceLine}}</view>
        <view class="bridge-share">{{arcadeResultActionBridge.shareLine}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.primaryShareLabel}}">{{arcadeResultActionBridge.primaryShareLabel}}｜{{arcadeResultActionBridge.returnWindow}}</view>
        <view class="bridge-line" wx:if="{{arcadeResultActionBridge.shareChallengeTitle}}">接力任务：{{arcadeResultActionBridge.shareChallengeTitle}}｜{{arcadeResultActionBridge.receiverRoute}}</view>
        <button class="bridge-action share" open-type="share" wx:if="{{arcadeResultActionBridge.shareChallengePayload}}">{{arcadeResultActionBridge.primaryShareLabel}}</button>
        <view class="bridge-action-grid">
          <button
            class="bridge-action"
            wx:for="{{arcadeResultActionBridge.actions}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-label="{{item.label}}"
            data-route="{{item.route}}"
            data-reason="{{item.reason}}"
            data-capability-id="{{item.capabilityId}}"
            bindtap="runArcadeResultBridgeAction"
          >{{item.label}}</button>
        </view>
      </view>
      <view class="result-actions">
        <button class="primary-btn" bindtap="restartRound">{{resultAdvice.primary}}</button>
        <button class="secondary-btn" bindtap="runResultSecondary">{{resultAdvice.secondary}}</button>
      </view>
    </view>

    <view class="feedback-line" wx:if="{{feedbackText && !result}}">{{feedbackText}}</view>
  </scroll-view>
</view>
