<view class="page arcade-page safe-bottom">
  <view class="page-positioning arcade-positioning" wx:if="{{showLegacyEntryContent}}">
    <view class="positioning-kicker">游戏化轻练习</view>
    <view class="positioning-title">玩一小局，错的卡回到复习队列</view>
    <view class="positioning-flow">游戏负责让孩子愿意再练一下；错题和模糊点会回到修卡点，不做排行。</view>
  </view>
  <view class="arcade-topbar" wx:if="{{showLegacyEntryContent}}">
    <button class="nav-back" bindtap="goBack">‹</button>
    <view class="nav-title">轻练习</view>
    <button class="nav-home" bindtap="goHome">首页</button>
  </view>

  <scroll-view class="arcade-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="ux-entry ux-entry-island ux-kit-screen ux-kit-review arcade-hero-shell">
      <view class="arcade-dash-top">
        <view class="arcade-dash-brand">
          <image class="arcade-dash-mark" mode="aspectFit" src="/assets/reference/brand-house.png" />
          <view>
            <text>轻练习岛</text>
            <text>5 分钟迁移验证</text>
          </view>
        </view>
        <view class="arcade-dash-pill">不排行</view>
      </view>
      <view class="arcade-dash-hero">
        <view class="arcade-dash-copy">
          <view class="arcade-dash-kicker">先回忆，再核对</view>
          <view class="arcade-dash-title">把一个卡点玩成可验证的小关</view>
          <view class="arcade-dash-sub">每局只练一个知识点：说出第一步、核对过程、做一张变式卡，最后把证据回流给家长。</view>
        </view>
        <image class="arcade-dash-art" mode="aspectFill" src="/assets/reference/entry-map.png" />
      </view>
      <view class="arcade-map-card">
        <view class="arcade-map-head">
          <text>本局路线</text>
          <text>短、轻、可回访</text>
        </view>
        <view class="arcade-map-line">
          <view class="arcade-map-node active"><text>1</text><text>回忆</text></view>
          <view class="arcade-map-node active"><text>2</text><text>核对</text></view>
          <view class="arcade-map-node"><text>3</text><text>变式</text></view>
          <view class="arcade-map-node"><text>4</text><text>回流</text></view>
        </view>
      </view>
      <view class="arcade-stats-grid">
        <view>
          <text>{{cards.length || 0}}</text>
          <text>可用卡片</text>
        </view>
        <view>
          <text>{{round.total || 0}}</text>
          <text>本局题数</text>
        </view>
        <view>
          <text>{{xpGained || 0}}</text>
          <text>留证回访</text>
        </view>
      </view>
      <view class="ux-kit-jump-grid">
        <view class="ux-kit-jump-card primary arcade-jump-card" data-scene="review" bindtap="openEntryDetail">
          <text>90 秒回忆</text>
          <text>先说第一步</text>
        </view>
        <view class="ux-kit-jump-card arcade-jump-card" data-scene="tutor" bindtap="openEntryDetail">
          <text>卡住求助</text>
          <text>回私教追问</text>
        </view>
        <view class="ux-kit-jump-card arcade-jump-card" data-scene="parent" bindtap="openEntryDetail">
          <text>给家长看</text>
          <text>只看证据</text>
        </view>
      </view>
      <view class="arcade-dash-action-row">
        <view class="ux-kit-primary arcade-primary" data-scene="review" bindtap="openEntryDetail">开始这一关</view>
        <view class="ux-kit-secondary arcade-secondary" data-scene="tutor" bindtap="openEntryDetail">卡住就追问</view>
      </view>
    </view>
    <view class="arcade-subcheck ux-kit-subcheck">
      <view class="subcheck-main" data-scene="review" bindtap="openEntryDetail">
        <view class="subcheck-copy">
          <text>复习岛不是刷题</text>
          <text>先回忆，再核对，再换一道题验证迁移。</text>
        </view>
        <image class="subcheck-art" mode="aspectFill" src="/assets/reference/entry-review.png" />
      </view>
      <view class="subcheck-side">
        <view data-scene="tutor" bindtap="openEntryDetail"><text>不会开始</text><text>回私教追问</text></view>
        <view data-scene="parent" bindtap="openEntryDetail"><text>完成后</text><text>给家长看证据</text></view>
      </view>
    </view>
    <view class="arcade-hero" wx:if="{{showLegacyEntryContent}}">
      <view class="hero-art">
        <view class="hero-orbit">
          <view class="hero-core"></view>
          <view class="hero-dot one"></view>
          <view class="hero-dot two"></view>
          <view class="hero-dot three"></view>
        </view>
      </view>
      <view class="hero-kicker">学科 × 知识类型 × 游戏类型</view>
      <view class="hero-title">今天把知识打一小关</view>
      <view class="hero-copy">不是把复习换皮，而是让短回忆、概念和步骤进入合适玩法。</view>
      <view class="hero-stats">
        <view class="hero-stat">
          <view class="hero-stat-num">{{cards.length || 0}}</view>
          <view class="hero-stat-label">可用卡片</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat-num">{{round.total || 0}}</view>
          <view class="hero-stat-label">本局题数</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat-num">{{xpGained || 0}}</view>
          <view class="hero-stat-label">留证回访</view>
        </view>
      </view>
    </view>

    <view class="challenge-brief-card" wx:if="{{challengeBrief}}">
      <block wx:if="{{showLegacyEntryContent}}">
    <view class="story-mission" wx:if="{{reportSourcePanel}}">
        <view class="story-mission-title">{{reportSourcePanel.title}}</view>
        <view class="story-mission-line">{{reportSourcePanel.line}}</view>
        <view class="story-mission-rule">来源：已接入家长报告 / 错题回访 / 今日轻练</view>
        <view class="story-mission-rule" wx:if="{{reportSourcePanel.firstQuestion}}">本局先练：{{reportSourcePanel.firstQuestion}}</view>
        <view class="story-mission-rule">来源卡：{{reportSourcePanel.matchedCount}} 张；原题、答案和分数不会进入分享。</view>
        <view class="story-mission-rule" wx:if="{{reportSourcePanel.openMaicBridgeStatus}}">小讲堂回流：先说第一步，再锁明天回访。</view>
        <view class="story-mission-rule" wx:if="{{reportSourcePanel.returnRoute}}">{{reportSourcePanel.returnRouteLine}}</view>
      </view>
      <view class="challenge-brief-top">
        <view>
          <view class="challenge-brief-kicker">本局目标</view>
          <view class="challenge-brief-title">{{challengeBrief.modeLabel}}</view>
        </view>
        <view class="challenge-brief-pill">{{challengeBrief.roundSize}} 题 · 回访门槛</view>
      </view>
      <view class="challenge-brief-line">{{challengeBrief.questTitle}} 路 {{challengeBrief.questProgress}}</view>
      <view class="quest-action-row" wx:if="{{challengeBrief.questActions.length}}">
        <button
          class="quest-action-btn"
          wx:for="{{challengeBrief.questActions}}"
          wx:key="id"
          data-route="{{item.route}}"
          data-quest-id="{{item.id}}"
          data-label="{{item.label}}"
          bindtap="goQuestRoute"
        >{{item.label}} {{item.progressText}}</button>
      </view>
      <view class="story-mission first-step-sprint-card" wx:if="{{challengeBrief.firstStepSprint}}">
        <view class="story-mission-title">{{challengeBrief.firstStepSprint.title}}</view>
        <view class="story-mission-line">{{challengeBrief.firstStepSprint.sourceLine}}</view>
        <view class="story-mission-rule">本局只练：{{challengeBrief.firstStepSprint.weakKey}}</view>
        <view class="story-mission-rule">{{challengeBrief.firstStepSprint.goalLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.firstStepSprint.rewardLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.firstStepSprint.parentLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.firstStepSprint.nextDayLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.firstStepSprint.safetyLine}}</view>
        <view class="quest-action-row">
          <button class="quest-action-btn" bindtap="startNinetySecondRecall">开始 90 秒第一步</button>
          <button class="quest-action-btn" data-route="{{challengeBrief.firstStepSprint.reviewRoute}}" data-quest-id="first_step_sprint_review" data-label="明天回访" bindtap="goQuestRoute">明天回访</button>
        </view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.firstStepSprintCheckpoints}}" wx:key="id">{{item.label}}：{{item.evidence}}</view>
      </view>
      <view class="story-mission public-k12-challenge-mission" wx:if="{{challengeBrief.publicK12IntakeChallenge}}">
        <view class="story-mission-title">{{challengeBrief.publicK12IntakeChallenge.title}}</view>
        <view class="story-mission-line">公开 K12 挑战卡 {{challengeBrief.publicK12IntakeChallenge.challengeCount}} 张，可执行 {{challengeBrief.publicK12IntakeChallenge.executableCardCount}} 张；必须用自己的作业材料说第一步。</view>
        <view class="story-mission-rule">第一步：{{challengeBrief.publicK12IntakeChallenge.observableFirstMove}}</view>
        <view class="story-mission-rule">不会说时：{{challengeBrief.publicK12IntakeChallenge.fallbackIfNoChildInput}}</view>
        <view class="story-mission-rule">安全分享字段：{{challengeBrief.publicK12IntakeChallenge.shareSafeFields}}</view>
        <view class="story-mission-rule">安全边界：不带原题、完整答案、分数和同伴比较。</view>
        <view class="quest-action-row">
          <button class="quest-action-btn" data-route="{{challengeBrief.publicK12IntakeChallenge.route}}" data-quest-id="public_k12_arcade" data-label="开始挑战" bindtap="goQuestRoute">开始挑战</button>
          <button class="quest-action-btn" data-route="{{challengeBrief.publicK12IntakeChallenge.reviewRoute}}" data-quest-id="public_k12_review" data-label="明天回访" bindtap="goQuestRoute">明天回访</button>
        </view>
        <view class="story-mission-rule public-k12-card-action" wx:for="{{challengeBrief.publicK12IntakeChallenge.cards}}" wx:key="id" data-route="{{item.route}}" data-review-route="{{item.reviewRoute}}" data-challenge-id="{{item.id}}" data-subject="{{item.subject}}" data-task-type="{{item.taskType}}" data-first-step="{{item.observableFirstMove}}" data-fallback="{{item.fallbackIfNoChildInput}}" data-quest-id="public_k12_card" data-label="{{item.subject}} · {{item.taskType}}" bindtap="goQuestRoute">{{item.subject}} · {{item.taskType}}：{{item.observableFirstMove}}</view>
      </view>
      <view class="challenge-brief-sub">{{challengeBrief.bossLine}}</view>
      <view class="challenge-brief-sub">{{challengeBrief.rewardLine}}</view>
      <view class="story-mission" wx:if="{{challengeBrief.storyTitle}}">
        <view class="story-mission-title">{{challengeBrief.storyTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.storyLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.storyRule}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.subjectDepthLine}}">
        <view class="story-mission-title">{{challengeBrief.subjectDepthLabel}}</view>
        <view class="story-mission-line">题型第一步：{{challengeBrief.subjectDepthLine}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.subjectDepthGameLine}}">本局练：{{challengeBrief.subjectDepthGameLine}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.subjectDepthEvidenceLine}}">留下证据：{{challengeBrief.subjectDepthEvidenceLine}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.curriculumLine}}">
        <view class="story-mission-title">{{challengeBrief.curriculumTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.curriculumLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.curriculumProgression}}" wx:key="id">{{item.order}}. {{item.label}}：{{item.evidence}}</view>
        <view class="story-mission-rule">{{challengeBrief.curriculumScaleLine}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.courseUnitTitle}}">
        <view class="story-mission-title">{{challengeBrief.courseUnitTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.courseUnitLine}}</view>
        <view class="story-mission-rule">错因谱：{{challengeBrief.courseUnitWrongCauseLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionTypes}}" wx:key="*this">本局题型：{{item}}</view>
        <view class="story-mission-rule">{{challengeBrief.courseUnitReportContract}}</view>
        <view class="story-mission-rule">{{challengeBrief.courseUnitShareContract}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.courseUnitPracticeDeckTitle}}">{{challengeBrief.courseUnitPracticeDeckTitle}}：{{challengeBrief.courseUnitPracticeDeckLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitPracticeDeck}}" wx:key="id">{{item.label}} · 掌握度 {{item.masteryScore}} · 风险 {{item.risk}} · {{item.action}} · {{item.nextEvidence}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.courseUnitQuestionBankTitle}}">{{challengeBrief.courseUnitQuestionBankTitle}}：{{challengeBrief.courseUnitQuestionBankLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">题库卡：{{item.label}}｜{{item.prompt}}｜{{item.evidenceRequired}}</view>
        <view class="story-mission-rule" wx:if="{{challengeBrief.questionBankPlayableLine}}">{{challengeBrief.questionBankPlayableLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.questionBankPlayableCards}}" wx:key="id">本局卡：{{item.question}}｜第一步：{{item.answer}}｜{{item.revisitWindow}}</view>
        <view class="story-mission rule-retest-mission" wx:if="{{challengeBrief.ruleRetestChallengeTitle}}">
          <view class="story-mission-title">{{challengeBrief.ruleRetestChallengeTitle}}</view>
          <view class="story-mission-line">{{challengeBrief.ruleRetestChallengeLine}}</view>
          <view class="story-mission-rule">{{challengeBrief.ruleRetestChallengeXpGate}}</view>
          <view class="story-mission-rule">{{challengeBrief.ruleRetestChallengeParentLine}}</view>
          <view class="story-mission-rule" wx:for="{{challengeBrief.ruleRetestChallengeCards}}" wx:key="id">复测卡：{{item.title}} · {{item.prompt}} · {{item.releaseGate}}</view>
        </view>
      </view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">样例：{{item.sampleStem}}｜第一步：{{item.firstStepHint}}｜近迁移：{{item.nearTransferStem}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">进阶路径：{{item.progression.entryTask}}｜明天：{{item.progression.nextDayRevisit}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.courseUnitQuestionBankCards}}" wx:key="id">掌握门槛：{{item.progression.masteryGate}}</view>
      <view class="story-mission" wx:if="{{challengeBrief.questionBankShareRelayDeckTitle}}">
        <view class="story-mission-title">{{challengeBrief.questionBankShareRelayDeckTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.questionBankShareRelayDeckLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.questionBankShareRelayParentLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.questionBankShareRelayCards}}" wx:key="id">接力卡：{{item.label}}｜第一步：{{item.firstStep}}｜{{item.parentCheck}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.questionBankShareRelayWindows}}" wx:key="id">{{item.label}}：{{item.action}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.commercialDepthRunwayTitle}}">
        <view class="story-mission-title">{{challengeBrief.commercialDepthRunwayTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.commercialDepthRunwayLine}}</view>
        <view class="story-mission-rule">{{challengeBrief.commercialDepthRunwayBoundary}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.commercialDepthRunwayLanes}}" wx:key="id">{{item.label}}：{{item.evidenceLine}}｜下一步：{{item.nextAction}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.commercialDepthMemoryCadence}}" wx:key="id">{{item.label}}：{{item.action}}</view>
      </view>
      <view class="story-mission" wx:if="{{challengeBrief.sevenSubjectMasterySprintTitle}}">
        <view class="story-mission-title">{{challengeBrief.sevenSubjectMasterySprintTitle}}</view>
        <view class="story-mission-line">{{challengeBrief.sevenSubjectMasterySprintLine}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.sevenSubjectMasterySprintLanes}}" wx:key="id">{{item.label}}：{{item.target}}</view>
        <view class="story-mission-rule" wx:for="{{challengeBrief.sevenSubjectMasterySprintSubjects}}" wx:key="id">{{item.label}}：{{item.memoryGameTarget}}</view>
        <view class="story-mission-rule">{{challengeBrief.sevenSubjectMasterySprintMoat}}</view>
      </view>
      <view class="challenge-brief-sub" wx:if="{{challengeBrief.evidenceBiasLine}}">为什么开这局：{{challengeBrief.evidenceBiasLine}}</view>
      </block>
    </view>

    <view class="daily-return-card primary-recall-card" wx:if="{{dailyPrimaryRecallAction}}">
      <view class="daily-return-top">
        <view>
          <view class="daily-return-kicker">今日主回忆</view>
          <view class="daily-return-title">{{dailyPrimaryRecallAction.title}}</view>
        </view>
        <view class="daily-return-pill">只做这一件</view>
      </view>
      <view class="daily-return-line">{{dailyPrimaryRecallAction.oneActionLine}}</view>
      <view class="daily-return-rule">{{dailyPrimaryRecallAction.xpGate}}</view>
      <view class="daily-return-rule">明天回访：{{dailyPrimaryRecallAction.nextReturnWindow}}｜{{dailyPrimaryRecallAction.parentLine}}</view>
      <view class="daily-return-rule" wx:if="{{dailyPrimaryRecallEvidencePacket}}">已写入：明天回访已锁定，待补第一步和错因回放。</view>
      <view class="daily-return-rule">{{dailyPrimaryRecallAction.shareBoundary}}</view>
      <button class="daily-return-button" bindtap="runDailyPrimaryRecallAction">开始主回忆</button>
    </view>

    <view class="daily-return-card" wx:if="{{dailyReturnMission}}">
      <view class="daily-return-top">
        <view>
          <view class="daily-return-kicker">今日主回忆</view>
          <view class="daily-return-title">{{dailyReturnMission.title}}</view>
        </view>
        <view class="daily-return-pill">只做这一件</view>
      </view>
      <view class="daily-return-line">{{dailyReturnMission.promiseLine}}</view>
      <view class="daily-return-rule" wx:if="{{ninetySecondRecallDeck.playableExperience}}">{{ninetySecondRecallDeck.playableExperience.headline}}</view>
      <view class="daily-return-rule" wx:if="{{ninetySecondRecallDeck.playableExperience}}">{{ninetySecondRecallDeck.playableExperience.whyThisWorks}}</view>
      <view class="daily-return-rule" wx:if="{{ninetySecondRecallState}}">状态：{{ninetySecondRecallState.statusLabel}} · 当前：{{ninetySecondRecallState.currentStepLabel}} · {{ninetySecondRecallState.completionLine}}</view>
      <view class="daily-return-rule timeout" wx:if="{{ninetySecondRecallState.failureDowngradeLine}}">{{ninetySecondRecallState.failureDowngradeLine}}</view>
      <view class="daily-return-rule" wx:if="{{ninetySecondRecallState}}">状态：{{ninetySecondRecallState.status}} · 剩余 {{ninetySecondRecallState.secondsLeft}} 秒 · 当前第 {{ninetySecondRecallState.stepIndex + 1}} 步</view>
      <button class="daily-return-button" bindtap="startNinetySecondRecall">开始 90 秒</button>
      <view class="daily-return-steps compact" wx:if="{{ninetySecondRecallDeck.playableExperience}}">
        <view class="daily-return-step" wx:for="{{ninetySecondRecallDeck.playableExperience.loop}}" wx:key="id">
          <view class="daily-return-step-order">{{index + 1}}</view>
          <view class="daily-return-step-body">
            <view class="daily-return-step-action">{{item.label}}：{{item.playerAction}}</view>
            <view class="daily-return-step-proof">证据 {{item.proof}}</view>
          </view>
        </view>
      </view>
      <view class="daily-return-steps enhanced">
        <view class="daily-return-step {{item.uiClass}}" wx:for="{{ninetySecondRecallState.interactions}}" wx:key="id" data-step-id="{{item.id}}" bindtap="completeNinetySecondRecallStep">
          <view class="daily-return-step-order">{{item.order}}</view>
          <view class="daily-return-step-body">
            <view class="daily-return-step-action">{{item.prompt}}</view>
            <input wx:if="{{item.inputType === 'short_text' && item.isCurrent}}" class="daily-return-step-input" placeholder="写下孩子自己的第一步" value="{{item.inputValue}}" data-step-id="{{item.id}}" bindinput="handleNinetySecondRecallInput" />
            <view wx:if="{{item.inputType === 'two_choice' && item.isCurrent}}" class="daily-return-choice-row">
              <button class="daily-return-choice {{choice.id === item.selectedChoiceId ? 'selected' : ''}}" wx:for="{{item.choices}}" wx:for-item="choice" wx:key="id" data-step-id="{{item.id}}" data-choice-id="{{choice.id}}" bindtap="selectNinetySecondRecallChoice">{{choice.label}}</button>
            </view>
            <view class="daily-return-step-state" wx:if="{{item.isCurrent}}">当前只做这一步</view>
            <view class="daily-return-step-state done" wx:if="{{item.isCompleted}}">已留证</view>
            <view class="daily-return-step-proof">{{item.seconds}} 秒 · 证据 {{item.passEvidence}}</view>
          </view>
        </view>
      </view>
      <view class="daily-return-rule" wx:if="{{ninetySecondRecallState && ninetySecondRecallState.completedStepIds.length}}">
        已完成：
        <text wx:for="{{ninetySecondRecallState.completedStepIds}}" wx:key="*this">{{item}} </text>
      </view>
      <button class="daily-return-button" wx:if="{{ninetySecondRecallState && ninetySecondRecallState.finished}}" bindtap="resetNinetySecondRecall">重来一轮</button>
      <view class="daily-return-rule">{{dailyReturnMission.xpGate}}</view>
      <view class="daily-return-rule">{{dailyReturnMission.parentLine}}</view>
      <view class="daily-return-rule">{{dailyReturnMission.shareLine}}</view>
    </view>

    <view class="daily-return-card" wx:if="{{dailyReturnContract}}">
      <view class="daily-return-top">
        <view>
          <view class="daily-return-kicker">今日主回忆</view>
          <view class="daily-return-title">{{dailyReturnContract.title}}</view>
        </view>
        <view class="daily-return-pill">只做这一件</view>
      </view>
      <view class="daily-return-line">{{dailyReturnContract.comebackCopy}}</view>
      <view class="daily-return-steps">
        <view class="daily-return-step" wx:for="{{dailyReturnContract.loop}}" wx:key="id">
          <view class="daily-return-step-order">{{index + 1}}</view>
          <view class="daily-return-step-body">
            <view class="daily-return-step-action">{{item.label}}：{{item.action}}</view>
            <view class="daily-return-step-proof">{{item.trigger}} · 证据 {{item.proof}}</view>
          </view>
        </view>
      </view>
      <view class="daily-return-rule">家长只问：{{dailyReturnContract.parentReceipt.question}}</view>
      <view class="daily-return-rule">AI 只改写表达；本地代码决定回访节奏、奖励放行、画像放行和分享字段。</view>
      <view class="daily-return-rule">{{dailyReturnContract.shareCard.receiverAction}}</view>
    </view>

    <view class="surface-depth-card arcade-surface-depth" wx:if="{{surfaceDepthPack}}">
      <view class="surface-depth-title">{{surfaceDepthPack.title}}</view>
