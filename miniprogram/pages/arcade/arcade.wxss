  padding: 30rpx;
  border-radius: 32rpx;
  background: #FFF7D7;
  color: #1B4332;
  box-shadow: 0 18rpx 42rpx rgba(155, 123, 31, 0.14);
  overflow: hidden;
}

.bubble-board::before {
  content: "";
  position: absolute;
  right: -50rpx;
  top: -60rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(168, 218, 220, 0.34);
}

.bubble-board::after {
  content: "";
  position: absolute;
  left: -42rpx;
  bottom: -52rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
}

.bubble-board > view {
  position: relative;
  z-index: 1;
}

