.arcade-page {
  min-height: 100vh;
  color: #1a211d;
  background: #f5f3ed;
}

.arcade-page button {
  box-sizing: border-box;
}

.arcade-page button::after {
  border: 0;
}

.arcade-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.arcade-hero-shell {
  position: relative;
  margin: calc(108rpx + env(safe-area-inset-top)) 28rpx calc(126rpx + env(safe-area-inset-bottom));
  padding: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 9% 5%, rgba(248, 198, 34, 0.20), transparent 24%),
    radial-gradient(circle at 92% 11%, rgba(34, 185, 92, 0.14), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
}

.arcade-evidence-panel {
  width: max-content;
  max-width: 100%;
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #effaf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.arcade-dash-top,
.arcade-dash-brand,
.arcade-dash-hero,
.arcade-map-head,
.arcade-dash-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.arcade-dash-top {
  margin-top: 14rpx;
}

.arcade-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.arcade-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  border-radius: 18rpx;
  background: #fff6c9;
  border: 1rpx solid rgba(248, 198, 34, 0.26);
  box-shadow: 0 14rpx 26rpx rgba(248, 198, 34, 0.20);
}

.arcade-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arcade-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.arcade-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.arcade-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.arcade-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  align-items: center;
  margin-top: 18rpx;
}

.arcade-dash-kicker {
  width: max-content;
  max-width: 100%;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  color: #26754c;
  background: #effaf0;
  font-size: 21rpx;
  font-weight: 900;
}

.arcade-dash-title {
  margin-top: 12rpx;
  color: #101a16;
  font-size: 35rpx;
  font-weight: 950;
  line-height: 1.1;
  letter-spacing: 0;
}

.arcade-dash-sub {
  display: -webkit-box;
  margin-top: 9rpx;
  overflow: hidden;
  color: #64706a;
  font-size: 21rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.arcade-dash-art {
  width: 148rpx;
  height: 128rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 30rpx;
  background: #f3fbef;
}

.arcade-map-card {
  margin-top: 14rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(38, 58, 43, 0.05);
}

.arcade-map-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.arcade-map-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
  white-space: nowrap;
}

.arcade-map-line {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 9rpx;
  margin-top: 14rpx;
}

.arcade-map-node {
  position: relative;
  display: grid;
  min-height: 108rpx;
  align-content: center;
  justify-items: center;
  gap: 5rpx;
  padding: 10rpx 4rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.92);
  border-radius: 19rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f7f1 100%);
  box-shadow: 0 10rpx 24rpx rgba(38, 58, 43, 0.06);
  text-align: center;
}

.arcade-map-node.active {
  background: linear-gradient(180deg, #ffffff 0%, #ecf9ed 100%);
}

.arcade-map-node.final {
  background: linear-gradient(180deg, #ffffff 0%, #fff4eb 100%);
}

.arcade-map-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
  padding: 6rpx;
  border-radius: 15rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(38, 58, 43, 0.08);
}

.arcade-map-node text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arcade-map-node text:nth-child(2) {
  color: #173f31;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.15;
}

.arcade-map-node text:nth-child(3) {
  color: #68756d;
  font-size: 16rpx;
  font-weight: 780;
  line-height: 1.15;
}

.arcade-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.arcade-stats-grid view {
  min-width: 0;
  padding: 15rpx 10rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  text-align: center;
}

.arcade-stats-grid text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arcade-stats-grid text:first-child {
  color: #16a34a;
  font-size: 30rpx;
  font-weight: 950;
}

.arcade-stats-grid text:last-child {
  margin-top: 5rpx;
  color: #728078;
  font-size: 18rpx;
  font-weight: 800;
}

.arcade-hero-shell .ux-kit-jump-grid {
  gap: 12rpx;
  margin-top: 16rpx;
}

.arcade-jump-card {
  background:
    radial-gradient(circle at 80% 15%, rgba(248, 198, 34, 0.18), transparent 32%),
    #ffffff;
}

.arcade-dash-action-row {
  margin-top: 16rpx;
}

.arcade-primary,
.arcade-secondary {
  flex: 1 1 0;
  margin-top: 0;
}
