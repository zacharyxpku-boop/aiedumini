  box-shadow: inset 0 -8rpx 0 rgba(27, 67, 50, 0.10), 0 16rpx 28rpx rgba(155, 123, 31, 0.20);
}

.bubble-tile.matched {
  opacity: 0.38;
  transform: scale(0.94);
  pointer-events: none;
}

.bubble-tile[disabled] {
