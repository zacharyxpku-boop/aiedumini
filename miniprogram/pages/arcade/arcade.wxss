  min-width: 0;
  word-break: break-word;
}

.bubble-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.bubble-tile {
  position: relative;
  min-height: 132rpx;
  padding: 20rpx 18rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #1B4332;
  box-shadow: inset 0 -8rpx 0 rgba(27, 67, 50, 0.06), 0 10rpx 24rpx rgba(27, 67, 50, 0.08);
  text-align: left;
  overflow: hidden;
  transition: transform 120ms ease, opacity 120ms ease;
}

.bubble-tile::after {
  content: "";
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
}

