<view class="entry-detail-page">
  <view class="entry-detail-top">
    <button class="entry-back" bindtap="goBack">‹</button>
    <view class="entry-brand">
      <image mode="aspectFit" src="/assets/reference/brand-house.png" />
      <text>原点智学</text>
    </view>
  </view>

  <view class="entry-detail-hero scene-{{sceneKey}}">
    <view>
      <view class="entry-badge">{{scene.badge}}</view>
      <view class="entry-title">{{scene.title}}</view>
      <view class="entry-subtitle">{{scene.subtitle}}</view>
      <view class="entry-mini-path">
        <text>依据</text>
        <text>行动</text>
        <text>回流</text>
      </view>
    </view>
    <image class="entry-image" mode="aspectFill" src="{{scene.heroImage}}" />
  </view>

  <view class="entry-loop-rail">
    <view
      class="entry-loop-node {{item.key === sceneKey ? 'active' : ''}}"
      wx:for="{{loopNodes}}"
      wx:key="key"
      data-scene="{{item.key}}"
      bindtap="openScene"
    >
      <image mode="aspectFit" src="{{item.image}}" />
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="entry-actions">
    <button class="entry-primary" bindtap="goPrimary">{{scene.primaryLabel}}</button>
    <button class="entry-secondary" bindtap="goSecondary">{{scene.secondaryLabel}}</button>
  </view>

  <view class="entry-spotlight scene-{{sceneKey}}" wx:if="{{scene.spotlight}}">
    <view class="entry-spotlight-main">
      <view class="entry-spotlight-kicker">{{scene.spotlight.kicker}}</view>
      <view class="entry-spotlight-title">{{scene.spotlight.title}}</view>
      <view class="entry-spotlight-metrics">
        <view wx:for="{{scene.spotlight.metrics}}" wx:key="label">
          <text>{{item.label}}</text>
          <text>{{item.value}}</text>
        </view>
      </view>
    </view>
    <image class="entry-spotlight-image" mode="aspectFit" src="{{scene.spotlight.image}}" />
    <view class="entry-spotlight-points">
      <view wx:for="{{scene.spotlight.points}}" wx:key="*this">
        <text></text>
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="entry-card-grid">
    <view class="entry-card" wx:for="{{scene.cards}}" wx:key="label">
      <image class="entry-card-icon" mode="aspectFill" src="{{item.icon}}" />
      <view>
        <view class="entry-card-label">{{item.label}}</view>
        <view class="entry-card-value">{{item.value}}</view>
      </view>
    </view>
  </view>

  <view class="entry-jump-section">
    <view class="entry-jump-title">
      <text>继续看其他入口</text>
      <text>每个入口只看一件事，点开后再进入下一步</text>
    </view>
    <view class="entry-jump-grid">
      <button class="entry-jump-card" wx:for="{{sceneLinks}}" wx:key="key" data-scene="{{item.key}}" bindtap="openScene">
        <image mode="aspectFit" src="{{item.image}}" />
        <text>{{item.label}}</text>
      </button>
    </view>
  </view>

  <view class="entry-proof-strip">
    <button
      class="entry-proof-node {{item.active ? 'active' : ''}} {{index === scene.proofSteps.length - 1 ? 'final' : ''}}"
      wx:for="{{scene.proofSteps}}"
      wx:key="label"
      data-scene="{{item.scene}}"
      bindtap="openScene"
    >
      <image class="entry-proof-icon" mode="aspectFit" src="{{item.icon}}" />
      <text>{{item.label}}</text>
      <text class="entry-proof-hint">{{item.hint}}</text>
    </button>
  </view>
</view>
