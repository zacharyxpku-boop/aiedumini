<view class="entry-detail-page">
  <view class="entry-detail-top">
    <button class="entry-back" bindtap="goBack">‹</button>
    <view class="entry-brand">
      <image mode="aspectFit" src="/assets/reference/brand-house.png" />
      <text>原点智学</text>
    </view>
  </view>

  <view class="entry-detail-hero scene-{{sceneKey}}">
    <view>
      <view class="entry-badge">{{scene.badge}}</view>
      <view class="entry-title">{{scene.title}}</view>
      <view class="entry-subtitle">{{scene.subtitle}}</view>
      <view class="entry-mini-path">
        <text>依据</text>
        <text>行动</text>
        <text>回流</text>
      </view>
    </view>
    <image class="entry-image" mode="aspectFill" src="{{scene.heroImage}}" />
  </view>

  <view class="entry-loop-rail">
    <view
      class="entry-loop-node {{item.key === sceneKey ? 'active' : ''}}"
      wx:for="{{loopNodes}}"
      wx:key="key"
      data-scene="{{item.key}}"
      bindtap="openScene"
    >
      <image mode="aspectFit" src="{{item.image}}" />
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="entry-actions">
    <button class="entry-primary" bindtap="goPrimary">{{scene.primaryLabel}}</button>
    <button class="entry-secondary" bindtap="goSecondary">{{scene.secondaryLabel}}</button>
  </view>

  <view class="entry-card-grid">
    <view class="entry-card" wx:for="{{scene.cards}}" wx:key="label">
      <view class="entry-card-icon">{{index + 1}}</view>
      <view>
        <view class="entry-card-label">{{item.label}}</view>
        <view class="entry-card-value">{{item.value}}</view>
      </view>
    </view>
  </view>

  <view class="entry-jump-section">
    <view class="entry-jump-title">
      <text>继续看其他入口</text>
      <text>切换后仍在当前子页面，不回到长下拉</text>
    </view>
    <view class="entry-jump-grid">
      <button class="entry-jump-card" wx:for="{{sceneLinks}}" wx:key="key" data-scene="{{item.key}}" bindtap="openScene">
        <image mode="aspectFit" src="{{item.image}}" />
        <text>{{item.label}}</text>
      </button>
    </view>
  </view>

  <view class="entry-proof-strip">
    <view class="entry-proof-node">
      <image class="entry-proof-icon" mode="aspectFit" src="/assets/reference/entry-report.png" />
      <text>先看依据</text>
    </view>
    <view class="entry-proof-node">
      <image class="entry-proof-icon" mode="aspectFit" src="/assets/reference/entry-tutor.png" />
      <text>再做一步</text>
    </view>
    <view class="entry-proof-node final">
      <image class="entry-proof-icon" mode="aspectFit" src="/assets/reference/entry-parent.png" />
      <text>回流证据</text>
    </view>
  </view>
</view>
