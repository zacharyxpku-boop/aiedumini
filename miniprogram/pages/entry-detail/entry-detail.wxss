.entry-detail-page {
  min-height: 100vh;
  padding: calc(44rpx + env(safe-area-inset-top)) 28rpx calc(72rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 10%, rgba(248, 198, 34, 0.16), transparent 22%),
    radial-gradient(circle at 88% 8%, rgba(76, 159, 255, 0.10), transparent 20%),
    linear-gradient(180deg, rgba(34, 185, 92, 0.045), rgba(255, 255, 255, 0) 34%),
    #fbfcfa;
  color: #203127;
}

.entry-detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.entry-back {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background: #ffffff;
  color: #203127;
  font-size: 44rpx;
  line-height: 72rpx;
  box-shadow: 0 12rpx 24rpx rgba(32, 49, 39, 0.07);
}

.entry-brand {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx 10rpx 12rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 999rpx;
  background: #ffffff;
  color: #174c3d;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(32, 49, 39, 0.05);
}

.entry-brand image {
  width: 36rpx;
  height: 36rpx;
}

.entry-detail-hero {
  position: relative;
  min-height: 302rpx;
  padding: 28rpx 26rpx;
  overflow: hidden;
  border: 1rpx solid #e8eee6;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 86% 20%, rgba(34, 185, 92, 0.13), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #f3fbef 100%);
  display: grid;
  grid-template-columns: minmax(0, 1fr) 210rpx;
  gap: 10rpx;
  align-items: center;
  box-shadow: 0 22rpx 50rpx rgba(42, 68, 52, 0.08);
}

.entry-detail-hero::before {
  content: "";
  position: absolute;
  right: -58rpx;
  bottom: -54rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 58rpx;
  background: rgba(34, 185, 92, 0.10);
  transform: rotate(-12deg);
}

.entry-detail-hero::after {
  content: "";
  position: absolute;
  left: 30rpx;
  bottom: 28rpx;
  width: 86rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #f8c622;
  transform: rotate(-5deg);
}

.entry-detail-hero.scene-tutor {
  background:
    radial-gradient(circle at 84% 18%, rgba(76, 159, 255, 0.16), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #eef7ff 100%);
}

.entry-detail-hero.scene-review {
  background:
    radial-gradient(circle at 84% 18%, rgba(248, 198, 34, 0.18), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #fff8df 100%);
}

.entry-detail-hero.scene-parent {
  background:
    radial-gradient(circle at 84% 18%, rgba(255, 122, 69, 0.15), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #fff1ea 100%);
}

.entry-detail-hero.scene-upload {
  background:
    radial-gradient(circle at 84% 18%, rgba(34, 185, 92, 0.17), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #eefbed 100%);
}

.entry-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e9f8ef;
  color: #16a34a;
  font-size: 21rpx;
  font-weight: 850;
  margin-bottom: 14rpx;
}

.entry-title {
  position: relative;
  z-index: 1;
  font-size: 42rpx;
  line-height: 1.12;
  font-weight: 950;
  letter-spacing: 0;
}

.entry-subtitle {
  position: relative;
  z-index: 1;
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  font-size: 24rpx;
  line-height: 1.46;
  color: #56645c;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.entry-mini-path {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  max-width: 330rpx;
  margin-top: 18rpx;
}

.entry-mini-path text {
  min-height: 44rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(34, 185, 92, 0.15);
  color: #174c3d;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 44rpx;
  text-align: center;
  white-space: nowrap;
}

.entry-image {
  position: relative;
  z-index: 1;
  width: 210rpx;
  height: 210rpx;
  justify-self: end;
  overflow: hidden;
  border: 0;
  border-radius: 34rpx;
  filter: drop-shadow(0 18rpx 24rpx rgba(47, 88, 58, 0.14));
}

.entry-actions {
  display: grid;
  grid-template-columns: 1.15fr .85fr;
  gap: 12rpx;
  margin: 14rpx 0;
}

.entry-loop-rail {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 12rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 14rpx 30rpx rgba(32, 49, 39, 0.045);
}

.entry-loop-node {
  position: relative;
  display: grid;
  min-width: 0;
  min-height: 108rpx;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border-radius: 22rpx;
  color: #5a675f;
  background: #f9fbf7;
  font-size: 20rpx;
  font-weight: 900;
  overflow: hidden;
}

.entry-loop-node::after {
  content: "";
  position: absolute;
  right: -24rpx;
  bottom: -26rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(34, 185, 92, 0.08);
}

.entry-loop-node.active {
  color: #0d7a3d;
  background: linear-gradient(180deg, #eaf9ef 0%, #ffffff 100%);
  box-shadow: inset 0 0 0 2rpx rgba(34, 185, 92, 0.18);
}

.entry-loop-node image {
  width: 54rpx;
  height: 54rpx;
  position: relative;
  z-index: 1;
}

.entry-loop-node text {
  position: relative;
  z-index: 1;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-primary,
.entry-secondary {
  min-height: 78rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.2;
}

.entry-primary {
  background: linear-gradient(180deg, #ffd84d 0%, #f8c622 100%);
  color: #183023;
  box-shadow: 0 16rpx 28rpx rgba(248, 198, 34, 0.24);
}

.entry-secondary {
  background: #ffffff;
  color: #16a34a;
  border: 2rpx solid rgba(34, 185, 92, 0.22);
}

.entry-card-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.entry-card {
  min-width: 0;
  min-height: 178rpx;
  padding: 16rpx 14rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  justify-items: start;
  gap: 10rpx;
  box-shadow: 0 12rpx 26rpx rgba(32, 49, 39, 0.045);
}

.entry-card-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  color: #174c3d;
  background:
    radial-gradient(circle at 34% 30%, rgba(255,255,255,0.8), transparent 34%),
    #f8c622;
  font-size: 24rpx;
  font-weight: 1000;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 10rpx 18rpx rgba(248, 198, 34, 0.22);
}

.entry-card-label {
  overflow: hidden;
  color: #16a34a;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.2;
  text-align: left;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-card-label::before {
  display: none;
}

.entry-card-value {
  display: -webkit-box;
  overflow: hidden;
  color: #455149;
  font-size: 20rpx;
  line-height: 1.34;
  text-align: left;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.entry-jump-section {
  margin-top: 14rpx;
  padding: 20rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(32, 49, 39, 0.05);
}

.entry-jump-title {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.entry-jump-title text:first-child {
  color: #203127;
  font-size: 24rpx;
  font-weight: 950;
}

.entry-jump-title text:last-child {
  color: #6c7970;
  font-size: 20rpx;
  font-weight: 760;
}

.entry-jump-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.entry-jump-card {
  min-width: 0;
  min-height: 136rpx;
  padding: 14rpx 10rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 8rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f4fbf1 100%);
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.1;
}

.entry-jump-card:nth-child(2n) {
  background: linear-gradient(180deg, #ffffff 0%, #eef7ff 100%);
}

.entry-jump-card:nth-child(3n) {
  background: linear-gradient(180deg, #ffffff 0%, #fff8df 100%);
}

.entry-jump-card image {
  width: 82rpx;
  height: 82rpx;
}

.entry-jump-card text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-proof-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.entry-proof-node {
  position: relative;
  display: grid;
  min-width: 0;
  min-height: 106rpx;
  justify-items: center;
  align-content: center;
  gap: 6rpx;
  padding: 12rpx 8rpx;
  border: 1rpx solid #e8eee6;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8faf5 100%);
  box-shadow: 0 12rpx 24rpx rgba(32, 49, 39, 0.05);
  overflow: visible;
}

.entry-proof-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.entry-proof-node:last-child::after {
  display: none;
}

.entry-proof-node.final {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.entry-proof-icon {
  width: 44rpx;
  height: 44rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #eef7ff;
}

.entry-proof-node.final .entry-proof-icon {
  background: #fff1bd;
}

.entry-proof-strip text {
  overflow: hidden;
  max-width: 100%;
  color: #17211d;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media (max-height: 760px) {
  .entry-detail-page {
    padding-top: calc(44rpx + env(safe-area-inset-top));
  }

  .entry-detail-hero {
    min-height: 270rpx;
  }

  .entry-title {
    font-size: 36rpx;
  }

  .entry-card {
    min-height: 158rpx;
  }

  .entry-proof-strip {
    margin-top: 14rpx;
  }
}
