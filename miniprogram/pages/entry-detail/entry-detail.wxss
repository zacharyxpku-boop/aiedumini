.entry-detail-page {
  min-height: 100vh;
  padding: calc(46rpx + env(safe-area-inset-top)) 32rpx calc(76rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 8%, rgba(248, 198, 34, 0.14), transparent 26%),
    radial-gradient(circle at 92% 18%, rgba(34, 185, 92, 0.12), transparent 24%),
    #f8f4e9;
  color: #203127;
}

.entry-detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.entry-back {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background: #ffffff;
  color: #203127;
  font-size: 44rpx;
  line-height: 72rpx;
  box-shadow: 0 14rpx 30rpx rgba(32, 49, 39, 0.08);
}

.entry-brand {
  padding: 12rpx 18rpx;
  border: 1rpx solid rgba(23, 76, 61, 0.10);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #174c3d;
  font-size: 24rpx;
  font-weight: 900;
}

.entry-detail-hero {
  min-height: 256rpx;
  padding: 24rpx 22rpx 22rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 86% 18%, rgba(248, 198, 34, 0.22), transparent 28%),
    linear-gradient(145deg, #fffdf8 0%, #e8f6dd 100%);
  display: grid;
  grid-template-columns: minmax(0, 1fr) 148rpx;
  gap: 12rpx;
  align-items: center;
  box-shadow: 0 22rpx 48rpx rgba(32, 49, 39, 0.09);
}

.entry-badge {
  display: inline-flex;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  background: #174c3d;
  color: #fff7df;
  font-size: 21rpx;
  font-weight: 850;
  margin-bottom: 14rpx;
}

.entry-title {
  font-size: 36rpx;
  line-height: 1.12;
  font-weight: 950;
  letter-spacing: 0;
}

.entry-subtitle {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  font-size: 22rpx;
  line-height: 1.42;
  color: #56645c;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.entry-image {
  width: 148rpx;
  height: 154rpx;
  justify-self: end;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 28rpx;
}

.entry-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 16rpx 0;
}

.entry-primary,
.entry-secondary {
  min-height: 70rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1.2;
}

.entry-primary {
  background: #174c3d;
  color: #fff7df;
}

.entry-secondary {
  background: #ffffff;
  color: #174c3d;
  border: 2rpx solid rgba(23, 76, 61, 0.16);
}

.entry-card-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.entry-card {
  min-width: 0;
  min-height: 150rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: #ffffff;
  display: grid;
  align-content: start;
  gap: 10rpx;
  box-shadow: 0 14rpx 28rpx rgba(32, 49, 39, 0.06);
}

.entry-card-label {
  overflow: hidden;
  color: #174c3d;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.2;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-card-label::before {
  content: "";
  display: block;
  width: 34rpx;
  height: 34rpx;
  margin: 0 auto 8rpx;
  border-radius: 14rpx;
  background:
    radial-gradient(circle at 50% 50%, #f8c622 0 8rpx, transparent 9rpx),
    rgba(34, 185, 92, 0.13);
  box-shadow: inset 0 0 0 1rpx rgba(34, 185, 92, 0.12);
}

.entry-card-value {
  display: -webkit-box;
  overflow: hidden;
  color: #455149;
  font-size: 20rpx;
  line-height: 1.36;
  text-align: center;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.entry-proof-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(23, 76, 61, 0.10);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.78);
}

.entry-proof-strip view {
  display: grid;
  min-width: 0;
  grid-template-columns: 30rpx minmax(0, 1fr);
  gap: 7rpx;
  align-items: center;
}

.entry-proof-strip text:first-child {
  width: 30rpx;
  height: 30rpx;
  color: #174c3d;
  background: #f8c622;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 1000;
  line-height: 30rpx;
  text-align: center;
}

.entry-proof-strip text:last-child {
  overflow: hidden;
  color: #4f5f56;
  font-size: 18rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media (max-height: 760px) {
  .entry-detail-page {
    padding-top: calc(44rpx + env(safe-area-inset-top));
  }

  .entry-detail-hero {
    min-height: 270rpx;
  }

  .entry-title {
    font-size: 36rpx;
  }

  .entry-card {
    min-height: 150rpx;
  }

  .entry-proof-strip {
    margin-top: 14rpx;
  }
}
