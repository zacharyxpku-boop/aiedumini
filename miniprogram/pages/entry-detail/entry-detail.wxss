.entry-detail-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
  background: #f8f4e9;
  color: #203127;
}

.entry-detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.entry-back {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background: #ffffff;
  color: #203127;
  font-size: 44rpx;
  line-height: 72rpx;
  box-shadow: 0 14rpx 30rpx rgba(32, 49, 39, 0.08);
}

.entry-brand {
  font-size: 28rpx;
  font-weight: 800;
}

.entry-detail-hero {
  min-height: 360rpx;
  padding: 38rpx 34rpx 30rpx;
  border-radius: 40rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #e8f6dd 100%);
  display: grid;
  grid-template-columns: 1fr 210rpx;
  gap: 18rpx;
  align-items: center;
  box-shadow: 0 28rpx 60rpx rgba(32, 49, 39, 0.1);
}

.entry-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #174c3d;
  color: #fff7df;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 26rpx;
}

.entry-title {
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 900;
  letter-spacing: 0;
}

.entry-subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #56645c;
}

.entry-image {
  width: 210rpx;
  height: 250rpx;
}

.entry-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 26rpx 0;
}

.entry-primary,
.entry-secondary {
  height: 92rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.entry-primary {
  background: #174c3d;
  color: #fff7df;
}

.entry-secondary {
  background: #ffffff;
  color: #174c3d;
  border: 2rpx solid rgba(23, 76, 61, 0.16);
}

.entry-card-grid {
  display: grid;
  gap: 18rpx;
}

.entry-card {
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 160rpx 1fr;
  gap: 16rpx;
  align-items: start;
  box-shadow: 0 18rpx 40rpx rgba(32, 49, 39, 0.07);
}

.entry-card-label {
  font-size: 26rpx;
  font-weight: 900;
  color: #174c3d;
}

.entry-card-value {
  font-size: 26rpx;
  line-height: 1.45;
  color: #455149;
}
