<view class="tutor-page safe-bottom">
  <view class="tutor-shell">

    <scroll-view class="tutor-main" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="main-inner">
        <view class="tutor-hero-shell ux-entry ux-entry-tutor ux-kit-screen ux-kit-tutor">
          <view class="tutor-dash-top">
            <view class="tutor-dash-brand">
              <image class="tutor-dash-mark" mode="aspectFit" src="/assets/reference/brand-house.png" />
              <view>
                <text>原小点</text>
                <text>只追问第一步</text>
              </view>
            </view>
            <view class="tutor-dash-pill" bindtap="goRadar">看报告</view>
          </view>

          <view class="tutor-dash-hero">
            <image class="tutor-dash-mascot" mode="aspectFill" src="/assets/brand/gudian-reader.png" />
            <view class="tutor-dash-bubble">
              <view>你先说第一步</view>
              <text>咕点不会替你写答案。你说题目或卡点，它只问下一句最小提示。</text>
              <view class="tutor-chip-row">
                <text>不给完整答案</text>
                <text>只问依据</text>
              </view>
            </view>
          </view>

          <view class="tutor-flow-card">
            <view class="tutor-section-head">
              <text>原小点点拨边界</text>
              <text>先启动，再迁移</text>
            </view>
            <view class="tutor-ladder">
              <view class="tutor-ladder-node active">
                <image class="tutor-ladder-icon" mode="aspectFit" src="/assets/reference/entry-tutor.png" />
                <text>说卡点</text>
                <text>孩子先讲</text>
              </view>
              <view class="tutor-ladder-node">
                <image class="tutor-ladder-icon" mode="aspectFit" src="/assets/reference/entry-report.png" />
                <text>问依据</text>
                <text>不猜答案</text>
              </view>
              <view class="tutor-ladder-node">
                <image class="tutor-ladder-icon" mode="aspectFit" src="/assets/reference/entry-map.png" />
                <text>小提示</text>
                <text>只给一步</text>
              </view>
              <view class="tutor-ladder-node final">
                <image class="tutor-ladder-icon" mode="aspectFit" src="/assets/reference/entry-review.png" />
                <text>进复习</text>
                <text>留下证据</text>
              </view>
            </view>
          </view>

          <view class="tutor-entry-grid ux-kit-jump-grid">
            <view class="tutor-entry-card ux-kit-jump-card primary" data-scene="tutor" bindtap="openEntryDetail">
              <image mode="aspectFill" src="/assets/reference/entry-tutor.png" />
              <text>发题目</text>
              <text>先说卡在哪里</text>
            </view>
            <view class="tutor-entry-card ux-kit-jump-card" data-scene="today" bindtap="openEntryDetail">
              <image mode="aspectFill" src="/assets/reference/entry-map.png" />
              <text>排顺序</text>
              <text>今晚先做哪题</text>
            </view>
            <view class="tutor-entry-card ux-kit-jump-card" data-scene="review" bindtap="openEntryDetail">
              <image mode="aspectFill" src="/assets/reference/entry-review.png" />
              <text>沉淀卡</text>
              <text>说完加入复习</text>
            </view>
          </view>

          <view class="tutor-action-row">
            <view class="tutor-primary" data-scene="tutor" bindtap="openEntryDetail">发送第一步</view>
            <view class="tutor-secondary" data-scene="review" bindtap="openEntryDetail">加入复习卡</view>
          </view>
        </view>
        <view class="tutor-subcheck ux-kit-subcheck">
          <view class="subcheck-main" data-scene="tutor" bindtap="openEntryDetail">
            <view class="subcheck-copy">
              <text>今天只做一件事</text>
              <text>把卡住的题说出第一步，不要直接要答案。</text>
            </view>
            <image class="subcheck-art" mode="aspectFill" src="/assets/brand/gudian-reader.png" />
          </view>
          <view class="subcheck-side">
            <view data-scene="review" bindtap="openEntryDetail">
              <image class="subcheck-side-icon" mode="aspectFill" src="/assets/reference/entry-review.png" />
              <text>沉淀卡点</text><text>说完自动进复习</text>
            </view>
            <view data-scene="parent" bindtap="openEntryDetail">
              <image class="subcheck-side-icon" mode="aspectFill" src="/assets/reference/entry-parent.png" />
              <text>家长看证据</text><text>只问一句</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

  </view>
</view>
