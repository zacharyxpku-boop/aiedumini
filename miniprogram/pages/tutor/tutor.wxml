<view class="tutor-page safe-bottom">
  <view class="tutor-shell">
    <view class="page-positioning socratic-positioning">
      <view class="positioning-kicker">作业点拨</view>
      <view class="positioning-title">咕点用追问陪你说第一步，不直接讲答案</view>
      <view class="positioning-flow">先说你准备怎么开始，咕点再给下一句提示；说清以后去专注舱坐一段。</view>
      <view class="positioning-actions">
        <button bindtap="goFocus">带着这一小步去专注</button>
        <button bindtap="goReview">把卡点整理成错题卡</button>
      </view>
    </view>
    <view class="top-nav">
      <button class="home-back" bindtap="goHome">首页</button>
      <view class="nav-brand">
        <view class="brand-title">原点智学</view>
        <view class="brand-subtitle">作业点拨只说一步</view>
      </view>
      <button class="nav-pill" bindtap="goRadar"><text class="nav-dot"></text>只问一步</button>
    </view>

    <scroll-view class="tutor-main" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="main-inner">
        <view class="chat-card">
          <view class="chat-head">
            <view class="chat-avatar">
              <view class="chat-avatar-eye"></view>
              <view class="chat-avatar-eye"></view>
            </view>
            <view class="chat-head-copy">
              <view class="chat-kicker">和原小点对话</view>
              <view class="chat-title">把题目或第一步发过来</view>
              <view class="chat-subtitle">简单题直接核对，卡住时只点拨下一步。</view>
            </view>
            <view class="chat-live-dot"></view>
          </view>
          <scroll-view class="chat" scroll-y>
            <view class="message {{item.role}}" wx:for="{{messages}}" wx:key="index">
              <view class="bubble">
                <view class="hint-label" wx:if="{{item.hint_label}}">{{item.hint_label}}</view>
                <text>{{item.text}}</text>
              </view>
            </view>
            <view class="message assistant" wx:if="{{loading}}">
              <view class="bubble">我先看一步。</view>
            </view>
          </scroll-view>
          <view class="chat-suggestion-row">
            <button class="suggestion-pill {{activeStep === item.id ? 'active' : ''}}" wx:for="{{quickActions}}" wx:key="id" wx:if="{{index < 4}}" data-step="{{item.id}}" bindtap="sendQuick">
              {{item.label}}
            </button>
          </view>
        </view>

        <view class="selected-card" wx:if="{{selected}}">
          <view class="selected-label">今晚必须做</view>
          <view class="selected-text">{{selected.text}}</view>
          <view class="selected-reason" wx:if="{{selected.reason}}">{{selected.reason}}</view>
        </view>

        <view class="mode-strip">
          <scroll-view class="mode-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
            <view class="chips-grid">
              <button class="chip {{activeStep === item.id ? 'active' : ''}}" wx:for="{{quickActions}}" wx:key="id" wx:if="{{index >= 4 && index < 8}}" data-step="{{item.id}}" bindtap="sendQuick">
                {{item.label}}
              </button>
            </view>
          </scroll-view>
          <button class="must-do-mini" bindtap="quickStart">锁定今晚</button>
        </view>

        <view class="receipt-card" wx:if="{{thinkingReceipt}}">
          <view class="receipt-head">
            <view>
              <view class="receipt-title">这轮卡点 · 思路记录</view>
              <view class="receipt-subtitle">{{thinkingReceipt.status}}</view>
            </view>
            <view class="receipt-score">{{thinkingReceipt.score}}</view>
          </view>
          <view class="receipt-focus">{{thinkingReceipt.focus}}</view>
          <view class="receipt-diagnostic" wx:if="{{thinkingReceipt.diagnostic_probe}}">
            <view class="receipt-diagnostic-title">这轮怎么追问</view>
            <view class="receipt-diagnostic-line">{{thinkingReceipt.diagnostic_probe.prompt}}</view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.diagnostic_probe.goal}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.firstStepBoard}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.firstStepBoard.title}}</view>
            <view class="receipt-board-body">{{thinkingReceipt.firstStepBoard.body}}</view>
            <view class="receipt-board-structure">{{thinkingReceipt.firstStepBoard.structure}}</view>
            <view class="receipt-board-line">第一步：{{thinkingReceipt.firstStepBoard.firstMove}}</view>
            <view class="receipt-board-line">孩子说：{{thinkingReceipt.firstStepBoard.childPrompt}}</view>
            <view class="receipt-board-parent">家长只问：{{thinkingReceipt.firstStepBoard.parentPrompt}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.firstStepBoard.avoid}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.subjectSkillDepth}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.subjectSkillDepth.label}}</view>
            <view class="receipt-board-line">第一步：{{thinkingReceipt.subjectSkillDepth.firstStep}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.subjectSkillDepth.blackboard}}" wx:key="order">{{item.order}}. {{item.text}}</view>
            <view class="receipt-board-parent">家长只问：{{thinkingReceipt.subjectSkillDepth.parentQuestion}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.subjectSkillDepth.reportSignal}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.subjectSkillDepth.socraticAssessment}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.subjectSkillDepth.socraticAssessment.title}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.misconceptionChecks}}" wx:key="id">误区{{item.order}}：{{item.text}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.probeSequence}}" wx:key="id">追问{{item.order}}：{{item.text}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.recoveryMoves}}" wx:key="id">答不上来：{{item.text}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.questionTypeRubric}}" wx:key="id">题型轴{{item.order}}：{{item.misconception}}｜{{item.probe}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.visualExplanationSteps}}" wx:key="id">{{item.boardMove}}｜{{item.childReply}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.subjectSkillDepth.socraticAssessment.fallbackLadder}}" wx:key="id">兜底：{{item.label}}｜{{item.move}}</view>
            <view class="receipt-board-avoid">迁移检查：{{thinkingReceipt.subjectSkillDepth.socraticAssessment.transferCheck}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.subjectSkillDepth.socraticAssessment.evidenceContractLine}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.question_type_socratic_path}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.question_type_socratic_path.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.question_type_socratic_path.scaleLine}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.question_type_socratic_path.probeBank}}" wx:key="id">追问轴{{item.order}}：{{item.misconception}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.question_type_socratic_path.visualMoves}}" wx:key="id">{{item.boardMove}}｜{{item.parentPrompt}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.question_type_socratic_path.fallbackLadder}}" wx:key="id">失败兜底：{{item.label}}｜{{item.move}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.question_type_socratic_path.evidenceContractLine}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.question_type_socratic_path.noFullAnswerBoundary}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.questionTypeCoverageAtlas}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.questionTypeCoverageAtlas.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.questionTypeCoverageAtlas.summary}}</view>
            <view class="receipt-board-line">当前轴：{{thinkingReceipt.questionTypeCoverageAtlas.activeLine}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.questionTypeCoverageAtlas.paths}}" wx:key="id">{{item.taskType}}：{{item.probeCount}} 追问 / {{item.visualMoveCount}} 小黑板 / {{item.fallbackCount}} 兜底</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.questionTypeCoverageAtlas.boundary}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.socraticQualityEvaluationSuite}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.socraticQualityEvaluationSuite.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.socraticQualityEvaluationSuite.summary}}</view>
            <view class="receipt-board-line">{{thinkingReceipt.socraticQualityEvaluationSuite.reportLine}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.socraticQualityEvaluationSuite.gates}}" wx:key="*this">门槛：{{item}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.socraticQualityEvaluationSuite.activeCase.scenarios}}" wx:key="id">{{item.trigger}}：{{item.expectedMove}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.socraticQualityEvaluationSuite.activeCase.passLine}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.socraticQualityEvaluationSuite.shareBoundary}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.courseUnitQuestionBank}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.courseUnitQuestionBank.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.courseUnitQuestionBank.summary}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.courseUnitQuestionBankCards}}" wx:key="id">{{item.sampleStem}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.courseUnitQuestionBankCards}}" wx:key="id">第一步：{{item.firstStepHint}} / 小黑板：{{item.blackboardMove}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.courseUnitQuestionBankCards}}" wx:key="id">近迁移：{{item.nearTransferStem}} / 家长：{{item.parentCheck}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.courseUnitQuestionBankCards}}" wx:key="id">进阶：{{item.progression.entryTask}} / 掌握门槛：{{item.progression.masteryGate}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.courseUnitQuestionBankCards}}" wx:key="id">明天回访：{{item.progression.nextDayRevisit}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.courseUnitQuestionBank.boundary}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.sevenSubjectMasterySprint}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.sevenSubjectMasterySprint.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.sevenSubjectMasterySprint.tutorBoundaryLine}}</view>
            <view class="receipt-board-line">{{thinkingReceipt.sevenSubjectMasterySprint.summary}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.sevenSubjectMasterySprint.lanes}}" wx:key="id">{{item.label}}：{{item.target}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.sevenSubjectMasterySprint.moatLine}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.visualSocraticMatrix}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.visualSocraticMatrix.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.visualSocraticMatrix.visualBoundary}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.visualSocraticMatrix.boardMoves}}" wx:key="id">{{item.order}}. {{item.drawAction}}：{{item.evidence}}</view>
            <view class="receipt-board-line" wx:if="{{thinkingReceipt.visualSocraticMatrix.blackboardBlueprint}}">{{thinkingReceipt.visualSocraticMatrix.blackboardBlueprint.openingQuestion}}</view>
            <view class="receipt-board-parent" wx:if="{{thinkingReceipt.visualSocraticMatrix.blackboardBlueprint}}">{{thinkingReceipt.visualSocraticMatrix.blackboardBlueprint.stopRule}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.visualSocraticMatrix.socraticQuestions}}" wx:key="id">追问{{item.order}}：{{item.question}}</view>
            <view class="receipt-board-line">{{thinkingReceipt.visualSocraticMatrix.fallback.whenSilent}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.visualSocraticMatrix.fallback.whenAsksAnswer}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.activeCourseUnit}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.activeCourseUnit.subjectLabel}} · {{thinkingReceipt.activeCourseUnit.unitLabel}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.courseUnitMap.boundary}}</view>
            <view class="receipt-board-line">{{thinkingReceipt.activeCourseUnit.blackboardBlueprint.title}}</view>
            <view class="receipt-board-line">{{thinkingReceipt.activeCourseUnit.blackboardBlueprint.firstStroke}}</view>
            <view class="receipt-board-parent">{{thinkingReceipt.activeCourseUnit.blackboardBlueprint.stopRule}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.activeCourseUnit.diagnosticProbes}}" wx:key="*this">单元追问：{{item}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.activeCourseUnit.wrongCauseAtlas}}" wx:key="*this">错因谱：{{item}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.activeCourseUnit.practiceLoop.repair}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.activeCourseUnit.reportContract}}</view>
          </view>
          <view class="receipt-first-step-board" wx:if="{{thinkingReceipt.commercialDepthRunway}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.commercialDepthRunway.title}}</view>
            <view class="receipt-board-avoid">{{thinkingReceipt.commercialDepthRunway.boundary}}</view>
            <view class="receipt-board-line" wx:for="{{thinkingReceipt.commercialDepthRunway.lanes}}" wx:key="id">{{item.label}}：{{item.nextAction}}</view>
            <view class="receipt-board-parent" wx:for="{{thinkingReceipt.commercialDepthRunway.visualBoardMoves}}" wx:key="*this">小黑板：{{item}}</view>
          </view>
          <view class="receipt-contract" wx:if="{{thinkingReceipt.socratic_contract}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.socratic_contract.title}}</view>
            <view class="receipt-diagnostic-line">为什么这样问：{{thinkingReceipt.socratic_contract.whyThisQuestion}}</view>
            <view class="receipt-diagnostic-line">下一句：{{thinkingReceipt.socratic_contract.nextQuestion}}</view>
            <view class="receipt-diagnostic-sub">停止规则：{{thinkingReceipt.socratic_contract.stopRule}}</view>
            <view class="receipt-diagnostic-sub">沉淀证据：{{thinkingReceipt.socratic_contract.evidenceToSave}}</view>
          </view>
          <view class="receipt-fallback-plan" wx:if="{{thinkingReceipt.socratic_fallback_plan}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.socratic_fallback_plan.title}}</view>
            <view class="receipt-diagnostic-line">触发：{{thinkingReceipt.socratic_fallback_plan.trigger}}</view>
            <view class="receipt-diagnostic-line">降级动作：{{thinkingReceipt.socratic_fallback_plan.firstMove}}</view>
            <view class="receipt-choice-row">
              <text wx:for="{{thinkingReceipt.socratic_fallback_plan.microChoices}}" wx:key="id">{{item.label}}：{{item.text}}</text>
            </view>
            <view class="receipt-diagnostic-sub">家长话术：{{thinkingReceipt.socratic_fallback_plan.parentScript}}</view>
            <view class="receipt-diagnostic-sub">小黑板：{{thinkingReceipt.socratic_fallback_plan.blackboardMove}}</view>
            <view class="receipt-diagnostic-sub">停止规则：{{thinkingReceipt.socratic_fallback_plan.stopRule}}</view>
          </view>
          <view class="receipt-fallback-plan" wx:if="{{thinkingReceipt.visual_socratic_recovery}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.visual_socratic_recovery.title}}</view>
            <view class="receipt-diagnostic-line">兜底模式：{{thinkingReceipt.visual_socratic_recovery.recoveryMode}}</view>
            <view class="receipt-diagnostic-line" wx:for="{{thinkingReceipt.visual_socratic_recovery.boardLayers}}" wx:key="id">小黑板：{{item.label}}｜{{item.move}}</view>
            <view class="receipt-diagnostic-sub" wx:for="{{thinkingReceipt.visual_socratic_recovery.failureBranches}}" wx:key="id">失败分支：{{item.trigger}}｜{{item.move}}</view>
            <view class="receipt-choice-row">
              <text wx:for="{{thinkingReceipt.visual_socratic_recovery.microChoiceScript}}" wx:key="id">{{item.label}}：{{item.text}}</text>
            </view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.visual_socratic_recovery.parentHandoff.line}}</view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.visual_socratic_recovery.parentHandoff.shareBoundary}}</view>
            <view class="receipt-diagnostic-sub" wx:for="{{thinkingReceipt.visual_socratic_recovery.exitCriteria}}" wx:key="*this">退出条件：{{item}}</view>
          </view>
          <view class="receipt-fallback-plan" wx:if="{{thinkingReceipt.fallback_recovery_bridge}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.fallback_recovery_bridge.title}}</view>
            <view class="receipt-diagnostic-line">触发：{{thinkingReceipt.fallback_recovery_bridge.trigger}}</view>
            <view class="receipt-diagnostic-line">下一小步：{{thinkingReceipt.fallback_recovery_bridge.nextSmallAction}}</view>
            <view class="receipt-diagnostic-sub">小黑板：{{thinkingReceipt.fallback_recovery_bridge.blackboardLine}}</view>
            <view class="receipt-diagnostic-sub">微选择：{{thinkingReceipt.fallback_recovery_bridge.microChoiceLine}}</view>
            <view class="receipt-diagnostic-sub" wx:for="{{thinkingReceipt.fallback_recovery_bridge.recoverySequence}}" wx:key="id">{{item.label}}：{{item.action}}</view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.fallback_recovery_bridge.parentDecisionLine}}</view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.fallback_recovery_bridge.reportLine}}</view>
            <view class="receipt-diagnostic-sub">{{thinkingReceipt.fallback_recovery_bridge.shareBoundary}}</view>
          </view>
          <view class="receipt-move-row" wx:if="{{thinkingReceipt.allowed_moves.length}}">
            <text wx:for="{{thinkingReceipt.allowed_moves}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="receipt-transfer" wx:if="{{thinkingReceipt.transfer_prompt}}">{{thinkingReceipt.transfer_prompt}}</view>
          <view class="tutor-handoff-plan" wx:if="{{thinkingReceipt.handoffPlan}}">
            <view class="receipt-diagnostic-title">{{thinkingReceipt.handoffPlan.title}}</view>
            <view class="receipt-diagnostic-line">{{thinkingReceipt.handoffPlan.summary}}</view>
            <view class="tutor-handoff-grid">
              <button
                class="tutor-handoff-action"
                wx:for="{{thinkingReceipt.handoffPlan.actions}}"
                wx:key="id"
                data-id="{{item.id}}"
                data-label="{{item.label}}"
                data-route="{{item.route}}"
                data-reason="{{item.reason}}"
                data-evidence="{{item.evidence}}"
                bindtap="runTutorHandoffAction"
              >
                <text class="tutor-handoff-label">{{item.label}}</text>
                <text class="tutor-handoff-reason">{{item.reason}}</text>
              </button>
            </view>
            <view class="receipt-diagnostic-sub">证据：{{thinkingReceipt.handoffPlan.evidenceLine}}</view>
          </view>
        </view>

        <view class="surface-depth-card tutor-surface-depth" wx:if="{{surfaceDepthPack}}">
          <view class="surface-depth-title">{{surfaceDepthPack.title}}</view>
          <view class="surface-depth-subtitle">{{surfaceDepthPack.summary}}</view>
          <view class="surface-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
          <view class="surface-depth-grid">
            <view class="surface-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
              <text class="surface-depth-chip-title">{{item.displayLabel}}</text>
              <text class="surface-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
            </view>
          </view>
          <view class="surface-depth-note">{{surfaceDepthPack.familyLine}}</view>
        </view>

        <view class="tutor-detail-toggle">
          <view>
            <view class="detail-toggle-title">为什么只提示一步</view>
            <view class="detail-toggle-subtitle">为什么不直接整题代做</view>
          </view>
          <button class="detail-toggle-button" bindtap="toggleTutorDetails">{{showTutorDetails ? '收起' : '展开'}}</button>
        </view>

        <block wx:if="{{showTutorDetails}}">
          <view class="process-section">
            <view class="section-label">今晚怎么一起往下走</view>
            <view class="process-list">
              <view class="process-item">
                <view class="process-num">1</view>
                <view class="process-content">先说一步<text>你提供已知或困惑</text></view>
              </view>
              <view class="process-item">
                <view class="process-num">2</view>
                <view class="process-content">只给最小提示<text>克制启发，保留思考空间</text></view>
              </view>
              <view class="process-item">
                <view class="process-num">3</view>
                <view class="process-content">说出错因<text>定位思维盲区</text></view>
              </view>
              <view class="process-item">
                <view class="process-num">4</view>
                <view class="process-content">用自己的话说回去<text>说清下次先查什么</text></view>
              </view>
            </view>
          </view>

          <view class="coach-strip" wx:if="{{coachConsole}}">
            <view class="coach-item">
              <view class="coach-label">带学原则</view>
              <view class="coach-value">{{coachConsole.currentAction}}</view>
            </view>
            <view class="coach-item">
              <view class="coach-label">今晚先看</view>
              <view class="coach-value">{{coachConsole.wrongCause}}</view>
            </view>
            <view class="coach-item">
              <view class="coach-label">别急着要答案</view>
              <view class="coach-value">{{pasteRisk.level}}</view>
            </view>
          </view>
        </block>

        <view hidden>{{pedagogy.title}}{{pasteRisk.title}}{{coachConsole.title}}</view>
      </view>
    </scroll-view>

    <view class="composer-area">
      <view class="composer-inner">
        <textarea
          class="composer-input"
          value="{{input}}"
          bindinput="onInput"
          auto-height
          maxlength="900"
          placeholder="说第一步，或把题目贴过来。"
        />
        <button class="composer-btn" bindtap="send" loading="{{loading}}" aria-label="发送">
          <text class="send-arrow">➤</text>
        </button>
      </view>
    </view>
  </view>
</view>
