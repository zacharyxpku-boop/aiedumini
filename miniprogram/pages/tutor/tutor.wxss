.chat-card {
  position: relative;
  display: flex;
  min-height: calc(100vh - 318rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  max-height: calc(100vh - 260rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  flex-direction: column;
  overflow: hidden;
  padding: 24rpx 22rpx 18rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 226, 217, 0.78);
  border-radius: 38rpx;
  box-shadow: 0 30rpx 88rpx rgba(45, 44, 42, 0.075);
}

.chat-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(27, 67, 50, 0.045) 2rpx, transparent 2rpx);
  background-size: 28rpx 28rpx;
  pointer-events: none;
}

.chat-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 2rpx 6rpx 20rpx;
}

.chat-head-copy {
  min-width: 0;
  flex: 1;
}

.chat-avatar {
  display: flex;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(242, 212, 121, 0.18);
}

.chat-avatar-eye {
  width: 7rpx;
  height: 7rpx;
  background: #2D2C2A;
  border-radius: 999rpx;
}

.chat-kicker {
  color: #1B4332;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1.15;
}

.chat-title {
  margin-top: 4rpx;
  overflow: hidden;
  color: #2D2C2A;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #8B8982;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-live-dot {
  width: 18rpx;
  height: 18rpx;
  flex: 0 0 auto;
  background: #1B4332;
  border: 4rpx solid #EAF5EE;
  border-radius: 999rpx;
}

.chat {
  position: relative;
  z-index: 1;
  min-height: 0;
  flex: 1;
  height: auto;
  padding: 4rpx 2rpx 12rpx;
  box-sizing: border-box;
}

.message {
  display: flex;
  margin-bottom: 20rpx;
}

.message.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 90%;
  padding: 22rpx 26rpx;
  color: #2D2C2A;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #E5E2D9;
  border-radius: 28rpx;
  border-top-left-radius: 10rpx;
  box-shadow: 0 8rpx 22rpx rgba(45, 44, 42, 0.045);
  font-size: 28rpx;
  font-weight: 760;
  line-height: 1.55;
}

.message.user .bubble {
  color: #FFFFFF;
  background: #1B4332;
  border-color: #1B4332;
  border-top-right-radius: 10rpx;
  border-top-left-radius: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 67, 50, 0.16);
}

.hint-label {
  display: inline-flex;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  color: #1a5336;
  background: rgba(247, 208, 104, 0.28);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.2;
}

.chat-suggestion-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(229, 226, 217, 0.76);
}

.suggestion-pill {
  display: flex;
  min-width: 0;
  min-height: 62rpx;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  overflow: hidden;
  color: #5A5854;
  background: #F4F2EC;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-pill.active {
  color: #1B4332;
  background: #FFF8DE;
  border-color: #1B4332;
}

.composer-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  padding: 18rpx 16rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, #FFFFFF 82%, rgba(255, 255, 255, 0) 100%);
}

.composer-inner {
  display: flex;
  width: 100%;
  max-width: 720rpx;
  min-height: 104rpx;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 34rpx rgba(45, 44, 42, 0.075);
}

.composer-input {
  min-width: 0;
  flex: 1;
  width: 0;
  min-height: 54rpx;
  max-height: 150rpx;
  color: #2D2C2A;
  font-size: 30rpx;
  font-weight: 720;
  line-height: 1.42;
}

.composer-btn {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
}

.send-arrow {
  margin-left: -3rpx;
  font-size: 28rpx;
  line-height: 1;
  transform: rotate(-18deg);
}

.surface-depth-card {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(27, 67, 50, 0.12);
}

.surface-depth-title {
  color: #1B4332;
  font-size: 26rpx;
  font-weight: 1000;
}

.surface-depth-subtitle,
.surface-depth-next,
.surface-depth-note {
  color: #4B5563;
  font-size: 22rpx;
  line-height: 1.45;
}

.surface-depth-next {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #F2D47933;
  font-weight: 850;
}

.surface-depth-grid {
  display: grid;
  gap: 10rpx;
}

.surface-depth-chip {
  display: grid;
  gap: 4rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  background: #fff;
}

.surface-depth-chip.ready {
  background: #ECFDF5;
}

.surface-depth-chip-title {
  color: #111827;
  font-size: 21rpx;
  font-weight: 900;
}

.surface-depth-chip-line {
  color: #6B7280;
  font-size: 19rpx;
  line-height: 1.35;
}

/* Later-tab visual pass: keep the first tutor screen dense and card-like. */
.main-inner {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(138rpx + env(safe-area-inset-bottom));
}

