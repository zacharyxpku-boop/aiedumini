page {
  background: #F4F2EC;
}

.tutor-page {
  min-height: 100vh;
  overflow: hidden;
  color: #2D2C2A;
  background:
    radial-gradient(circle at 50% -80rpx, rgba(242, 212, 121, 0.18), rgba(242, 212, 121, 0) 360rpx),
    #F4F2EC;
}

.tutor-shell {
  position: relative;
  min-height: 100vh;
}

.top-nav {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 140rpx;
  min-height: calc(112rpx + env(safe-area-inset-top));
  align-items: center;
  gap: 14rpx;
  padding: calc(30rpx + env(safe-area-inset-top)) 24rpx 14rpx;
  background: linear-gradient(180deg, #F4F2EC 78%, rgba(244, 242, 236, 0) 100%);
}

.home-back {
  display: flex;
  min-height: 54rpx;
  align-items: center;
  justify-content: center;
  color: #1B4332;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 900;
}

.nav-brand {
  min-width: 0;
}

.brand-title {
  overflow: hidden;
  color: #2D2C2A;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
  letter-spacing: 1rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #8B8982;
  font-size: 21rpx;
  font-weight: 740;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-pill {
  display: flex;
  min-height: 52rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 16rpx;
  color: #5A5854;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 800;
}

.nav-dot {
  width: 12rpx;
  height: 12rpx;
  background: #F2D479;
  border-radius: 999rpx;
}

.tutor-main {
  height: calc(100vh - 112rpx - env(safe-area-inset-top));
}

.main-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 16rpx calc(178rpx + env(safe-area-inset-bottom));
}

.tutor-hero-shell {
  position: relative;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 8% 4%, rgba(248, 198, 34, 0.17), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(34, 185, 92, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

.tutor-dash-top,
.tutor-dash-brand,
.tutor-dash-hero,
.tutor-chip-row,
.tutor-section-head,
.tutor-ladder,
.tutor-entry-grid,
.tutor-action-row {
  box-sizing: border-box;
}

.tutor-dash-top,
.tutor-dash-brand,
.tutor-section-head,
.tutor-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tutor-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.tutor-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  border-radius: 18rpx;
  background: #eef7ff;
  border: 1rpx solid rgba(76, 159, 255, 0.16);
  box-shadow: 0 14rpx 26rpx rgba(76, 159, 255, 0.12);
}

.tutor-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tutor-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.tutor-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.tutor-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.tutor-dash-hero {
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  margin-top: 26rpx;
}

.tutor-dash-mascot {
  width: 194rpx;
  height: 178rpx;
  border-radius: 36rpx;
  background: #effaf0;
}

.tutor-dash-bubble {
  min-width: 0;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
}

.tutor-dash-bubble view:first-child {
  color: #101a16;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.12;
}

.tutor-dash-bubble > text {
  display: block;
  margin-top: 10rpx;
  color: #64706a;
  font-size: 23rpx;
  line-height: 1.55;
}

.tutor-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tutor-chip-row text {
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #f0fbf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 820;
  white-space: nowrap;
}

.tutor-flow-card {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
}

.tutor-section-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.tutor-section-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
}

.tutor-ladder {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.tutor-ladder-node {
  position: relative;
  min-width: 0;
  min-height: 126rpx;
  padding: 13rpx 7rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8faf5 100%);
  box-shadow: 0 12rpx 24rpx rgba(41, 65, 52, 0.07);
  overflow: visible;
}

.tutor-ladder-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.tutor-ladder-node:last-child::after {
  display: none;
}

.tutor-ladder-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 7rpx;
  border-radius: 17rpx;
  background: #f0f8ee;
}

.tutor-ladder-node text:nth-child(2) {
  max-width: 100%;
  color: #17211d;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.tutor-ladder-node text:nth-child(3) {
  max-width: 100%;
  color: #526158;
  font-size: 17rpx;
  font-weight: 780;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.tutor-ladder-node.active {
  border-color: rgba(76, 159, 255, 0.32);
  background: linear-gradient(180deg, #eef7ff 0%, #ffffff 100%);
}

.tutor-ladder-node.final {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.tutor-ladder-node.active .tutor-ladder-icon {
  background: #e5f2ff;
}

.tutor-ladder-node.final .tutor-ladder-icon {
  background: #fff1bd;
}

.tutor-entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.tutor-entry-card {
  min-width: 0;
  min-height: 166rpx;
  padding: 16rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(38, 58, 43, 0.055);
}

.tutor-entry-card.primary {
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf0 100%);
}

.tutor-entry-card image {
  width: 86rpx;
  height: 74rpx;
  border-radius: 18rpx;
}

.tutor-entry-card text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.tutor-entry-card text:nth-child(2) {
  color: #17211d;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.tutor-entry-card text:nth-child(3) {
  color: #66746d;
  font-size: 19rpx;
  line-height: 1.35;
}

.tutor-action-row {
  margin-top: 20rpx;
}

.tutor-primary,
.tutor-secondary {
  flex: 1 1 0;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 76rpx;
  text-align: center;
}

.tutor-primary {
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
}

.tutor-secondary {
  color: #14854a;
  background: #ebf9ed;
}

.hero {
  position: relative;
  padding-top: 4rpx;
}

.

/* Later-tab visual pass: keep the first tutor screen dense and card-like. */
.main-inner {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(138rpx + env(safe-area-inset-bottom));
}

.tutor-hero-shell {
  margin-top: 0;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 34rpx;
}

.tutor-dash-hero {
  grid-template-columns: 176rpx minmax(0, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.tutor-dash-mascot {
  width: 176rpx;
  height: 168rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 36rpx;
}

.tutor-dash-bubble {
  min-height: 168rpx;
  padding: 16rpx;
}

.tutor-dash-bubble view:first-child {
  font-size: 30rpx;
  line-height: 1.12;
}

.tutor-dash-bubble > text {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  font-size: 22rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tutor-chip-row {
  gap: 8rpx;
  margin-top: 12rpx;
}

.tutor-chip-row text {
  padding: 7rpx 12rpx;
  font-size: 19rpx;
}

.tutor-flow-card {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 24rpx;
}

.tutor-ladder {
  gap: 9rpx;
  margin-top: 14rpx;
}

.tutor-ladder-node {
  min-height: 108rpx;
  padding: 10rpx 4rpx;
  border-radius: 19rpx;
}

.tutor-ladder-node::after {
  right: -14rpx;
  width: 18rpx;
}

.tutor-ladder-icon {
  width: 42rpx;
  height: 42rpx;
  padding: 6rpx;
  border-radius: 15rpx;
}

.tutor-ladder-node text:nth-child(2) {
  font-size: 18rpx;
}

.tutor-ladder-node text:nth-child(3) {
  font-size: 16rpx;
}

.tutor-entry-grid {
  gap: 12rpx;
  margin-top: 16rpx;
}

.tutor-entry-card {
  min-height: 132rpx;
  padding: 11rpx 9rpx;
  border-radius: 22rpx;
}

.tutor-entry-card image {
  width: 72rpx;
  height: 56rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.tutor-action-row {
  margin-top: 16rpx;
}

.tutor-primary,
.tutor-secondary {
  height: 70rpx;
  font-size: 24rpx;
  line-height: 70rpx;
}

/* Child-flow polish: entry-detail jumps should not show the older capsule row. */
.top-nav {
  display: none;
}

.tutor-main {
  height: 100vh;
}
