page {
  background: #F4F2EC;
}

.tutor-page {
  min-height: 100vh;
  overflow: hidden;
  color: #2D2C2A;
  background:
    radial-gradient(circle at 50% -80rpx, rgba(242, 212, 121, 0.18), rgba(242, 212, 121, 0) 360rpx),
    #F4F2EC;
}

.tutor-shell {
  position: relative;
  min-height: 100vh;
}

.top-nav {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 140rpx;
  min-height: calc(112rpx + env(safe-area-inset-top));
  align-items: center;
  gap: 14rpx;
  padding: calc(30rpx + env(safe-area-inset-top)) 24rpx 14rpx;
  background: linear-gradient(180deg, #F4F2EC 78%, rgba(244, 242, 236, 0) 100%);
}

.home-back {
  display: flex;
  min-height: 54rpx;
  align-items: center;
  justify-content: center;
  color: #1B4332;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 900;
}

.nav-brand {
  min-width: 0;
}

.brand-title {
  overflow: hidden;
  color: #2D2C2A;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
  letter-spacing: 1rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #8B8982;
  font-size: 21rpx;
  font-weight: 740;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-pill {
  display: flex;
  min-height: 52rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 16rpx;
  color: #5A5854;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 800;
}

.nav-dot {
  width: 12rpx;
  height: 12rpx;
  background: #F2D479;
  border-radius: 999rpx;
}

.tutor-main {
  height: calc(100vh - 112rpx - env(safe-area-inset-top));
}

.main-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 16rpx calc(178rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  padding-top: 4rpx;
}

.hero-decorative-bg {
  position: absolute;
  top: -38rpx;
  right: -22rpx;
  z-index: 0;
  color: rgba(139, 137, 130, 0.08);
  font-family: Georgia, serif;
  font-size: 250rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 0.85;
  pointer-events: none;
}

.hero-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.hero-title-group {
  min-width: 0;
  max-width: 470rpx;
}

.hero-badge {
  color: #1B4332;
  font-size: 23rpx;
  font-weight: 950;
  letter-spacing: 4rpx;
  line-height: 1.2;
}

.hero-title {
  margin-top: 10rpx;
  color: #2D2C2A;
  font-size: 48rpx;
  font-weight: 1000;
  line-height: 1.12;
  letter-spacing: 0;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding-left: 20rpx;
  color: #5A5854;
  border-left: 4rpx solid #F2D479;
  font-size: 25rpx;
  font-weight: 720;
  line-height: 1.5;
}

.mascot-stamp {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  flex: 0 0 auto;
}

.stamp-ring {
  position: absolute;
  inset: 0;
  border: 2rpx dashed rgba(27, 67, 50, 0.48);
  border-radius: 999rpx;
  animation: rotateStamp 20s linear infinite;
}

.stamp-word {
  position: absolute;
  left: 50%;
  width: 128rpx;
  margin-left: -64rpx;
  color: #1B4332;
  font-size: 16rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.stamp-word.top {
  top: 10rpx;
}

.stamp-word.right {
  top: 68rpx;
  transform: rotate(90deg);
}

.stamp-word.bottom {
  bottom: 10rpx;
  transform: rotate(180deg);
}

@keyframes rotateStamp {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.stamp-face {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  width: 66rpx;
  height: 66rpx;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 28rpx rgba(242, 212, 121, 0.48);
  transform: translate(-50%, -50%);
}

.stamp-eye {
  width: 8rpx;
  height: 8rpx;
  background: #2D2C2A;
  border-radius: 999rpx;
}

.selected-card,
.receipt-card {
  padding: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 226, 217, 0.74);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(45, 44, 42, 0.045);
}

.mode-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 0;
  padding: 0 4rpx;
}

.mode-scroll {
  min-width: 0;
  flex: 1;
  white-space: nowrap;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #2D2C2A;
  font-size: 36rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.card-title::after {
  content: "";
  flex: 1;
  height: 1rpx;
  background: #E5E2D9;
}

.chips-grid {
  display: inline-flex;
  gap: 12rpx;
  padding: 2rpx 2rpx 4rpx;
}

.chip {
  display: inline-flex;
  min-width: 142rpx;
  min-height: 56rpx;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  color: #5A5854;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1.25;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(45, 44, 42, 0.035);
}

.chip:active {
  color: #1B4332;
  background: #FFFFFF;
  border-color: #1B4332;
}

.chip.active {
  color: #1B4332;
  background: #FFF8DE;
  border-color: #1B4332;
}

.must-do-mini {
  display: flex;
  min-width: 144rpx;
  min-height: 56rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 67, 50, 0.18);
  font-size: 22rpx;
  font-weight: 950;
}

.btn-primary {
  display: flex;
  width: 100%;
  min-height: 104rpx;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 28rpx;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(27, 67, 50, 0.25);
  font-size: 32rpx;
  font-weight: 1000;
  letter-spacing: 1rpx;
}

.btn-icon {
  color: #F2D479;
  font-size: 32rpx;
}

.selected-card {
  margin-top: 2rpx;
  padding: 24rpx 26rpx;
  background: #FFFCF3;
  border-radius: 30rpx;
}

.selected-label {
  display: inline-flex;
  min-height: 42rpx;
  align-items: center;
  padding: 0 16rpx;
  color: #1B4332;
  background: rgba(242, 212, 121, 0.32);
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
}

.selected-text {
  margin-top: 14rpx;
  color: #2D2C2A;
  font-size: 27rpx;
  font-weight: 1000;
  line-height: 1.42;
}

.selected-reason {
  margin-top: 12rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.46;
}

.process-section {
  padding: 4rpx 0;
}

.tutor-detail-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 4rpx;
  padding: 20rpx 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid #E5E2D9;
  border-radius: 26rpx;
}

.detail-toggle-title {
  color: #2D2C2A;
  font-size: 25rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.detail-toggle-subtitle {
  margin-top: 5rpx;
  color: #8B8982;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.3;
}

.detail-toggle-button {
  display: flex;
  min-width: 104rpx;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  color: #1B4332;
  background: #F2D479;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 54rpx;
}

.section-label {
  color: #8B8982;
  font-size: 21rpx;
  font-style: italic;
  font-weight: 850;
  letter-spacing: 3rpx;
  line-height: 1.3;
  text-align: center;
}

.process-list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 46rpx;
  margin-top: 34rpx;
  padding-left: 68rpx;
}

.process-list::before {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  bottom: 36rpx;
  width: 2rpx;
  background: linear-gradient(180deg, #E5E2D9 0%, #E5E2D9 80%, rgba(229, 226, 217, 0) 100%);
}

.process-item {
  position: relative;
}

.process-num {
  position: absolute;
  left: -68rpx;
  top: -2rpx;
  z-index: 2;
  display: flex;
  width: 46rpx;
  height: 46rpx;
  align-items: center;
  justify-content: center;
  color: #2D2C2A;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
}

.process-content {
  color: #2D2C2A;
  font-size: 33rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.process-content text {
  display: block;
  margin-top: 8rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.4;
}

.coach-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: -28rpx;
}

.coach-item {
  min-width: 0;
  padding: 20rpx 16rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid #E5E2D9;
  border-radius: 28rpx;
}

.coach-label {
  overflow: hidden;
  color: #8B8982;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coach-value {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #1B4332;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1.25;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.receipt-card {
  padding: 24rpx 26rpx;
  background: #FBF8EF;
  border-radius: 30rpx;
}

.receipt-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.receipt-title {
  color: #2D2C2A;
  font-size: 31rpx;
  font-weight: 1000;
}

.receipt-subtitle,
.receipt-focus {
  margin-top: 8rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.42;
}

.receipt-score {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 1000;
}

.receipt-focus {
  color: #5A5854;
  font-weight: 820;
}

.receipt-diagnostic {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(27, 67, 50, 0.08);
}

.receipt-contract {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FFF7E1;
  border: 1rpx solid rgba(184, 128, 34, 0.18);
}

.receipt-fallback-plan {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #F2F8F4;
  border: 1rpx solid rgba(27, 67, 50, 0.16);
}

.receipt-first-step-board {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #112A23;
  color: #FFFDF8;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.receipt-first-step-board .receipt-diagnostic-title {
  color: #F2D479;
}

.receipt-board-body,
.receipt-board-line,
.receipt-board-parent,
.receipt-board-avoid {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.55;
}

.receipt-board-body {
  color: rgba(255, 253, 248, 0.88);
}

.receipt-board-structure {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(242, 212, 121, 0.15);
  color: #F7E6A4;
  font-size: 20rpx;
  font-weight: 900;
}

.receipt-board-parent {
  color: #DDEBDD;
}

.receipt-board-avoid {
  color: rgba(255, 253, 248, 0.68);
}

.receipt-diagnostic-title {
  color: #1B4332;
  font-size: 22rpx;
  font-weight: 1000;
}

.receipt-diagnostic-line,
.receipt-diagnostic-sub,
.receipt-transfer {
  margin-top: 8rpx;
  color: #5A5854;
  font-size: 22rpx;
  line-height: 1.5;
}

.receipt-diagnostic-sub {
  color: #8B8982;
}

.receipt-choice-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 12rpx;
}

.receipt-choice-row text {
  min-width: 0;
  padding: 10rpx 12rpx;
  color: #1B4332;
  background: #FFFFFF;
  border-radius: 14rpx;
  font-size: 20rpx;
  font-weight: 850;
  line-height: 1.35;
}

.receipt-move-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.receipt-move-row text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #1B4332;
  font-size: 20rpx;
  font-weight: 850;
}

.receipt-transfer {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
}

.chat-card {
  position: relative;
  display: flex;
  min-height: calc(100vh - 318rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  max-height: calc(100vh - 260rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  flex-direction: column;
  overflow: hidden;
  padding: 24rpx 22rpx 18rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 226, 217, 0.78);
  border-radius: 38rpx;
  box-shadow: 0 30rpx 88rpx rgba(45, 44, 42, 0.075);
}

.chat-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(27, 67, 50, 0.045) 2rpx, transparent 2rpx);
  background-size: 28rpx 28rpx;
  pointer-events: none;
}

.chat-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 2rpx 6rpx 20rpx;
}

.chat-head-copy {
  min-width: 0;
  flex: 1;
}

.chat-avatar {
  display: flex;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(242, 212, 121, 0.18);
}

.chat-avatar-eye {
  width: 7rpx;
  height: 7rpx;
  background: #2D2C2A;
  border-radius: 999rpx;
}

.chat-kicker {
  color: #1B4332;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1.15;
}

.chat-title {
  margin-top: 4rpx;
  overflow: hidden;
  color: #2D2C2A;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #8B8982;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-live-dot {
  width: 18rpx;
  height: 18rpx;
  flex: 0 0 auto;
  background: #1B4332;
  border: 4rpx solid #EAF5EE;
  border-radius: 999rpx;
}

.chat {
  position: relative;
  z-index: 1;
  min-height: 0;
  flex: 1;
  height: auto;
  padding: 4rpx 2rpx 12rpx;
  box-sizing: border-box;
}

.message {
  display: flex;
  margin-bottom: 20rpx;
}

.message.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 90%;
  padding: 22rpx 26rpx;
  color: #2D2C2A;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #E5E2D9;
  border-radius: 28rpx;
  border-top-left-radius: 10rpx;
  box-shadow: 0 8rpx 22rpx rgba(45, 44, 42, 0.045);
  font-size: 28rpx;
  font-weight: 760;
  line-height: 1.55;
}

.message.user .bubble {
  color: #FFFFFF;
  background: #1B4332;
  border-color: #1B4332;
  border-top-right-radius: 10rpx;
  border-top-left-radius: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 67, 50, 0.16);
}

.hint-label {
  display: inline-flex;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  color: #1a5336;
  background: rgba(247, 208, 104, 0.28);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.2;
}

.chat-suggestion-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(229, 226, 217, 0.76);
}

.suggestion-pill {
  display: flex;
  min-width: 0;
  min-height: 62rpx;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  overflow: hidden;
  color: #5A5854;
  background: #F4F2EC;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-pill.active {
  color: #1B4332;
  background: #FFF8DE;
  border-color: #1B4332;
}

.composer-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  justify-content: center;
  padding: 18rpx 16rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, #FFFFFF 82%, rgba(255, 255, 255, 0) 100%);
}

.composer-inner {
  display: flex;
  width: 100%;
  max-width: 720rpx;
  min-height: 104rpx;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 34rpx rgba(45, 44, 42, 0.075);
}

.composer-input {
  min-width: 0;
  flex: 1;
  width: 0;
  min-height: 54rpx;
  max-height: 150rpx;
  color: #2D2C2A;
  font-size: 30rpx;
  font-weight: 720;
  line-height: 1.42;
}

.composer-btn {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
}

.send-arrow {
  margin-left: -3rpx;
  font-size: 28rpx;
  line-height: 1;
  transform: rotate(-18deg);
}

.surface-depth-card {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(27, 67, 50, 0.12);
}

.surface-depth-title {
  color: #1B4332;
  font-size: 26rpx;
  font-weight: 1000;
}

.surface-depth-subtitle,
.surface-depth-next,
.surface-depth-note {
  color: #4B5563;
  font-size: 22rpx;
  line-height: 1.45;
}

.surface-depth-next {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #F2D47933;
  font-weight: 850;
}

.surface-depth-grid {
  display: grid;
  gap: 10rpx;
}

.surface-depth-chip {
  display: grid;
  gap: 4rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  background: #fff;
}

.surface-depth-chip.ready {
  background: #ECFDF5;
}

.surface-depth-chip-title {
  color: #111827;
  font-size: 21rpx;
  font-weight: 900;
}

.surface-depth-chip-line {
  color: #6B7280;
  font-size: 19rpx;
  line-height: 1.35;
}
