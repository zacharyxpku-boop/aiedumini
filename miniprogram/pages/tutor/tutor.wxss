page {
  background: #F4F2EC;
}

.tutor-page {
  min-height: 100vh;
  overflow: hidden;
  color: #2D2C2A;
  background:
    radial-gradient(circle at 50% -80rpx, rgba(242, 212, 121, 0.18), rgba(242, 212, 121, 0) 360rpx),
    #F4F2EC;
}

.tutor-shell {
  position: relative;
  min-height: 100vh;
}

.top-nav {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 140rpx;
  min-height: calc(112rpx + env(safe-area-inset-top));
  align-items: center;
  gap: 14rpx;
  padding: calc(30rpx + env(safe-area-inset-top)) 24rpx 14rpx;
  background: linear-gradient(180deg, #F4F2EC 78%, rgba(244, 242, 236, 0) 100%);
}

.home-back {
  display: flex;
  min-height: 54rpx;
  align-items: center;
  justify-content: center;
  color: #1B4332;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 900;
}

.nav-brand {
  min-width: 0;
}

.brand-title {
  overflow: hidden;
  color: #2D2C2A;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
  letter-spacing: 1rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.brand-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #8B8982;
  font-size: 21rpx;
  font-weight: 740;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-pill {
  display: flex;
  min-height: 52rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 16rpx;
  color: #5A5854;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 44, 42, 0.025);
  font-size: 22rpx;
  font-weight: 800;
}

.nav-dot {
  width: 12rpx;
  height: 12rpx;
  background: #F2D479;
  border-radius: 999rpx;
}

.tutor-main {
  height: calc(100vh - 112rpx - env(safe-area-inset-top));
}

.main-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 16rpx calc(178rpx + env(safe-area-inset-bottom));
}

.tutor-hero-shell {
  position: relative;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 8% 4%, rgba(248, 198, 34, 0.17), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(34, 185, 92, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

.tutor-dash-top,
.tutor-dash-brand,
.tutor-dash-hero,
.tutor-chip-row,
.tutor-section-head,
.tutor-ladder,
.tutor-entry-grid,
.tutor-action-row {
  box-sizing: border-box;
}

.tutor-dash-top,
.tutor-dash-brand,
.tutor-section-head,
.tutor-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tutor-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.tutor-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  border-radius: 18rpx;
  background: #eef7ff;
  border: 1rpx solid rgba(76, 159, 255, 0.16);
  box-shadow: 0 14rpx 26rpx rgba(76, 159, 255, 0.12);
}

.tutor-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tutor-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.tutor-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.tutor-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.tutor-dash-hero {
  display: grid;
  grid-template-columns: 190rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  margin-top: 26rpx;
}

.tutor-dash-mascot {
  width: 194rpx;
  height: 178rpx;
  border-radius: 36rpx;
  background: #effaf0;
}

.tutor-dash-bubble {
  min-width: 0;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
}

.tutor-dash-bubble view:first-child {
  color: #101a16;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.12;
}

.tutor-dash-bubble > text {
  display: block;
  margin-top: 10rpx;
  color: #64706a;
  font-size: 23rpx;
  line-height: 1.55;
}

.tutor-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tutor-chip-row text {
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #f0fbf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 820;
  white-space: nowrap;
}

.tutor-flow-card {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
}

.tutor-section-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.tutor-section-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
}

.tutor-ladder {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 9rpx;
  margin-top: 18rpx;
}

.tutor-ladder view {
  min-width: 0;
  padding: 12rpx 6rpx;
  display: grid;
  justify-items: center;
  gap: 7rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 18rpx;
  background: #f8faf5;
}

.tutor-ladder text:first-child {
  width: 34rpx;
  height: 34rpx;
  color: #5f6d65;
  background: #ffffff;
  border-radius: 50%;
  font-size: 19rpx;
  font-weight: 950;
  line-height: 34rpx;
  text-align: center;
}

.tutor-ladder text:last-child {
  color: #526158;
  font-size: 19rpx;
  font-weight: 820;
  line-height: 1.2;
  text-align: center;
}

.tutor-ladder .active text:first-child {
  color: #ffffff;
  background: #4c9fff;
}

.tutor-entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.tutor-entry-card {
  min-width: 0;
  min-height: 166rpx;
  padding: 16rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(38, 58, 43, 0.055);
}

.tutor-entry-card.primary {
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf0 100%);
}

.tutor-entry-card image {
  width: 86rpx;
  height: 74rpx;
  border-radius: 18rpx;
}

.tutor-entry-card text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.tutor-entry-card text:nth-child(2) {
  color: #17211d;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.tutor-entry-card text:nth-child(3) {
  color: #66746d;
  font-size: 19rpx;
  line-height: 1.35;
}

.tutor-action-row {
  margin-top: 20rpx;
}

.tutor-primary,
.tutor-secondary {
  flex: 1 1 0;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 76rpx;
  text-align: center;
}

.tutor-primary {
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
}

.tutor-secondary {
  color: #14854a;
  background: #ebf9ed;
}

.hero {
  position: relative;
  padding-top: 4rpx;
}

.hero-decorative-bg {
  position: absolute;
  top: -38rpx;
  right: -22rpx;
  z-index: 0;
  color: rgba(139, 137, 130, 0.08);
  font-family: Georgia, serif;
  font-size: 250rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 0.85;
  pointer-events: none;
}

.hero-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.hero-title-group {
  min-width: 0;
  max-width: 470rpx;
}

.hero-badge {
  color: #1B4332;
  font-size: 23rpx;
  font-weight: 950;
  letter-spacing: 4rpx;
  line-height: 1.2;
}

.hero-title {
  margin-top: 10rpx;
  color: #2D2C2A;
  font-size: 48rpx;
  font-weight: 1000;
  line-height: 1.12;
  letter-spacing: 0;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding-left: 20rpx;
  color: #5A5854;
  border-left: 4rpx solid #F2D479;
  font-size: 25rpx;
  font-weight: 720;
  line-height: 1.5;
}

.mascot-stamp {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  flex: 0 0 auto;
}

.stamp-ring {
  position: absolute;
  inset: 0;
  border: 2rpx dashed rgba(27, 67, 50, 0.48);
  border-radius: 999rpx;
  animation: rotateStamp 20s linear infinite;
}

.stamp-word {
  position: absolute;
  left: 50%;
  width: 128rpx;
  margin-left: -64rpx;
  color: #1B4332;
  font-size: 16rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.stamp-word.top {
  top: 10rpx;
}

.stamp-word.right {
  top: 68rpx;
  transform: rotate(90deg);
}

.stamp-word.bottom {
  bottom: 10rpx;
  transform: rotate(180deg);
}

@keyframes rotateStamp {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.stamp-face {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  width: 66rpx;
  height: 66rpx;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 28rpx rgba(242, 212, 121, 0.48);
  transform: translate(-50%, -50%);
}

.stamp-eye {
  width: 8rpx;
  height: 8rpx;
  background: #2D2C2A;
  border-radius: 999rpx;
}

.selected-card,
.receipt-card {
  padding: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 226, 217, 0.74);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(45, 44, 42, 0.045);
}

.mode-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 0;
  padding: 0 4rpx;
}

.mode-scroll {
  min-width: 0;
  flex: 1;
  white-space: nowrap;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #2D2C2A;
  font-size: 36rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.card-title::after {
  content: "";
  flex: 1;
  height: 1rpx;
  background: #E5E2D9;
}

.chips-grid {
  display: inline-flex;
  gap: 12rpx;
  padding: 2rpx 2rpx 4rpx;
}

.chip {
  display: inline-flex;
  min-width: 142rpx;
  min-height: 56rpx;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  color: #5A5854;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1.25;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(45, 44, 42, 0.035);
}

.chip:active {
  color: #1B4332;
  background: #FFFFFF;
  border-color: #1B4332;
}

.chip.active {
  color: #1B4332;
  background: #FFF8DE;
  border-color: #1B4332;
}

.must-do-mini {
  display: flex;
  min-width: 144rpx;
  min-height: 56rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 67, 50, 0.18);
  font-size: 22rpx;
  font-weight: 950;
}

.btn-primary {
  display: flex;
  width: 100%;
  min-height: 104rpx;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 28rpx;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(27, 67, 50, 0.25);
  font-size: 32rpx;
  font-weight: 1000;
  letter-spacing: 1rpx;
}

.btn-icon {
  color: #F2D479;
  font-size: 32rpx;
}

.selected-card {
  margin-top: 2rpx;
  padding: 24rpx 26rpx;
  background: #FFFCF3;
  border-radius: 30rpx;
}

.selected-label {
  display: inline-flex;
  min-height: 42rpx;
  align-items: center;
  padding: 0 16rpx;
  color: #1B4332;
  background: rgba(242, 212, 121, 0.32);
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
}

.selected-text {
  margin-top: 14rpx;
  color: #2D2C2A;
  font-size: 27rpx;
  font-weight: 1000;
  line-height: 1.42;
}

.selected-reason {
  margin-top: 12rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.46;
}

.process-section {
  padding: 4rpx 0;
}

.tutor-detail-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 4rpx;
  padding: 20rpx 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid #E5E2D9;
  border-radius: 26rpx;
}

.detail-toggle-title {
  color: #2D2C2A;
  font-size: 25rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.detail-toggle-subtitle {
  margin-top: 5rpx;
  color: #8B8982;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.3;
}

.detail-toggle-button {
  display: flex;
  min-width: 104rpx;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  color: #1B4332;
  background: #F2D479;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 54rpx;
}

.section-label {
  color: #8B8982;
  font-size: 21rpx;
  font-style: italic;
  font-weight: 850;
  letter-spacing: 3rpx;
  line-height: 1.3;
  text-align: center;
}

.process-list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 46rpx;
  margin-top: 34rpx;
  padding-left: 68rpx;
}

.process-list::before {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  bottom: 36rpx;
  width: 2rpx;
  background: linear-gradient(180deg, #E5E2D9 0%, #E5E2D9 80%, rgba(229, 226, 217, 0) 100%);
}

.process-item {
  position: relative;
}

.process-num {
  position: absolute;
  left: -68rpx;
  top: -2rpx;
  z-index: 2;
  display: flex;
  width: 46rpx;
  height: 46rpx;
  align-items: center;
  justify-content: center;
  color: #2D2C2A;
  background: #FFFFFF;
  border: 1rpx solid #E5E2D9;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
}

.process-content {
  color: #2D2C2A;
  font-size: 33rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.process-content text {
  display: block;
  margin-top: 8rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.4;
}

.coach-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: -28rpx;
}

.coach-item {
  min-width: 0;
  padding: 20rpx 16rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid #E5E2D9;
  border-radius: 28rpx;
}

.coach-label {
  overflow: hidden;
  color: #8B8982;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coach-value {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #1B4332;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1.25;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.receipt-card {
  padding: 24rpx 26rpx;
  background: #FBF8EF;
  border-radius: 30rpx;
}

.receipt-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.receipt-title {
  color: #2D2C2A;
  font-size: 31rpx;
  font-weight: 1000;
}

.receipt-subtitle,
.receipt-focus {
  margin-top: 8rpx;
  color: #8B8982;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.42;
}

.receipt-turnline {
  display: grid;
  grid-template-columns: auto auto minmax(0, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  color: #1b4332;
  background: rgba(27, 67, 50, 0.07);
  border: 1rpx solid rgba(27, 67, 50, 0.12);
  border-radius: 18rpx;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1.35;
}

.receipt-score {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: #1B4332;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 1000;
}

.receipt-focus {
  color: #5A5854;
  font-weight: 820;
}

.socratic-feedback-panel {
  display: grid;
  gap: 10rpx;
  margin-top: 18rpx;
}

.socratic-feedback-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.socratic-feedback-button {
  display: flex;
  min-width: 0;
  min-height: 72rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 14rpx;
  color: #1B4332;
  background: #FFFFFF;
  border: 1rpx solid rgba(27, 67, 50, 0.18);
  border-radius: 18rpx;
  box-shadow: none;
  font-size: 23rpx;
  font-weight: 1000;
  line-height: 1.2;
  text-align: center;
}

.socratic-feedback-button::after {
  border: 0;
}

.socratic-feedback-button.primary {
  color: #FFFFFF;
  background: #1B4332;
  border-color: #1B4332;
}

.socratic-feedback-state,
.socratic-feedback-next {
  color: #667A6C;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.35;
}

.socratic-feedback-next {
  padding: 12rpx 14rpx;
  color: #1B4332;
  background: rgba(27, 67, 50, 0.08);
  border-radius: 16rpx;
}

.receipt-diagnostic {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(27, 67, 50, 0.08);
}

.receipt-contract {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FFF7E1;
  border: 1rpx solid rgba(184, 128, 34, 0.18);
}

.receipt-fallback-plan {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
