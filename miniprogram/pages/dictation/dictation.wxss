.light-page {
  min-height: 100vh;
  padding: 96rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: #f9f8f5;
  color: #1a211d;
}

.light-title {
  font-size: 40rpx;
  font-weight: 800;
}

.light-subtitle,
.light-page view {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

textarea,
input {
  width: 100%;
  margin-top: 18rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #fffdf8;
}

button {
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #245c48;
  color: #fff;
}

.voice-card,
.empty-card,
.transition-card {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1rpx solid #e8e0d2;
  border-radius: 8rpx;
  background: #fffdf8;
}

.voice-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.voice-card text,
.empty-card {
  color: #5f675f;
}
