<view class="light-page">
  <view class="light-title">{{session.title}}</view>
  <view class="light-subtitle">做完后先看第一步，不直接照抄结果。</view>
  <view class="math-meta">
    <text wx:if="{{session.gradeBand === 'lower'}}">1-2 年级 · 20 以内加减</text>
    <text wx:elif="{{session.gradeBand === 'middle'}}">3-4 年级 · 乘除混合</text>
    <text wx:else>5-6 年级 · 小数/分数</text>
    <text bindtap="regenerate">换一组</text>
  </view>

  <view class="global-depth-card" wx:if="{{surfaceDepthPack}}">
    <view class="global-depth-head">
      <view>
        <view class="global-depth-title">{{surfaceDepthPack.title}}</view>
        <view class="global-depth-summary">{{surfaceDepthPack.summary}}</view>
      </view>
      <view class="global-depth-score">{{surfaceDepthPack.readyCount}}/{{surfaceDepthPack.totalCount}}</view>
    </view>
    <view class="global-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
    <view class="global-depth-grid">
      <view class="global-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
        <text>{{item.displayLabel}}</text>
      </view>
    </view>
    <view class="global-depth-note">{{surfaceDepthPack.familyLine}}</view>
  </view>

  <view class="global-depth-card" wx:if="{{lightSeedBank}}">
    <view class="global-depth-title">{{lightSeedBank.title}}</view>
    <view class="global-depth-summary">{{lightSeedBank.summary}}</view>
    <view class="global-depth-note">{{lightSeedBank.modelLine}}</view>
    <view class="global-depth-note">{{lightSeedBank.evidenceLine}}</view>
    <view class="global-depth-note">{{lightSeedBank.routeLine}}</view>
    <view class="global-depth-grid">
      <view class="global-depth-chip ready" wx:for="{{lightSeedBank.seeds}}" wx:key="id">
        <text class="global-depth-chip-title">{{item.label}}</text>
        <text>{{item.modelLine}}</text>
        <text>{{item.firstStep}}</text>
        <text>{{item.parentQuestion}}</text>
        <text>{{item.evidenceLine}}</text>
        <text>{{item.loopLine}}</text>
      </view>
    </view>
  </view>

  <view class="light-list">
    <view class="light-item" wx:for="{{session.items}}" wx:key="id">
      <text>{{index + 1}}. {{item.prompt}}</text>
      <input data-index="{{index}}" bindinput="onAnswerInput" placeholder="{{item.firstStepCheck}}" />
    </view>
  </view>
  <button bindtap="submit">提交并看第一步反馈</button>
  <view wx:if="{{result}}" class="result-card">
    <view class="feedback-title">先回看第一眼</view>
    <view>{{result.feedback}}</view>
    <view class="share-card">
      <view>{{result.shareCard.title}}</view>
      <text>{{result.shareCard.body}}</text>
    </view>
    <button open-type="share" bindtap="shareFirstStep">分享今晚我先做了什么</button>
  </view>
  <view wx:if="{{transitionPrompt}}" class="transition-card">
    <view>{{transitionPrompt.title}}</view>
    <view>{{transitionPrompt.body}}</view>
    <button bindtap="goCoreLoopFromMath">{{transitionPrompt.acceptText}}</button>
    <button bindtap="dismissMathTransition">{{transitionPrompt.rejectText}}</button>
  </view>
</view>
