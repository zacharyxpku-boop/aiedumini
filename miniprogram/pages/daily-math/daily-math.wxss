.light-page {
  min-height: 100vh;
  padding: 96rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: #f9f8f5;
  color: #1a211d;
}

.light-title {
  font-size: 40rpx;
  font-weight: 800;
}

.light-subtitle,
.light-item,
.light-page view {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.math-meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  color: #5f675f;
  font-size: 24rpx;
  font-weight: 800;
}

.light-item {
  padding: 18rpx;
  border: 1rpx solid #e8e0d2;
  border-radius: 8rpx;
  background: #fffdf8;
}

input {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f2efe8;
}

button {
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #245c48;
  color: #fff;
}

.result-card,
.share-card {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1rpx solid #e8e0d2;
  border-radius: 8rpx;
  background: #fffdf8;
}

.feedback-title {
  font-weight: 900;
}

.share-card {
  background: linear-gradient(145deg, #fff7d6, #e7f4ee);
  color: #174c3e;
}

.share-card view {
  font-size: 30rpx;
  font-weight: 900;
}

.share-card text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
}
