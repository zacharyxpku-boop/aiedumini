<view class="page module-play-page safe-bottom" wx:if="{{module}}">
  <view class="yd-page yd-shell">
    <view class="app-subpage-topbar">
      <view class="app-subpage-brand">
        <view class="app-subpage-logo"><view class="app-subpage-logo-core"></view></view>
        <view class="app-subpage-brand-copy">
          <view class="app-subpage-brand-name">原点智学</view>
          <view class="app-subpage-brand-sub">学习小局</view>
        </view>
      </view>
      <view class="app-subpage-pill">{{module.minutes}} 分钟</view>
      <button class="subpage-home" bindtap="goHome">首页</button>
    </view>

    <view class="module-play-hero">
      <view class="module-play-copy">
        <view class="module-play-badge">{{module.subject}} · {{module.type}}</view>
        <view class="module-play-title">{{module.title}}</view>
        <view class="module-play-subtitle">{{module.scene}}</view>
      </view>
      <view class="module-play-art">
        <view class="module-play-art-badge"></view>
        <view class="module-play-art-sheet"></view>
      </view>
    </view>

    <view class="module-yd-card">
      <view class="module-yd-card-title">现在就做这一小局</view>
      <view class="module-play-steps">
        <view class="module-play-step" wx:for="{{sessionSteps}}" wx:key="id">
            <view class="module-play-step-index">{{index + 1}}</view>
            <view class="module-play-step-copy">
              <view class="module-play-step-title">{{item.title}}</view>
              <view class="module-play-step-body">{{item.desc}}</view>
              <view class="module-play-step-proof">这一步留下什么证据：{{item.evidence}}</view>
            </view>
          </view>
        </view>
      <textarea class="module-play-input" value="{{evidenceText}}" bindinput="onEvidenceInput" placeholder="写一句你已经会了什么，或这类题下次先检查什么。" />
      <view class="module-play-actions">
        <button class="module-yd-primary" bindtap="startModule">进入作业点拨</button>
        <button class="module-yd-secondary" bindtap="completeAndReview">完成并加入复习</button>
      </view>
    </view>

    <view class="module-yd-card quiet">
      <view class="module-yd-card-title">掌握标准</view>
      <view class="module-yd-card-body">{{module.mastery}}</view>
      <view class="module-play-divider"></view>
      <view class="module-yd-card-title">收尾复述一句话</view>
      <view class="module-yd-card-body">{{module.parentScript}}</view>
    </view>


    <view class="global-depth-card" wx:if="{{surfaceDepthPack}}">
      <view class="global-depth-head">
        <view>
          <view class="global-depth-title">{{surfaceDepthPack.title}}</view>
          <view class="global-depth-summary">{{surfaceDepthPack.summary}}</view>
        </view>
        <view class="global-depth-score">{{surfaceDepthPack.readyCount}}/{{surfaceDepthPack.totalCount}}</view>
      </view>
      <view class="global-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
      <view class="global-depth-grid">
        <view class="global-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
          <text class="global-depth-chip-title">{{item.displayLabel}}</text>
          <text class="global-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
        </view>
      </view>
      <view class="global-depth-note">{{surfaceDepthPack.familyLine}}</view>
    </view>

    <view class="module-yd-card" wx:if="{{reviewPreview.length}}">
      <view class="module-yd-card-title">把这个方法变成复习卡</view>
      <view class="module-play-preview-list">
        <view class="module-play-preview-card" wx:for="{{reviewPreview}}" wx:key="id">
          <view class="module-play-preview-title">{{item.question}}</view>
          <view class="module-play-preview-meta">{{item.cardType}} / Q{{item.quality}}</view>
        </view>
      </view>
      <button class="module-play-link" bindtap="goReview">打开轻回访</button>
    </view>
  </view>
</view>
