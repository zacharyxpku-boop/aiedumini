  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  color: #1a5336;
  background: #eaf5ee;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
}

.source-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.source-card {
  display: flex;
  min-width: 0;
  min-height: 172rpx;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 28rpx;
}

.source-card.app {
  background: linear-gradient(135deg, #eaf5ec 0%, #e1f0e4 100%);
  border: 1rpx solid #d5e8d8;
}

.source-card.offline {
  background: linear-gradient(135deg, #fff7ea 0%, #fff0d4 100%);
  border: 1rpx solid #fbe6c2;
}

.source-icon {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 16rpx;
}

.source-icon.auto::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 12rpx;
  width: 22rpx;
  height: 22rpx;
  border: 5rpx solid #d97706;
  border-left-color: transparent;
  border-radius: 50%;
}

.source-icon.book::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 10rpx;
  width: 24rpx;
  height: 30rpx;
  border: 4rpx solid #1a5336;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
}

.source-title {
  color: #1a211d;
  font-size: 25rpx;
  font-weight: 1000;
}

.source-body {
  margin-top: 8rpx;
  color: #626a63;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1.35;
}

.repair-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.repair-card {
  padding: 20rpx;
  background: #f9f8f5;
  border: 1rpx solid #eee9de;
  border-radius: 26rpx;
}

.repair-reason {
  display: inline-flex;
  min-height: 38rpx;
  align-items: center;
  padding: 0 14rpx;
  color: #8b650f;
  background: rgba(247, 208, 104, 0.22);
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 900;
}

.repair-question {
  margin-top: 14rpx;
  color: #1a211d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.42;
}

.repair-preview {
  margin-top: 10rpx;
  color: #697069;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.4;
}

.repair-action {
  display: inline-flex;
  min-height: 48rpx;
  align-items: center;
  margin-top: 16rpx;
  padding: 0 18rpx;
  color: #ffffff;
  background: #1a5336;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
}

.repair-empty {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #f9f8f5;
  border: 1rpx dashed #dcd6c9;
  border-radius: 26rpx;
}

.repair-empty-title {
  color: #1a211d;
  font-size: 24rpx;
  font-weight: 950;
}

.repair-empty-body {
  margin-top: 8rpx;
  color: #687067;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.4;
}

.import-textarea {
  width: 100%;
  min-height: 128rpx;
  box-sizing: border-box;
  padding: 20rpx;
  color: #1a211d;
