page {
  background: #f9f8f5;
}

.review-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1a211d;
  background: #f9f8f5;
}

.review-brand-text {
  color: #1a5336;
  font-size: 44rpx;
  font-weight: 1000;
  line-height: 1.06;
}

.review-brand-sub {
  margin-top: 8rpx;
  color: #6d736c;
  font-size: 24rpx;
  font-weight: 720;
}

.review-due-pill {
  display: flex;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  padding: 0 22rpx;
  color: #1a5336;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid #eee9de;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.content-area {
  position: relative;
  z-index: 2;
  height: calc(100vh - 118rpx - env(safe-area-inset-top));
  box-sizing: border-box;
}

.content-inner {
  padding: 0 28rpx calc(190rpx + env(safe-area-inset-bottom));
}

.review-hero-shell {
  position: relative;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 8% 4%, rgba(248, 198, 34, 0.18), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(34, 185, 92, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

