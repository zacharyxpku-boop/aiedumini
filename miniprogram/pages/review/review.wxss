page {
  background: #f9f8f5;
}

.review-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1a211d;
  background: #f9f8f5;
}

.review-bg,
.review-glow {
  position: absolute;
  pointer-events: none;
}

.review-bg.dots {
  inset: 0;
  opacity: 0.72;
  background-image: radial-gradient(#d8d4c9 2rpx, transparent 2rpx);
  background-size: 36rpx 36rpx;
}

.review-bg.dots::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(249, 248, 245, 0.14), #f9f8f5 86%);
}

.review-glow {
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  filter: blur(88rpx);
}

.review-glow.amber {
  top: -150rpx;
  right: -180rpx;
  background: rgba(247, 208, 104, 0.18);
}

.review-glow.mint {
  top: 410rpx;
  left: -210rpx;
  background: rgba(26, 83, 54, 0.08);
}

.v1-topbar {
  position: relative;
  z-index: 3;
  display: flex;
  min-height: calc(118rpx + env(safe-area-inset-top));
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  padding: calc(42rpx + env(safe-area-inset-top)) 40rpx 22rpx;
}

.review-brand-text {
  color: #1a5336;
  font-size: 44rpx;
  font-weight: 1000;
  line-height: 1.06;
}

.review-brand-sub {
  margin-top: 8rpx;
  color: #6d736c;
  font-size: 24rpx;
  font-weight: 720;
}

.review-due-pill {
  display: flex;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  padding: 0 22rpx;
  color: #1a5336;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid #eee9de;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.content-area {
  position: relative;
  z-index: 2;
  height: calc(100vh - 118rpx - env(safe-area-inset-top));
  box-sizing: border-box;
}

.content-inner {
  padding: 0 28rpx calc(190rpx + env(safe-area-inset-bottom));
}

.hero,
.source-panel,
.weakspot-panel,
.repair-panel,
.import-panel,
.quest-panel {
  position: relative;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 40rpx;
  box-shadow: 0 16rpx 52rpx rgba(26, 83, 54, 0.052);
}

.weakspot-panel {
  margin-top: 24rpx;
  padding: 30rpx;
  background: #1A5336;
  border: 0;
  color: #FFFFFF;
}

.weakspot-panel .panel-title {
  color: #FFFFFF;
}

.weakspot-panel .panel-subtitle {
  color: rgba(255, 255, 255, 0.68);
}

.weakspot-score {
  flex: 0 0 auto;
  min-height: 52rpx;
  padding: 0 18rpx;
  color: #1A5336;
  background: #F7D068;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 1000;
  line-height: 52rpx;
}

.weakspot-name {
  margin-top: 24rpx;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.weakspot-row {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  background: rgba(255, 255, 255, 0.10);
}

.weakspot-row.highlight {
  color: #1A5336;
  background: #F7D068;
}

.weakspot-label {
  color: #F7D068;
  font-size: 20rpx;
  font-weight: 950;
}

.weakspot-row.highlight .weakspot-label {
  color: rgba(26, 83, 54, 0.72);
}

.weakspot-text {
  margin-top: 7rpx;
  font-size: 24rpx;
  font-weight: 780;
  line-height: 1.45;
}

.transfer-practice-card,
.outcome-check-card,
.post-repair-bridge-card,
.rule-retest-card,
.memory-prescription-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border: 1rpx solid #eee4d1;
  border-radius: 28rpx;
  background: #fffaf0;
}

.memory-prescription-card {
  background: #ffffff;
  border-color: #d9eadf;
}

.memory-prescription-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.memory-prescription-kicker,
.memory-prescription-section-title {
  color: #1a5336;
  font-size: 21rpx;
  font-weight: 950;
}

.memory-prescription-title {
  margin-top: 6rpx;
  color: #1a211d;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.22;
}

.memory-prescription-pill {
  flex: 0 0 auto;
  min-height: 48rpx;
  padding: 0 18rpx;
  color: #1a5336;
  background: #f7d068;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 48rpx;
}

.memory-prescription-subtitle,
.memory-prescription-dose,
.memory-prescription-foot,
.memory-prescription-line {
  margin-top: 10rpx;
  color: #5f675f;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.45;
}

.memory-prescription-dose {
  color: #1a5336;
  font-weight: 900;
}

.memory-prescription-list {
  margin-top: 16rpx;
}

.memory-prescription-item {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(26, 83, 54, 0.07);
}

.memory-prescription-label {
  color: #1a5336;
  font-size: 21rpx;
  font-weight: 950;
}

.memory-prescription-question {
  margin-top: 6rpx;
  color: #1a211d;
  font-size: 25rpx;
  font-weight: 880;
  line-height: 1.38;
}

.memory-prescription-action {
  margin-top: 6rpx;
  color: #6d736c;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 1.42;
}

.memory-prescription-section {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #edf1ea;
}

.memory-prescription-cta {
  display: flex;
  min-height: 64rpx;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  color: #ffffff;
  background: #1a5336;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 950;
}

.transfer-status,
.outcome-score,
.post-repair-title {
  margin-top: 10rpx;
  color: #1a5336;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.35;
}

.transfer-safety,
.outcome-line,
.transfer-parent,
.post-repair-line,
.rule-retest-line,
.rule-retest-gate {
  margin-top: 10rpx;
  color: #6d736c;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.45;
}

.transfer-step {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.82);
}

.transfer-step.done {
  background: rgba(26, 83, 54, 0.08);
}

.transfer-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.transfer-label {
  color: #8b650f;
  font-size: 21rpx;
  font-weight: 950;
}

.transfer-prompt {
  margin-top: 6rpx;
  color: #1a211d;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1.42;
}

.transfer-check {
  margin-top: 6rpx;
  color: #6d736c;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.42;
}

.transfer-action,
.outcome-action,
.post-repair-action {
  flex: 0 0 auto;
  min-height: 58rpx;
  margin: 0;
  padding: 0 20rpx;
  color: #ffffff;
  background: #1a5336;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.outcome-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.post-repair-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.post-repair-action {
  min-width: 0;
  padding: 0 10rpx;
  font-size: 21rpx;
}

.rule-retest-card {
  background: #fff9ea;
  border-color: #ead7a8;
}

.rule-retest-badge {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(27, 67, 50, 0.08);
  color: #1b4332;
  font-size: 21rpx;
  font-weight: 800;
}

.rule-retest-cadence {
  display: grid;
  gap: 10rpx;
  margin-top: 14rpx;
}

.rule-retest-step {
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #4e463d;
  font-size: 22rpx;
}

.rule-retest-action {
  margin-top: 16rpx;
  min-height: 64rpx;
  border-radius: 18rpx;
  background: #1b4332;
  color: #fff;
  font-size: 24rpx;
  font-weight: 850;
}

.hero {
  padding: 32rpx;
  overflow: hidden;
}

.hero::after {
  content: "";
  position: absolute;
  right: -72rpx;
  top: -78rpx;
  width: 250rpx;
  height: 250rpx;
  background: rgba(247, 208, 104, 0.14);
  border-radius: 50%;
}

.hero-tag {
  position: relative;
  z-index: 1;
  display: inline-flex;
  min-height: 44rpx;
  align-items: center;
  padding: 0 18rpx;
  color: #8b650f;
  background: rgba(247, 208, 104, 0.25);
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.review-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: #1a211d;
  font-size: 42rpx;
  font-weight: 1000;
  line-height: 1.16;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #606861;
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.48;
}

.route-strip {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.route-strip text {
  flex: 1 1 0;
  min-width: 0;
  padding: 9rpx 8rpx;
  overflow: hidden;
  color: #687067;
  background: rgba(249, 248, 245, 0.78);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-strip text.active {
  color: #1a5336;
  background: rgba(247, 208, 104, 0.34);
  border-color: rgba(247, 208, 104, 0.50);
  font-weight: 1000;
}

.route-note {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #7a827b;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.34;
}

.companion-line {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #5a6c60;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.32;
}

.loop-rail {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 28rpx;
  padding: 8rpx 6rpx 2rpx;
}

.loop-line {
  position: absolute;
  left: 62rpx;
  right: 62rpx;
  top: 38rpx;
  z-index: 0;
  border-top: 3rpx dashed #e3dfd4;
}

.loop-step {
  position: relative;
  z-index: 1;
  min-width: 0;
  text-align: center;
}

.loop-dot {
  position: relative;
  width: 74rpx;
  height: 74rpx;
  margin: 0 auto 12rpx;
  background: #ffffff;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-shadow: 0 4rpx 14rpx rgba(26, 83, 54, 0.06);
}

.loop-dot.collect {
  background: #eef8f2;
}

.loop-dot.inspect {
  background: #fff6df;
}

.loop-dot.transfer {
  background: #edf4ff;
}

.loop-dot.quest {
  background: #fff0f0;
}

.loop-dot::before,
.loop-dot::after {
  content: "";
  position: absolute;
}

.loop-dot.collect::before {
  left: 21rpx;
  top: 18rpx;
  width: 26rpx;
  height: 32rpx;
  border: 5rpx solid #2e7d32;
  border-radius: 5rpx 12rpx 12rpx 5rpx;
}

.loop-dot.inspect::before {
  left: 17rpx;
  top: 17rpx;
  width: 24rpx;
  height: 24rpx;
  border: 5rpx solid #d97706;
  border-radius: 50%;
}

.loop-dot.inspect::after {
  left: 41rpx;
  top: 43rpx;
  width: 18rpx;
  height: 5rpx;
  background: #d97706;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.loop-dot.transfer::before {
  left: 23rpx;
  top: 16rpx;
  width: 28rpx;
  height: 34rpx;
  background: #1d4ed8;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  transform: rotate(18deg);
}

.loop-dot.transfer::after {
  left: 15rpx;
  top: 14rpx;
  width: 14rpx;
  height: 14rpx;
  background: #f7d068;
  border-radius: 50%;
}

.loop-dot.quest::before {
  left: 22rpx;
  top: 16rpx;
  width: 6rpx;
  height: 42rpx;
  background: #e53935;
  border-radius: 999rpx;
}

.loop-dot.quest::after {
  left: 27rpx;
  top: 16rpx;
  width: 28rpx;
  height: 22rpx;
  background: #e53935;
  border-radius: 4rpx 12rpx 12rpx 4rpx;
}

.loop-step.active .loop-dot {
  box-shadow: 0 0 0 8rpx rgba(26, 83, 54, 0.07), 0 5rpx 16rpx rgba(26, 83, 54, 0.08);
}

.loop-step text {
  display: block;
  overflow: hidden;
  color: #5f665f;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.hero-stat {
  min-width: 0;
  padding: 18rpx 14rpx;
  background: #f9f8f5;
  border: 1rpx solid #eee9de;
  border-radius: 24rpx;
}

.hero-stat.strong {
  background: #1a5336;
  border-color: #1a5336;
}

.hero-stat-value {
  overflow: hidden;
  color: #1a5336;
  font-size: 34rpx;
  font-weight: 1000;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-stat-label {
  margin-top: 8rpx;
  color: #6d736c;
  font-size: 20rpx;
  font-weight: 850;
}

.hero-stat.strong .hero-stat-value,
.hero-stat.strong .hero-stat-label {
  color: #ffffff;
}

.source-panel,
.repair-panel,
.import-panel,
.quest-panel {
  margin-top: 24rpx;
  padding: 28rpx;
}

.review-more-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 83, 54, 0.035);
}

.review-more-title {
  color: #1a5336;
  font-size: 25rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.review-more-subtitle {
  margin-top: 5rpx;
  color: #6b746d;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.3;
}

.review-more-button {
  display: flex;
  min-width: 104rpx;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  color: #1a5336;
  background: #f7d068;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 54rpx;
}

.quest-panel {
  overflow: hidden;
}

.quest-panel::before {
  content: "";
  position: absolute;
  right: -80rpx;
  top: 120rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(26, 83, 54, 0.04);
  border-radius: 50%;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-head.compact {
  margin-bottom: 20rpx;
}

.panel-title {
  color: #1a211d;
  font-size: 31rpx;
  font-weight: 1000;
  line-height: 1.18;
}

.panel-subtitle {
  margin-top: 8rpx;
  color: #687067;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 1.4;
}

.panel-count,
.xp-pill {
  display: flex;
  min-width: 58rpx;
