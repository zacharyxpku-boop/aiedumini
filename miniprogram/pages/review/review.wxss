/* Focused review entry: keep child-flow screenshots on the new visual system. */
.content-area {
  height: 100vh;
}

.content-inner {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(138rpx + env(safe-area-inset-bottom));
}

.review-hero-shell {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 34rpx;
}

.review-dash-hero {
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-dash-title {
  font-size: 35rpx;
  line-height: 1.1;
}

.review-dash-sub {
  display: -webkit-box;
  margin-top: 9rpx;
  overflow: hidden;
  font-size: 21rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.review-dash-art {
  width: 148rpx;
  height: 128rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 30rpx;
}

.review-map-card {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 24rpx;
}

.review-map-line {
  gap: 9rpx;
  margin-top: 14rpx;
}

.review-map-node {
  min-height: 108rpx;
  padding: 10rpx 4rpx;
  border-radius: 19rpx;
}

.review-map-node::after {
  right: -14rpx;
  width: 18rpx;
}

.review-map-icon {
  width: 42rpx;
  height: 42rpx;
  padding: 6rpx;
  border-radius: 15rpx;
}

.review-map-node text:nth-child(2) {
  font-size: 18rpx;
}

.review-map-node text:nth-child(3) {
  font-size: 16rpx;
}

.review-challenge-grid {
  gap: 12rpx;
  margin-top: 16rpx;
}

.review-challenge-card {
  min-height: 132rpx;
  padding: 11rpx 9rpx;
  border-radius: 22rpx;
}

.review-challenge-card image {
  width: 72rpx;
  height: 56rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.review-main-cta {
  height: 70rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 70rpx;
}
.review-evidence-panel {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin: 18rpx 0;
}

.review-evidence-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(232, 238, 230, 0.95);
  box-shadow: 0 14rpx 34rpx rgba(36, 72, 46, 0.08);
}

.review-evidence-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1f3828;
  margin-bottom: 12rpx;
}

.review-evidence-line {
  font-size: 24rpx;
  line-height: 1.45;
  color: #31513b;
  margin-top: 8rpx;
}

.review-evidence-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #6a7a6c;
}

