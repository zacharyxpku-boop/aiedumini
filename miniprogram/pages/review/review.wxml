<view class="review-page">
  <view class="page-positioning review-positioning">
    <view class="positioning-kicker">错题修复</view>
    <view class="positioning-title">错题不是抄进本子，是留下下次先检查什么</view>
    <view class="positioning-flow">只修一个真实卡点：错在哪里、下一次第一步先看哪里；修完进入轻回访或小游戏。</view>
  </view>
  <view class="review-bg dots"></view>
  <view class="review-glow amber"></view>
  <view class="review-glow mint"></view>

  <view class="v1-topbar">
    <view>
      <view class="review-brand-text">修卡点</view>
      <view class="review-brand-sub">今晚只修一个真实卡点</view>
    </view>
    <view class="review-due-pill">{{gameRunway.due || 0}} 张到期</view>
  </view>

  <scroll-view class="content-area" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="content-inner">
      <view class="rc14-review-first-screen">
      <view class="hero">
        <view class="route-note short">{{reviewViewModel.routePill}}</view>
        <view class="companion-route-strip">{{reviewViewModel.companionStrip}}</view>
        <view class="review-title">{{reviewViewModel.title}}</view>
        <view class="hero-subtitle">{{reviewViewModel.subtitle}}</view>

        <view class="rc14-main-card">
        <view class="review-empty-state" wx:if="{{reviewViewModel.emptyState}}">
          <view>{{reviewViewModel.emptyState.text}}</view>
          <view class="mini-action review-empty-action" bindtap="goHome">{{reviewViewModel.emptyState.cta}}</view>
        </view>

        <view class="review-focus-block" wx:if="{{reviewViewModel.primaryCard.sections.length}}">
          <view class="focus-row" wx:for="{{reviewViewModel.primaryCard.sections}}" wx:key="id">
            <view class="focus-label">{{item.label}}</view>
            <view class="focus-text">{{item.text}}</view>
          </view>
        </view>
        <view class="blackboard-card" wx:if="{{reviewViewModel.blackboard}}">
          <view class="blackboard-kicker">原点小黑板</view>
          <view class="blackboard-intro">{{reviewViewModel.blackboard.intro}}</view>
          <view class="blackboard-title">{{reviewViewModel.blackboard.title}}</view>
          <view class="blackboard-body">{{reviewViewModel.blackboard.body}}</view>
          <view class="blackboard-structure">{{reviewViewModel.blackboard.structure}}</view>
          <view class="blackboard-first-step" wx:if="{{reviewViewModel.blackboard.firstMove}}">{{reviewViewModel.blackboard.firstMove}}</view>
          <view class="blackboard-child-prompt" wx:if="{{reviewViewModel.blackboard.childPrompt}}">{{reviewViewModel.blackboard.childPrompt}}</view>
          <view class="blackboard-parent-prompt" wx:if="{{reviewViewModel.blackboard.parentPrompt}}">家长只问：{{reviewViewModel.blackboard.parentPrompt}}</view>
          <view class="blackboard-avoid" wx:if="{{reviewViewModel.blackboard.avoid}}">{{reviewViewModel.blackboard.avoid}}</view>
        </view>
        <view class="surface-depth-card review-surface-depth" wx:if="{{surfaceDepthPack}}">
          <view class="surface-depth-title">{{surfaceDepthPack.title}}</view>
          <view class="surface-depth-subtitle">{{surfaceDepthPack.summary}}</view>
          <view class="surface-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
          <view class="surface-depth-grid">
            <view class="surface-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
              <text class="surface-depth-chip-title">{{item.displayLabel}}</text>
              <text class="surface-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
            </view>
          </view>
        </view>
        </view>

        <view class="pack-primary review-hero-cta" wx:if="{{reviewViewModel.primaryCta.action === 'review'}}" data-action="review" bindtap="runPlaybookAction">{{reviewViewModel.primaryCta.text}}</view>
        <view class="pack-primary review-hero-cta" wx:elif="{{reviewViewModel.primaryCta.action === 'home'}}" bindtap="goHome">{{reviewViewModel.primaryCta.text}}</view>
        <view class="pack-primary review-hero-cta" wx:elif="{{reviewViewModel.primaryCta.action === 'complete'}}" bindtap="completeTodayRepair">{{reviewViewModel.primaryCta.text}}</view>
        <view class="pack-primary review-hero-cta completed" wx:elif="{{reviewViewModel.primaryCta.action === 'tools'}}" bindtap="goTools">{{reviewViewModel.primaryCta.text}}</view>
        <view class="mini-action route-next-action" wx:if="{{reviewViewModel.focusCabinCta}}" bindtap="goFocus">{{reviewViewModel.focusCabinCta.text}}</view>
        <view class="mini-repair-action" wx:if="{{reviewViewModel.miniAction}}">
          <view class="mini-repair-question">{{reviewViewModel.miniAction.question}}</view>
          <view class="mini-repair-helper">{{reviewViewModel.miniAction.helper}}</view>
          <view class="mini-choice-row" wx:if="{{reviewViewModel.miniAction.quickChoices.length}}">
            <view
              class="mini-choice"
              wx:for="{{reviewViewModel.miniAction.quickChoices}}"
              wx:key="*this"
              data-text="{{item}}"
              bindtap="chooseMiniAction"
            >{{item}}</view>
          </view>
          <textarea
            class="mini-repair-input"
            value="{{miniActionText}}"
            maxlength="80"
            auto-height
            bindinput="onMiniActionInput"
            placeholder="{{reviewViewModel.miniAction.placeholder}}"
          />
          <button class="mini-repair-button" bindtap="markMiniActionDone">{{reviewViewModel.miniAction.saveCta}}</button>
        </view>
      </view>
      </view>
      <view class="rc14-review-after-first-screen"></view>
      <view class="hero review-secondary-hero">
        <view class="focus-status-pill" wx:if="{{todayFocus}}">{{mistakeHub.weakSpot && mistakeHub.weakSpot.statusText ? mistakeHub.weakSpot.statusText : '未开始'}}</view>
        <view class="repair-complete-note" wx:if="{{todayFocus && todayFocus.repairStatus === 'completed'}}">已生成明天回访卡。下一步：去轻轻回访。</view>
        <view class="mini-action route-next-action" wx:if="{{todayFocus && todayFocus.repairStatus === 'completed'}}" bindtap="goTools">去轻回访</view>
        <view class="review-progress-line review-secondary-progress" wx:if="{{todayFocus && todayFocus.repairStatus === 'completed'}}">
          <view class="review-progress-track"><view class="review-progress-fill" style="width: {{gameRunway.percent || 0}}%;"></view></view>
          <view class="review-progress-copy">今日闭环进度 {{gameRunway.percent || 0}}%</view>
        </view>

        <view class="loop-rail soft review-secondary-rail" wx:if="{{showAdvancedReview}}">
          <view class="loop-line"></view>
          <view class="loop-step active">
            <view class="loop-dot collect"></view>
            <text>收错题</text>
          </view>
          <view class="loop-step">
            <view class="loop-dot inspect"></view>
            <text>找卡点</text>
          </view>
          <view class="loop-step">
            <view class="loop-dot transfer"></view>
            <text>举一反三</text>
          </view>
          <view class="loop-step">
            <view class="loop-dot quest"></view>
            <text>轻回访</text>
          </view>
        </view>

        <view class="hero-stats soft review-secondary-stats" wx:if="{{todayFocus && showAdvancedReview}}">
          <view class="hero-stat strong">
            <view class="hero-stat-value">{{mistakeHub.totalMistakes || 0}}</view>
            <view class="hero-stat-label">卡点卡</view>
          </view>
          <view class="hero-stat">
            <view class="hero-stat-value">{{mistakeHub.repairReady || 0}}</view>
            <view class="hero-stat-label">待修</view>
          </view>
          <view class="hero-stat">
            <view class="hero-stat-value">{{gameRunway.streak || 0}}</view>
            <view class="hero-stat-label">连续天</view>
          </view>
        </view>
      </view>

      <view class="weakspot-panel rc-sunk" wx:if="{{showAdvancedReview && mistakeHub.weakSpot}}">
        <view class="panel-head compact">
          <view>
            <view class="panel-title">今晚先修这个卡点</view>
            <view class="panel-subtitle">来自今天卡住的地方和复习记录。</view>
          </view>
          <view class="weakspot-score">{{mistakeHub.weakSpot.confidence}}%</view>
        </view>
        <view class="weakspot-name">{{mistakeHub.weakSpot.name}}</view>
        <view class="weakspot-row">
          <view class="weakspot-label">为什么修它</view>
          <view class="weakspot-text">{{mistakeHub.weakSpot.evidence}}</view>
        </view>
        <view class="weakspot-row">
          <view class="weakspot-label">孩子原话</view>
          <view class="weakspot-text">{{mistakeHub.weakSpot.cause}}</view>
        </view>
        <view class="weakspot-row highlight">
          <view class="weakspot-label">怎么修</view>
          <view class="weakspot-text">{{mistakeHub.weakSpot.next}}</view>
        </view>
        <view class="weakspot-row">
          <view class="weakspot-label">谁来帮</view>
          <view class="weakspot-text">{{mistakeHub.weakSpot.helper}}</view>
        </view>
      </view>

      <view class="quest-panel rc-after-repair" wx:if="{{todayFocus && todayFocus.repairStatus === 'completed'}}">
        <view class="panel-head compact">
          <view>
            <view class="panel-title">5 分钟轻回访</view>
            <view class="panel-subtitle">{{gameRunway.due ? '按记忆间隔，只推今天该回忆的卡。' : '今天没有到期卡，可以先录入或生成新错题。'}}</view>
          </view>
          <view class="xp-pill">回访中</view>
        </view>

        <view class="quest-badges">
          <view class="quest-badge flame">连续 {{gameRunway.streak || 0}} 天</view>
          <view class="quest-badge target">今日 {{gameRunway.percent || 0}}%</view>
        </view>

        <view class="progress-wrap">
          <view class="progress-track">
            <view class="progress-fill" style="width: {{gameRunway.percent}}%;"></view>
          </view>
          <view class="progress-copy">进度 {{cards.length ? index + 1 : 0}} / {{cards.length || 0}}</view>
        </view>

        <view class="review-question-card" wx:if="{{current}}">
          <view class="card-label">先自己想，再核对</view>
          <view class="question-text">{{current.question}}</view>
          <view class="hint-text"><text class="hint-icon">i</text>卡住会回到卡点和同类题</view>

          <view class="answer-panel" wx:if="{{showAnswer}}">
            <view class="answer-label">核对思路</view>
            <view class="answer-text">{{current.answer}}</view>
          </view>

          <view class="options-group">
            <view class="option-btn selected" wx:if="{{!showAnswer}}" bindtap="reveal">
              <text class="letter">A</text>
              我先回忆，点这里核对思路
            </view>
            <view class="option-btn" wx:if="{{showAnswer}}" data-rating="again" bindtap="rate">
              <text class="letter">A</text>
              没想起来，回卡点再练
            </view>
            <view class="option-btn" wx:if="{{showAnswer}}" data-rating="good" bindtap="rate">
              <text class="letter">B</text>
              记住了，下一张
            </view>
            <view class="option-btn" wx:if="{{showAnswer}}" data-rating="easy" bindtap="rate">
              <text class="letter">C</text>
              很熟了，晚点再出现
            </view>
          </view>
        </view>

        <view class="transfer-practice-card" wx:if="{{current && transferPractice}}">
          <view class="card-label">{{transferPractice.title}}</view>
          <view class="transfer-status">{{transferPractice.statusLine}}</view>
          <view class="transfer-safety">{{transferPractice.subtitle}}</view>
          <view
            class="transfer-step {{item.done ? 'done' : ''}}"
            wx:for="{{transferPractice.prompts}}"
            wx:key="id"
          >
            <view class="transfer-copy">
              <view class="transfer-label">{{item.label}}</view>
              <view class="transfer-prompt">{{item.prompt}}</view>
              <view class="transfer-check">{{item.check}}</view>
            </view>
            <button
              class="transfer-action"
              data-prompt-id="{{item.id}}"
              bindtap="recordTransferPractice"
            >{{item.actionLabel}}</button>
          </view>
          <view class="transfer-parent" wx:if="{{transferPractice.parentPrompt}}">家长只问：{{transferPractice.parentPrompt}}</view>
        </view>

        <view class="outcome-check-card" wx:if="{{current && outcomeCheck}}">
          <view class="card-label">{{outcomeCheck.title}}</view>
          <view class="outcome-score">掌握 {{outcomeCheck.score}}% · 下一层：{{outcomeCheck.nextLevel}}</view>
          <view class="outcome-line">{{outcomeCheck.line}}</view>
          <view class="outcome-actions">
            <button
              class="outcome-action"
              wx:for="{{outcomeCheck.actions}}"
              wx:key="id"
              data-field="{{item.field}}"
              bindtap="recordOutcomeCheck"
            >{{item.label}}</button>
          </view>
        </view>

        <view class="review-question-card done-card" wx:if="{{done}}">
          <view class="card-label">今日完成</view>
          <view class="question-text">今天这轮结束了。</view>
          <view class="hint-text">可以录入一道新错题，或者用作业点拨拆一个关键卡点。</view>
        </view>

        <view class="quest-actions">
          <view class="pack-primary review-main-cta" wx:if="{{current && !showAnswer}}" bindtap="reveal">开始这一关</view>
          <view class="pack-primary review-main-cta" wx:elif="{{current && showAnswer}}" data-rating="good" bindtap="rate">下一张</view>
          <view class="pack-primary review-main-cta" wx:else data-action="{{gameRunway.primaryAction}}" bindtap="runPlaybookAction">{{gameRunway.primaryLabel}}</view>
          <view class="mini-action" bindtap="goTutor">卡住了，再看关键一步</view>
        </view>
      </view>

      <view class="review-more-toggle">
        <view>
          <view class="review-more-title">错题本管理</view>
          <view class="review-more-subtitle">录入本子错题、看来源、生成同类题</view>
        </view>
        <button class="review-more-button" bindtap="toggleAdvancedReview">{{showAdvancedReview ? '收起' : '展开'}}</button>
      </view>

      <block wx:if="{{showAdvancedReview}}">
        <view class="source-panel">
          <view class="panel-head">
            <view>
              <view class="panel-title">错题从哪里来</view>
              <view class="panel-subtitle">自动收集 App 内错题，也能手动录入本子上的错题。</view>
            </view>
          </view>

          <view class="source-grid">
            <view class="source-card app">
              <view class="source-icon auto"></view>
              <view class="source-copy">
                <view class="source-title">App 里做错</view>
                <view class="source-body">{{mistakeHub.appMistakes || 0}} 张来自复习、测验、作业点拨和学习任务</view>
              </view>
            </view>
            <view class="source-card offline" bindtap="openImportPanel">
              <view class="source-icon book"></view>
              <view class="source-copy">
                <view class="source-title">本子上做错</view>
                <view class="source-body">{{mistakeHub.manualMistakes || 0}} 张已手动录入，点这里继续补</view>
              </view>
            </view>
          </view>
        </view>

        <view class="repair-panel">
          <view class="panel-head">
            <view>
              <view class="panel-title">先抓一个关键卡点</view>
              <view class="panel-subtitle">不是把错题堆起来，而是找出下次先检查哪一步。</view>
            </view>
            <view class="panel-count">{{mistakeHub.repairReady || 0}}</view>
          </view>

          <view class="repair-list" wx:if="{{mistakeHub.repairItems && mistakeHub.repairItems.length}}">
            <view
              class="repair-card"
              wx:for="{{mistakeHub.repairItems}}"
              wx:key="noteId"
            >
              <view class="repair-reason">{{item.reason}}</view>
              <view class="repair-question">{{item.question}}</view>
              <view class="repair-preview" wx:if="{{item.repairPreviewQuestion}}">{{item.repairPreviewQuestion}}</view>
              <view class="repair-action" data-note-id="{{item.noteId}}" bindtap="editQueueItem">生成同类题</view>
            </view>
          </view>

          <view class="repair-empty" wx:else>
            <view class="repair-empty-title">暂时没有急着修的卡点</view>
            <view class="repair-empty-body">继续复习或录入新错题后，这里会自动出现需要举一反三的题。</view>
          </view>
        </view>

        <view class="import-panel">
          <view class="panel-head compact">
            <view>
              <view class="panel-title">录入一道线下错题</view>
              <view class="panel-subtitle">把题目、孩子写错的一步、老师批注放进来。</view>
            </view>
          </view>
          <textarea
            class="import-textarea"
            value="{{importText}}"
            placeholder="例：题目 + 我写到哪一步 + 错在哪里..."
            maxlength="3000"
            bindinput="onImportInput"
          />
          <view class="preview-list" wx:if="{{importPreview && importPreview.length}}">
            <view class="preview-chip" wx:for="{{importPreview}}" wx:key="id">{{item.type || '卡点卡'}}</view>
          </view>
          <view class="import-actions">
            <view class="mini-action" bindtap="goUpload">贴题/本子</view>
            <view class="primary-action" bindtap="importCards">整理进错题本</view>
          </view>
        </view>
      </block>

      <view class="feedback-line" wx:if="{{feedbackText}}">{{feedbackText}}</view>

      <view hidden>{{showAdvancedReview ? 'advanced open' : 'advanced closed'}}</view>
      <button hidden bindtap="toggleAdvancedReview">toggleAdvancedReview</button>
      <button hidden bindtap="reveal">先回忆，再选择</button>
      <button hidden data-rating="good" bindtap="rate">记住了</button>
    </view>
  </scroll-view>
</view>
