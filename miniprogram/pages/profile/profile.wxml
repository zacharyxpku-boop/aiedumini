          <view wx:for="{{communityShareRelayBoard.peerRelayChallengeLadder.stages}}" wx:key="id">接力阶梯：{{item.label}}｜{{item.visibleLine}}｜{{item.receiverAction}}｜证据 {{item.proofRequired}}</view>
          <view wx:for="{{communityShareRelayBoard.copyableChallengeTemplates}}" wx:key="id">可复制挑战：{{item.title}}｜{{item.copy}}｜证据 {{item.proofRequired}}</view>
          <view wx:for="{{communityShareRelayBoard.sourceBackedChallengeDeck}}" wx:key="id">来源挑战：{{item.title}}｜{{item.receiverPrompt}}｜使用判断 {{item.commercialDecision}}｜许可 {{item.licenseSignal}}</view>
          <view wx:for="{{communityShareRelayBoard.publicK12IntakeChallengeDeck}}" wx:key="id">公开作业挑战：{{item.title}}｜{{item.firstStepPrompt}}｜{{item.shareHook}}｜禁止 {{item.blockedUse[0]}}</view>
          <view wx:if="{{communityShareRelayBoard.localSpreadReleaseGate}}">
            本地放行门禁：{{communityShareRelayBoard.localSpreadReleaseGate.status}}｜{{communityShareRelayBoard.localSpreadReleaseGate.rule}}
          </view>
          <view wx:for="{{communityShareRelayBoard.lanes}}" wx:key="id">{{item.label}}：{{item.action}}｜{{item.evidence}}</view>
          <view wx:for="{{communityShareRelayBoard.visualRelayProtocol}}" wx:key="id">小黑板接力协议：{{item.label}}｜{{item.action}}｜证据 {{item.evidence}}｜禁止 {{item.blocked}}</view>
          <view wx:for="{{communityShareRelayBoard.visualRelayProofChecklist}}" wx:key="*this">小黑板证据清单：{{item}}</view>
          <view wx:if="{{communityShareRelayBoard.visualRelayBoundary}}">小黑板接力边界：{{communityShareRelayBoard.visualRelayBoundary}}</view>
          <view wx:for="{{communityShareRelayBoard.recentRuns}}" wx:key="id">接力记录：{{item.code}} · {{item.evidence}}</view>
          <view wx:for="{{communityShareRelayBoard.challengeCompletions}}" wx:key="id">完成回流：{{item.share_code || item.code}} · {{item.completion_kind || item.type}}</view>
          <view>{{communityShareRelayBoard.contractLine}}</view>
          <view>{{communityShareRelayBoard.returnPathLine}}</view>
          <view wx:if="{{communityShareRelayBoard.safeRelayChallengePacket}}">
            安全字段：{{communityShareRelayBoard.safeRelayChallengePacket.allowedFields}}
          </view>
          <view wx:if="{{communityShareRelayBoard.safeRelayChallengePacket}}">
            不带字段：{{communityShareRelayBoard.safeRelayChallengePacket.blockedFields}}
          </view>
          <view wx:if="{{communityShareRelayBoard.wrongCauseViralChallengePack}}">
            错因挑战传播包：{{communityShareRelayBoard.wrongCauseViralChallengePack.wrongCause}}｜{{communityShareRelayBoard.wrongCauseViralChallengePack.receiverAction}}
          </view>
          <view wx:for="{{communityShareRelayBoard.wrongCauseViralChallengePack.hooks}}" wx:key="id">错因传播钩子：{{item.label}}｜{{item.line}}</view>
          <view wx:for="{{communityShareRelayBoard.wrongCauseViralChallengePack.receiverSteps}}" wx:key="id">错因接收步骤：{{item.label}}｜{{item.action}}</view>
          <view wx:if="{{communityShareRelayBoard.wrongCauseViralChallengePack}}">
            错因传播边界：{{communityShareRelayBoard.wrongCauseViralChallengePack.blockedFields}}
          </view>
        </view>
        <view class="share-conversation-card" wx:if="{{learningReportSummary.weeklyEvidenceFlywheel}}">
          <view class="share-conversation-title">{{learningReportSummary.weeklyEvidenceFlywheel.title}}</view>
          <view>{{learningReportSummary.weeklyEvidenceFlywheel.shareLine}}</view>
          <view>{{learningReportSummary.weeklyEvidenceFlywheel.privacyBoundary}}</view>
          <view wx:for="{{learningReportSummary.weeklyEvidenceFlywheelDays}}" wx:key="day">第{{item.day}}天：{{item.label}}｜{{item.evidence}}</view>
          <view>可分享字段：{{learningReportSummary.weeklyEvidenceFlywheelSharePayload.allowed_fields}}</view>
          <view>禁止字段：{{learningReportSummary.weeklyEvidenceFlywheelSharePayload.blocked_fields}}</view>
        </view>
        <view class="share-invite">{{dailyShareCard.inviteLine}}</view>
        <view class="wechat-share-row">
          <button
            class="wechat-share-btn parent"
            open-type="share"
            data-intent="parent_card"
            bindtap="setShareIntent"
          >
            发给家长看
          </button>
          <button
            class="wechat-share-btn peer"
            open-type="share"
            data-intent="peer_challenge"
            bindtap="setShareIntent"
          >
            继续轻回访
          </button>
        </view>
        <view class="share-archive">{{dailyShareCard.shareArchiveLabel}}</view>
        <view class="share-actions">
          <button class="share-primary" open-type="share" data-intent="peer_challenge" bindtap="setShareIntent">{{dailyShareCard.shareButton}}</button>
          <button class="share-secondary" data-action="arcade" bindtap="runParentReportAction">去轻回访</button>
        </view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'loop'}}">
      <view class="parent-section-card game-profile-card" wx:if="{{gameProfileCard}}">
        <view class="section-title-row compact">
          <view class="section-stick yellow"></view>
          <view class="parent-card-title">{{gameProfileCard.title}}</view>
        </view>
        <view class="game-profile-top">
          <view>
            <view class="game-level">连续 {{gameProfileCard.streak}} 天有记录</view>
            <view class="game-level-sub">今天只看有没有说清第一步</view>
          </view>
          <view class="coin-pill">轻回访</view>
        </view>
        <view class="game-progress-track">
          <view class="game-progress-fill" style="width: {{gameProfileCard.level.progress}}%;"></view>
        </view>
        <view class="game-profile-grid">
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.xp}}</view>
            <view class="game-profile-label">回访</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.streak}}</view>
            <view class="game-profile-label">连续天</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.lives}}</view>
            <view class="game-profile-label">次数</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.unlockedCount}}</view>
            <view class="game-profile-label">记录</view>
          </view>
        </view>
        <view class="achievement-line">{{gameProfileCard.achievementText}}</view>
        <view class="leaderboard-notice">{{gameProfileCard.leaderboardNotice}}</view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'family' && showAdvancedProfile}}">
      <view class="parent-section-card unlock-card" wx:if="{{commercialUnlockCard}}">
        <view class="section-title-row compact">
          <view class="section-stick yellow"></view>
          <view class="parent-card-title">{{commercialUnlockCard.title}}</view>
        </view>
        <view class="unlock-body">{{commercialUnlockCard.body}}</view>
        <view class="unlock-progress">{{commercialUnlockCard.done}}/{{commercialUnlockCard.total}} 已完成</view>
        <view class="unlock-step-row">
          <view class="unlock-step {{item.done ? 'done' : ''}}" wx:for="{{commercialUnlockCard.steps}}" wx:key="id">
            <view class="unlock-dot"></view>
            <view class="unlock-label">{{item.label}}</view>
          </view>
        </view>
        <button class="unlock-button" data-action="{{commercialUnlockCard.action}}" bindtap="runParentReportAction">{{commercialUnlockCard.cta}}</button>
        <button class="unlock-secondary" wx:if="{{commercialUnlockCard.secondaryCta}}" data-action="{{commercialUnlockCard.secondaryAction}}" bindtap="runParentReportAction">{{commercialUnlockCard.secondaryCta}}</button>
        <view class="lead-card" wx:if="{{showLeadCard}}">
          <view class="lead-title">申请人工复盘</view>
          <view class="lead-body">把这周的追问、回访和错因记录整理成一次人工复盘。我们只看哪里值得继续修，不承诺结果。</view>
          <input class="lead-input" value="{{lead.name}}" data-field="name" bindinput="onLeadInput" placeholder="称呼" />
          <input class="lead-input" value="{{lead.phone}}" data-field="phone" bindinput="onLeadInput" placeholder="联系方式" />
          <button class="lead-submit" bindtap="submitLead" loading="{{sending}}">提交复盘申请</button>
        </view>
      </view>
      </block>
      </block>

      <view class="section more-toggle">
        <button class="manage-button" bindtap="toggleAdvancedProfile">更多建议</button>
      </view>

      <block wx:if="{{showAdvancedProfile}}">
        <view class="section panel stack advanced-card">
          <view class="v1-section-title">账号与同步</view>
          <view class="v1-section-subtitle">这里保留本机记录、登录和同步入口，平时不用管。</view>
          <view class="field">
            <view class="label">孩子昵称</view>
            <input class="input" value="{{profile.name}}" data-field="name" bindinput="onProfileInput" placeholder="可不填真实姓名" />
          </view>
          <view class="field">
            <view class="label">年级</view>
            <input class="input" value="{{profile.grade}}" data-field="grade" bindinput="onProfileInput" />
          </view>
          <button class="primary-button" bindtap="initSession">{{loginText}}</button>
          <button class="secondary-button" bindtap="syncNow">同步本地记录</button>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
