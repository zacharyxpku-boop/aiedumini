            <view class="label">年级</view>
            <input class="input" value="{{profile.grade}}" data-field="grade" bindinput="onProfileInput" />
          </view>
          <button class="primary-button" bindtap="initSession">{{loginText}}</button>
          <button class="secondary-button" bindtap="syncNow">同步本地记录</button>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
