        </view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'loop'}}">
      <view class="parent-section-card loop-proof-card" wx:if="{{parentLoopProof}}">
        <view class="section-title-row compact">
          <view class="section-stick green"></view>
          <view class="parent-card-title">学习闭环记录</view>
        </view>
        <view class="loop-proof-label">{{parentLoopProof.label}}</view>
        <view class="loop-proof-grid">
          <view class="loop-proof-cell" wx:for="{{parentLoopProof.cards}}" wx:key="id">
            <view class="loop-proof-value">{{item.value}}</view>
            <view class="loop-proof-name">{{item.label}}</view>
            <view class="loop-proof-body">{{item.body}}</view>
          </view>
        </view>
        <view class="loop-proof-next">{{parentLoopProof.next}}</view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'repair'}}">
      <view class="wrong-title-row">
        <view class="wrong-title">我的卡点修复</view>
        <view class="wrong-subtitle">看见反复错在哪里，再举一反三</view>
      </view>

      <view class="wrong-cause-grid" wx:if="{{wrongCauseSummary}}">
        <view class="wrong-cause-card {{item.level}}" wx:for="{{wrongCauseSummary.cards}}" wx:key="id">
          <view class="wrong-icon {{item.level}}"></view>
          <view class="wrong-cause-label">{{item.label}}</view>
          <view class="wrong-cause-num {{wrongCauseSummary.total ? '' : 'pending'}}">{{item.display}}</view>
        </view>
      </view>
      <view class="wrong-cause-note" wx:if="{{wrongCauseSummary}}">{{wrongCauseSummary.label}}</view>
      </block>

      <block wx:if="{{profilePanel === 'share'}}">
      <view class="daily-share-card" wx:if="{{dailyShareCard}}">
        <view class="share-card-top">
          <view>
            <view class="share-kicker">家长复盘卡</view>
            <view class="share-title">{{dailyShareCard.identityTag}}</view>
          </view>
          <view class="share-code">复盘码 {{dailyShareCard.inviteCode}}</view>
        </view>
        <view class="share-headline">{{dailyShareCard.title}}</view>
        <view class="share-subtitle">{{dailyShareCard.subtitle}}</view>
        <view class="share-family-action-line" wx:if="{{dailyShareCard.unifiedNextAction}}">下一步：{{dailyShareCard.unifiedNextAction.actionLabel}}</view>
        <view class="share-family-action-line" wx:if="{{dailyShareCard.globalEvidenceBrief}}">{{dailyShareCard.globalEvidenceBrief.shareLine}}</view>
        <view class="share-family-action-line" wx:if="{{dailyShareCard.reportDailyAction.ready}}">今日行动：{{dailyShareCard.reportDailyAction.actionLine}}</view>
        <view class="share-level-row">
          <view class="share-level">{{dailyShareCard.levelText}}</view>
          <view class="share-achievement">{{dailyShareCard.achievementText}}</view>
        </view>
        <view class="share-family-action" wx:if="{{dailyShareCard.familyActionCard}}">
          <view class="share-family-action-title">{{dailyShareCard.familyActionCard.title}}</view>
          <view class="share-family-action-line">{{dailyShareCard.familyActionCard.judgement}}</view>
          <view class="share-family-action-line">今晚：{{dailyShareCard.familyActionCard.tonightAction}}</view>
          <view class="share-family-action-line">家长只问：{{dailyShareCard.familyActionCard.parentQuestion}}</view>
          <view class="share-family-action-line">明天复核：{{dailyShareCard.familyActionCard.tomorrowCheck}}</view>
          <view class="share-family-action-evidence">{{dailyShareCard.familyActionCard.evidenceLine}}</view>
          <view class="share-family-action-evidence" wx:if="{{dailyShareCard.familyActionCard.capabilityLine}}">{{dailyShareCard.familyActionCard.capabilityLine}}</view>
          <view class="share-family-action-evidence" wx:if="{{dailyShareCard.familyActionCard.subjectDepthLine}}">题型：{{dailyShareCard.familyActionCard.subjectDepthLine}}</view>
          <view class="share-family-action-boundary">{{dailyShareCard.familyActionCard.boundary}}</view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.subjectSkillDepth}}">
          <view class="share-conversation-title">{{dailyShareCard.subjectSkillDepth.label}}</view>
          <view>第一步：{{dailyShareCard.subjectSkillDepth.firstStep}}</view>
          <view>家长只问：{{dailyShareCard.subjectSkillDepth.parentQuestion}}</view>
          <view wx:if="{{dailyShareCard.subjectSkillDepth.reportSignal}}">{{dailyShareCard.subjectSkillDepth.reportSignal}}</view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.curriculumSpine}}">
          <view class="share-conversation-title">{{dailyShareCard.curriculumSpine.title}}</view>
          <view>{{dailyShareCard.curriculumSpine.shareLine}}</view>
          <view>{{dailyShareCard.curriculumSpine.parentDecisionLine}}</view>
          <view wx:for="{{dailyShareCard.curriculumSpine.progression}}" wx:key="id">{{item.order}}. {{item.label}}：{{item.evidence}}</view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.visualSocraticMatrix}}">
          <view class="share-conversation-title">{{dailyShareCard.visualSocraticMatrix.title}}</view>
          <view>{{dailyShareCard.visualSocraticMatrix.visualBoundary}}</view>
          <view wx:for="{{dailyShareCard.visualSocraticMatrix.boardMoves}}" wx:key="id">{{item.order}}. {{item.drawAction}}</view>
          <view wx:for="{{dailyShareCard.visualSocraticMatrix.socraticQuestions}}" wx:key="id">追问{{item.order}}：{{item.question}}</view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.capabilityGap}}">
          <view class="share-conversation-title">{{dailyShareCard.capabilityGap.label}}</view>
          <view>{{dailyShareCard.capabilityGap.nextAction}}</view>
          <view wx:if="{{dailyShareCard.capabilityGap.evidenceLine}}">{{dailyShareCard.capabilityGap.evidenceLine}}</view>
          <view wx:if="{{dailyShareCard.capabilityGap.ledgerLine}}">{{dailyShareCard.capabilityGap.ledgerLine}}</view>
        </view>
        <view class="share-stat-grid">
          <view class="share-stat" wx:for="{{dailyShareCard.stats}}" wx:key="id">
            <view class="share-stat-value">{{item.value}}</view>
            <view class="share-stat-label">{{item.label}}</view>
          </view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.parentConversationPlan}}">
          <view class="share-conversation-title">今晚这样问</view>
          <view>开场：{{dailyShareCard.parentConversationPlan.open}}</view>
          <view>追问：{{dailyShareCard.parentConversationPlan.follow}}</view>
          <view>边界：{{dailyShareCard.parentConversationPlan.avoid}}</view>
          <view wx:if="{{dailyShareCard.shareOutcome}}">明天：{{dailyShareCard.shareOutcome.nextAction}}</view>
        </view>
        <view class="share-conversation-card" wx:if="{{dailyShareCard.shareChallengePlan}}">
          <view class="share-conversation-title">{{dailyShareCard.shareChallengePlan.title}}</view>
          <view>{{dailyShareCard.shareChallengePlan.goal}}</view>
          <view>{{dailyShareCard.shareChallengePlan.noRankingLine}}</view>
          <view>{{dailyShareCard.shareChallengePlan.modeLine}}</view>
          <view wx:for="{{dailyShareCard.shareChallengePlan.steps}}" wx:key="id">{{item.label}}：{{item.text}}</view>
          <view wx:for="{{dailyShareCard.shareChallengePlan.reviewCadence}}" wx:key="id">{{item.label}}回访：{{item.text}}</view>
          <view>{{dailyShareCard.shareChallengePlan.privacyBoundary}}</view>
          <view>{{dailyShareCard.shareChallengePlan.peerSafeLine}}</view>
          <view>{{dailyShareCard.shareChallengePlan.evidenceContractLine}}</view>
          <view wx:for="{{dailyShareCard.shareChallengePlan.relayChain}}" wx:key="id">{{item.label}}接力：{{item.text}}</view>
          <view wx:for="{{dailyShareCard.shareChallengePlan.returnPathContract}}" wx:key="id">{{item.label}}：{{item.text}}</view>
          <view>{{dailyShareCard.shareChallengePlan.parentEvidenceLine}}</view>
          <view>{{dailyShareCard.shareChallengePlan.successRule}}</view>
          <view>{{dailyShareCard.shareChallengePlan.failureFallback}}</view>
        </view>
        <view class="share-invite">{{dailyShareCard.inviteLine}}</view>
        <view class="wechat-share-row">
          <button
            class="wechat-share-btn parent"
            open-type="share"
            data-intent="parent_card"
            bindtap="setShareIntent"
          >
            发给家长看
          </button>
          <button
            class="wechat-share-btn peer"
            open-type="share"
            data-intent="peer_challenge"
            bindtap="setShareIntent"
          >
            继续轻回访
          </button>
        </view>
        <view class="share-archive">{{dailyShareCard.shareArchiveLabel}}</view>
        <view class="share-actions">
          <button class="share-primary" open-type="share" data-intent="peer_challenge" bindtap="setShareIntent">{{dailyShareCard.shareButton}}</button>
          <button class="share-secondary" data-action="arcade" bindtap="runParentReportAction">去轻回访</button>
        </view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'loop'}}">
      <view class="parent-section-card game-profile-card" wx:if="{{gameProfileCard}}">
        <view class="section-title-row compact">
          <view class="section-stick yellow"></view>
          <view class="parent-card-title">{{gameProfileCard.title}}</view>
        </view>
        <view class="game-profile-top">
          <view>
            <view class="game-level">连续 {{gameProfileCard.streak}} 天有记录</view>
            <view class="game-level-sub">今天只看有没有说清第一步</view>
          </view>
          <view class="coin-pill">轻回访</view>
        </view>
        <view class="game-progress-track">
          <view class="game-progress-fill" style="width: {{gameProfileCard.level.progress}}%;"></view>
        </view>
        <view class="game-profile-grid">
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.xp}}</view>
            <view class="game-profile-label">回访</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.streak}}</view>
            <view class="game-profile-label">连续天</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.lives}}</view>
            <view class="game-profile-label">次数</view>
          </view>
          <view class="game-profile-cell">
            <view class="game-profile-value">{{gameProfileCard.unlockedCount}}</view>
            <view class="game-profile-label">记录</view>
          </view>
        </view>
        <view class="achievement-line">{{gameProfileCard.achievementText}}</view>
        <view class="leaderboard-notice">{{gameProfileCard.leaderboardNotice}}</view>
      </view>
      </block>

      <block wx:if="{{profilePanel === 'family' && showAdvancedProfile}}">
      <view class="parent-section-card unlock-card" wx:if="{{commercialUnlockCard}}">
        <view class="section-title-row compact">
          <view class="section-stick yellow"></view>
          <view class="parent-card-title">{{commercialUnlockCard.title}}</view>
        </view>
        <view class="unlock-body">{{commercialUnlockCard.body}}</view>
        <view class="unlock-progress">{{commercialUnlockCard.done}}/{{commercialUnlockCard.total}} 已完成</view>
        <view class="unlock-step-row">
          <view class="unlock-step {{item.done ? 'done' : ''}}" wx:for="{{commercialUnlockCard.steps}}" wx:key="id">
            <view class="unlock-dot"></view>
            <view class="unlock-label">{{item.label}}</view>
          </view>
        </view>
        <button class="unlock-button" data-action="{{commercialUnlockCard.action}}" bindtap="runParentReportAction">{{commercialUnlockCard.cta}}</button>
        <button class="unlock-secondary" wx:if="{{commercialUnlockCard.secondaryCta}}" data-action="{{commercialUnlockCard.secondaryAction}}" bindtap="runParentReportAction">{{commercialUnlockCard.secondaryCta}}</button>
        <view class="lead-card" wx:if="{{showLeadCard}}">
          <view class="lead-title">申请人工复盘</view>
          <view class="lead-body">把这周的追问、回访和错因记录整理成一次人工复盘。我们只看哪里值得继续修，不承诺结果。</view>
          <input class="lead-input" value="{{lead.name}}" data-field="name" bindinput="onLeadInput" placeholder="称呼" />
          <input class="lead-input" value="{{lead.phone}}" data-field="phone" bindinput="onLeadInput" placeholder="联系方式" />
          <button class="lead-submit" bindtap="submitLead" loading="{{sending}}">提交复盘申请</button>
        </view>
      </view>
      </block>
      </block>

      <view class="section more-toggle">
        <button class="manage-button" bindtap="toggleAdvancedProfile">更多建议</button>
      </view>

      <block wx:if="{{showAdvancedProfile}}">
        <view class="section panel stack advanced-card">
          <view class="v1-section-title">账号与同步</view>
          <view class="v1-section-subtitle">这里保留本机记录、登录和同步入口，平时不用管。</view>
          <view class="field">
            <view class="label">孩子昵称</view>
            <input class="input" value="{{profile.name}}" data-field="name" bindinput="onProfileInput" placeholder="可不填真实姓名" />
          </view>
          <view class="field">
            <view class="label">年级</view>
            <input class="input" value="{{profile.grade}}" data-field="grade" bindinput="onProfileInput" />
          </view>
          <button class="primary-button" bindtap="initSession">{{loginText}}</button>
          <button class="secondary-button" bindtap="syncNow">同步本地记录</button>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
