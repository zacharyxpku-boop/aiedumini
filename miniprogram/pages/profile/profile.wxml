<view class="page safe-bottom profile-page">
  <view class="page-positioning profile-positioning">
    <view class="positioning-kicker">家长复盘</view>
    <view class="positioning-title">家长今晚只问一句：刚才你第一步先看了哪里？</view>
    <view class="positioning-flow">先看今晚真实证据，再决定去修卡点、专注舱或轻回访；不是报表墙。</view>
  </view>
  <view class="profile-glow glow-one"></view>
  <view class="profile-glow glow-two"></view>

  <scroll-view class="profile-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="profile-shell">
      <view class="v1-topbar">
        <view class="profile-brand">
          <view class="profile-logo"><view class="profile-logo-leaf"></view></view>
          <view class="profile-brand-copy">
            <view class="profile-brand-name">我的</view>
            <view class="profile-brand-sub">家长 5 秒复盘</view>
          </view>
        </view>
        <view class="profile-pill"><text class="pill-dot"></text>真实记录</view>
      </view>

      <block wx:if="{{profilePanel === 'main'}}">
      <view class="rc14-profile-first-screen">
      <view class="parent-hero">
        <view class="mine-hero-copy">
          <view class="route-strip compact">{{profileViewModel.routePill}}</view>
          <view class="companion-route-strip">{{profileViewModel.companionStrip}}</view>
          <view class="parent-title">{{profileViewModel.title}}</view>
          <view class="parent-subtitle">{{profileViewModel.subtitle}}</view>
        </view>

        <view class="family-summary-card rc14-main-card friend-profile-core">
          <view class="family-summary-title">今晚决策首页：5 秒行动卡，听一句、问一句、明天回访</view>
          <view class="family-summary-body family-readable">
            <view class="profile-empty-state" wx:if="{{profileSafeSummary.isEmpty}}">再用两晚后，咕点会帮你看见模式。</view>
            <view class="parent-brief-block tonight-parent-decision-card" wx:if="{{learningReportSummary.tonightParentDecisionCard}}">
              <text class="parent-brief-label">{{learningReportSummary.tonightParentDecisionCard.title}}</text>
              <text>{{learningReportSummary.tonightParentDecisionCard.subtitle}}</text>
              <text wx:for="{{learningReportSummary.tonightParentDecisionCardRows}}" wx:key="id">{{item.label}}：{{item.text}}</text>
              <text>{{learningReportSummary.tonightParentDecisionCard.evidenceLine}}</text>
              <text>{{learningReportSummary.tonightParentDecisionCard.safetyLine}}</text>
              <button class="copy-action family-decision-primary" wx:if="{{learningReportSummary.tonightParentDecisionCardRoute}}" bindtap="runFamilyDecisionHomepageAction">{{learningReportSummary.tonightParentDecisionCardCtaLabel}}</button>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.familyDecisionHomepage}}">
              <text class="parent-brief-label">今晚结论</text>
              <text>{{learningReportSummary.familyDecisionHomepageHeadline}}</text>
              <text>状态：{{learningReportSummary.familyDecisionHomepageStatus}}</text>
              <text wx:if="{{learningReportSummary.familyDecisionHomepagePrimaryBlocker}}">当前缺口：{{learningReportSummary.familyDecisionHomepagePrimaryBlocker}}</text>
              <text wx:if="{{learningReportSummary.familyDecisionHomepageNextLocalAction}}">下一步：{{learningReportSummary.familyDecisionHomepageNextLocalAction}}</text>
              <text wx:if="{{learningReportSummary.familyDecisionHomepageSourceLine}}">依据：{{learningReportSummary.familyDecisionHomepageSourceLine}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.familyDecisionHomepageStatusSteps.length}}">
              <text class="parent-brief-label">证据状态条</text>
              <text wx:for="{{learningReportSummary.familyDecisionHomepageStatusSteps}}" wx:key="id">{{item.label}}：{{item.status}} · {{item.line}}</text>
            </view>
            <view class="parent-action-snapshot">
              <view class="parent-action-head">
                <text>今晚做 / 不做 / 明天验收</text>
                <text>{{profileSafeSummary.confidenceLabel}}</text>
              </view>
              <view class="parent-action-grid">
                <view class="parent-action-chip" wx:for="{{profileSafeSummary.parentActionChecklist}}" wx:key="id">
                  <text class="parent-action-label">{{item.label}}</text>
                  <text class="parent-action-text">{{item.text}}</text>
                </view>
              </view>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.familyDecisionHomepageDoList.length}}">
              <text class="parent-brief-label">今晚做</text>
              <text wx:for="{{learningReportSummary.familyDecisionHomepageDoList}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.familyDecisionHomepageDontList.length}}">
              <text class="parent-brief-label">今晚不做</text>
              <text wx:for="{{learningReportSummary.familyDecisionHomepageDontList}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">今晚卡住</text>
              <text>{{profileSafeSummary.stuckLine}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">第一步证据</text>
              <text>{{profileSafeSummary.firstStepLine}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">只问一句</text>
              <text>{{profileSafeSummary.parentQuestion}}</text>
              <button class="copy-action" bindtap="copyParentOneQuestion">复制</button>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">明天回访</text>
              <text>{{learningReportSummary.familyDecisionHomepageTomorrow || profileSafeSummary.tomorrowRevisit}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.familyDecisionHomepageEvidenceList.length}}">
              <text class="parent-brief-label">证据来自</text>
              <text wx:for="{{learningReportSummary.familyDecisionHomepageEvidenceList}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">最近小结</text>
              <text>{{profileSafeSummary.recentSummary}}</text>
              <text wx:if="{{profileSafeSummary.threeNightSummary}}">{{profileSafeSummary.threeNightSummary}}</text>
              <text wx:if="{{profileSafeSummary.sevenNightSummary}}">{{profileSafeSummary.sevenNightSummary}}</text>
              <text wx:if="{{profileSafeSummary.weeklySummary}}">{{profileSafeSummary.weeklySummary}}</text>
            </view>
            <view class="parent-brief-reason" wx:if="{{learningReportSummary.reportEvidenceTopLine}}">报告一口径：{{learningReportSummary.reportEvidenceTopLine}}</view>
            <view class="parent-brief-reason" wx:if="{{learningReportSummary.nextEvidenceTopLine}}">下一证据：{{learningReportSummary.nextEvidenceTopLine}}</view>
            <view class="parent-brief-reason">{{learningReportSummary.familyDecisionHomepageLocalAiSplitLine}}</view>
            <view class="parent-brief-reason" wx:if="{{learningReportSummary.familyDecisionHomepageShareBoundary}}">{{learningReportSummary.familyDecisionHomepageShareBoundary}}</view>
            <view class="parent-brief-reason">{{profileSafeSummary.evidenceBoundaryLine}}</view>
            <button class="copy-action family-decision-primary" wx:if="{{learningReportSummary.familyDecisionHomepageRoute}}" bindtap="runFamilyDecisionHomepageAction">{{learningReportSummary.familyDecisionHomepageCtaLabel}}</button>
          </view>
        </view>

        <view class="family-summary-card profile-material-decision-snapshot" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossier}}">
          <view class="family-summary-title">测评/错题资料决策卡</view>
          <view class="family-summary-body family-readable">
            <view class="parent-brief-block" wx:if="{{learningReportSummary.personalizedParentReportPreview}}">
              <text class="parent-brief-label">标准版 HTML 报告</text>
              <text>{{learningReportSummary.personalizedParentReportTitle}}</text>
              <text>标准版本：{{learningReportSummary.personalizedParentReportStandardVersion}}｜格式：{{learningReportSummary.personalizedParentReportFormat}}</text>
              <text>导出规则：{{learningReportSummary.personalizedParentReportExportLine}}</text>
              <text wx:if="{{learningReportSummary.personalizedParentReportPrintRule}}">PDF：{{learningReportSummary.personalizedParentReportPrintRule}}</text>
              <text wx:for="{{learningReportSummary.personalizedParentReportQualityGates}}" wx:key="*this">质量门槛：{{item}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.personalizedParentReportSop && showAdvancedProfile}}">
              <text class="parent-brief-label">报告 SOP</text>
              <text>录入：{{learningReportSummary.personalizedParentReportSop.intake}}</text>
              <text>归一：{{learningReportSummary.personalizedParentReportSop.normalize}}</text>
              <text>分析：{{learningReportSummary.personalizedParentReportSop.analyze}}</text>
              <text>验证：{{learningReportSummary.personalizedParentReportSop.validate}}</text>
              <text>交付：{{learningReportSummary.personalizedParentReportSop.deliver}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.personalizedParentReportCompetitorBenchmarks.length && showAdvancedProfile}}">
              <text class="parent-brief-label">外部优秀做法后的闭环动作</text>
              <text wx:for="{{learningReportSummary.personalizedParentReportCompetitorBenchmarks}}" wx:key="id">{{item.outsideLine}}｜我们承接：{{item.productAnswer}}｜入口：{{item.route}}｜回流：{{item.evidenceReturn}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.personalizedParentReportMiniappPlan && showAdvancedProfile}}">
              <text class="parent-brief-label">小程序/轻量 APP 承接</text>
              <text>{{learningReportSummary.personalizedParentReportMiniappPlan.primarySurface}}</text>
              <text>{{learningReportSummary.personalizedParentReportMiniappPlan.lightAppSurface}}</text>
              <text wx:for="{{learningReportSummary.personalizedParentReportMiniappPlan.nextBuildOrder}}" wx:key="*this">顺序：{{item}}</text>
              <text>禁止捷径：{{learningReportSummary.personalizedParentReportMiniappPlan.blockedShortcut}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">{{learningReportSummary.uploadedMaterialDecisionDossierTitle}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierSummary}}</text>
              <text wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierReleaseGate.status === 'portrait_candidate'}}">{{learningReportSummary.uploadedMaterialDecisionDossierChildStrengthLine}}</text>
              <text wx:else>方法候选：先用真实错题、隔天回访和第 7 天小变式验证，不贴天赋或人格标签。</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">怎么学更好</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierHowToLearnBetter}}" wx:key="id">{{item.label}}：{{item.method}}｜验证：{{item.verifyWith}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierWrongPaperDiagnosisCards}}" wx:key="id">错题修复：{{item.label}}｜{{item.nextAction}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMethodCandidateCards.length}}">
              <text class="parent-brief-label">方法候选卡</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierMethodCandidateCards}}" wx:key="id">{{item.label}}｜今晚：{{item.tonightTry}}｜明天：{{item.parentQuestionTomorrow}}｜第7天：{{item.day7Evidence}}</text>
            </view>
            <button class="copy-action family-decision-primary" wx:if="{{!showAdvancedProfile}}" bindtap="toggleAdvancedProfile">查看更多证据和方法依据</button>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyGuide && showAdvancedProfile}}">
              <text class="parent-brief-label">{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyGuideTitle}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyGuideSummary}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyGuidePrimary}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyGuideServiceMode}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyCards}}" wx:key="id">{{item.label}}｜适用：{{item.useWhen}}｜报告写法：{{item.reportLine}}｜验证：{{item.evidenceGate}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierMethodologyRules}}" wx:key="*this">报告规则：{{item}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierDecisionHeatmap.length && showAdvancedProfile}}">
              <text class="parent-brief-label">决策热区</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierDecisionHeatmap}}" wx:key="id">{{item.label}}｜{{item.status}}｜证据：{{item.evidence}}｜下一步：{{item.nextAction}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierFamilyActionStack.length && showAdvancedProfile}}">
              <text class="parent-brief-label">家庭行动栈</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierFamilyActionStack}}" wx:key="id">{{item.label}}｜{{item.action}}｜门槛：{{item.gate}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierAiQualityGate && showAdvancedProfile}}">
              <text class="parent-brief-label">AI解析质量门控</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierAiQualityLine}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierAiQualityPlan}}" wx:key="id">{{item.label}}｜{{item.status}}｜{{item.action}}｜证据：{{item.evidence}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorSolutionPack && showAdvancedProfile}}">
              <text class="parent-brief-label">家庭私教方案｜{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorSolutionPack.title}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorSolutionPack.positioning}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorSolutionPack.primaryPromise}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDeliveryView.modeCards}}" wx:key="id">{{item.label}}｜{{item.whenLine}}｜{{item.gateLine}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorDeliveryLoop}}" wx:key="day">{{item.label}}｜{{item.action}}｜证据：{{item.evidence}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierPrivateTutorMoatSignals}}" wx:key="*this">护城河：{{item}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierSolutionBlueprint && showAdvancedProfile}}">
              <text class="parent-brief-label">个性化学习方案蓝图</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierSolutionBlueprint.recommendedMode.label}}：{{learningReportSummary.uploadedMaterialDecisionDossierSolutionBlueprint.recommendedMode.why}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierSolutionBlueprint.servicePathwayHint}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDeliveryView.solutionCards}}" wx:key="id">{{item.label}}｜{{item.triggerLine}}｜{{item.gateLine}}｜{{item.aiLine}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierSolutionFusionRules}}" wx:key="id">{{item.label}}｜用于：{{item.useFor}}｜验证：{{item.mustVerifyWith}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierSolutionOwnership}}" wx:key="id">{{item.label}}：{{item.reason}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialServiceHandoffPack && showAdvancedProfile}}">
              <text class="parent-brief-label">{{learningReportSummary.uploadedMaterialServiceHandoffTitle}}</text>
              <text>{{learningReportSummary.uploadedMaterialServiceHandoffSummary}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialServiceHandoffCards}}" wx:key="id">{{item.label}}｜{{item.line}}｜{{item.evidenceLine}}</text>
              <text>{{learningReportSummary.uploadedMaterialServiceHandoffReleaseLine}}</text>
              <text>{{learningReportSummary.uploadedMaterialServiceHandoffBlockedLine}}</text>
              <view class="profile-action-row" wx:if="{{learningReportSummary.uploadedMaterialServiceHandoffActions.length}}">
                <button class="profile-small-primary" wx:for="{{learningReportSummary.uploadedMaterialServiceHandoffActions}}" wx:key="id" data-id="{{item.id}}" data-label="{{item.label}}" data-route="{{item.route}}" data-reason="{{item.reason}}" bindtap="runUploadedMaterialDossierAction">{{item.label}}</button>
              </view>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.reportRevisitEvidence && showAdvancedProfile}}">
              <text class="parent-brief-label">报告回访验证</text>
              <text>当前阶段：{{learningReportSummary.reportRevisitValidationStage}}｜次日回访 {{learningReportSummary.reportRevisitNextDayCount}} 次</text>
              <text>长期画像：{{learningReportSummary.reportRevisitLongTermPortraitRelease}}｜第7天证据：{{learningReportSummary.reportRevisitDay7Ready ? '已就绪' : '未就绪'}}</text>
              <text>{{learningReportSummary.reportRevisitLocalRule}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierFamilyDecisionCalendar && showAdvancedProfile}}">
              <text class="parent-brief-label">{{learningReportSummary.uploadedMaterialDecisionDossierFamilyDecisionCalendar.title}}</text>
              <text>{{learningReportSummary.uploadedMaterialDecisionDossierFamilyDecisionCalendar.summary}}</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierFamilyDecisionWeeks}}" wx:key="id">{{item.label}}｜家长判断：{{item.parentDecision}}｜孩子证据：{{item.childEvidence}}｜门槛：{{item.releaseGate}}</text>
              <text wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMonthlyReview}}">月度复盘：{{learningReportSummary.uploadedMaterialDecisionDossierMonthlyReview.decision}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierDetailedSections.length && showAdvancedProfile}}">
              <text class="parent-brief-label">详细报告章节</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierDetailedSections}}" wx:key="id">{{item.label}}｜{{item.status}}｜{{item.body}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">资料入口</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierMaterialLanes}}" wx:key="id">{{item.label}}：{{item.collected ? '已接入' : '待补充'}}｜{{item.output}}</text>
            </view>
            <view class="parent-brief-reason">{{learningReportSummary.uploadedMaterialDecisionDossierTalentRule}}</view>
            <view class="parent-brief-reason">{{learningReportSummary.uploadedMaterialDecisionDossierWrongPaperRule}}</view>
            <view class="parent-brief-reason" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierReleaseGate}}">放行门槛：{{learningReportSummary.uploadedMaterialDecisionDossierReleaseGate.status}}</view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMethodValidationStages.length && showAdvancedProfile}}">
              <text class="parent-brief-label">方法验证链</text>
              <text wx:for="{{learningReportSummary.uploadedMaterialDeliveryView.methodValidationCards}}" wx:key="id">{{item.label}}｜{{item.ownerLine}}｜{{item.unlockLine}}</text>
              <text wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMethodValidationReleaseRule}}">{{learningReportSummary.uploadedMaterialDeliveryView.releaseLine}}</text>
              <text wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierMethodValidationNextAction}}">下一步：{{learningReportSummary.uploadedMaterialDecisionDossierMethodValidationNextAction}}</text>
            </view>
            <view class="profile-action-row" wx:if="{{learningReportSummary.uploadedMaterialDecisionDossierRouteActions.length && showAdvancedProfile}}">
              <button class="profile-small-primary" wx:for="{{learningReportSummary.uploadedMaterialDecisionDossierRouteActions}}" wx:key="id" data-id="{{item.id}}" data-label="{{item.label}}" data-route="{{item.route}}" data-reason="{{item.reason}}" bindtap="runUploadedMaterialDossierAction">{{item.label}}</button>
            </view>
          </view>
        </view>

        <view class="family-summary-card profile-partner-workbench" wx:if="{{learningReportSummary.partnerDeliveryWorkbench && showAdvancedProfile}}">
          <view class="family-summary-title">{{learningReportSummary.partnerWorkbenchTitle}}</view>
          <view class="family-summary-body family-readable">
            <view class="parent-brief-block">
              <text class="parent-brief-label">交付状态</text>
              <text>{{learningReportSummary.partnerWorkbenchStatusLine}}</text>
              <text wx:if="{{learningReportSummary.partnerWorkbenchChildRecord}}">孩子档案：{{learningReportSummary.partnerWorkbenchChildRecord.id}}｜{{learningReportSummary.partnerWorkbenchChildRecord.gradeBand}}｜{{learningReportSummary.partnerWorkbenchChildRecord.evidenceStage}}</text>
              <text>{{learningReportSummary.partnerWorkbenchNextAction}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchMaterialLedger.length}}">
              <text class="parent-brief-label">材料台账</text>
              <text wx:for="{{learningReportSummary.partnerWorkbenchMaterialLedger}}" wx:key="id">{{item.title}}｜{{item.kind}}｜{{item.status}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchSolutionPipeline.length}}">
              <text class="parent-brief-label">方案流水线</text>
              <text wx:for="{{learningReportSummary.partnerWorkbenchSolutionPipeline}}" wx:key="id">{{item.label}}｜{{item.owner}}｜{{item.status}}｜{{item.releaseGate}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchAdvisorQueue.length}}">
              <text class="parent-brief-label">顾问下一步</text>
              <text wx:for="{{learningReportSummary.partnerWorkbenchAdvisorQueue}}" wx:key="id">{{item.priority}}. {{item.action}}｜{{item.status}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchCrmExport}}">
              <text class="parent-brief-label">CRM 安全字段</text>
              <text>允许：{{learningReportSummary.partnerWorkbenchCrmAllowedLine}}</text>
              <text>禁止：{{learningReportSummary.partnerWorkbenchCrmBlockedLine}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchPilotReadiness}}">
              <text class="parent-brief-label">试点就绪 {{learningReportSummary.partnerWorkbenchPilotReadiness.score}}%</text>
              <text>{{learningReportSummary.partnerWorkbenchPilotStatusLine}}</text>
              <text wx:for="{{learningReportSummary.partnerWorkbenchPilotDisplayRows}}" wx:key="id">{{item.label}}｜{{item.readyText}}｜{{item.nextAction}}</text>
              <text>{{learningReportSummary.partnerWorkbenchPilotReadiness.operatorScript}}</text>
              <text>{{learningReportSummary.partnerWorkbenchPilotReadiness.stopRule}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerWorkbenchRevenueDisplayRows.length}}">
              <text class="parent-brief-label">服务包节点</text>
              <text wx:for="{{learningReportSummary.partnerWorkbenchRevenueDisplayRows}}" wx:key="id">{{item.label}}｜{{item.statusText}}｜{{item.gate}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerPilotDeliveryPacket}}">
              <text class="parent-brief-label">{{learningReportSummary.partnerPilotDeliveryPacket.title}}</text>
              <text>{{learningReportSummary.partnerPilotDeliveryPacket.statusLine}}</text>
              <text>{{learningReportSummary.partnerPilotDeliveryPacket.offerLine}}</text>
              <text wx:for="{{learningReportSummary.partnerPilotDeliveryRows}}" wx:key="id">{{item.label}}｜{{item.owner}}｜{{item.action}}｜{{item.releaseGate}}</text>
              <text wx:for="{{learningReportSummary.partnerPilotTalkTrack}}" wx:key="*this">合作话术：{{item}}</text>
              <text>禁止承诺：{{learningReportSummary.partnerPilotBlockedPromises}}</text>
              <text>{{learningReportSummary.partnerPilotDeliveryPacket.revenueGateLine}}</text>
              <text>下一步：{{learningReportSummary.partnerPilotDeliveryPacket.closeNextAction}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{learningReportSummary.partnerServiceReviewCard}}">
              <text class="parent-brief-label">{{learningReportSummary.partnerServiceReviewTitle}}</text>
              <text>{{learningReportSummary.partnerServiceReviewStatusLine}}</text>
              <text>{{learningReportSummary.partnerServiceReviewDecisionLine}}</text>
              <text>{{learningReportSummary.partnerServiceReviewEvidenceLine}}</text>
              <text>{{learningReportSummary.partnerServiceReviewNextActionLine}}</text>
              <text>{{learningReportSummary.partnerServiceReviewReleaseLine}}</text>
              <view class="profile-action-row" wx:if="{{learningReportSummary.partnerServiceReviewActions.length}}">
                <button class="profile-small-primary" wx:for="{{learningReportSummary.partnerServiceReviewActions}}" wx:key="id" data-id="{{item.id}}" data-label="{{item.label}}" data-route="{{item.route}}" data-reason="{{item.reason}}" bindtap="runUploadedMaterialDossierAction">{{item.label}}</button>
              </view>
