<view class="page safe-bottom profile-page">
  <view class="profile-glow glow-one"></view>
  <view class="profile-glow glow-two"></view>

  <scroll-view class="profile-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="profile-shell">
      <view class="ux-entry ux-entry-parent ux-kit-screen ux-kit-parent parent-hero-shell">
        <view class="parent-dash-top">
          <view class="parent-dash-brand">
            <image class="parent-dash-mark" mode="aspectFit" src="/assets/reference/brand-house.png" />
            <view>
              <text>原点智学</text>
              <text>证据与下一步</text>
            </view>
          </view>
          <view class="parent-dash-pill">5 秒看懂</view>
        </view>
        <view class="parent-dash-hero">
          <view class="parent-dash-copy">
            <view class="parent-dash-kicker">今晚不用盯全程</view>
            <view class="parent-dash-kicker companion-route-strip route-strip compact">{{profileViewModel.companionStrip}}</view>
            <view class="parent-dash-title">{{profileViewModel.title}}</view>
            <view class="parent-dash-title">只看孩子有没有走出第一步</view>
            <view class="parent-dash-sub">把测评、成绩、错题和复习回访合成一张家长行动卡：先看证据，再问一句，明天再验证。</view>
          </view>
          <image class="parent-dash-art" mode="aspectFill" src="/assets/reference/entry-parent.png" />
        </view>
        <view class="parent-dash-proof-grid">
          <view class="parent-dash-proof primary"><text>今晚结论</text><text>先稳住一个真实卡点</text></view>
          <view class="parent-dash-proof"><text>第一步证据</text><text>孩子能说出从哪看起</text></view>
          <view class="parent-dash-proof"><text>明天回访</text><text>用 90 秒复述验证</text></view>
        </view>
        <view class="parent-dash-evidence">
          <view class="parent-dash-section-head">
            <text>证据来源</text>
            <text>不靠感觉判断</text>
          </view>
          <view class="parent-report-preview" data-scene="parent" bindtap="openEntryDetail">
            <image class="parent-report-thumb" mode="aspectFill" src="/assets/reference/entry-report.png" />
            <view class="parent-report-copy">
              <text>个性化报告预览</text>
              <text>把天赋画像、成绩波动、错题卡点合成一张家长能看懂的下一步。</text>
            </view>
            <view class="parent-report-badge">查看</view>
          </view>
          <view class="parent-dash-evidence-grid">
            <view><text>测评报告</text><text>天赋画像</text></view>
            <view><text>成绩单</text><text>科目波动</text></view>
            <view><text>错题</text><text>真实卡点</text></view>
            <view><text>下一证据</text><text>回访验证方法有效性</text></view>
          </view>
        </view>
        <view class="ux-kit-jump-grid">
          <view class="ux-kit-jump-card primary parent-jump-card" data-scene="parent" bindtap="openEntryDetail">
            <text>今晚安排</text>
            <text>看行动卡</text>
          </view>
          <view class="ux-kit-jump-card parent-jump-card" data-scene="upload" bindtap="openEntryDetail">
            <text>补充材料</text>
            <text>上传新证据</text>
          </view>
          <view class="ux-kit-jump-card parent-jump-card" data-scene="review" bindtap="openEntryDetail">
            <text>复习回访</text>
            <text>验证是否迁移</text>
          </view>
        </view>
        <view class="parent-dash-route">
          <view class="parent-route-node active">
            <image class="parent-route-icon" mode="aspectFit" src="/assets/reference/entry-upload.png" />
            <text>上传</text>
            <text>证据进来</text>
          </view>
          <view class="parent-route-node active">
            <image class="parent-route-icon" mode="aspectFit" src="/assets/reference/entry-report.png" />
            <text>分析</text>
            <text>看方法匹配</text>
          </view>
          <view class="parent-route-node">
            <image class="parent-route-icon" mode="aspectFit" src="/assets/reference/entry-review.png" />
            <text>回访</text>
            <text>验证迁移</text>
          </view>
          <view class="parent-route-node final">
            <image class="parent-route-icon" mode="aspectFit" src="/assets/reference/entry-parent.png" />
            <text>周报</text>
            <text>家长看下一步</text>
          </view>
        </view>
        <view class="parent-dash-action-row">
          <view class="ux-kit-primary parent-primary" data-scene="parent" bindtap="openEntryDetail">{{profileViewModel.primaryCta}}</view>
          <view class="ux-kit-secondary parent-secondary" data-scene="upload" bindtap="openEntryDetail">补一份材料</view>
        </view>
      </view>

      <view class="parent-subcheck ux-kit-subcheck">
        <view class="subcheck-main" data-scene="parent" bindtap="openEntryDetail">
          <view class="subcheck-copy">
            <text>家长今晚只看三件事</text>
            <text>证据从哪来、孩子卡在哪、明天怎么验证。</text>
          </view>
          <image class="subcheck-art" mode="aspectFill" src="/assets/reference/entry-parent.png" />
        </view>
        <view class="subcheck-side">
          <view data-scene="upload" bindtap="openEntryDetail">
            <image class="subcheck-side-icon" mode="aspectFill" src="/assets/reference/entry-upload.png" />
            <text>材料缺口</text><text>补测评/错题</text>
          </view>
          <view data-scene="review" bindtap="openEntryDetail">
            <image class="subcheck-side-icon" mode="aspectFill" src="/assets/reference/entry-review.png" />
            <text>明天回访</text><text>90 秒复述</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
