<view class="page safe-bottom profile-page">
  <view class="page-positioning profile-positioning">
    <view class="positioning-kicker">家长复盘</view>
    <view class="positioning-title">家长今晚只问一句：刚才你第一步先看了哪里？</view>
    <view class="positioning-flow">先看今晚真实证据，再决定去修卡点、专注舱或轻回访；不是报表墙。</view>
  </view>
  <view class="profile-glow glow-one"></view>
  <view class="profile-glow glow-two"></view>

  <scroll-view class="profile-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="profile-shell">
      <view class="v1-topbar">
        <view class="profile-brand">
          <view class="profile-logo"><view class="profile-logo-leaf"></view></view>
          <view class="profile-brand-copy">
            <view class="profile-brand-name">我的</view>
            <view class="profile-brand-sub">家长 5 秒复盘</view>
          </view>
        </view>
        <view class="profile-pill"><text class="pill-dot"></text>真实记录</view>
      </view>

      <block wx:if="{{profilePanel === 'main'}}">
      <view class="rc14-profile-first-screen">
      <view class="parent-hero">
        <view class="mine-hero-copy">
          <view class="route-strip compact">{{profileViewModel.routePill}}</view>
          <view class="companion-route-strip">{{profileViewModel.companionStrip}}</view>
          <view class="parent-title">{{profileViewModel.title}}</view>
          <view class="parent-subtitle">{{profileViewModel.subtitle}}</view>
        </view>

        <view class="family-summary-card rc14-main-card friend-profile-core">
          <view class="family-summary-title">今晚卡住、只问一句、最近小结</view>
          <view class="family-summary-body family-readable">
            <view class="profile-empty-state" wx:if="{{profileSafeSummary.isEmpty}}">再用两晚后，咕点会帮你看见模式。</view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">今晚卡住</text>
              <text>{{profileSafeSummary.stuckLine}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">只问一句</text>
              <text>{{profileSafeSummary.parentQuestion}}</text>
              <button class="copy-action" bindtap="copyParentOneQuestion">复制</button>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">最近小结</text>
              <text>{{profileSafeSummary.recentSummary}}</text>
              <text wx:if="{{profileSafeSummary.threeNightSummary}}">{{profileSafeSummary.threeNightSummary}}</text>
              <text wx:if="{{profileSafeSummary.sevenNightSummary}}">{{profileSafeSummary.sevenNightSummary}}</text>
              <text wx:if="{{profileSafeSummary.weeklySummary}}">{{profileSafeSummary.weeklySummary}}</text>
            </view>
          </view>
        </view>

        <view class="family-summary-card profile-readiness-snapshot" wx:if="{{profileReadinessSnapshot}}">
          <view class="family-summary-title">{{profileReadinessSnapshot.title}}</view>
          <view class="family-summary-body family-readable">
            <view class="parent-brief-block">
              <text class="parent-brief-label">结论</text>
              <text>{{profileReadinessSnapshot.conclusion}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">流转</text>
              <text>{{profileReadinessSnapshot.flowLine}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">证据</text>
              <text>{{profileReadinessSnapshot.evidenceLine}}</text>
            </view>
            <view class="parent-brief-block">
              <text class="parent-brief-label">下一步</text>
              <text>{{profileReadinessSnapshot.nextActionReason}}</text>
              <button class="profile-small-primary" bindtap="runUnifiedNextAction">{{profileReadinessSnapshot.nextActionLabel}}</button>
            </view>
            <view class="parent-brief-reason">{{profileReadinessSnapshot.boundaryLine}}</view>
            <view class="ai-boundary-panel" wx:if="{{profileReadinessSnapshot.aiBoundaryRows}}">
              <view class="ai-boundary-head">
                <text>{{profileReadinessSnapshot.aiBoundaryTitle}}</text>
                <text>{{profileReadinessSnapshot.aiBoundarySummary}}</text>
              </view>
              <view class="ai-boundary-row" wx:for="{{profileReadinessSnapshot.aiBoundaryRows}}" wx:key="id">
                <text class="ai-boundary-label">{{item.label}}</text>
                <text class="ai-boundary-body">{{item.body}}</text>
              </view>
              <view class="ai-boundary-rule">{{profileReadinessSnapshot.aiBoundaryReleaseRule}}</view>
            </view>
          </view>
        </view>

        <view class="family-summary-card capability-ledger-card" wx:if="{{capabilityEvidenceLedger}}">
          <view class="family-summary-title">{{capabilityEvidenceLedger.title}}</view>
          <view class="family-summary-body family-readable">
            <view class="parent-brief-block">
              <text class="parent-brief-label">总账</text>
              <text>{{capabilityEvidenceLedger.readyCount}} / {{capabilityEvidenceLedger.totalCount}} · {{capabilityEvidenceLedger.summary}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{capabilityEvidenceLedger.nextCapability}}">
              <text class="parent-brief-label">先补哪条</text>
              <text>{{capabilityEvidenceLedger.nextCapability.label}} · {{capabilityEvidenceLedger.nextCapability.nextAction}}</text>
              <button class="profile-small-primary" data-route="{{capabilityEvidenceLedger.nextCapability.route}}" bindtap="goCapabilityLedgerRoute">去处理</button>
            </view>
            <view class="module-flow-mini-grid">
              <view class="module-flow-mini-chip {{item.ready ? 'ready' : ''}}" wx:for="{{capabilityEvidenceLedger.rows}}" wx:key="id">{{item.label}}</view>
            </view>
            <view class="parent-brief-reason">{{capabilityEvidenceLedger.moatLine}}</view>
          </view>
        </view>

        <view class="family-summary-card capability-ledger-card" wx:if="{{capabilityMaturityQueue}}">
          <view class="family-summary-title">{{capabilityMaturityQueue.title}}</view>
          <view class="family-summary-body family-readable">
            <view class="parent-brief-block">
              <text class="parent-brief-label">商用厚度</text>
              <text>{{capabilityMaturityQueue.readyCount}} / {{capabilityMaturityQueue.totalCount}} · {{capabilityMaturityQueue.summary}}</text>
            </view>
            <view class="parent-brief-block" wx:if="{{capabilityMaturityQueue.next}}">
              <text class="parent-brief-label">先补这里</text>
              <text>{{capabilityMaturityQueue.next.label}} · {{capabilityMaturityQueue.next.nextAction}}</text>
              <text>{{capabilityMaturityQueue.next.acceptanceLine}}</text>
              <text>{{capabilityMaturityQueue.next.fallbackLine}}</text>
              <text>{{capabilityMaturityQueue.next.parentCheckLine}}</text>
              <button class="profile-small-primary" data-id="{{capabilityMaturityQueue.next.id}}" data-route="{{capabilityMaturityQueue.next.route}}" bindtap="runCapabilityMaturityAction">去推进</button>
            </view>
            <view class="module-flow-mini-grid">
              <view class="module-flow-mini-chip {{item.ready ? 'ready' : ''}}" wx:for="{{capabilityMaturityQueue.items}}" wx:key="id" data-id="{{item.id}}" data-route="{{item.route}}" bindtap="runCapabilityMaturityAction">{{item.label}} {{item.score}}%</view>
            </view>
            <view class="parent-brief-reason">{{capabilityMaturityQueue.positioningLine}}</view>
          </view>
        </view>

      <view class="parent-hero-actions">
        <button class="parent-hero-primary" data-action="review" bindtap="runParentReportAction">{{profileViewModel.primaryCta}}</button>
        <view class="route-next-lite profile-next-lite" wx:if="{{profileViewModel.nextStep}}">{{profileViewModel.nextStep}}</view>
      </view>
      </view>
      </view>
      <view class="rc14-profile-after-first-screen"></view>

      <view class="family-summary-card profile-subtle-card assessment-entry-card">
        <view class="family-summary-title">孩子测评与学习方法建议</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">家长输入</text>
            <text>成绩、测评描述、哪科卡住、学习方法哪里不顺，都放这里。</text>
          </view>
          <button class="focus-cabin-link" bindtap="startAssessmentFromProfile">录入成绩/测评</button>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{showAdvancedProfile}}">
        <view class="family-summary-title">服务状态</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">当前可用</text>
            <text>作业点拨、专注舱、错题修复、轻回访和家长复盘已经连成闭环。资料越完整，学习画像越具体。</text>
          </view>
          <button class="focus-cabin-link" bindtap="inviteParentView">邀请另一位家长一起关注</button>
          <button class="focus-cabin-link quiet" bindtap="contactSupport">反馈建议</button>
          <view class="parent-invite-card" wx:if="{{parentInviteCard}}">
            <view>{{parentInviteCard.title}}</view>
            <view>{{parentInviteCard.badge}}</view>
            <text>{{parentInviteCard.body}}</text>
            <text>{{parentInviteCard.action}}</text>
            <text>{{parentInviteCard.path}}</text>
          </view>
          <canvas canvas-id="weeklySummaryCanvas" class="weekly-summary-canvas"></canvas>
        </view>
      </view>

      <view class="family-summary-card growth-memory-card profile-subtle-card" wx:if="{{profileViewModel.growthMemoryCard}}">
        <view class="legacy-growth-anchor">今晚学习记录</view>
        <view class="family-summary-title">{{profileViewModel.growthMemoryCard.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-reason">{{profileViewModel.growthMemoryCard.body}}</view>
          <view class="parent-brief-block" wx:if="{{profileViewModel.growthMemoryCard.tomorrow}}">
            <text class="parent-brief-label">明天回访</text>
            <text>{{profileViewModel.growthMemoryCard.tomorrow}}</text>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card light-evidence-card" wx:if="{{lightFeatureEvidence}}">
        <view class="family-summary-title">{{lightFeatureEvidence.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">轻入口</text>
            <text>{{lightFeatureEvidence.summary}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">可回流</text>
            <text>{{lightFeatureEvidence.parentLine}}</text>
          </view>
          <view class="module-flow-mini-grid" wx:if="{{lightFeatureEvidence.cards.length}}">
            <view class="module-flow-mini-chip ready" wx:for="{{lightFeatureEvidence.cards}}" wx:key="id">{{item.label}} {{item.count}}</view>
          </view>
          <view class="parent-brief-reason">{{lightFeatureEvidence.nextAction}}</view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{learningDepthMap && showAdvancedProfile}}">
        <view class="family-summary-title">{{learningDepthMap.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">厚度进度</text>
            <text>{{learningDepthMap.readyCount}} / {{learningDepthMap.totalCount}} · {{learningDepthMap.summary}}</text>
          </view>
          <view class="parent-brief-block" wx:for="{{learningDepthMap.dimensions}}" wx:key="id">
            <text class="parent-brief-label">{{item.label}}</text>
            <text>{{item.ready ? '已接上' : '待补齐'}} · {{item.evidence}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">下一步</text>
            <text>{{learningDepthMap.nextBestAction}}</text>
          </view>
          <view class="parent-brief-reason">{{learningDepthMap.summary}}</view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{learningQuestArc && showAdvancedProfile}}">
        <view class="family-summary-title">{{learningQuestArc.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">当前剧情</text>
            <text>{{learningQuestArc.currentLabel}} · {{learningQuestArc.currentTitle}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">完成进度</text>
            <text>{{learningQuestArc.doneCount}} / {{learningQuestArc.totalCount}} · {{learningQuestArc.summary}}</text>
          </view>
          <view class="parent-brief-block" wx:for="{{learningQuestArc.stages}}" wx:key="id">
            <text class="parent-brief-label">{{item.displayLabel}}</text>
            <text>{{item.done ? '已接上' : '下一步'}} · {{item.body}}</text>
          </view>
          <view class="parent-brief-reason">{{learningQuestArc.parentHook}}</view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{moduleFlowCompass && showAdvancedProfile}}">
        <view class="family-summary-title">模块流转罗盘</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">闭环进度</text>
            <text>{{moduleFlowCompass.readyCount}} / {{moduleFlowCompass.totalCount}} · {{moduleFlowCompass.summary}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">当前断点</text>
            <text>{{moduleFlowCompass.currentLabel}} · {{moduleFlowCompass.currentNextAction}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">证据</text>
            <text>{{moduleFlowCompass.currentEvidence}}</text>
          </view>
          <view class="module-flow-mini-grid">
            <view class="module-flow-mini-chip {{item.ready ? 'ready' : ''}}" wx:for="{{moduleFlowCompass.modules}}" wx:key="id">{{item.displayLabel}}</view>
          </view>
          <view class="parent-brief-reason">{{moduleFlowCompass.summary}}</view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{surfaceDepthPack && showAdvancedProfile}}">
        <view class="family-summary-title">{{surfaceDepthPack.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">板块结论</text>
            <text>{{surfaceDepthPack.summary}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">下一步</text>
            <text>{{surfaceDepthPack.nextAction}}</text>
          </view>
          <view class="module-flow-mini-grid">
            <view class="module-flow-mini-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id">{{item.displayLabel}}</view>
          </view>
          <view class="parent-brief-reason">{{surfaceDepthPack.familyLine}}</view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{unifiedNextAction && showAdvancedProfile}}">
        <view class="family-summary-title">{{unifiedNextAction.title}}</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">{{unifiedNextAction.sourceLabel}}</text>
            <text>{{unifiedNextAction.actionLabel}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">为什么</text>
            <text>{{unifiedNextAction.reasonLine}}</text>
          </view>
          <view class="module-flow-mini-grid">
            <view class="module-flow-mini-chip" wx:for="{{unifiedNextAction.candidates}}" wx:key="source">{{item.sourceLabel}}</view>
          </view>
          <view class="parent-brief-reason">{{unifiedNextAction.readinessLine}}</view>
          <button class="profile-small-primary" bindtap="runUnifiedNextAction">{{unifiedNextAction.actionLabel}}</button>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{surfaceDepthActionSummary && showAdvancedProfile}}">
        <view class="family-summary-title">妯″潡琛屽姩璁板綍</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <view wx:if="{{globalEvidenceBrief.latestUnifiedAction}}">
              <text class="parent-brief-label">建议已执行</text>
              <text>{{globalEvidenceBrief.latestUnifiedAction.displayLabel}}</text>
            </view>
            <text class="parent-brief-label">{{surfaceDepthActionSummary.routeEvidenceLabel}}</text>
            <text>{{surfaceDepthActionSummary.label}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">{{surfaceDepthActionSummary.latestActionLabel}}</text>
            <text>{{surfaceDepthActionSummary.parentLine}}</text>
          </view>
          <view class="module-flow-mini-grid">
            <view class="module-flow-mini-chip" wx:for="{{surfaceDepthActionSummary.recent}}" wx:key="id">{{item.displayLabel}}</view>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{parentActionGuide && showAdvancedProfile}}">
        <view class="family-summary-title">家长行动指南</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">今晚复盘</text>
            <text>{{parentActionGuide.tonightRecap}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">本周模式</text>
            <text>{{parentActionGuide.weekPattern}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">下周一句</text>
            <text>{{parentActionGuide.monthSuggestion}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.parentPhraseTraining}}">
            <text class="parent-brief-label">今晚话术</text>
            <text>{{parentActionGuide.parentPhraseTraining.tonightScript}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.parentPhraseTraining}}">
            <text class="parent-brief-label">答不上来</text>
            <text>{{parentActionGuide.parentPhraseTraining.cannotAnswerFallback}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.parentPhraseTraining}}">
            <text class="parent-brief-label">先肯定</text>
            <text>{{parentActionGuide.parentPhraseTraining.praiseLine}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.parentReflectionSummary}}">
            <text class="parent-brief-label">追问回执</text>
            <text>{{parentActionGuide.parentReflectionSummary.line}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.weeklyPatternSynthesis}}">
            <text class="parent-brief-label">一周归因</text>
            <text>{{parentActionGuide.weeklyPatternSynthesis.summary}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.learningDecisionPath}}">
            <text class="parent-brief-label">下一步</text>
            <text>{{parentActionGuide.learningDecisionPath.action}}：{{parentActionGuide.learningDecisionPath.reason}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.masteryRubric}}">
            <text class="parent-brief-label">掌握度</text>
            <text>{{parentActionGuide.masteryRubric.line}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.interventionPlaybook}}">
            <text class="parent-brief-label">干预打法</text>
            <text>{{parentActionGuide.interventionPlaybook.summary}}</text>
          </view>
          <view class="parent-brief-block" wx:if="{{parentActionGuide.outcomeReviewSummary}}">
            <text class="parent-brief-label">结果复核</text>
            <text>{{parentActionGuide.outcomeReviewSummary.line}}</text>
          </view>
          <view class="parent-brief-block" wx:for="{{parentActionGuide.sevenDayParentPlan}}" wx:key="day">
            <text class="parent-brief-label">第 {{item.day}} 晚</text>
            <text>{{item.action}}：{{item.script}}</text>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{isDevMode && isBetaTester && experienceChecklist && experienceChecklist.length}}">
        <view class="family-summary-title">体验检查</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block" wx:for="{{experienceChecklist}}" wx:key="id">
            <text class="parent-brief-label">{{item.label}}</text>
            <text>{{item.done ? '已记录' : '待记录'}} · {{item.field}}</text>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{isDevMode && isBetaTester && experienceDashboard}}">
        <view class="family-summary-title">体验记录</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">轻入口完成</text>
            <text>{{experienceDashboard.lightEntryDAU}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">进入闭环</text>
            <text>{{experienceDashboard.coreLoopEntryRate}}%</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">第一步质量</text>
            <text>空白 {{experienceDashboard.firstStepQualityTrend.empty}} / 模糊 {{experienceDashboard.firstStepQualityTrend.vague}} / 部分 {{experienceDashboard.firstStepQualityTrend.partial}} / 可执行 {{experienceDashboard.firstStepQualityTrend.actionable}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">scaffoldingCompletionRate</text>
            <text>{{experienceDashboard.scaffoldingCompletionRate.completionRate}}%</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">parentInterventionRate</text>
            <text>直接讲 {{experienceDashboard.parentInterventionRate.directAnswerRate}}% / 用话术 {{experienceDashboard.parentInterventionRate.usedPhrase}} / 暂停 {{experienceDashboard.parentInterventionRate.pauseUsed}}</text>
          </view>
          <view class="parent-brief-block">
            <text class="parent-brief-label">服务意向</text>
            <text>{{experienceDashboard.serviceIntentRate.rate}}%</text>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{isDevMode && isBetaTester && developerFunnel}}">
        <view class="family-summary-title">流程记录</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block" wx:for="{{developerFunnel.nodes}}" wx:key="node">
            <text class="parent-brief-label">{{item.node}}</text>
            <text>{{item.count}}</text>
          </view>
        </view>
      </view>

      <view class="family-summary-card profile-subtle-card" wx:if="{{focusCabinSummary}}">
        <view class="family-summary-title">今晚专注痕迹</view>
        <view class="family-summary-body family-readable">
          <view class="parent-brief-block">
            <text class="parent-brief-label">做完这一小步</text>
            <text>{{focusCabinSummary.tonightCompletionCount}} 段，累计 {{focusCabinSummary.totalFocusMinutes}} 分钟</text>
          </view>
          <view class="parent-brief-block" wx:if="{{latestFocusSession}}">
            <text class="parent-brief-label">家长看一句</text>
            <text>{{latestFocusSession.parentRecap}}</text>
          </view>
          <view class="parent-brief-reason" wx:else>还没有专注完成记录。可以让孩子先进专注舱坐 15 分钟。</view>
          <button class="focus-cabin-link" bindtap="goFocus">打开专注舱</button>
        </view>
      </view>

      <view class="process-summary-lite profile-secondary-process profile-subtle-card" wx:if="{{tutorProcessSummary && showAdvancedProfile}}">
        <view class="process-summary-line">查看咕点怎么点拨：没有直接给结果，先让孩子说第一步。</view>
        <view class="process-summary-items collapsed">
          <view class="process-summary-item" wx:for="{{tutorProcessSummary.items}}" wx:key="id">
            <text>{{item.label}}：</text>{{item.text}}
          </view>
        </view>
        <view class="process-summary-line" wx:if="{{tutorProcessSummary.fallbackRecoveryLine}}">{{tutorProcessSummary.fallbackRecoveryLine}}</view>
        <view class="process-summary-line" wx:if="{{tutorProcessSummary.fallbackParentDecisionLine}}">{{tutorProcessSummary.fallbackParentDecisionLine}}</view>
        <view class="process-summary-line" wx:if="{{tutorProcessSummary.fallbackShareBoundary}}">{{tutorProcessSummary.fallbackShareBoundary}}</view>
      </view>

