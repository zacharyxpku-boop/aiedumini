page {
  background: #F9F8F4;
}

.profile-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1F2933;
  background: #F9F8F4;
}

.profile-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.profile-shell {
  position: relative;
  z-index: 2;
  padding: 0 44rpx calc(170rpx + env(safe-area-inset-bottom));
}

.profile-glow {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  border-radius: 999rpx;
  filter: blur(58rpx);
}

.glow-one {
  top: -80rpx;
  right: -120rpx;
  width: 480rpx;
  height: 480rpx;
  background: rgba(242, 212, 121, 0.38);
}

.glow-two {
  top: 250rpx;
  left: -180rpx;
  width: 540rpx;
  height: 540rpx;
  background: rgba(216, 226, 220, 0.62);
}

.profile-page .v1-topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  min-height: calc(104rpx + env(safe-area-inset-top));
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin: 0 -44rpx;
  padding: calc(22rpx + env(safe-area-inset-top)) 44rpx 18rpx;
  background: rgba(249, 248, 244, 0.84);
  backdrop-filter: blur(24rpx);
}

.profile-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
}

.profile-logo {
  position: relative;
  display: flex;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  background: #1B4332;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(27, 67, 50, 0.12);
}

.profile-logo-leaf {
  width: 26rpx;
  height: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 24rpx 6rpx;
  transform: rotate(-28deg);
}

.profile-brand-copy {
  min-width: 0;
}

.profile-brand-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
}

.profile-brand-sub {
  margin-top: 6rpx;
  color: #6B7280;
  font-size: 21rpx;
  font-weight: 760;
  letter-spacing: 1rpx;
}

.profile-pill {
  display: flex;
  min-height: 56rpx;
  flex: 0 0 auto;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  color: #374151;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 231, 235, 0.85);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.025);
  font-size: 23rpx;
  font-weight: 850;
}

.pill-dot {
  width: 12rpx;
  height: 12rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(242, 212, 121, 0.24);
}

.parent-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.hero-spark {
  position: absolute;
  top: 54rpx;
  left: -20rpx;
  color: #F2D479;
  font-size: 42rpx;
  font-weight: 1000;
}

.parent-hero-badge {
  display: inline-flex;
  width: max-content;
  min-height: 52rpx;
  align-items: center;
  padding: 0 20rpx;
  color: #9A7300;
  background: rgba(242, 212, 121, 0.24);
  border-radius: 16rpx;
  font-size: 23rpx;
  font-weight: 1000;
}

.parent-title {
  margin-top: 6rpx;
  color: #111827;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.16;
  letter-spacing: 0;
}

.parent-subtitle {
  max-width: 650rpx;
  color: #4B5563;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.48;
}

.parent-subtitle text {
  color: #111827;
  font-weight: 1000;
}

.route-strip {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.route-strip text {
  flex: 1 1 0;
  min-width: 0;
  padding: 9rpx 6rpx;
  overflow: hidden;
  color: #657069;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 850;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-strip text.active {
  color: #1B4332;
  background: rgba(242, 212, 121, 0.30);
  border-color: rgba(242, 212, 121, 0.48);
  font-weight: 1000;
}

.parent-hero-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 16rpx;
}

.hero-identity-card {
  position: relative;
  margin-top: 8rpx;
  padding: 24rpx;
  color: #11231C;
  background: linear-gradient(135deg, #FFF2B8 0%, #F8FCF6 52%, #D9F2E1 100%);
  border: 1rpx solid rgba(27, 67, 50, 0.10);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(27, 67, 50, 0.09);
}

.identity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.identity-kicker {
  color: #8A6A08;
  font-size: 21rpx;
  font-weight: 950;
}

.identity-name {
  margin-top: 6rpx;
  color: #11231C;
  font-size: 38rpx;
  font-weight: 1000;
  line-height: 1.12;
}

.identity-code {
  flex: 0 0 auto;
  min-height: 46rpx;
  padding: 0 16rpx;
  color: #FFFDF8;
  background: #1B4332;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 1000;
  line-height: 46rpx;
}

.identity-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.identity-stat {
  min-width: 0;
  padding: 14rpx 10rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 16rpx;
}

.identity-value {
  overflow: hidden;
  color: #1B4332;
  font-size: 26rpx;
  font-weight: 1000;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-label {
  margin-top: 6rpx;
  color: #6A665F;
  font-size: 18rpx;
  font-weight: 850;
}

.identity-line {
  margin-top: 14rpx;
  color: #6A4D05;
  font-size: 22rpx;
  font-weight: 820;
  line-height: 1.35;
}

.identity-share-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.identity-share-primary,
.identity-share-secondary {
  display: flex;
  min-height: 62rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.identity-share-primary {
  color: #FFFFFF;
  background: #1B4332;
}

.identity-share-secondary {
  color: #1B4332;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(27, 67, 50, 0.10);
}

.parent-hero-primary,
.parent-hero-secondary {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.profile-proof-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.profile-proof-card {
  min-width: 0;
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(27, 67, 50, 0.06);
}

.profile-proof-card.wrong {
  background: #FFF6E4;
  border: 1rpx solid rgba(180, 112, 30, 0.14);
}

.profile-proof-card.share {
  background: #EAF7F1;
  border: 1rpx solid rgba(27, 67, 50, 0.10);
}

.profile-proof-kicker {
  color: #7A5D14;
  font-size: 20rpx;
  font-weight: 850;
}

.profile-proof-title {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #11231C;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.profile-proof-body {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #5D675F;
  font-size: 20rpx;
  font-weight: 650;
  line-height: 1.36;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.parent-hero-primary {
  color: #FFFFFF;
  background: #1B4332;
  box-shadow: 0 18rpx 42rpx rgba(27, 67, 50, 0.20);
}

.parent-hero-secondary {
  color: #1F2933;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.025);
}

.parent-section-card {
  position: relative;
  margin-top: 54rpx;
  padding: 40rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid rgba(243, 244, 246, 0.90);
  border-radius: 46rpx;
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.04), 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
}

.game-profile-card {
  background: #1B4332;
  color: #FFFFFF;
  overflow: hidden;
}

.game-profile-card .parent-card-title,
.game-profile-card .section-title-row {
  color: #FFFFFF;
}

.game-profile-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.game-level {
  font-size: 42rpx;
  font-weight: 1000;
  line-height: 1.15;
}

.game-level-sub,
.achievement-line,
.leaderboard-notice {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.daily-share-card {
  position: relative;
  margin-top: 28rpx;
  padding: 34rpx;
  overflow: hidden;
  color: #11231C;
  background: linear-gradient(135deg, #FFF2B8 0%, #F7FBF4 46%, #D9F2E1 100%);
  border: 1rpx solid rgba(27, 67, 50, 0.10);
  border-radius: 38rpx;
  box-shadow: 0 24rpx 58rpx rgba(27, 67, 50, 0.10);
}

.daily-share-card::after {
  content: "";
  position: absolute;
  right: -68rpx;
  top: -72rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(27, 67, 50, 0.10);
  border-radius: 999rpx;
}

.share-card-top,
.share-stat-grid,
.share-actions,
.share-headline,
.share-subtitle,
.share-invite,
.share-level-row,
.share-proof-row,
.share-archive {
  position: relative;
  z-index: 1;
}

.share-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.share-kicker {
  color: #8A6A08;
  font-size: 22rpx;
  font-weight: 1000;
}

.share-title {
  margin-top: 6rpx;
  color: #11231C;
  font-size: 36rpx;
  font-weight: 1000;
  line-height: 1.14;
}

.share-code {
  flex: 0 0 auto;
  min-height: 48rpx;
  padding: 0 16rpx;
  color: #FFFDF8;
  background: #1B4332;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 1000;
  line-height: 48rpx;
}

.share-headline {
  margin-top: 24rpx;
  color: #11231C;
  font-size: 34rpx;
  font-weight: 1000;
  line-height: 1.22;
}

.share-subtitle {
  margin-top: 12rpx;
  color: #4D5A52;
  font-size: 24rpx;
  font-weight: 760;
  line-height: 1.42;
}

.share-level-row {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  margin-top: 18rpx;
}

.share-level,
.share-achievement {
  min-width: 0;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1.3;
}

.share-level {
  flex: 0 0 auto;
  color: #1B4332;
}

.share-achievement {
  flex: 1 1 auto;
  color: #5A625B;
}

.share-family-action {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(36, 85, 58, 0.14);
}

.share-family-action-title {
  color: #24553A;
  font-size: 27rpx;
  font-weight: 900;
}

.share-family-action-line {
  margin-top: 10rpx;
  color: #3F3A32;
  font-size: 24rpx;
  line-height: 1.55;
}

.share-family-action-evidence,
.share-family-action-boundary {
  margin-top: 12rpx;
  color: #756D63;
  font-size: 22rpx;
  line-height: 1.5;
}

.share-family-action-boundary {
  color: #8A5A1E;
}

.share-stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.share-stat {
  min-width: 0;
  padding: 16rpx 8rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 20rpx;
}

.share-stat-value {
  overflow: hidden;
  color: #1B4332;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1.08;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-stat-label {
  margin-top: 8rpx;
  color: #6A665F;
  font-size: 19rpx;
  font-weight: 880;
}

.share-invite {
  margin-top: 18rpx;
  color: #6A4D05;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1.36;
}

.share-conversation-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
  color: #4E463D;
  font-size: 23rpx;
  line-height: 1.6;
}

.share-conversation-title {
  margin-bottom: 8rpx;
  color: #1B4332;
  font-size: 25rpx;
  font-weight: 900;
}

.share-proof-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.share-proof-chip {
  display: flex;
  min-height: 50rpx;
  align-items: center;
  gap: 8rpx;
  padding: 0 14rpx;
  color: #1B4332;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-share-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.wechat-share-btn {
  min-width: 0;
  min-height: 68rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 68rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: keep-all;
}

.wechat-share-btn.parent {
  color: #1B4332;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(27, 67, 50, 0.14);
}

.wechat-share-btn.peer {
  color: #1B4332;
  background: rgba(247, 208, 104, 0.72);
  border: 1rpx solid rgba(138, 106, 8, 0.14);
}

.share-archive {
  margin-top: 10rpx;
  color: #778078;
  font-size: 20rpx;
  font-weight: 780;
  line-height: 1.35;
}

.share-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
  margin-top: 22rpx;
}

.share-primary,
.share-secondary {
  min-width: 0;
  min-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 1000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-primary {
  color: #FFFDF8;
  background: #1B4332;
}

.share-secondary {
  color: #1B4332;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(27, 67, 50, 0.14);
}

.focus-cabin-link {
  width: 100%;
  min-height: 72rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  color: #1B4332;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(27, 67, 50, 0.14);
  font-size: 24rpx;
  font-weight: 900;
}

.coin-pill {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  color: #1B4332;
  background: #F2D479;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 1000;
}

.game-progress-track {
  height: 14rpx;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  overflow: hidden;
}

.game-progress-fill {
  height: 100%;
  background: #F2D479;
  border-radius: 999rpx;
}

.game-profile-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.game-profile-cell {
  min-width: 0;
  padding: 18rpx 10rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 22rpx;
}

.game-profile-value {
  color: #F2D479;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
}

.game-profile-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  font-weight: 800;
}

.shop-preview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.shop-preview-item {
  min-width: 0;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
}

.shop-title {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.35;
}

.shop-price {
  margin-top: 8rpx;
  color: #F2D479;
  font-size: 20rpx;
  font-weight: 900;
}

.tonight-card::after {
  content: "";
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 180rpx;
  height: 180rpx;
  background: #F9F8F4;
  border-radius: 999rpx;
  opacity: 0.60;
}

.section-title-row,
.weekly-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weekly-head {
  justify-content: space-between;
}

.section-title-row.compact {
  gap: 14rpx;
}

.section-stick {
  width: 10rpx;
  height: 32rpx;
  border-radius: 999rpx;
}

.section-stick.yellow {
  background: #F2D479;
}

.section-stick.green {
  background: #1B4332;
}

.parent-card-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.parent-timeline {
  position: relative;
  z-index: 1;
  margin-top: 38rpx;
}

.timeline-line {
  position: absolute;
  left: 24rpx;
  top: 18rpx;
  bottom: 144rpx;
  width: 3rpx;
  background: #F3F4F6;
  border-radius: 999rpx;
}

.timeline-row {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 34rpx;
}

.timeline-dot {
  position: relative;
  z-index: 2;
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  background: #FEE2E2;
  border: 6rpx solid #FFFFFF;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.055);
}

.timeline-dot.high {
  background: #FEE2E2;
}

.timeline-dot.mid {
  background: #DBEAFE;
}

.timeline-dot.low {
  background: rgba(27, 67, 50, 0.12);
}

.timeline-copy {
  min-width: 0;
  padding-top: 4rpx;
}

.timeline-label {
  color: #9CA3AF;
  font-size: 22rpx;
  font-weight: 820;
  letter-spacing: 1rpx;
}

.timeline-title {
  margin-top: 8rpx;
  color: #1F2933;
