page {
  background: #F9F8F4;
}

.profile-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1F2933;
  background: #F9F8F4;
}

.profile-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.profile-shell {
  position: relative;
  z-index: 2;
  padding: 0 44rpx calc(170rpx + env(safe-area-inset-bottom));
}

.parent-hero-shell {
  position: relative;
  margin: 18rpx 0 26rpx;
  padding: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 9% 3%, rgba(248, 198, 34, 0.18), transparent 24%),
    radial-gradient(circle at 92% 12%, rgba(76, 159, 255, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
}

.parent-dash-top,
.parent-dash-brand,
.parent-dash-hero,
.parent-dash-section-head,
.parent-dash-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.parent-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.parent-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  border-radius: 18rpx;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  box-shadow: 0 14rpx 26rpx rgba(34, 185, 92, 0.24);
}

.parent-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.parent-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.parent-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.parent-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.parent-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 172rpx;
  align-items: center;
  margin-top: 28rpx;
}

.parent-dash-kicker {
  width: max-content;
  max-width: 100%;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  color: #9a6b00;
  background: #fff4c9;
  font-size: 21rpx;
  font-weight: 900;
}

.parent-dash-title {
  margin-top: 14rpx;
  color: #101a16;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 1.09;
  letter-spacing: 0;
}

.parent-dash-sub {
  margin-top: 12rpx;
  color: #64706a;
  font-size: 23rpx;
  line-height: 1.5;
}

.parent-dash-art {
  width: 186rpx;
  height: 164rpx;
  border-radius: 34rpx;
  background: #fff1ea;
}

.parent-dash-proof-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.parent-dash-proof,
.parent-dash-evidence {
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(38, 58, 43, 0.05);
}

.parent-dash-proof {
  min-width: 0;
  min-height: 116rpx;
  padding: 18rpx 14rpx;
}

.parent-dash-proof.primary {
  background: #ecf9ed;
  border-color: rgba(34, 185, 92, 0.18);
}

.parent-dash-proof text {
  display: block;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.parent-dash-proof text:first-child {
  color: #173f31;
  font-size: 24rpx;
  font-weight: 950;
  white-space: nowrap;
}

.parent-dash-proof text:last-child {
  margin-top: 8rpx;
  color: #657069;
  font-size: 20rpx;
  font-weight: 780;
  line-height: 1.32;
}

.parent-dash-evidence {
  margin-top: 18rpx;
  padding: 20rpx;
}

.parent-dash-section-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.parent-dash-section-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
  white-space: nowrap;
}

.parent-dash-evidence-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.parent-report-preview {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(248, 198, 34, 0.16), transparent 36%),
    linear-gradient(135deg, #f2fbef 0%, #ffffff 72%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.parent-report-thumb {
  width: 112rpx;
  height: 84rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 20rpx;
  background: #edf8ff;
}

.parent-report-copy {
  min-width: 0;
}

.parent-report-copy text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
}

.parent-report-copy text:first-child {
  color: #173f31;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.18;
  white-space: nowrap;
}

.parent-report-copy text:nth-child(2) {
  display: -webkit-box;
  margin-top: 6rpx;
  color: #66756d;
  font-size: 19rpx;
  font-weight: 760;
  line-height: 1.28;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.parent-report-badge {
  flex: 0 0 auto;
  padding: 9rpx 13rpx;
  border-radius: 999rpx;
  color: #0f7b43;
  background: #ffffff;
  border: 1rpx solid rgba(34, 185, 92, 0.18);
  font-size: 19rpx;
  font-weight: 950;
  white-space: nowrap;
}

.parent-dash-evidence-grid view {
  min-width: 0;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: #f8fbf3;
  text-align: center;
}

.parent-dash-evidence-grid text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.parent-dash-evidence-grid text:first-child {
  color: #174533;
  font-size: 21rpx;
  font-weight: 950;
}

.parent-dash-evidence-grid text:last-child {
  margin-top: 6rpx;
  color: #728078;
  font-size: 19rpx;
  font-weight: 780;
}

.parent-hero-shell .ux-kit-jump-grid {
  gap: 12rpx;
  margin-top: 18rpx;
}

.parent-jump-card {
  background:
    radial-gradient(circle at 82% 18%, rgba(248, 198, 34, 0.18), transparent 32%),
    #ffffff;
}

.parent-dash-route {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.parent-route-node {
  position: relative;
  min-width: 0;
  min-height: 126rpx;
  padding: 13rpx 7rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  color: #17211d;
  background: linear-gradient(180deg, #ffffff 0%, #f8faf5 100%);
  box-shadow: 0 12rpx 24rpx rgba(41, 65, 52, 0.07);
  overflow: visible;
}

.parent-route-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.parent-route-node:last-child::after {
  display: none;
}

.parent-route-node.active {
  border-color: rgba(34, 185, 92, 0.28);
  background: linear-gradient(180deg, #effbf2 0%, #ffffff 100%);
}

.parent-route-node.final {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.parent-route-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 7rpx;
  border-radius: 17rpx;
  background: #f0f8ee;
}

.parent-route-node.active .parent-route-icon {
  background: #dff7e6;
}

.parent-route-node.final .parent-route-icon {
  background: #fff1bd;
}

.parent-route-node text:nth-child(2) {
  max-width: 100%;
  color: #17211d;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.parent-route-node text:nth-child(3) {
  max-width: 100%;
  color: #526158;
  font-size: 17rpx;
  font-weight: 780;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.parent-dash-action-row {
  margin-top: 18rpx;
}

.parent-primary,
.parent-secondary {
  flex: 1 1 0;
  margin-top: 0;
}

.profile-glow {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  border-radius: 999rpx;
  filter: blur(58rpx);
}

.glow-one {
  top: -80rpx;
  right: -120rpx;
  width: 480rpx;
  height: 480rpx;
  background: rgba(242, 212, 121, 0.38);
}

.glow-two {
  top: 250rpx;
  left: -180rpx;
  width: 540rpx;
  height: 540rpx;
  background: rgba(216, 226, 220, 0.62);
}

.profile-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
}

.profile-logo {
  position: relative;
  display: flex;
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  background: #1B4332;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(27, 67, 50, 0.12);
}

.profile-logo-leaf {
  width: 26rpx;
  height: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 24rpx 6rpx;
  transform: rotate(-28deg);
}

.profile-brand-copy {
  min-width: 0;
}

.profile-brand-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
}

.profile-brand-sub {
  margin-top: 6rpx;
  color: #6B7280;
  font-size: 21rpx;
  font-weight: 760;
  letter-spacing: 1rpx;
}

.profile-pill {
  display: flex;
  min-height: 56rpx;
  flex: 0 0 auto;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  color: #374151;
  background: #FFFFFF;
  border: 1rpx solid rgba(229, 231, 235, 0.85);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.025);
  font-size: 23rpx;
  font-weight: 850;
}

.pill-dot {
  width: 12rpx;
  height: 12rpx;
  background: #F2D479;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(242, 212, 121, 0.24);
}

.parent-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.hero-spark {
  position: absolute;
  top: 54rpx;
  left: -20rpx;
  color: #F2D479;
  font-size: 42rpx;
  font-weight: 1000;
}

.parent-hero-badge {
  display: inline-flex;
  width: max-content;
  min-height: 52rpx;
  align-items: center;
  padding: 0 20rpx;
  color: #9A7300;
  background: rgba(242, 212, 121, 0.24);
  border-radius: 16rpx;
  font-size: 23rpx;
  font-weight: 1000;
}

.parent-title {
  margin-top: 6rpx;
  color: #111827;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.16;
  letter-spacing: 0;
}

.parent-subtitle {
  max-width: 650rpx;
  color: #4B5563;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.48;
}

.parent-subtitle text {
  color: #111827;
  font-weight: 1000;
}

.route-strip {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.route-strip text {
  flex: 1 1 0;
  min-width: 0;
  padding: 9rpx 6rpx;
  overflow: hidden;
  color: #657069;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 850;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-strip text.active {
  color: #1B4332;
  background: rgba(242, 212, 121, 0.30);
  border-color: rgba(242, 212, 121, 0.48);
  font-weight: 1000;
}

.parent-hero-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 16rpx;
}

.hero-identity-card {
  position: relative;
  margin-top: 8rpx;
  padding: 24rpx;
  color: #11231C;
  background: linear-gradient(135deg, #FFF2B8 0%, #F8FCF6 52%, #D9F2E1 100%);
  border: 1rpx solid rgba(27, 67, 50, 0.10);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(27, 67, 50, 0.09);
}

.identity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.identity-kicker {
  color: #8A6A08;
  font-size: 21rpx;
  font-weight: 950;
}

.identity-name {
  margin-top: 6rpx;
  color: #11231C;
  font-size: 38rpx;
  font-weight: 1000;
  line-height: 1.12;
}

.identity-code {
  flex: 0 0 auto;
  min-height: 46rpx;
  padding: 0 16rpx;
  color: #FFFDF8;
  background: #1B4332;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 1000;
  line-height: 46rpx;
}

.identity-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.identity-stat {
  min-width: 0;
  padding: 14rpx 10rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(27, 67, 50, 0.08);
  border-radius: 16rpx;
}

.identity-value {
  overflow: hidden;
  color: #1B4332;
  font-size: 26rpx;
  font-weight: 1000;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-label {
  margin-top: 6rpx;
  color: #6A665F;
  font-size: 18rpx;
  font-weight: 850;
}

.identity-line {
  margin-top: 14rpx;
  color: #6A4D05;
  font-size: 22rpx;
  font-weight: 820;
  line-height: 1.35;
}

.identity-share-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.identity-share-primary,
.identity-share-secondary {
  display: flex;
  min-height: 62rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.identity-share-primary {
  color: #FFFFFF;
  background: #1B4332;
}

.identity-share-secondary {
  color: #1B4332;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(27, 67, 50, 0.10);
}

.parent-hero-primary,
.parent-hero-secondary {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.profile-proof-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.profile-proof-card {
  min-width: 0;
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(27, 67, 50, 0.06);
}

.profile-proof-card.wrong {
  background: #FFF6E4;
  border: 1rpx solid rgba(180, 112, 30, 0.14);
}

.profile-proof-card.share {
  background: #EAF7F1;
  border: 1rpx solid rgba(27, 67, 50, 0.10);
}

.profile-proof-kicker {
  color: #7A5D14;
  font-size: 20rpx;
  font-weight: 850;
}

.profile-proof-title {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #11231C;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.profile-proof-body {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #5D675F;
  font-size: 20rpx;
  font-weight: 650;
  line-height: 1.36;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.parent-hero-primary {
  color: #FFFFFF;
  background: #1B4332;
  box-shadow: 0 18rpx 42rpx rgba(27, 67, 50, 0.20);
}

.parent-hero-secondary {
  color: #1F2933;
  background: #FFFFFF;
  border: 1rpx solid #E5E7EB;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.025);
}

.parent-section-card {
  position: relative;
  margin-top: 54rpx;
  padding: 40rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid rgba(243, 244, 246, 0.90);
  border-radius: 46rpx;
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.04), 0 8rpx 24rpx rgba(0, 0, 0, 0.02);
}

.game-profile-card {
  background: #1B4332;
  color: #FFFFFF;
  overflow: hidden;
}

.game-profile-card .parent-card-title,
.game-profile-card .section-title-row {
  color: #FFFFFF;
}

.game-profile-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.game-level {
  font-size: 42rpx;
  font-weight: 1000;
  line-height: 1.15;
}

.game-level-sub,
.achievement-line,
.leaderboard-notice {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

/* Later-tab visual pass: parent tab enters directly below the WeChat capsule. */
.profile-shell {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(138rpx + env(safe-area-inset-bottom));
}

.parent-hero-shell {
  margin-top: 0;
  padding: 18rpx;
  border-radius: 34rpx;
}
