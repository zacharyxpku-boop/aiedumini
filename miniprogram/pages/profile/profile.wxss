page {
  background: #F9F8F4;
}

.profile-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1F2933;
  background: #F9F8F4;
}

.profile-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
}

.profile-shell {
  position: relative;
  z-index: 2;
  padding: 0 44rpx calc(170rpx + env(safe-area-inset-bottom));
}

.parent-hero-shell {
  position: relative;
  margin: 18rpx 0 26rpx;
  padding: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 9% 3%, rgba(248, 198, 34, 0.18), transparent 24%),
    radial-gradient(circle at 92% 12%, rgba(76, 159, 255, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
}

.parent-dash-top,
.parent-dash-brand,
.parent-dash-hero,
.parent-dash-section-head,
.parent-dash-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.parent-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.parent-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  border-radius: 18rpx;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  box-shadow: 0 14rpx 26rpx rgba(34, 185, 92, 0.24);
}

.parent-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.parent-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.parent-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.parent-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.parent-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 172rpx;
  align-items: center;
  margin-top: 28rpx;
}

.parent-dash-kicker {
  width: max-content;
  max-width: 100%;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  color: #9a6b00;
  background: #fff4c9;
  font-size: 21rpx;
  font-weight: 900;
}

.parent-dash-title {
  margin-top: 14rpx;
  color: #101a16;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 1.09;
  letter-spacing: 0;
}

.parent-dash-sub {
  margin-top: 12rpx;
  color: #64706a;
  font-size: 23rpx;
  line-height: 1.5;
}

.parent-dash-art {
  width: 186rpx;
  height: 164rpx;
  border-radius: 34rpx;
  background: #fff1ea;
}

.parent-dash-proof-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.parent-dash-proof,
.parent-dash-evidence {
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(38, 58, 43, 0.05);
}

.parent-dash-proof {
  min-width: 0;
  min-height: 116rpx;
  padding: 18rpx 14rpx;
}

.parent-dash-proof.primary {
  background: #ecf9ed;
  border-color: rgba(34, 185, 92, 0.18);
}

.parent-dash-proof text {
  display: block;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.parent-dash-proof text:first-child {
  color: #173f31;
  font-size: 24rpx;
  font-weight: 950;
  white-space: nowrap;
}

.parent-dash-proof text:last-child {
  margin-top: 8rpx;
  color: #657069;
  font-size: 20rpx;
  font-weight: 780;
  line-height: 1.32;
}

.parent-dash-evidence {
  margin-top: 18rpx;
  padding: 20rpx;
}

.parent-dash-section-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.parent-dash-section-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
  white-space: nowrap;
}

.parent-dash-evidence-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.parent-report-preview {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(248, 198, 34, 0.16), transparent 36%),
    linear-gradient(135deg, #f2fbef 0%, #ffffff 72%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.parent-report-thumb {
  width: 112rpx;
  height: 84rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 20rpx;
  background: #edf8ff;
}

.parent-report-copy {
  min-width: 0;
}

.parent-report-copy text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
}

.parent-report-copy text:first-child {
  color: #173f31;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.18;
  white-space: nowrap;
}

.parent-report-copy text:nth-child(2) {
  display: -webkit-box;
  margin-top: 6rpx;
  color: #66756d;
  font-size: 19rpx;
  font-weight: 760;
  line-height: 1.28;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.parent-report-badge {
  flex: 0 0 auto;
  padding: 9rpx 13rpx;
  border-radius: 999rpx;
  color: #0f7b43;
  background: #ffffff;
  border: 1rpx solid rgba(34, 185, 92, 0.18);
  font-size: 19rpx;
  font-weight: 950;
  white-space: nowrap;
}

.parent-dash-evidence-grid view {
  min-width: 0;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: #f8fbf3;
  text-align: center;
}

.parent-dash-evidence-grid text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.parent-dash-evidence-grid text:first-child {
  color: #174533;
  font-size: 21rpx;
  font-weight: 950;
}

.parent-dash-evidence-grid text:last-child {
  margin-top: 6rpx;
  color: #728078;
  font-size: 19rpx;
  font-weight: 780;
}

.parent-hero-shell .ux-kit-jump-grid {
  gap: 12rpx;
  margin-top: 18rpx;
}

.parent-jump-card {
  background:
    radial-gradient(circle at 82% 18%, rgba(248, 198, 34, 0.18), transparent 32%),
    #ffffff;
}

.parent-dash-route {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.parent-route-node {
  position: relative;
  min-width: 0;
  min-height: 126rpx;
  padding: 13rpx 7rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  color: #17211d;
  background: linear-gradient(180deg, #ffffff 0%, #f8faf5 100%);
  box-shadow: 0 12rpx 24rpx rgba(41, 65, 52, 0.07);
  overflow: visible;
}

.parent-route-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.parent-route-node:last-child::after {
  display: none;
}

.parent-route-node.active {
  border-color: rgba(34, 185, 92, 0.28);
  background: linear-gradient(180deg, #effbf2 0%, #ffffff 100%);
}

.parent-route-node.final {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.parent-route-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 7rpx;
  border-radius: 17rpx;
  background: #f0f8ee;
}

.parent-route-node.active .parent-route-icon {
  background: #dff7e6;
}

.parent-route-node.final .parent-route-icon {
  background: #fff1bd;
}

.parent-route-node text:nth-child(2) {
  max-width: 100%;
  color: #17211d;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.parent-route-node text:nth-child(3) {
  max-width: 100%;
  color: #526158;
  font-size: 17rpx;
  font-weight: 780;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.parent-dash-action-row {
  margin-top: 18rpx;
}

.parent-primary,
.parent-secondary {
  flex: 1 1 0;
  margin-top: 0;
}

.profile-glow {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  border-radius: 999rpx;
  filter: blur(58rpx);
}

.glow-one {
  top: -80rpx;
  right: -120rpx;
  width: 480rpx;
  height: 480rpx;
  background: rgba(242, 212, 121, 0.38);
}

.glow-two {
  top: 250rpx;
  left: -180rpx;
  width: 540rpx;
  height: 540rpx;
  background: rgba(216, 226, 220, 0.62);
}

.

/* Later-tab visual pass: parent tab enters directly below the WeChat capsule. */
.profile-shell {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(138rpx + env(safe-area-inset-bottom));
}

.parent-hero-shell {
  margin-top: 0;
  padding: 18rpx;
  border-radius: 34rpx;
}
