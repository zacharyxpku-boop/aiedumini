  width: fit-content;
  max-width: 100%;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  color: #5f6f66;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1.22;
}

.profile-companion-line {
  margin-top: 10rpx;
  color: #5a6c60;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.32;
}

.profile-empty-state {
  color: #4f5d54;
  padding: 16rpx 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.38;
}

.weekly-summary-canvas {
  width: 320px;
  height: 430px;
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.profile-next-lite {
  margin-top: 10rpx;
  color: #5f6f66;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.3;
  text-align: center;
}

.family-summary-body.family-readable view.parent-one-question {
  color: #0F4F3D;
  padding: 18rpx 20rpx;
  background: rgba(247, 208, 104, 0.32);
  border-color: rgba(247, 208, 104, 0.58);
  box-shadow: 0 10rpx 24rpx rgba(154, 115, 0, 0.08);
  font-size: 24rpx;
  font-weight: 950;
  -webkit-line-clamp: unset;
}

.family-summary-body.family-readable .parent-one-question {
  gap: 8rpx;
  -webkit-line-clamp: unset;
}

.family-summary-body.family-readable .parent-one-question .parent-brief-label {
  color: #8A6508;
  font-size: 22rpx;
}

.family-summary-body.family-readable .blackboard-one-line {
  -webkit-line-clamp: 1;
}

.process-summary-items.collapsed {
  display: none;
}

.profile-entry-grid,
.parent-goal-card,
.profile-main-actions,
.profile-subtle-card,
.profile-lead-card {
  margin-top: 22rpx;
  opacity: 0.62;
}

.profile-entry-grid {
  transform: scale(0.96);
  transform-origin: top center;
}

.parent-invite-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #fff7d6, #e7f4ee);
  color: #174c3e;
}

.parent-invite-card view {
  font-size: 30rpx;
  font-weight: 900;
}

.parent-invite-card text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.real-trial-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.real-trial-actions button {
  flex: 1 1 260rpx;
  min-width: 0;
}

.borrow-workbench-card {
  border: 1rpx solid rgba(15, 79, 61, 0.1);
  background: rgba(255, 255, 255, 0.78);
}

.borrow-workbench-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 12rpx;
}

.borrow-workbench-lane {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid rgba(15, 79, 61, 0.1);
  border-radius: 8rpx;
  background: #f7fbf8;
}

.borrow-workbench-lane text {
  color: #45564c;
  font-size: 21rpx;
  line-height: 1.36;
}

.borrow-workbench-label {
  color: #103f32 !important;
  font-size: 22rpx !important;
  font-weight: 900;
}

.borrow-workbench-blocked {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.borrow-workbench-blocked text {
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(153, 66, 54, 0.08);
  color: #7a372f;
  font-size: 20rpx;
  font-weight: 760;
}

.borrow-workbench-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.borrow-workbench-actions button {
  flex: 1 1 220rpx;
  min-width: 0;
  margin: 0;
  border-radius: 8rpx;
  background: #123f35;
  color: #fff;
  font-size: 22rpx;
  font-weight: 850;
}


@media (max-height: 700px) {
  .profile-page .parent-hero {
    padding: 20rpx;
  }

  .parent-title {
    font-size: 34rpx;
  }

  .profile-page .parent-subtitle {
    display: none;
  }

  .family-summary-body.family-readable view {
    padding: 8rpx 10rpx;
    font-size: 20rpx;
    -webkit-line-clamp: 1;
  }
}
