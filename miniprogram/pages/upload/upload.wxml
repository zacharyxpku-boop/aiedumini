<view class="upload-page">

  <scroll-view class="upload-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="upload-content">
      <view class="upload-hero-shell ux-entry ux-entry-upload ux-kit-screen ux-kit-upload">
        <view class="upload-dash-top">
          <view class="upload-dash-brand">
            <image class="upload-dash-mark" mode="aspectFit" src="/assets/reference/brand-house.png" />
            <view>
              <text>原点智学</text>
              <text>资料进入证据链</text>
            </view>
          </view>
          <view class="upload-dash-pill">学习包</view>
        </view>

        <view class="upload-dash-hero">
          <view class="upload-dash-copy">
            <view class="upload-dash-title">先把材料分清楚</view>
            <view class="upload-dash-sub">测评、成绩、错题和家长观察会进入不同证据位，再生成报告和今晚路线。</view>
            <view class="upload-dash-proof">
              <text>不公开分享</text>
              <text>先分类再分析</text>
            </view>
          </view>
          <image class="upload-dash-mascot" mode="aspectFill" src="/assets/reference/entry-upload.png" />
        </view>

        <view class="upload-material-grid ux-kit-jump-grid">
          <view class="upload-material-card ux-kit-jump-card primary" data-scene="upload" bindtap="openEntryDetail">
            <image class="upload-material-icon" mode="aspectFit" src="/assets/reference/entry-upload.png" />
            <text>上传材料</text>
            <text>作业/错题/成绩</text>
          </view>
          <view class="upload-material-card ux-kit-jump-card" data-scene="parent" bindtap="openEntryDetail">
            <image class="upload-material-icon blue" mode="aspectFit" src="/assets/reference/entry-report.png" />
            <text>家长报告</text>
            <text>证据与方法匹配</text>
          </view>
          <view class="upload-material-card ux-kit-jump-card" data-scene="today" bindtap="openEntryDetail">
            <image class="upload-material-icon yellow" mode="aspectFit" src="/assets/reference/entry-map.png" />
            <text>今晚路线</text>
            <text>直接生成任务</text>
          </view>
        </view>

        <view class="upload-dash-pipeline">
          <view class="done"><text>1</text><text>分类材料</text></view>
          <view><text>2</text><text>提取证据</text></view>
          <view><text>3</text><text>生成报告</text></view>
          <view><text>4</text><text>进入私教</text></view>
        </view>
        <view class="upload-dash-primary" data-scene="upload" bindtap="openEntryDetail">生成学习包</view>
      </view>
      <view class="upload-subcheck ux-kit-subcheck">
        <view class="subcheck-main" data-scene="upload" bindtap="openEntryDetail">
          <view class="subcheck-copy">
            <text>材料先进证据链</text>
            <text>测评、成绩、错题、观察会被分开处理，不混成一句空建议。</text>
          </view>
          <image class="subcheck-art" mode="aspectFill" src="/assets/reference/entry-upload.png" />
        </view>
        <view class="subcheck-side">
          <view data-scene="parent" bindtap="openEntryDetail"><text>出报告</text><text>给家长看结论</text></view>
          <view data-scene="today" bindtap="openEntryDetail"><text>变任务</text><text>回到今晚路线</text></view>
        </view>
      </view>
      <view class="upload-intake-panel">
        <view wx:if="{{uploadIntakePacket}}">结构化入口 {{uploadIntakePacket.summaryLine}}</view>
        <view>UPLOAD TO TRIAGE LOOP</view>
        <view>MATERIAL TO MEMORY ENGINE</view>
        <view>Import to review</view>
        <view>Tonight preview</view>
        <view class="material-source-tabs">
          <view class="material-source-chip">公众号摘录</view>
          <view class="material-source-chip">网页摘录</view>
          <view class="material-source-chip">PDF 摘录</view>
        </view>
        <view class="material-boundary">只处理你粘贴的内容，不自动抓取链接</view>
        <view class="material-boundary" wx:if="{{uploadIntakePacket.nextActionQueue}}">下一步动作队列</view>
        <view class="material-boundary" wx:for="{{uploadIntakePacket.nextActionQueue}}" wx:key="id" data-route="{{item.route}}" bindtap="goIntakeAction">{{item.label}} {{item.action}}</view>
        <view class="upload-three-step-card">
          <view class="upload-entry-chip {{uploadEntryMode === item.id ? 'active' : ''}}" wx:for="{{uploadEntryDeck}}" wx:key="id" data-mode="{{item.id}}" bindtap="setUploadEntryMode">
            <text>{{item.title}}</text>
            <text>{{item.subtitle}}</text>
          </view>
        </view>
        <view class="material-report-hero" bindtap="openMaterialReportPanel">
          <view>家长材料报告</view>
          <view>标准版家长 HTML 报告</view>
          <view>预览 HTML/PDF</view>
          <view>AI 草稿只做归纳，结论由本地证据门槛放行</view>
          <button data-type="talent_assessment" bindtap="openQuickAssessment">学习偏好</button>
          <button data-type="score_sheet" bindtap="openQuickAssessment">成绩单</button>
          <button data-type="pdf_excerpt" bindtap="openQuickAssessment">PDF/OCR 文本</button>
          <button bindtap="chooseMaterialFile">选择PDF/报告文件</button>
        </view>
        <textarea class="homework-input" value="{{homeworkText}}" placeholder="{{homeworkPlaceholder}}" maxlength="1200" auto-height bindinput="onHomeworkInput" />
        <view class="structured-evidence-card" wx:if="{{structuredEvidenceCapture}}">
          <view class="structured-evidence-title">证据补全</view>
          <view class="structured-evidence-field" wx:for="{{structuredEvidenceCapture.fields}}" wx:key="id">
            <text>{{item.label}}</text>
            <input value="{{item.value}}" data-id="{{item.id}}" bindinput="onStructuredEvidenceInput" />
          </view>
        </view>
        <view class="material-preview-card" wx:if="{{materialPreview}}">
          <textarea value="{{materialText}}" placeholder="{{materialPreview.examplePlaceholder}}" maxlength="1600" auto-height bindinput="onMaterialInput" />
          <view>{{materialPreview.statusLine}}</view>
          <view>{{materialPreview.modeLine}}</view>
          <view>{{materialPreview.blockedClaimsLine}}</view>
          <view>{{materialPreview.sourceReadinessView.gateLine}}</view>
        </view>
        <view class="last-report-card" wx:if="{{lastReportCta}}">
          <view>{{lastReportCta.title}}</view>
          <view>小讲堂任务单</view>
          <view wx:if="{{lastReportCta.tonightTaskCard}}">今晚任务卡</view>
          <view>{{lastReportCta.tonightTaskCard.firstStep}}</view>
          <view>{{lastReportCta.tonightTaskCard.parentCheck}}</view>
          <view>{{lastReportCta.tonightTaskCard.tomorrowReview}}</view>
          <view>{{lastReportCta.aiLocalReleaseLine}}</view>
          <view>{{lastReportCta.safeRelayReturnLine}}</view>
          <view wx:if="{{lastReportCta.servicePathway}}">学习服务路径 {{lastReportCta.servicePathway.status}}</view>
          <view wx:if="{{lastReportCta.serviceHandoffPack}}">
            <view wx:for="{{lastReportCta.serviceHandoffPack.cards}}" wx:key="id">{{item.title}}</view>
            <view>{{lastReportCta.serviceHandoffPack.releaseLine}}</view>
            <view>{{lastReportCta.serviceHandoffPack.blockedLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.dailyExecutionSeed}}">
            <view>{{lastReportCta.dailyExecutionSeed.todayLine}}</view>
            <view>{{lastReportCta.dailyExecutionSeed.gameLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.aiMaterialSolutionView}}">
            <view wx:for="{{lastReportCta.aiMaterialSolutionView.routes}}" wx:key="id">{{item.label}}</view>
            <view>{{lastReportCta.aiMaterialSolutionView.scoreLine}}</view>
            <view>{{lastReportCta.aiMaterialSolutionView.coverageLine}}</view>
            <view>{{lastReportCta.aiMaterialSolutionView.qualityLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.modeRecommendationView}}">
            <view>{{lastReportCta.modeRecommendationView.summaryLine}}</view>
            <view wx:for="{{lastReportCta.modeRecommendationView.cards}}" wx:key="id">
              <text>{{item.roleLine}}</text>
              <text>{{item.reasonLine}}</text>
              <text>{{item.entryLine}}</text>
              <text>{{item.boundaryLine}}</text>
            </view>
          </view>
          <view wx:if="{{lastReportCta.productTierView}}">{{lastReportCta.productTierView.summaryLine}}</view>
          <view wx:if="{{lastReportCta.modeChoiceProtocolView}}">
            <view wx:for="{{lastReportCta.modeChoiceProtocolView.choiceCards}}" wx:key="id">{{item.label}}</view>
            <view>{{lastReportCta.modeChoiceProtocolView.releaseGateLine}}</view>
            <view wx:for="{{lastReportCta.modeChoiceProtocolView.blockedModeCards}}" wx:key="id">暂不开启 {{item.label}}</view>
          </view>
          <view wx:if="{{lastReportCta.partnerServiceDeliveryLedger}}">
            <view>合作交付账本</view>
          </view>
          <view wx:if="{{lastReportCta.partnerDeliveryLedgerView}}">
            <view>{{lastReportCta.partnerDeliveryLedgerView.statusLine}}</view>
            <view>{{lastReportCta.partnerDeliveryLedgerView.releaseGateLine}}</view>
            <view>{{lastReportCta.partnerDeliveryLedgerView.visibleFieldLine}}</view>
            <view>{{lastReportCta.partnerDeliveryLedgerView.blockedFieldLine}}</view>
            <view wx:for="{{lastReportCta.partnerDeliveryLedgerView.packageCards}}" wx:key="id">
              <text>{{item.title}}</text>
              <text>{{item.entryGateLine}}</text>
            </view>
          </view>
          <view wx:if="{{lastReportCta.postPilotRetentionView}}">
            <view wx:for="{{lastReportCta.postPilotRetentionView.cards}}" wx:key="id">{{item.label}}</view>
            <view>{{lastReportCta.postPilotRetentionView.operatorLine}}</view>
            <view>{{lastReportCta.postPilotRetentionView.crmLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.personalizedClosureView}}">
            <view>{{lastReportCta.personalizedClosureView.contentLine}}</view>
            <view>{{lastReportCta.personalizedClosureView.gameLine}}</view>
            <view>{{lastReportCta.personalizedClosureView.releaseLine}}</view>
            <view>{{lastReportCta.personalizedClosureView.evidenceLine}}</view>
            <view>{{lastReportCta.personalizedClosureView.lockedLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.parentConfirmation}}">
            <view>{{lastReportCta.parentConfirmation.evidenceLine}}</view>
            <button wx:if="{{lastReportCta.needsParentConfirmation}}" bindtap="confirmReportParentConsent">家长确认</button>
          </view>
          <view>商业闭环：学习偏好/测评资料</view>
          <view>AI 辅助学习方法候选</view>
          <view>学习偏好/测评资料</view>
          <view wx:if="{{lastReportCta.validationPlanView}}">
            <view wx:for="{{lastReportCta.validationPlanView.cards}}" wx:key="id">
              <text>{{item.evidenceLine}}</text>
              <text>{{item.acceptanceLine}}</text>
              <text>{{item.stopLine}}</text>
            </view>
            <view>{{lastReportCta.validationPlanView.successLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.productTierView}}">
            <view>{{lastReportCta.productTierView.summaryLine}}</view>
            <view wx:for="{{lastReportCta.productTierView.cards}}" wx:key="id">
              <text>{{item.entryGateLine}}</text>
              <text>{{item.blockedClaimsLine}}</text>
              <text>{{item.evidenceLine}}</text>
            </view>
          </view>
          <view wx:if="{{lastReportCta.quickAssessmentBridgeView}}">
            <view>{{lastReportCta.quickAssessmentBridgeView.gateLine}}</view>
            <view>{{lastReportCta.quickAssessmentBridgeView.evidenceLine}}</view>
            <view>{{lastReportCta.quickAssessmentBridgeView.boundaryLine}}</view>
          </view>
          <view wx:if="{{lastReportCta.aiLocalDeliveryView}}">
            <view>{{lastReportCta.aiLocalDeliveryView.summaryLine}}</view>
            <view wx:for="{{lastReportCta.aiLocalDeliveryView.cards}}" wx:key="id">
              <text>{{item.ownsLine}}</text>
              <text>{{item.familyLine}}</text>
              <text>{{item.boundaryLine}}</text>
            </view>
          </view>
          <view wx:if="{{lastReportCta.publicK12BorrowView}}">
            <view>{{lastReportCta.publicK12BorrowView.summaryLine}}</view>
            <view wx:for="{{lastReportCta.publicK12BorrowView.cards}}" wx:key="id">
              <text>{{item.localGuardLine}}</text>
              <text>{{item.aiUseLine}}</text>
              <text>{{item.blockedLine}}</text>
            </view>
          </view>
          <view>7 天验证</view>
          <view>AI 草案字段</view>
          <view>{{lastReportCta.guardedAiReportDraft.visibleLine}}</view>
          <button bindtap="viewLatestReport">{{lastReportCta.primaryLabel}}</button>
          <button wx:if="{{lastReportCta.gameRoute}}" bindtap="runReportGameAction">去轻练习</button>
          <view>AI 只做改写和追问</view>
        </view>
      </view>
      </view>
  </scroll-view>
</view>
