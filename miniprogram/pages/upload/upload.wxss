page {
  background: #FAF9F5;
}

.upload-page {
  min-height: 100vh;
  color: #33312E;
  background: #FAF9F5;
}

.upload-nav {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 84rpx minmax(0, 1fr) 96rpx;
  min-height: calc(96rpx + env(safe-area-inset-top));
  align-items: center;
  gap: 12rpx;
  padding: env(safe-area-inset-top) 32rpx 0;
  background: rgba(250, 249, 245, 0.92);
  border-bottom: 1rpx solid rgba(234, 230, 223, 0.55);
  backdrop-filter: blur(18rpx);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  color: #33312E;
}

.nav-back-icon {
  font-size: 54rpx;
  line-height: 1;
}

.nav-title {
  min-width: 0;
  overflow: hidden;
  color: #33312E;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-home {
  display: flex;
  min-height: 52rpx;
  align-items: center;
  justify-content: center;
  color: #1E4233;
  background: #FFFFFF;
  border: 1rpx solid #E8E2D5;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.upload-scroll {
  height: calc(100vh - 96rpx - env(safe-area-inset-top));
}

.upload-content {
  padding: 26rpx 40rpx 96rpx;
}

.upload-hero-shell {
  position: relative;
  margin-bottom: 30rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 10% 4%, rgba(248, 198, 34, 0.16), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(76, 159, 255, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

.upload-dash-top,
.upload-dash-brand,
.upload-dash-proof,
.upload-dash-hero,
.upload-material-grid,
.upload-dash-pipeline {
  box-sizing: border-box;
}

.upload-dash-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.upload-dash-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
}

.upload-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 18rpx;
  box-shadow: 0 14rpx 26rpx rgba(34, 185, 92, 0.24);
}

.upload-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.upload-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.upload-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.upload-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 170rpx;
  gap: 20rpx;
  align-items: center;
  margin-top: 30rpx;
}

.upload-dash-title {
  color: #101a16;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1.08;
  letter-spacing: 0;
}

.upload-dash-sub {
  margin-top: 12rpx;
  color: #64706a;
  font-size: 24rpx;
  line-height: 1.55;
}

.upload-dash-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.upload-dash-proof text {
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #f0fbf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 820;
  white-space: nowrap;
}

.upload-type-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.upload-type-strip text {
  padding: 7rpx 12rpx;
  color: #6d5b25;
  background: #fff7df;
  border: 1rpx solid rgba(248, 198, 34, 0.24);
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 800;
  white-space: nowrap;
}

.upload-dash-mascot {
  width: 196rpx;
  height: 176rpx;
  border-radius: 34rpx;
  background: #f6fbf0;
}

.upload-material-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.upload-material-card {
  min-width: 0;
  min-height: 170rpx;
  padding: 16rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(38, 58, 43, 0.055);
}

.upload-material-card.primary {
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf0 100%);
}

.upload-material-icon {
  width: 62rpx;
  height: 62rpx;
  display: block;
  box-sizing: border-box;
  padding: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 20rpx;
  background: #effaf0;
}

.upload-material-icon.blue { background: #eef7ff; }
.upload-material-icon.yellow { background: #fff7df; }

.upload-material-card text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.upload-material-card text:nth-child(2) {
  color: #17211d;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.upload-material-card text:nth-child(3) {
  color: #66746d;
  font-size: 19rpx;
  line-height: 1.35;
}

.upload-dash-pipeline {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.upload-pipeline-node {
  position: relative;
  min-width: 0;
  min-height: 126rpx;
  padding: 13rpx 7rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border: 1rpx solid rgba(220, 232, 220, 0.95);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbf3 100%);
  box-shadow: 0 12rpx 24rpx rgba(41, 65, 52, 0.07);
  overflow: visible;
}

.upload-pipeline-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.upload-pipeline-node:last-child::after {
  display: none;
}

.upload-pipeline-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 7rpx;
  border-radius: 17rpx;
  background: #f0f8ee;
}

.upload-pipeline-node text:nth-child(2) {
  max-width: 100%;
  color: #17211d;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.upload-pipeline-node text:nth-child(3) {
  max-width: 100%;
  color: #526158;
  font-size: 17rpx;
  font-weight: 780;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.upload-pipeline-node.done {
  border-color: rgba(34, 185, 92, 0.28);
  background: linear-gradient(180deg, #effbf2 0%, #ffffff 100%);
}

.upload-pipeline-node.active {
  border-color: rgba(76, 159, 255, 0.32);
  background: linear-gradient(180deg, #eef7ff 0%, #ffffff 100%);
}

.upload-pipeline-node.next {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.upload-pipeline-node.done .upload-pipeline-icon {
  background: #dff7e6;
}

.upload-pipeline-node.active .upload-pipeline-icon {
  background: #e5f2ff;
}

.upload-pipeline-node.next .upload-pipeline-icon {
  background: #fff1bd;
}

.upload-dash-primary {
  height: 78rpx;
  margin-top: 22rpx;
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
  border-radius: 999rpx;
  box-shadow: 0 16rpx 28rpx rgba(248, 198, 34, 0.22);
  font-size: 27rpx;
  font-weight: 950;
  line-height: 78rpx;
  text-align: center;
}

.upload-brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 38rpx;
}

.upload-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
}

.upload-logo {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1E4233;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(30, 66, 51, 0.16);
}

.upload-logo-leaf {
  width: 22rpx;
  height: 26rpx;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  transform: rotate(-28deg);
}

.upload-brand-copy {
  min-width: 0;
}

.upload-brand-line {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  white-space: nowrap;
}

.upload-brand-name {
  color: #33312E;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: -0.5rpx;
}

.upload-brand-divider {
  color: #D4D0C8;
  font-size: 22rpx;
}

.upload-brand-sub {
  color: #8A857D;
  font-size: 22rpx;
  font-weight: 700;
}

.upload-soft-pill {
  display: flex;
  min-height: 44rpx;
  flex: 0 0 auto;
  align-items: center;
  gap: 6rpx;
  padding: 0 18rpx;
  color: #7A7366;
  background: #F0EBE1;
  border: 1rpx solid #E8E2D5;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(65, 48, 28, 0.04);
  font-size: 20rpx;
  font-weight: 700;
}

.pill-spark {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #22b95c;
  box-shadow: 0 0 0 8rpx rgba(34, 185, 92, 0.1);
}

.upload-hero {
  margin-bottom: 32rpx;
}

.upload-badge {
  display: inline-flex;
  width: auto;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 22rpx;
  padding: 4rpx 14rpx 4rpx 12rpx;
  color: #2A5C45;
  background: #EAF0EB;
  border: 1rpx solid #D5E2DA;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #2A5C45;
}

.upload-hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.upload-hero-copy {
  flex: 1;
  min-width: 0;
}

.upload-title {
  color: #21201E;
  font-size: 44rpx;
  font-weight: 950;
  letter-spacing: -0.8rpx;
  line-height: 1.16;
}

.upload-subtitle {
  margin-top: 14rpx;
  color: #7A756C;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.6;
  text-align: justify;
}

.paper-stack {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  flex: 0 0 auto;
  margin-top: 8rpx;
}

.paper {
  position: absolute;
  inset: 0;
  border: 1rpx solid #EAE6DF;
  border-radius: 20rpx;
}

.paper-back {
  background: #F4F1E8;
  transform: rotate(6deg);
  transform-origin: right bottom;
}

.paper-mid {
  background: #FCFAF5;
  box-shadow: 0 4rpx 12rpx rgba(65, 48, 28, 0.05);
  transform: rotate(-3deg);
  transform-origin: left bottom;
}

.paper-front {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
  padding: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(65, 48, 28, 0.05);
}

.paper-line {
  height: 6rpx;
  background: #E8E5DF;
  border-radius: 999rpx;
}

.paper-line.full {
  width: 100%;
}

.paper-line.short {
  width: 74%;
}

.paper-line.bottom {
  margin-top: 6rpx;
}

.paper-spark {
  position: absolute;
  top: -18rpx;
  right: -16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #f8c622;
  box-shadow: 0 0 0 10rpx rgba(248, 198, 34, 0.16);
}

.upload-stack {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.soft-card {
  padding: 34rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  border-radius: 40rpx;
  box-shadow: 0 8rpx 48rpx -12rpx rgba(0, 0, 0, 0.03), 0 4rpx 16rpx -4rpx rgba(0, 0, 0, 0.02);
}

.upload-three-step-card {
  border-color: rgba(65, 113, 92, 0.12);
}

.upload-entry-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin: 18rpx 0;
}

.upload-entry-chip {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  padding: 22rpx;
  text-align: left;
  background: #F9F7F1;
  border: 1rpx solid #EEE7D8;
  border-radius: 18rpx;
  color: #34312C;
  line-height: 1.35;
}

.upload-entry-chip.active {
  background: #EFF6F1;
  border-color: rgba(65, 113, 92, 0.28);
}

.upload-entry-label {
  color: #41715C;
  font-size: 22rpx;
  font-weight: 850;
}

.upload-entry-title {
  color: #292722;
  font-size: 28rpx;
  font-weight: 850;
}

.upload-entry-line {
  color: #767067;
  font-size: 23rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.card-title-row.compact {
  margin-bottom: 22rpx;
}

.card-title-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A857D;
  background: #F5F3EC;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.card-title {
  color: #33312E;
  font-size: 30rpx;
  font-weight: 850;
}

.time-stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx;
  background: #FAF9F5;
  border: 1rpx solid #F0EBE1;
  border-radius: 32rpx;
}

.step-button {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A857D;
  background: #FFFFFF;
  border: 1rpx solid #EAE6DF;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(65, 48, 28, 0.055);
  font-size: 38rpx;
  font-weight: 850;
}

.time-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-number {
  color: #1E4233;
  font-size: 64rpx;
  font-weight: 950;
  letter-spacing: -1rpx;
  line-height: 1;
}

.time-unit {
  margin-left: 8rpx;
  color: #8A857D;
  font-size: 26rpx;
  font-weight: 700;
}

.textarea-box {
  position: relative;
  padding: 28rpx;
  background: #FAF9F5;
  border: 1rpx solid #F0EBE1;
  border-radius: 32rpx;
}

.homework-textarea {
  width: 100%;
  min-height: 220rpx;
  color: #33312E;
  background: transparent;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.65;
}

.voice-hint {
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  color: #B8B4AC;
  font-size: 20rpx;
  font-weight: 650;
}

.wrongbook-strip {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  background: #F8F3E3;
  border: 1rpx solid rgba(194, 146, 35, 0.18);
  border-radius: 24rpx;
}

.wrongbook-dot {
  width: 20rpx;
  height: 20rpx;
  flex: 0 0 auto;
  background: #E2B33F;
  border: 6rpx solid #FFF5CF;
  border-radius: 999rpx;
}

.wrongbook-copy {
  min-width: 0;
}

.wrongbook-title {
  color: #4A3820;
  font-size: 24rpx;
  font-weight: 900;
}

.wrongbook-desc {
  margin-top: 4rpx;
  color: #776240;
  font-size: 22rpx;
  font-weight: 680;
  line-height: 1.35;
}

.intake-packet-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #d9eadf;
  border-radius: 24rpx;
  background: #ffffff;
}

.intake-packet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.intake-packet-kicker {
  color: #1a5336;
  font-size: 20rpx;
  font-weight: 950;
}

.intake-packet-title {
  margin-top: 5rpx;
  color: #1a211d;
  font-size: 28rpx;
  font-weight: 1000;
}

.intake-packet-pill {
  flex: 0 0 auto;
  min-height: 44rpx;
  padding: 0 16rpx;
  color: #1a5336;
  background: #f7d068;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 44rpx;
}

.intake-packet-feedback,
.intake-packet-line,
.intake-packet-boundary {
  margin-top: 10rpx;
  color: #626a62;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.42;
}

.intake-packet-line {
  color: #1a5336;
  font-weight: 900;
}

.intake-packet-evidence {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.intake-packet-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #7a6a4a;
  background: #f8f3e3;
  font-size: 20rpx;
  font-weight: 850;
}

.intake-packet-chip.ready {
  color: #1a5336;
  background: rgba(26, 83, 54, 0.10);
}

.intake-action-queue {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tonight-task-card {
  margin-top: 16rpx;
  padding: 18rpx;
  background: #F7FBF0;
  border: 1rpx solid rgba(26, 83, 54, 0.14);
  border-radius: 18rpx;
}

.intake-action-title {
  color: #1a211d;
  font-size: 23rpx;
  font-weight: 950;
}

.intake-action-item {
  padding: 16rpx;
  background: #f8faf8;
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 18rpx;
}

.intake-action-item.ready {
  border-color: rgba(26, 83, 54, 0.18);
  background: rgba(26, 83, 54, 0.055);
}

.intake-action-item.required {
  border-color: rgba(247, 208, 104, 0.42);
  background: #fff9e8;
}

.intake-action-item.locked {
  opacity: 0.66;
}

.intake-action-main,
.intake-action-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.intake-action-main text:first-child {
  color: #1a5336;
  font-size: 23rpx;
  font-weight: 950;
}

.intake-action-main text:last-child,
.intake-action-meta text {
  color: #657065;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.34;
}

.intake-action-meta {
  margin-top: 8rpx;
}

.quick-wrap {
  margin-top: 26rpx;
}

.quick-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  color: #8A857D;
  font-size: 22rpx;
  font-weight: 750;
}

.quick-label-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #f8c622;
  box-shadow: 0 0 0 8rpx rgba(248, 198, 34, 0.14);
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.quick-chip {
  min-height: 56rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0 22rpx;
  color: #6B655B;
  background: #F5F3EC;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 760;
}

.quick-plus {
  font-size: 20rpx;
}

.submit-button {
  width: 100%;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 36rpx 0 28rpx;
  color: #FFFFFF;
  background: #1E4233;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx -12rpx rgba(30, 66, 51, 0.4);
  font-size: 32rpx;
  font-weight: 850;
}

.submit-arrow {
  font-size: 28rpx;
  font-weight: 900;
}

.upload-detail-toggle {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 18rpx;
  align-items: center;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #EAE6DF;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(65, 48, 28, 0.04);
}

.upload-detail-title {
  color: #21201E;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.upload-detail-subtitle {
  margin-top: 8rpx;
  color: #7A756C;
  font-size: 22rpx;
  font-weight: 680;
  line-height: 1.35;
}

.upload-detail-button {
  min-height: 64rpx;
  color: #1E4233;
  background: #F5F3EC;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 850;
}

.plan-card {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 30rpx 24rpx;
  background: linear-gradient(180deg, #F7F9F8 0%, #FFFFFF 100%);
  border: 1rpx solid rgba(234, 230, 223, 0.75);
  border-radius: 40rpx;
}

.plan-bg {
  position: absolute;
  top: -60rpx;
  right: -70rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
}

.plan-hint {
  position: relative;
  z-index: 1;
  margin-bottom: 26rpx;
  color: #8A857D;
  font-size: 24rpx;
  font-weight: 750;
  text-align: center;
}

.plan-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.plan-cell {
  min-width: 0;
  min-height: 172rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 14rpx;
  border-radius: 24rpx;
}

.plan-cell.must {
  background: #FFF8F7;
  border: 1rpx solid #FFEBE9;
}

.plan-cell.flexible {
  background: #F7F9FF;
  border: 1rpx solid #EBEFFF;
}

.plan-cell.skip {
  background: #F7FFF9;
  border: 1rpx solid #E6F4EA;
}

.plan-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.must .plan-icon {
  color: #E05243;
  background: #FFEBE9;
}

.flexible .plan-icon {
  color: #4374E0;
  background: #EBEFFF;
}

.skip .plan-icon {
  color: #34A853;
  background: #E6F4EA;
}

.plan-title {
  font-size: 26rpx;
  font-weight: 850;
}

.must .plan-title { color: #4A2622; }
.flexible .plan-title { color: #25365A; }
.skip .plan-title { color: #1F452A; }

.plan-lines {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
}

.line {
  height: 10rpx;
  border-radius: 999rpx;
  opacity: 0.62;
}

.line.long { width: 100%; }
.line.mid { width: 78%; }
.line.short { width: 66%; }
.must .line { background: #FFDED9; }
.flexible .line { background: #D6E0FE; }
.skip .line { background: #CEECD6; }

.plan-count {
  margin-top: 14rpx;
  color: #8A857D;
  font-size: 21rpx;
  font-weight: 850;
}

.preview-card,
.material-toggle,
.material-card {
  margin-top: 24rpx;
  padding: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid #EAE6DF;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(65, 48, 28, 0.04);
}

.preview-kicker {
  color: #2A5C45;
  font-size: 22rpx;
  font-weight: 900;
}

.preview-title,
.material-title {
  margin-top: 6rpx;
  color: #21201E;
  font-size: 30rpx;
  font-weight: 900;
}

.preview-first {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #F7F9F8;
  border-radius: 22rpx;
}

.preview-first.empty {
  color: #7A756C;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.preview-first-title {
  color: #21201E;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.45;
}

.preview-first-reason {
  margin-top: 10rpx;
  color: #7A756C;
  font-size: 23rpx;
  font-weight: 680;
  line-height: 1.5;
}

.secondary-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.secondary-button,
.material-toggle-btn,
.material-import {
  min-height: 72rpx;
  color: #1E4233;
  background: #F5F3EC;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 850;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: 18rpx;
  background: #EFEAE1;
}

.photo-hint {
  margin-top: 12rpx;
  color: #8A857D;
  font-size: 22rpx;
  font-weight: 680;
  line-height: 1.45;
}

.material-report-hero {
  margin-top: 24rpx;
  padding: 26rpx;
  background: #F7FBF7;
  border: 1rpx solid #DCEBDD;
  border-radius: 28rpx;
}

.material-report-kicker {
  color: #2A5C45;
  font-size: 22rpx;
  font-weight: 900;
}

.material-report-title {
  margin-top: 8rpx;
  color: #1F241F;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.material-report-desc {
  margin-top: 10rpx;
  color: #6D685F;
  font-size: 23rpx;
  font-weight: 680;
  line-height: 1.5;
}

.material-report-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.material-report-chip {
  min-height: 64rpx;
  padding: 0 18rpx;
  color: #1E4233;
  background: #FFFFFF;
  border: 1rpx solid #CFE0D1;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.material-toggle {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 18rpx;
  align-items: center;
}

.material-desc {
  margin-top: 8rpx;
  color: #7A756C;
  font-size: 23rpx;
  font-weight: 680;
  line-height: 1.48;
}

.material-source-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.material-source-chip {
  min-height: 64rpx;
  padding: 0 14rpx;
  color: #554F45;
  background: #F7F4EA;
  border: 1rpx solid #E9DFC9;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.material-source-chip.active {
  color: #FFFFFF;
  background: #2A5C45;
  border-color: #2A5C45;
}

.material-source-line,
.material-boundary {
  margin-top: 12rpx;
  color: #6E685E;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 1.45;
}

.material-boundary {
  color: #8A6141;
  background: #FFF8EA;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
}

.material-textarea {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  color: #33312E;
  background: #FAF9F5;
  border: 1rpx solid #F0EBE1;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.material-import {
  width: 100%;
  margin-top: 18rpx;
  color: #FFFFFF;
  background: #1E4233;
}

.structured-evidence-card {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #F7FBF7;
  border: 1rpx solid #D8E8D8;
  border-radius: 22rpx;
}

.structured-evidence-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.structured-evidence-kicker {
  color: #2A5C45;
  font-size: 20rpx;
  font-weight: 900;
}

.structured-evidence-title {
  margin-top: 4rpx;
  color: #1F241F;
  font-size: 27rpx;
  font-weight: 900;
}

.structured-evidence-score {
  color: #1E4233;
  font-size: 24rpx;
  font-weight: 950;
}

.structured-evidence-summary,
.structured-evidence-gate,
.structured-evidence-next {
  margin-top: 10rpx;
  color: #655F56;
  font-size: 22rpx;
  line-height: 1.45;
}

.structured-evidence-fields {
  margin-top: 14rpx;
  display: grid;
  gap: 12rpx;
}

.structured-evidence-field {
  padding: 14rpx;
  background: #FFFFFF;
  border: 1rpx solid #E7E2D8;
  border-radius: 18rpx;
}

.structured-evidence-field.ready {
  border-color: #A7C8A9;
}

.structured-evidence-label {
  color: #2A5C45;
  font-size: 21rpx;
  font-weight: 900;
}

.structured-evidence-input {
  margin-top: 8rpx;
  min-height: 58rpx;
  color: #2F2D29;
  font-size: 24rpx;
}

.service-pathway-card {
  margin-top: 18rpx;
  padding: 20rpx;
  background: #F3FAF5;
  border: 1rpx solid #D5E9D8;
  border-radius: 22rpx;
}

/* Later-tab visual pass: upload tab mirrors the home-tab density. */
.upload-content {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(132rpx + env(safe-area-inset-bottom));
}

.upload-hero-shell {
  margin-bottom: 22rpx;
  padding: 18rpx;
  border-radius: 34rpx;
}

.upload-dash-hero {
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 12rpx;
  margin-top: 20rpx;
}

.upload-dash-title {
  font-size: 35rpx;
  line-height: 1.1;
}

.upload-dash-sub {
  display: -webkit-box;
  margin-top: 9rpx;
  overflow: hidden;
  font-size: 21rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.upload-dash-proof {
  gap: 8rpx;
  margin-top: 12rpx;
}

.upload-dash-proof text {
  padding: 7rpx 12rpx;
  font-size: 19rpx;
}

.upload-type-strip {
  margin-top: 10rpx;
}

.upload-type-strip text {
  padding: 6rpx 10rpx;
  font-size: 17rpx;
}

.upload-dash-mascot {
  width: 148rpx;
  height: 128rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 30rpx;
}

.upload-material-grid {
  gap: 12rpx;
  margin-top: 16rpx;
}

.upload-material-card {
  min-height: 124rpx;
  padding: 11rpx 9rpx;
  border-radius: 22rpx;
}

.upload-material-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
}

.upload-material-card text:nth-child(2) {
  font-size: 22rpx;
}

.upload-material-card text:nth-child(3) {
  font-size: 18rpx;
}

.upload-dash-pipeline {
  gap: 9rpx;
  margin-top: 16rpx;
}

.upload-pipeline-node {
  min-height: 108rpx;
  padding: 10rpx 4rpx;
  border-radius: 19rpx;
}

.upload-pipeline-node::after {
  right: -14rpx;
  width: 18rpx;
  height: 4rpx;
}

.upload-pipeline-icon {
  width: 42rpx;
  height: 42rpx;
  padding: 6rpx;
  border-radius: 15rpx;
}

.upload-pipeline-node text:nth-child(2) {
  font-size: 18rpx;
}

.upload-pipeline-node text:nth-child(3) {
  font-size: 16rpx;
}

.upload-dash-primary {
  height: 72rpx;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 72rpx;
}

/* Child-flow polish: new upload surface owns its own safe area. */
.upload-nav {
  display: none;
}

.upload-scroll {
  height: 100vh;
}
