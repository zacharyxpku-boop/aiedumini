page {
  background: #FAF9F5;
}

.upload-page {
  min-height: 100vh;
  color: #33312E;
  background: #FAF9F5;
}

.upload-scroll {
  height: 100vh;
}

.upload-content {
  padding: 26rpx 40rpx 96rpx;
}

.upload-hero-shell {
  position: relative;
  margin-bottom: 30rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 10% 4%, rgba(248, 198, 34, 0.16), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(76, 159, 255, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

.upload-dash-top,
.upload-dash-brand,
.upload-dash-proof,
.upload-dash-hero,
.upload-material-grid,
.upload-dash-pipeline {
  box-sizing: border-box;
}

.upload-dash-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.upload-dash-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
}

.upload-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  display: block;
  padding: 7rpx;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 18rpx;
  box-shadow: 0 14rpx 26rpx rgba(34, 185, 92, 0.24);
}

.upload-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.upload-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.upload-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.upload-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 170rpx;
  gap: 20rpx;
  align-items: center;
  margin-top: 30rpx;
}

.upload-dash-title {
  color: #101a16;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1.08;
  letter-spacing: 0;
}

.upload-dash-sub {
  margin-top: 12rpx;
  color: #64706a;
  font-size: 24rpx;
  line-height: 1.55;
}

.upload-dash-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.upload-dash-proof text {
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #f0fbf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 820;
  white-space: nowrap;
}

.upload-type-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.upload-type-strip text {
  padding: 7rpx 12rpx;
  color: #6d5b25;
  background: #fff7df;
  border: 1rpx solid rgba(248, 198, 34, 0.24);
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 800;
  white-space: nowrap;
}

.upload-dash-mascot {
  width: 196rpx;
  height: 176rpx;
  border-radius: 34rpx;
  background: #f6fbf0;
}

.upload-material-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.upload-material-card {
  min-width: 0;
  min-height: 170rpx;
  padding: 16rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(38, 58, 43, 0.055);
}

.upload-material-card.primary {
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf0 100%);
}

.upload-material-icon {
  width: 62rpx;
  height: 62rpx;
  display: block;
  box-sizing: border-box;
  padding: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 20rpx;
  background: #effaf0;
}

.upload-material-icon.blue { background: #eef7ff; }
.upload-material-icon.yellow { background: #fff7df; }

.upload-material-card text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
}

.upload-material-card text:nth-child(2) {
  color: #17211d;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.upload-material-card text:nth-child(3) {
  color: #66746d;
  font-size: 19rpx;
  line-height: 1.35;
}

.upload-dash-pipeline {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.upload-pipeline-node {
  position: relative;
  min-width: 0;
  min-height: 126rpx;
  padding: 13rpx 7rpx 12rpx;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 5rpx;
  border: 1rpx solid rgba(220, 232, 220, 0.95);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbf3 100%);
  box-shadow: 0 12rpx 24rpx rgba(41, 65, 52, 0.07);
  overflow: visible;
}

.upload-pipeline-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -18rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #dce8dc;
  transform: translateY(-50%);
}

.upload-pipeline-node:last-child::after {
  display: none;
}

.upload-pipeline-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 7rpx;
  border-radius: 17rpx;
  background: #f0f8ee;
}

.upload-pipeline-node text:nth-child(2) {
  max-width: 100%;
  color: #17211d;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.upload-pipeline-node text:nth-child(3) {
  max-width: 100%;
  color: #526158;
  font-size: 17rpx;
  font-weight: 780;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
}

.upload-pipeline-node.done {
  border-color: rgba(34, 185, 92, 0.28);
  background: linear-gradient(180deg, #effbf2 0%, #ffffff 100%);
}

.upload-pipeline-node.active {
  border-color: rgba(76, 159, 255, 0.32);
  background: linear-gradient(180deg, #eef7ff 0%, #ffffff 100%);
}

.upload-pipeline-node.next {
  border-color: rgba(248, 198, 34, 0.34);
  background: linear-gradient(180deg, #fff8df 0%, #ffffff 100%);
}

.upload-pipeline-node.done .upload-pipeline-icon {
  background: #dff7e6;
}

.upload-pipeline-node.active .upload-pipeline-icon {
  background: #e5f2ff;
}

.upload-pipeline-node.next .upload-pipeline-icon {
  background: #fff1bd;
}

.upload-dash-primary {
  height: 78rpx;
  margin-top: 22rpx;
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
  border-radius: 999rpx;
  box-shadow: 0 16rpx 28rpx rgba(248, 198, 34, 0.22);
  font-size: 27rpx;
  font-weight: 950;
  line-height: 78rpx;
  text-align: center;
}

.upload-content {
  padding: calc(108rpx + env(safe-area-inset-top)) 34rpx calc(132rpx + env(safe-area-inset-bottom));
}

.upload-hero-shell {
  margin-bottom: 22rpx;
  padding: 18rpx;
  border-radius: 34rpx;
}

.upload-dash-hero {
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 12rpx;
  margin-top: 20rpx;
}

.upload-dash-title {
  font-size: 35rpx;
  line-height: 1.1;
}

.upload-dash-sub {
  display: -webkit-box;
  margin-top: 9rpx;
  overflow: hidden;
  font-size: 21rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.upload-dash-proof {
  gap: 8rpx;
  margin-top: 12rpx;
}

.upload-dash-proof text {
  padding: 7rpx 12rpx;
  font-size: 19rpx;
}

.upload-type-strip {
  margin-top: 10rpx;
}

.upload-type-strip text {
  padding: 6rpx 10rpx;
  font-size: 17rpx;
}

.upload-dash-mascot {
  width: 148rpx;
  height: 128rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 30rpx;
}

.upload-material-grid {
  gap: 12rpx;
  margin-top: 16rpx;
}

.upload-material-card {
  min-height: 124rpx;
  padding: 11rpx 9rpx;
  border-radius: 22rpx;
}

.upload-material-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
}

.upload-material-card text:nth-child(2) {
  font-size: 22rpx;
}

.upload-material-card text:nth-child(3) {
  font-size: 18rpx;
}

.upload-dash-pipeline {
  gap: 9rpx;
  margin-top: 16rpx;
}

.upload-pipeline-node {
  min-height: 108rpx;
  padding: 10rpx 4rpx;
  border-radius: 19rpx;
}

.upload-pipeline-node::after {
  right: -14rpx;
  width: 18rpx;
  height: 4rpx;
}

.upload-pipeline-icon {
  width: 42rpx;
  height: 42rpx;
  padding: 6rpx;
  border-radius: 15rpx;
}

.upload-pipeline-node text:nth-child(2) {
  font-size: 18rpx;
}

.upload-pipeline-node text:nth-child(3) {
  font-size: 16rpx;
}

.upload-dash-primary {
  height: 72rpx;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 72rpx;
}
