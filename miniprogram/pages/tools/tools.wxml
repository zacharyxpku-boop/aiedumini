<view class="arcade-page">
  <view class="page-positioning tools-positioning">
    <view class="positioning-kicker">轻回访与练习</view>
    <view class="positioning-title">回看昨天那一步，再把错题和材料变成可练的小卡</view>
    <view class="positioning-flow">轻练习不是工具箱：先接回访，再进游戏；错的卡会回到复习队列。</view>
  </view>
  <view class="arcade-bg arcade-bg-dots"></view>
  <view class="arcade-glow gold"></view>
  <view class="arcade-glow green"></view>

  <view class="arcade-header">
    <view>
      <view class="arcade-title">轻回访</view>
      <view class="arcade-subtitle">
        <view class="arcade-subdot"></view>
        <text>修过的卡点，轻轻回访一下</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="arcade-scroll">
    <view class="rc14-tools-first-screen">
    <view class="route-note top-route-note">{{toolsViewModel.routePill}}</view>
    <view class="companion-route-strip">{{toolsViewModel.companionStrip}}</view>
    <view class="arcade-main-title">{{toolsViewModel.title}}</view>
    <view class="arcade-main-subtitle">{{toolsViewModel.subtitle}}</view>

    <view class="rc14-main-card">
    <view class="focus-review-entry rc-focus-review" wx:if="{{toolsViewModel.primaryCard.hasReviewCard}}" bindtap="goReview">
      <view class="focus-review-dot"></view>
      <view class="focus-review-copy">
        <view class="focus-review-title">{{toolsViewModel.primaryCard.title}}</view>
        <view class="focus-review-body">{{toolsViewModel.primaryCard.body}}</view>
      </view>
      <view class="focus-review-arrow">{{toolsViewModel.primaryCta.text}}</view>
    </view>
    <view class="focus-review-entry rc-focus-review empty-review-card" wx:else>
      <view class="focus-review-dot"></view>
      <view class="focus-review-copy">
        <view class="focus-review-title">{{toolsViewModel.primaryCard.title}}</view>
        <view class="focus-review-body">{{toolsViewModel.primaryCard.body}}</view>
      </view>
      <view class="focus-review-arrow" bindtap="goFirstStep">{{toolsViewModel.primaryCta.text}}</view>
    </view>
    </view>
    </view>
    <view class="rc14-tools-after-first-screen"></view>

    <view class="global-depth-card" wx:if="{{surfaceDepthPack}}">
      <view class="global-depth-head">
        <view>
          <view class="global-depth-title">{{surfaceDepthPack.title}}</view>
          <view class="global-depth-summary">{{surfaceDepthPack.summary}}</view>
        </view>
        <view class="global-depth-score">{{surfaceDepthPack.readyCount}}/{{surfaceDepthPack.totalCount}}</view>
      </view>
      <view class="global-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
      <view class="global-depth-grid">
        <view class="global-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
          <text class="global-depth-chip-title">{{item.displayLabel}}</text>
          <text class="global-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
        </view>
      </view>
      <view class="global-depth-note">{{surfaceDepthPack.familyLine}}</view>
    </view>

    <view class="public-k12-ops-card" wx:if="{{publicK12ContentOps}}">
      <view class="public-k12-head">
        <view>
          <view class="public-k12-title">{{publicK12ContentOps.title}}</view>
          <view class="public-k12-summary">{{publicK12ContentOps.summary}}</view>
        </view>
        <view class="public-k12-badge">来源先过门槛</view>
      </view>
      <view class="public-k12-metrics">
        <view class="public-k12-metric" wx:for="{{publicK12ContentOps.metrics}}" wx:key="id">
          <text>{{item.value}}</text>
          <text>{{item.label}}</text>
        </view>
      </view>
      <view class="public-k12-lanes">
        <view class="public-k12-lane" wx:for="{{publicK12ContentOps.lanes}}" wx:key="id">
          <view class="public-k12-lane-label">{{item.label}}</view>
          <view class="public-k12-lane-body">{{item.body}}</view>
        </view>
      </view>
      <view class="public-k12-seeds" wx:if="{{publicK12ContentOps.challengeSeeds.length}}">
        <view class="public-k12-seed" wx:for="{{publicK12ContentOps.challengeSeeds}}" wx:key="id">
          <text>{{item.subject}}｜{{item.firstStepPrompt}}</text>
          <text>{{item.answerBoundary}}</text>
        </view>
      </view>
      <view class="public-k12-boundary">{{publicK12ContentOps.sourceLine}}</view>
      <view class="public-k12-action-row">
        <button class="public-k12-primary" data-route="{{publicK12ContentOps.primaryRoute}}" bindtap="runPublicK12ContentOps">贴自己的材料</button>
        <button class="public-k12-secondary" data-route="{{publicK12ContentOps.secondaryRoute}}" bindtap="runPublicK12ContentOps">玩第一步挑战</button>
      </view>
      <view class="public-k12-next">{{publicK12ContentOps.actionLine}}</view>
    </view>

    <view class="public-k12-ops-card moat-workbench-card" wx:if="{{competitiveMoatWorkbench}}">
      <view class="public-k12-head">
        <view>
          <view class="public-k12-title">{{competitiveMoatWorkbench.title}}</view>
          <view class="public-k12-summary">{{competitiveMoatWorkbench.summary}}</view>
        </view>
        <view class="public-k12-badge">{{competitiveMoatWorkbench.progressPercent}}%</view>
      </view>
      <view class="public-k12-metrics">
        <view class="public-k12-metric">
          <text>{{competitiveMoatWorkbench.sourceCounts.subjects}}</text>
          <text>学科</text>
        </view>
        <view class="public-k12-metric">
          <text>{{competitiveMoatWorkbench.sourceCounts.courseUnits}}</text>
          <text>单元</text>
        </view>
        <view class="public-k12-metric">
          <text>{{competitiveMoatWorkbench.sourceCounts.questionCards}}</text>
          <text>题型卡</text>
        </view>
        <view class="public-k12-metric">
          <text>{{competitiveMoatWorkbench.sourceCounts.publicK12Resources}}</text>
          <text>来源</text>
        </view>
      </view>
      <view class="public-k12-lanes">
        <view class="public-k12-lane" wx:for="{{competitiveMoatWorkbench.highLeverageLanes}}" wx:key="id">
          <view class="public-k12-lane-label">{{item.label}}</view>
          <view class="public-k12-lane-body">{{item.target}}</view>
          <view class="public-k12-lane-body">证据：{{item.currentEvidence}}</view>
          <view class="public-k12-lane-body">下一步：{{item.nextAction}}</view>
        </view>
      </view>
      <view class="public-k12-boundary">{{competitiveMoatWorkbench.aiLocalDecision.localBetter}}</view>
      <view class="public-k12-boundary">{{competitiveMoatWorkbench.aiLocalDecision.aiBetter}}</view>
      <view class="public-k12-boundary">{{competitiveMoatWorkbench.aiLocalDecision.doNotUse}}</view>
      <view class="public-k12-seeds">
        <view class="public-k12-seed" wx:for="{{competitiveMoatWorkbench.sourcePolicyRows}}" wx:key="id">
          <text>{{item.label}}：{{item.decision}}</text>
          <text>{{item.blocked}}</text>
        </view>
      </view>
      <view class="public-k12-seeds" wx:if="{{competitiveMoatWorkbench.sourceLicenseGateRows.length}}">
        <view class="public-k12-seed" wx:for="{{competitiveMoatWorkbench.sourceLicenseGateRows}}" wx:key="id">
          <text>{{item.label}}：{{item.status}}</text>
          <text>{{item.productUse}}</text>
          <text>{{item.blockedUse}}</text>
        </view>
      </view>
      <view class="public-k12-lanes" wx:if="{{competitiveMoatWorkbench.openMaicScenePack.length}}">
        <view class="public-k12-lane" wx:for="{{competitiveMoatWorkbench.openMaicScenePack}}" wx:key="id">
          <view class="public-k12-lane-label">{{item.label}}</view>
          <view class="public-k12-lane-body">本地负责：{{item.localCodeOwns}}</view>
          <view class="public-k12-lane-body">AI 更适合：{{item.aiBetterFor}}</view>
        </view>
      </view>
      <view class="public-k12-lanes" wx:if="{{competitiveMoatWorkbench.competitiveExecutionBoard.length}}">
        <view class="public-k12-lane" wx:for="{{competitiveMoatWorkbench.competitiveExecutionBoard}}" wx:key="id">
          <view class="public-k12-lane-label">{{item.label}}</view>
          <view class="public-k12-lane-body">{{item.tonightAction}}</view>
          <view class="public-k12-lane-body">证据：{{item.evidenceRequired}}</view>
          <view class="public-k12-lane-body">禁传：{{item.blockedFields}}</view>
        </view>
      </view>
      <view class="public-k12-lanes" wx:if="{{competitiveMoatWorkbench.reportInputLanes.length}}">
        <view class="public-k12-lane" wx:for="{{competitiveMoatWorkbench.reportInputLanes}}" wx:key="id">
          <view class="public-k12-lane-label">{{item.label}}</view>
          <view class="public-k12-lane-body">输入：{{item.acceptedInput}}</view>
          <view class="public-k12-lane-body">输出：{{item.output}}</view>
          <view class="public-k12-lane-body">放行：{{item.releaseRule}}</view>
        </view>
      </view>
      <view class="public-k12-next" wx:for="{{competitiveMoatWorkbench.nextOneDayBuild}}" wx:key="*this">{{item}}</view>
    </view>

    <view class="route-next-lite tools-next-lite" wx:if="{{toolsViewModel.nextStep}}" bindtap="goProfile">
      <text>{{toolsViewModel.nextStep.text}}</text>
      <text class="route-next-link">{{toolsViewModel.nextStep.cta}}</text>
    </view>

    <view class="route-next-lite tools-next-lite" wx:if="{{latestFocusSession}}" bindtap="goProfile">
      <text>上次专注：{{latestFocusSession.summary}}</text>
      <text class="route-next-link">给家长看</text>
    </view>

    <view class="game-panel tools-secondary-games">
      <view class="panel-head">
        <view class="panel-title">也可以轻松练一下</view>
        <view class="panel-pill">轻量选择</view>
      </view>
      <view class="game-loop-note">小游戏只是激励：玩一小局，错的卡会回到复习队列。</view>
      <view class="legacy-game-title">今天轻练哪一步</view>

      <view class="game-grid">
        <view
          class="game-card {{item.tone}} {{item.available ? 'ready' : 'locked'}}"
          wx:for="{{playgroundGames}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="openPlaygroundGame"
        >
          <view class="game-name">{{item.name}}</view>
          <view class="game-fit">{{item.fit}}</view>
          <view class="game-status">
            <view class="status-dot"></view>
            <text>{{item.statusLabel}}</text>
          </view>
          <view class="game-bubble">
            <view class="game-icon {{item.icon}}"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="material-panel">
      <view class="material-head">
        <view class="material-title">想练自己的内容？</view>
        <view class="material-subtitle">写一句、贴一题、贴一小段都可以，不用整理成资料。</view>
      </view>

      <view class="source-row">
        <view class="source-card {{factoryStudioMode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="setFactoryStudioMode">
          <view class="source-icon paste"></view>
          <text>写一句</text>
        </view>
        <view class="source-card {{factoryStudioMode === 'upload' ? 'active' : ''}}" data-mode="upload" bindtap="chooseFactoryMaterial">
          <view class="source-icon camera"></view>
          <text>贴题/本子</text>
        </view>
        <view class="source-card wrong" bindtap="goReview">
          <view class="source-icon wrong"></view>
          <text>从错题来</text>
        </view>
      </view>

      <view class="material-input" wx:if="{{factoryStudioMode === 'text'}}">
        <textarea
          class="material-textarea"
          value="{{factoryStudioInput}}"
          placeholder="例：我想练分数应用题，老是找不准单位1。"
          maxlength="3000"
          bindinput="onFactoryStudioInput"
        />
      </view>

      <view class="upload-hint" wx:else bindtap="chooseFactoryMaterial">
        <view class="upload-plus">+</view>
        <view>
          <view class="upload-title">选择学习材料</view>
          <view class="upload-body">照片只做本地留档；再补一句你想练什么。</view>
        </view>
      </view>

      <view class="plan-preview" wx:if="{{factoryStudioInput && factoryStudioPlan && factoryStudioPlan.cards.length}}">
        <view class="preview-title">这段材料可以先变成</view>
        <view class="preview-chips">
          <view class="preview-chip">知识卡</view>
          <view class="preview-chip">小测</view>
          <view class="preview-chip">复习卡</view>
        </view>
      </view>

      <view class="generate-button secondary-generate" bindtap="runFactoryStudioRemote">
        <view class="generate-star"></view>
        <text>用这一句生成轻练习</text>
      </view>
      <view class="material-flow-note">生成后先进入错题/材料卡，再去小游戏里轻练一轮。</view>
    </view>

    <view class="arcade-bottom-space"></view>
  </scroll-view>
</view>
