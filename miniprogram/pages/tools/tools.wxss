.arcade-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1a211d;
  background: #f9f8f5;
}

.arcade-bg,
.arcade-glow {
  position: absolute;
  pointer-events: none;
}

.arcade-bg-dots {
  inset: 0;
  opacity: 0.78;
  background-image: radial-gradient(#d9d5ca 2rpx, transparent 2rpx);
  background-size: 36rpx 36rpx;
}

.arcade-bg-dots::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(249, 248, 245, 0.28), #f9f8f5 86%);
}

.arcade-glow {
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  filter: blur(82rpx);
}

.arcade-glow.gold {
  top: -150rpx;
  right: -180rpx;
  background: rgba(247, 208, 104, 0.20);
}

.arcade-glow.green {
  top: 360rpx;
  left: -210rpx;
  background: rgba(26, 83, 54, 0.08);
}

.arcade-header {
  position: relative;
  z-index: 3;
  padding: calc(72rpx + env(safe-area-inset-top)) 220rpx 22rpx 40rpx;
}

.arcade-title {
  color: #1a5336;
  font-size: 44rpx;
  font-weight: 1000;
  line-height: 1.06;
  letter-spacing: 0;
}

.arcade-subtitle {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  color: #6d736c;
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.2;
}

.arcade-subdot {
  width: 10rpx;
  height: 10rpx;
  background: #f7d068;
  border-radius: 50%;
}

.arcade-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - 148rpx - env(safe-area-inset-top));
  box-sizing: border-box;
  padding-bottom: calc(164rpx + env(safe-area-inset-bottom));
}

.game-panel,
.material-panel {
  position: relative;
  margin: 0 28rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 44rpx;
  box-shadow: 0 16rpx 56rpx rgba(26, 83, 54, 0.055);
}

.game-panel {
  overflow: hidden;
  margin-top: 26rpx;
}

.tools-secondary-games {
  opacity: 0.78;
  transform: scale(0.97);
  transform-origin: top center;
}

.game-panel::after {
  content: "";
  position: absolute;
  top: -80rpx;
  right: -70rpx;
  width: 250rpx;
  height: 250rpx;
  background: rgba(247, 208, 104, 0.10);
  border-radius: 50%;
}

.panel-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.panel-title,
.material-title {
  color: #1a211d;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.18;
}

.panel-pill {
  flex: 0 0 auto;
  max-width: 230rpx;
  padding: 10rpx 18rpx;
  overflow: hidden;
  color: rgba(26, 83, 54, 0.82);
  background: rgba(26, 83, 54, 0.06);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.game-card {
  position: relative;
  min-height: 200rpx;
  overflow: hidden;
  padding: 24rpx 22rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(34, 28, 18, 0.035);
}

.game-card.gold {
  background: linear-gradient(135deg, #fff9e8 0%, #fff0c9 100%);
  border: 1rpx solid rgba(247, 208, 104, 0.28);
}

.game-card.green {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border: 1rpx solid rgba(95, 181, 128, 0.24);
}

.game-card.blue {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border: 1rpx solid rgba(92, 143, 222, 0.22);
}

.game-card.orange {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border: 1rpx solid rgba(255, 122, 69, 0.22);
}

.game-name {
  position: relative;
  z-index: 1;
  color: #242923;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.15;
}

.game-fit {
  position: relative;
  z-index: 1;
  display: -webkit-box;
  height: 56rpx;
  margin-top: 11rpx;
  overflow: hidden;
  color: rgba(73, 79, 74, 0.72);
  font-size: 20rpx;
  font-weight: 680;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.game-status {
  position: absolute;
  left: 20rpx;
  bottom: 18rpx;
  z-index: 2;
  display: flex;
  max-width: 150rpx;
  min-height: 40rpx;
  align-items: center;
  gap: 9rpx;
  padding: 0 16rpx;
  color: #687067;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.035);
  font-size: 19rpx;
  font-weight: 900;
}

.game-card.ready .game-status {
  color: #1a5336;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 auto;
  background: #a5aaa3;
  border-radius: 50%;
}

.game-card.ready .status-dot {
  background: #1a5336;
}

.game-bubble {
  position: absolute;
  right: -16rpx;
  bottom: -16rpx;
  display: flex;
  width: 116rpx;
  height: 116rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.44);
  border-radius: 50%;
  box-shadow: inset 0 8rpx 18rpx rgba(255, 255, 255, 0.82);
}

.game-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
}

.game-icon.mole::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 18rpx;
  width: 38rpx;
  height: 28rpx;
  background: #d97706;
  border-radius: 24rpx 24rpx 12rpx 12rpx;
}

.game-icon.mole::after {
  content: "";
  position: absolute;
  left: 23rpx;
  top: 6rpx;
  width: 12rpx;
  height: 24rpx;
  background: #d97706;
  border-radius: 999rpx;
  transform: rotate(35deg);
}

.game-icon.snake::before {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 14rpx;
  width: 48rpx;
  height: 28rpx;
  border: 8rpx solid #15803d;
  border-left-color: transparent;
  border-radius: 999rpx;
}

.game-icon.snake::after {
  content: "";
  position: absolute;
  right: 0;
  top: 17rpx;
  width: 15rpx;
  height: 15rpx;
  background: #15803d;
  border-radius: 50%;
}

.game-icon.map::before {
  content: "";
  position: absolute;
  inset: 7rpx 4rpx;
  border: 6rpx solid #1d4ed8;
  border-radius: 7rpx;
  transform: skewY(-12deg);
}

.game-icon.map::after {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 14rpx;
  width: 12rpx;
  height: 12rpx;
  background: rgba(29, 78, 216, 0.35);
  border-radius: 50%;
}

.game-icon.lab::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 6rpx;
  width: 22rpx;
  height: 44rpx;
  border: 6rpx solid #7e22ce;
  border-top: 0;
  border-radius: 0 0 18rpx 18rpx;
}

.game-icon.lab::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 4rpx;
  width: 34rpx;
  height: 6rpx;
  background: #7e22ce;
  border-radius: 999rpx;
}

.material-panel {
  margin-top: 24rpx;
}

.quick-play-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 18rpx;
  align-items: center;
  margin: 0 28rpx;
  padding: 28rpx;
  background: #1a5336;
  border-radius: 34rpx;
  box-shadow: 0 14rpx 40rpx rgba(26, 83, 54, 0.16);
}

.quick-play-kicker {
  color: rgba(247, 208, 104, 0.95);
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1.2;
}

.quick-play-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.quick-play-body {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.32;
}

.quick-play-button {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  color: #1a5336;
  background: #f7d068;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  white-space: nowrap;
}

.route-strip {
  display: flex;
  gap: 8rpx;
  margin: 16rpx 28rpx 0;
  overflow: hidden;
}

.route-strip text {
  flex: 1 1 0;
  min-width: 0;
  padding: 9rpx 6rpx;
  overflow: hidden;
  color: #657069;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 850;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-strip text.active {
  color: #1a5336;
  background: rgba(247, 208, 104, 0.30);
  border-color: rgba(247, 208, 104, 0.46);
  font-weight: 1000;
}

.route-note {
  margin: 8rpx 34rpx 0;
  overflow: hidden;
  color: #757d76;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.32;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tools-companion-line {
  margin: 8rpx 34rpx 0;
  color: #5a6c60;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.32;
}

.focus-review-entry {
  display: grid;
  grid-template-columns: 16rpx minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
  margin: 14rpx 28rpx 0;
  padding: 20rpx 22rpx;
  color: #1a5336;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(26, 83, 54, 0.12);
  border-radius: 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 83, 54, 0.035);
}

.focus-review-dot {
  width: 12rpx;
  height: 12rpx;
  background: #f7d068;
  border-radius: 50%;
}

.focus-review-copy {
  min-width: 0;
}

.focus-review-kicker {
  overflow: hidden;
  color: rgba(26, 83, 54, 0.66);
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.focus-review-title {
  margin-top: 4rpx;
  overflow: hidden;
  color: #1a5336;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1.18;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.focus-review-body {
  margin-top: 5rpx;
  overflow: hidden;
  color: #747b73;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.28;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.focus-review-arrow {
  max-width: 190rpx;
  overflow: hidden;
  color: rgba(26, 83, 54, 0.72);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-subtitle {
  margin-top: 10rpx;
  color: #6f756e;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.source-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.source-card {
  display: flex;
  min-width: 0;
  min-height: 92rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 8rpx;
  color: #303b34;
  background: #f9f8f5;
  border: 1rpx solid transparent;
  border-radius: 26rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.12;
  overflow: hidden;
}

.source-card.active {
  border-color: rgba(26, 83, 54, 0.18);
  background: #f4faf7;
}

.source-card text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: keep-all;
}

.source-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
  transform: scale(0.82);
  transform-origin: center;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.035);
}

.source-icon.paste::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 13rpx;
  width: 20rpx;
  height: 28rpx;
  border: 4rpx solid #1a5336;
  border-radius: 5rpx;
}

.source-icon.paste::after {
  content: "";
  position: absolute;
  left: 21rpx;
  top: 9rpx;
  width: 12rpx;
  height: 8rpx;
  border: 3rpx solid #1a5336;
  background: #ffffff;
  border-radius: 5rpx;
}

.source-icon.camera::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 17rpx;
  width: 30rpx;
  height: 22rpx;
  border: 4rpx solid #1a5336;
  border-radius: 7rpx;
}

.source-icon.camera::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 23rpx;
  width: 10rpx;
  height: 10rpx;
  border: 4rpx solid #1a5336;
  border-radius: 50%;
}

.source-icon.wrong::before,
.source-icon.wrong::after {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 25rpx;
  width: 24rpx;
  height: 5rpx;
  background: #d97706;
  border-radius: 999rpx;
}

.source-icon.wrong::before {
  transform: rotate(45deg);
}

.source-icon.wrong::after {
  transform: rotate(-45deg);
}

.material-input {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fffdf8;
  border: 1rpx solid #eee7dc;
  border-radius: 24rpx;
}

.material-textarea {
  width: 100%;
  min-height: 92rpx;
  color: #1a211d;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.48;
}

.material-textarea::placeholder {
  color: #a5a095;
}

.upload-hint {
  display: grid;
  grid-template-columns: 70rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 20rpx;
  background: #fffdf8;
  border: 2rpx dashed #cad8d0;
  border-radius: 24rpx;
}

.upload-plus {
  display: flex;
  width: 70rpx;
  height: 70rpx;
  align-items: center;
  justify-content: center;
  color: #fffdf8;
  background: #1a5336;
  border-radius: 22rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.upload-title {
  color: #1a211d;
  font-size: 25rpx;
  font-weight: 950;
}

.upload-body {
  margin-top: 7rpx;
  color: #6d736c;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.38;
}

.plan-preview {
  margin-top: 18rpx;
  padding: 16rpx;
  background: #f6fbf8;
  border: 1rpx solid #dfece5;
  border-radius: 22rpx;
}

.preview-title {
  color: #1a5336;
  font-size: 21rpx;
  font-weight: 900;
}

.preview-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.preview-chip {
  min-height: 38rpx;
  padding: 0 14rpx;
  color: #1a5336;
  background: #ffffff;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 38rpx;
}

.generate-button {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #fffdf8;
  background: #1a5336;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 34rpx rgba(26, 83, 54, 0.22);
  font-size: 30rpx;
  font-weight: 950;
}

.generate-star {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  color: #f7d068;
}

.generate-star::before,
.generate-star::after {
  content: "";
  position: absolute;
  background: currentColor;
  border-radius: 999rpx;
}

.generate-star::before {
  left: 10rpx;
  top: 0;
  width: 4rpx;
  height: 24rpx;
}

.generate-star::after {
  left: 0;
  top: 10rpx;
  width: 24rpx;
  height: 4rpx;
}

.empty-state,
.ready-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 26rpx 28rpx 0;
  padding: 26rpx 24rpx;
  text-align: center;
}

.empty-icon {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  background: #ebe9e0;
  border-radius: 50%;
}

.empty-icon::before {
  content: "";
  position: absolute;
  left: 28rpx;
  top: 43rpx;
  width: 36rpx;
  height: 6rpx;
  background: rgba(26, 83, 54, 0.28);
  border-radius: 999rpx;
}

.empty-title,
.ready-title {
  margin-top: 14rpx;
  color: #5f665f;
  font-size: 25rpx;
  font-weight: 950;
}

.empty-body,
.ready-body {
  margin-top: 8rpx;
  color: #8b8f88;
  font-size: 22rpx;
  font-weight: 700;
}

.ready-action {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 0 24rpx;
  color: #1a5336;
  background: #eaf5ee;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.arcade-bottom-space {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* RC0.6 visual reduction: lightweight recall first, material input later. */
.arcade-header {
  padding-top: calc(54rpx + env(safe-area-inset-top));
  padding-bottom: 14rpx;
}

.arcade-title {
  font-size: 40rpx;
}

.arcade-subtitle {
  font-size: 22rpx;
  line-height: 1.32;
}

.top-route-note {
  margin-top: 0;
  font-size: 20rpx;
}

.companion-route-strip {
  width: fit-content;
  max-width: 100%;
  margin-top: 8rpx;
  padding: 8rpx 14rpx;
  color: #5f6f66;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1.22;
}

.rc-focus-review {
  margin-top: 10rpx;
  padding: 18rpx 20rpx;
  box-shadow: none;
}

.arcade-main-subtitle {
  margin-top: 6rpx;
  color: #5f6f66;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 1.34;
}

.rc-focus-review .focus-review-title {
  font-size: 22rpx;
}

.empty-review-card {
  opacity: 0.86;
}

.tools-next-lite {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 8rpx;
  padding: 10rpx 14rpx;
  color: #5f6f66;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.32;
}

.tools-next-lite .route-next-link {
  flex-shrink: 0;
  color: #1a5336;
  font-weight: 880;
}

.public-k12-ops-card {
  margin: 18rpx 28rpx 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(26, 83, 54, 0.10);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(26, 83, 54, 0.055);
}

.public-k12-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.public-k12-title {
  color: #1a211d;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.18;
}

.public-k12-summary,
.public-k12-boundary,
.public-k12-next {
  margin-top: 8rpx;
  color: #5f6f66;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.42;
}

.public-k12-badge {
  flex: 0 0 auto;
  max-width: 180rpx;
  padding: 8rpx 12rpx;
  color: #1a5336;
  background: rgba(26, 83, 54, 0.07);
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.2;
}

.public-k12-metrics,
.public-k12-lanes {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.public-k12-metric,
.public-k12-lane,
.public-k12-seed {
  padding: 16rpx;
  background: #f8faf8;
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 18rpx;
}

.public-k12-quality {
  margin-top: 14rpx;
  padding: 16rpx;
  background: #f7fbf7;
  border: 1rpx solid rgba(26, 83, 54, 0.12);
  border-radius: 16rpx;
}

.public-k12-quality-title {
  color: #1a5336;
  font-size: 22rpx;
  font-weight: 920;
  line-height: 1.28;
}

.public-k12-quality-line {
  margin-top: 6rpx;
  color: #667269;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.36;
}

.public-k12-metric text:first-child {
  display: block;
  color: #1a5336;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1;
}

.public-k12-metric text:last-child,
.public-k12-lane-body,
.public-k12-seed text {
  display: block;
  margin-top: 6rpx;
  color: #667269;
  font-size: 20rpx;
  font-weight: 720;
  line-height: 1.34;
}

.public-k12-lane-label {
  color: #233029;
  font-size: 22rpx;
  font-weight: 920;
}

.public-k12-seeds {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 16rpx;
}

.public-k12-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.public-k12-primary,
.public-k12-secondary {
  min-height: 68rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 920;
  line-height: 68rpx;
}

.public-k12-primary {
  color: #fff;
  background: #1a5336;
}

.public-k12-secondary {
  color: #1a5336;
  background: rgba(26, 83, 54, 0.07);
}

.tools-more-toggle {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  margin: 14rpx 28rpx 0;
  color: #607069;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(26, 83, 54, 0.08);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.quick-play-panel {
  margin-top: 12rpx;
  padding: 22rpx;
  border-radius: 30rpx;
}

.quick-play-title {
  font-size: 26rpx;
}

.quick-play-body {
  font-size: 20rpx;
}

.quick-play-button {
  min-height: 64rpx;
  padding: 0 24rpx;
}

.game-panel {
  margin-top: 14rpx;
  padding: 22rpx;
  opacity: 0.92;
}

.material-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  opacity: 0.86;
}

.material-input {
  padding: 12rpx;
}

.material-textarea {
  min-height: 88rpx;
  max-height: 112rpx;
  font-size: 23rpx;
}

.secondary-generate {
  min-height: 64rpx;
  color: #1a5336;
  background: rgba(26, 83, 54, 0.06);
  border: 1rpx solid rgba(26, 83, 54, 0.10);
  box-shadow: none;
  font-size: 24rpx;
}

.secondary-generate .generate-star {
  display: none;
}

.arcade-bottom-space {
  height: calc(190rpx + env(safe-area-inset-bottom));
}
