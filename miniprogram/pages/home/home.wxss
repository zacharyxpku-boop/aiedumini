.classroom-card view {
  font-size: 26rpx;
  font-weight: 900;
  color: #1a211d;
}

.classroom-card text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d675f;
}
.friend-primary-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
}

.friend-primary-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(31, 79, 61, 0.12);
  box-shadow: 0 18rpx 48rpx rgba(28, 46, 39, 0.08);
}

.friend-primary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a24;
}

.friend-primary-body {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #59665d;
}

.friend-primary-cta {
  margin-top: 18rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: #0f6b50;
}

.surface-depth-card {
  margin: 24rpx 0;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.surface-depth-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.surface-depth-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.surface-depth-subtitle,
.surface-depth-note {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.45;
}

.surface-depth-score {
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 900;
}

.surface-depth-next {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #eff6ff;
  color: #1e40af;
  font-size: 23rpx;
  font-weight: 800;
}

.surface-depth-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.surface-depth-chip {
  display: grid;
  gap: 4rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.surface-depth-chip.ready {
  background: #ecfdf5;
  border-color: #bbf7d0;
}

.surface-depth-chip-title {
  color: #0f172a;
  font-size: 22rpx;
  font-weight: 900;
}

.surface-depth-chip-line {
  color: #64748b;
  font-size: 20rpx;
  line-height: 1.35;
}
