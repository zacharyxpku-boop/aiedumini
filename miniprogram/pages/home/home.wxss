.home-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1a211d;
  background: #f9f8f5;
}

.home-bg,
.home-glow {
  position: absolute;
  pointer-events: none;
}

.home-bg-dots {
  inset: 0;
  opacity: 0.82;
  background-image: radial-gradient(#e2e0d8 2rpx, transparent 2rpx);
  background-size: 48rpx 48rpx;
}

.home-bg-dots::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(249, 248, 245, 0.18), rgba(249, 248, 245, 0.88) 72%, #f9f8f5),
    linear-gradient(90deg, rgba(249, 248, 245, 0.38), transparent 28%, transparent 72%, rgba(249, 248, 245, 0.38));
}

.home-glow {
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  filter: blur(76rpx);
  opacity: 0.16;
}

.home-glow.gold {
  top: -170rpx;
  right: -150rpx;
  background: #f7d068;
}

.home-glow.green {
  top: 290rpx;
  left: -190rpx;
  background: #1a5336;
  opacity: 0.09;
}

.home-header {
  position: relative;
  z-index: 3;
  padding: calc(58rpx + env(safe-area-inset-top)) 220rpx 18rpx 40rpx;
}

.home-header::after {
  content: "•••  ◎";
  position: absolute;
  right: 38rpx;
  top: calc(58rpx + env(safe-area-inset-top));
  min-width: 178rpx;
  height: 68rpx;
  border: 1rpx solid rgba(214, 219, 214, 0.92);
  border-radius: 999rpx;
  color: #1a211d;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 26rpx rgba(38, 58, 43, 0.06);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 68rpx;
  text-align: center;
  letter-spacing: 5rpx;
}

.home-brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.home-brand-icon {
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 auto;
  border-radius: 20rpx;
}

.home-title {
  color: #1a1a1a;
  font-size: 38rpx;
  font-weight: 1000;
  line-height: 1.06;
  letter-spacing: 0;
}

.home-subtitle {
  margin-top: 7rpx;
  color: #8a8a8a;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1.25;
  white-space: nowrap;
}

.home-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - 132rpx - env(safe-area-inset-top));
  box-sizing: border-box;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.mini-home-shell {
  position: relative;
  z-index: 3;
  margin: 2rpx 36rpx 28rpx;
  padding: 0;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background: transparent;
  box-shadow: none;
  overflow: visible;
}

.mini-home-shell view,
.mini-home-shell text {
  box-sizing: border-box;
}

.mini-topline,
.mini-title-row,
.mini-report-head,
.mini-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.mini-topline {
  display: none;
}

.mini-brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.mini-brand-mark {
  display: block;
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #22b95c;
  box-shadow: 0 14rpx 26rpx rgba(34, 185, 92, 0.20);
}

.mini-brand text {
  display: block;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.mini-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.mini-family-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 999rpx;
  color: #1f2a24;
  background: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 850;
}

.mini-title {
  color: #101a16;
  font-size: 48rpx;
  font-weight: 950;
  line-height: 1.06;
  letter-spacing: 0;
}

.mini-subtitle {
  margin-top: 10rpx;
  color: #64706a;
  font-size: 26rpx;
  line-height: 1.45;
}

.mini-progress-ring {
  width: 98rpx;
  height: 98rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 12rpx solid rgba(34, 185, 92, 0.16);
  border-top-color: #22b95c;
  border-radius: 50%;
  background: #ffffff;
}

.mini-progress-ring text {
  color: #14854a;
  font-size: 26rpx;
  font-weight: 950;
}

.mini-hero-card,
.mini-report-card,
.mini-route-card {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(38, 58, 43, 0.07);
}

.mini-hero-card {
  position: relative;
  display: grid;
  min-height: 310rpx;
  grid-template-columns: minmax(0, 1fr) 318rpx;
  gap: 10rpx;
  align-items: center;
  padding: 52rpx 30rpx 36rpx 40rpx;
  background:
    radial-gradient(circle at 72% 72%, rgba(34, 185, 92, 0.16), transparent 28%),
    linear-gradient(180deg, #fffef8 0%, #f9fbf2 100%);
  overflow: hidden;
}

.mini-hero-mascot {
  position: absolute;
  right: 0;
  bottom: -2rpx;
  width: 360rpx;
  height: 346rpx;
}

.mini-report-card {
  display: none;
}

.mini-streak-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 28rpx;
  padding: 16rpx 24rpx;
  color: #1f2a24;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(38, 58, 43, 0.06);
  font-size: 24rpx;
  font-weight: 850;
}

.mini-streak-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #f8c622;
  box-shadow: 0 0 0 8rpx rgba(248, 198, 34, 0.14);
}

.mini-streak-pill text:nth-child(3) {
  color: #f5b300;
  font-size: 34rpx;
  font-weight: 1000;
}

.mini-hero-bubble {
  min-width: 0;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f9fbf5 100%);
}

.mini-hero-bubble view:first-child {
  color: #111a16;
  font-size: 32rpx;
  font-weight: 950;
  line-height: 1.15;
}

.mini-hero-bubble > text {
  display: block;
  margin-top: 10rpx;
  color: #5f6d65;
  font-size: 24rpx;
  line-height: 1.55;
}

.mini-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.mini-chip-row text {
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  color: #26754c;
  background: #f0fbf0;
  font-size: 20rpx;
  font-weight: 800;
  white-space: nowrap;
}

.mini-report-head text:first-child,
.mini-section-head text:first-child {
  color: #18211d;
  font-size: 28rpx;
  font-weight: 950;
}

.mini-report-head text:last-child,
.mini-section-head text:last-child {
  color: #738077;
  font-size: 21rpx;
  font-weight: 780;
}

.mini-report-body {
  display: grid;
  grid-template-columns: 170rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  margin-top: 20rpx;
}

.mini-radar {
  width: 168rpx;
  height: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(50% 5%, 90% 24%, 90% 74%, 50% 95%, 10% 74%, 10% 24%);
  background: linear-gradient(135deg, rgba(34, 185, 92, 0.18), rgba(76, 159, 255, 0.09));
}

.mini-radar view {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(34, 185, 92, 0.16);
  box-shadow: 0 0 0 38rpx rgba(34, 185, 92, 0.07);
}

.mini-report-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mini-report-tags text {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 820;
  line-height: 1.2;
}

.mini-report-tags .ok {
  color: #168249;
  background: #ebf9ed;
}

.mini-report-tags .warn {
  color: #c95c35;
  background: #fff0e9;
}

.mini-entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.mini-entry-card {
  position: relative;
  min-height: 304rpx;
  padding: 18rpx 12rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 0;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f9fbf5 100%);
  box-shadow: 0 14rpx 34rpx rgba(38, 58, 43, 0.06);
}

.mini-entry-card.green { background: linear-gradient(180deg, #ffffff 0%, #f1fbf1 100%); }
.mini-entry-card.blue { background: linear-gradient(180deg, #ffffff 0%, #eef7ff 100%); }
.mini-entry-card.yellow { background: linear-gradient(180deg, #ffffff 0%, #fff8df 100%); }
.mini-entry-card.orange { background: linear-gradient(180deg, #ffffff 0%, #fff1ea 100%); }
.mini-entry-card.map { background: linear-gradient(180deg, #ffffff 0%, #f3fbef 100%); }

.mini-entry-visual {
  width: 164rpx;
  height: 136rpx;
  margin: 2rpx auto 14rpx;
  flex: 0 0 auto;
  overflow: hidden;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.78);
}

.mini-art-folder::before {
  left: 13rpx;
  top: 30rpx;
  width: 50rpx;
  height: 32rpx;
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  background: linear-gradient(180deg, #77d974, #22b95c);
  box-shadow: inset 0 -6rpx 0 rgba(11, 96, 47, 0.1);
}

.mini-art-folder::after {
  left: 16rpx;
  top: 22rpx;
  width: 28rpx;
  height: 14rpx;
  border-radius: 8rpx 10rpx 0 0;
  background: #9be78b;
}

.mini-art-report::before {
  left: 20rpx;
  top: 12rpx;
  width: 34rpx;
  height: 50rpx;
  border: 4rpx solid #4c9fff;
  border-radius: 11rpx;
  background:
    linear-gradient(#f8c622 0 0) 21rpx 13rpx / 9rpx 10rpx no-repeat,
    linear-gradient(#22b95c 0 0) 21rpx 31rpx / 9rpx 10rpx no-repeat,
    #ffffff;
}

.mini-art-report::after {
  right: 8rpx;
  bottom: 8rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #4c9fff;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
}

.mini-art-bot::before {
  left: 15rpx;
  top: 25rpx;
  width: 44rpx;
  height: 32rpx;
  border-radius: 18rpx 18rpx 13rpx 13rpx;
  background: #1f2a24;
}

.mini-art-bot::after {
  left: 28rpx;
  top: 36rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #8dffb2;
  box-shadow: 15rpx 0 0 #8dffb2, 29rpx -19rpx 0 -3rpx #22b95c;
}

.mini-art-game::before {
  left: 10rpx;
  top: 31rpx;
  width: 54rpx;
  height: 31rpx;
  border-radius: 13rpx 13rpx 20rpx 20rpx;
  background: linear-gradient(180deg, #ffd84f, #f5b300);
}

.mini-art-game::after {
  left: 22rpx;
  top: 40rpx;
  width: 22rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: #26323d;
  box-shadow:
    8rpx -8rpx 0 -1rpx #26323d,
    8rpx 8rpx 0 -1rpx #26323d,
    38rpx -2rpx 0 -1rpx #22b95c,
    49rpx -8rpx 0 -2rpx #ff7a45,
    50rpx 7rpx 0 -2rpx #4c9fff;
}

.mini-art-family::before {
  left: 10rpx;
  bottom: 12rpx;
  width: 54rpx;
  height: 34rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 14rpx 12rpx, #ffd9bd 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 28rpx 8rpx, #ffd9bd 0 9rpx, transparent 10rpx),
    radial-gradient(circle at 41rpx 13rpx, #ffd9bd 0 8rpx, transparent 9rpx),
    linear-gradient(90deg, #ff9c6a 0 33%, #3f94e8 33% 66%, #22b95c 66%);
}

.mini-art-family::after {
  left: 17rpx;
  top: 24rpx;
  width: 42rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 4rpx 6rpx, #5a3926 0 4rpx, transparent 5rpx),
    radial-gradient(circle at 20rpx 4rpx, #5a3926 0 5rpx, transparent 6rpx),
    radial-gradient(circle at 36rpx 7rpx, #5a3926 0 4rpx, transparent 5rpx);
}

.mini-art-map::before {
  left: 13rpx;
  top: 17rpx;
  width: 48rpx;
  height: 44rpx;
  clip-path: polygon(0 9%, 32% 0, 66% 9%, 100% 0, 100% 91%, 68% 100%, 34% 91%, 0 100%);
  background:
    linear-gradient(130deg, transparent 0 38%, rgba(76, 159, 255, 0.62) 39% 45%, transparent 46%),
    linear-gradient(35deg, transparent 0 48%, rgba(34, 185, 92, 0.62) 49% 55%, transparent 56%),
    linear-gradient(90deg, #dff3d9 0 34%, #ffffff 34% 66%, #dcefff 66%);
}

.mini-art-map::after {
  right: 17rpx;
  top: 13rpx;
  width: 15rpx;
  height: 24rpx;
  border-radius: 6rpx 6rpx 6rpx 0;
  background: #ff7a45;
}

.mini-entry-card text {
  display: block;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
}

.mini-entry-card text:first-child {
  color: #17211d;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.mini-entry-card text:last-child {
  margin-top: 9rpx;
  color: #66746d;
  font-size: 23rpx;
  line-height: 1.42;
  white-space: normal;
}

.mini-entry-arrow {
  width: 36rpx;
  height: 36rpx;
  margin-top: 14rpx;
  color: #ffffff;
  background: #16a34a;
  border-radius: 50%;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 31rpx;
  text-align: center;
}

.mini-entry-arrow.blue {
  background: #4c9fff;
}

.mini-entry-arrow.orange {
  background: #ff7a45;
}

.mini-route-line {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
}

.mini-route-node {
  position: relative;
  min-width: 0;
  padding: 12rpx 6rpx 11rpx;
  display: grid;
  justify-items: center;
  gap: 6rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8faf5 100%);
  box-shadow: 0 10rpx 22rpx rgba(38, 58, 43, 0.06);
}

.mini-route-node:not(:last-child)::after {
  content: "";
  position: absolute;
  z-index: 0;
  top: 42rpx;
  left: calc(50% + 32rpx);
  width: calc(100% - 38rpx);
  height: 3rpx;
  border-radius: 999rpx;
  background: rgba(34, 185, 92, 0.22);
}

.mini-route-icon {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  display: block;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(38, 58, 43, 0.08);
}

.mini-route-node text {
  position: relative;
  z-index: 1;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-route-node text:nth-child(2) {
  color: #25312a;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 1.15;
}

.mini-route-node text:nth-child(3) {
  color: #526158;
  font-size: 18rpx;
  font-weight: 780;
  line-height: 1.2;
}

.mini-route-node.done {
  background: linear-gradient(180deg, #ffffff 0%, #ecfaee 100%);
}

.mini-route-node.active {
  border-color: rgba(76, 159, 255, 0.28);
  background: linear-gradient(180deg, #ffffff 0%, #edf6ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(76, 159, 255, 0.12);
}

.mini-route-node.final {
  background: linear-gradient(180deg, #ffffff 0%, #fff4eb 100%);
}

.mini-main-cta {
  margin-top: 20rpx;
  height: 82rpx;
  border-radius: 999rpx;
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
  box-shadow: 0 16rpx 28rpx rgba(248, 198, 34, 0.22);
  font-size: 27rpx;
  font-weight: 950;
  line-height: 82rpx;
  text-align: center;
}

.mini-bottom-grid {
  display: grid;
  grid-template-columns: 1.02fr 0.98fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.mini-progress-card,
.mini-sticker-card {
  min-height: 232rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(38, 58, 43, 0.07);
}

.mini-progress-body {
  display: grid;
  grid-template-columns: 108rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
}

.mini-progress-body > view:last-child text {
  display: block;
  color: #66746d;
  font-size: 22rpx;
  line-height: 1.45;
}

.mini-progress-body > view:last-child text:nth-child(2) {
  margin: 8rpx 0;
  color: #16a34a;
  font-size: 38rpx;
  font-weight: 1000;
}

.mini-sticker-card {
  position: relative;
  overflow: hidden;
}

.mini-sticker-card > text {
  position: relative;
  z-index: 1;
  display: block;
  max-width: 210rpx;
  margin-top: 20rpx;
  color: #66746d;
  font-size: 24rpx;
  line-height: 1.58;
}

.mini-sticker-card image {
  position: absolute;
  right: -8rpx;
  bottom: -10rpx;
  width: 174rpx;
  height: 184rpx;
}

/* Reference-aligned miniapp home overrides: keep the first tab as a compact app screen. */
.home-page {
  background: #fbfaf5;
}

.home-header {
  padding: calc(64rpx + env(safe-area-inset-top)) 220rpx 22rpx 38rpx;
}

.home-header::after {
  content: "•••  ◎";
}

.home-brand-icon {
  width: 72rpx;
  height: 72rpx;
}

.home-title {
  font-size: 42rpx;
}

.mini-home-shell {
  margin: 0 36rpx 28rpx;
  border: 0;
  border-radius: 0;
}

.mini-title {
  font-size: 46rpx;
}

.mini-hero-card,
.mini-route-card {
  margin-top: 22rpx;
}

.mini-hero-card {
  min-height: 300rpx;
  padding: 48rpx 30rpx 34rpx 40rpx;
  background:
    radial-gradient(circle at 94% 19%, rgba(248, 198, 34, 0.22) 0 4rpx, transparent 5rpx),
    radial-gradient(circle at 63% 17%, rgba(248, 198, 34, 0.24) 0 10rpx, transparent 11rpx),
    radial-gradient(circle at 72% 72%, rgba(34, 185, 92, 0.16), transparent 28%),
    linear-gradient(0deg, rgba(195, 225, 168, 0.28) 0 14%, transparent 15%),
    linear-gradient(180deg, #fffef8 0%, #f9fbf2 100%);
}

.mini-hero-mascot {
  bottom: -4rpx;
  width: 358rpx;
  height: 342rpx;
}

.mini-entry-grid {
  gap: 18rpx;
  margin-top: 22rpx;
}

.mini-entry-card {
  min-height: 304rpx;
  padding: 20rpx 12rpx 18rpx;
  border-radius: 28rpx;
}

.mini-entry-visual {
  width: 158rpx;
  height: 130rpx;
  margin: 0 auto 16rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.78);
}

.mini-entry-card text:first-child {
  font-size: 30rpx;
}

.mini-entry-arrow {
  margin-top: 13rpx;
}

.mini-route-line {
  gap: 8rpx;
  margin-top: 18rpx;
}

.mini-route-node {
  padding: 10rpx 4rpx 9rpx;
  border-radius: 20rpx;
}

.mini-route-node:not(:last-child)::after {
