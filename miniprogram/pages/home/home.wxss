  min-width: 82rpx;
  max-width: 82rpx;
  min-height: 82rpx;
  max-height: 82rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  line-height: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.mic-button {
  background: #f5f5f5;
}

.send-button {
  background: #1a5336;
  box-shadow: 0 4rpx 16rpx rgba(26, 83, 54, 0.25);
}

.mic-icon {
  position: relative;
  width: 16rpx;
  height: 24rpx;
  border: 3rpx solid #8b8b8b;
  border-radius: 999rpx;
}

.mic-icon::before {
  content: "";
  position: absolute;
  left: -9rpx;
  bottom: -9rpx;
  width: 28rpx;
  height: 14rpx;
  border-right: 3rpx solid #8b8b8b;
  border-bottom: 3rpx solid #8b8b8b;
  border-left: 3rpx solid #8b8b8b;
  border-radius: 0 0 999rpx 999rpx;
}

.mic-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -17rpx;
  width: 3rpx;
  height: 8rpx;
  background: #8b8b8b;
  border-radius: 999rpx;
  transform: translateX(-50%);
}

.thought-input {
  min-width: 0;
  height: 82rpx;
  flex: 1;
  color: #1a211d;
  font-size: 31rpx;
  font-weight: 720;
  line-height: 82rpx;
}

.thought-input::placeholder {
  color: #a3a3a3;
}

.send-icon {
  position: relative;
  width: 30rpx;
  height: 22rpx;
}

.send-icon::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 9rpx;
  width: 19rpx;
  height: 4rpx;
  background: #ffffff;
  border-radius: 999rpx;
}

.send-icon::after {
  content: "";
  position: absolute;
  right: 3rpx;
  top: 4rpx;
  width: 13rpx;
  height: 13rpx;
  border-top: 4rpx solid #ffffff;
  border-right: 4rpx solid #ffffff;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.coach-button {
  display: flex;
  width: 100%;
  min-height: 70rpx;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin: 12rpx 0 0;
  padding: 0;
  color: #1a5336;
