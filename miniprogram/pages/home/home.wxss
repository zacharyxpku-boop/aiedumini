.home-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1a211d;
  background: #f9f8f5;
}

.home-bg,
.home-glow {
  position: absolute;
  pointer-events: none;
}

.home-bg-dots {
  inset: 0;
  opacity: 0.82;
  background-image: radial-gradient(#e2e0d8 2rpx, transparent 2rpx);
  background-size: 48rpx 48rpx;
}

.home-bg-dots::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(249, 248, 245, 0.18), rgba(249, 248, 245, 0.88) 72%, #f9f8f5),
    linear-gradient(90deg, rgba(249, 248, 245, 0.38), transparent 28%, transparent 72%, rgba(249, 248, 245, 0.38));
}

.home-glow {
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  filter: blur(76rpx);
  opacity: 0.16;
}

.home-glow.gold {
  top: -170rpx;
  right: -150rpx;
  background: #f7d068;
}

.home-glow.green {
  top: 290rpx;
  left: -190rpx;
  background: #1a5336;
  opacity: 0.09;
}

.home-header {
  position: relative;
  z-index: 3;
  padding: calc(66rpx + env(safe-area-inset-top)) 220rpx 14rpx 40rpx;
}

.home-title {
  color: #1a1a1a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.06;
  letter-spacing: 0;
}

.home-subtitle {
  margin-top: 7rpx;
  color: #8a8a8a;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1.25;
  white-space: nowrap;
}

.home-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - 132rpx - env(safe-area-inset-top));
  box-sizing: border-box;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.flow-pill {
  display: inline-flex;
  max-width: calc(100vw - 64rpx);
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  margin: 18rpx 0 0 50%;
  transform: translateX(-50%);
  padding: 16rpx 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #f0ede5;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.flow-step {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
  color: #5c6661;
  font-size: 20rpx;
  font-weight: 760;
  line-height: 1;
  white-space: nowrap;
}

.flow-step.active {
  color: #1a5336;
  font-weight: 950;
}

.flow-step.muted {
  color: #8a8a8a;
}

.flow-dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 auto;
  background: rgba(26, 83, 54, 0.38);
  border-radius: 50%;
}

.flow-step.active .flow-dot {
  background: #1a5336;
}

.flow-step.hint .flow-dot {
  background: rgba(212, 152, 48, 0.52);
}

.flow-step.muted .flow-dot {
  background: rgba(138, 138, 138, 0.28);
}

.flow-arrow {
  width: 9rpx;
  height: 9rpx;
  flex: 0 0 auto;
  border-top: 2rpx solid #c4c4c4;
  border-right: 2rpx solid #c4c4c4;
  transform: rotate(45deg);
}

.hero-center {
  display: flex;
  min-height: 470rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 48rpx 0;
}

.mascot-wrap {
  position: relative;
  display: flex;
  width: 360rpx;
  height: 306rpx;
  align-items: center;
  justify-content: center;
}

.mascot-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  background: rgba(247, 208, 104, 0.24);
  border-radius: 50%;
  filter: blur(36rpx);
}

.mascot {
  position: relative;
  width: 216rpx;
  height: 236rpx;
  padding-top: 40rpx;
  background: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 88rpx;
  box-shadow:
    0 40rpx 80rpx rgba(26, 83, 54, 0.10),
    inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.03),
    inset 0 8rpx 24rpx rgba(255, 255, 255, 1);
}

.mascot-ear {
  position: absolute;
  top: 72rpx;
  z-index: -1;
  width: 28rpx;
  height: 64rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.mascot-ear.left {
  left: -15rpx;
  border-radius: 28rpx 0 0 28rpx;
}

.mascot-ear.right {
  right: -15rpx;
  border-radius: 0 28rpx 28rpx 0;
}

.mascot-antenna {
  position: absolute;
  top: -32rpx;
  left: 50%;
  z-index: -1;
  width: 16rpx;
  height: 44rpx;
  margin-left: -8rpx;
  background: linear-gradient(180deg, #f7d068 0%, #ffffff 100%);
  border-radius: 999rpx;
}

.mascot-antenna view {
  position: absolute;
  top: -8rpx;
  left: 50%;
  width: 24rpx;
  height: 24rpx;
  margin-left: -12rpx;
  background: #f7d068;
  border-radius: 50%;
  box-shadow: 0 0 18rpx rgba(247, 208, 104, 0.82);
}

.mascot-face {
  position: relative;
  width: 164rpx;
  height: 100rpx;
  margin: 0 auto;
  overflow: hidden;
  background: #1e2e25;
  border-radius: 40rpx;
  box-shadow: inset 0 4rpx 16rpx rgba(0, 0, 0, 0.34);
}

.mascot-shine {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 40%;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 0 0 999rpx 999rpx;
}

.mascot-eyes {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 42rpx;
}

.mascot-eyes view {
  width: 18rpx;
  height: 26rpx;
  background: #f7d068;
  border-radius: 999rpx;
  box-shadow: 0 0 14rpx rgba(247, 208, 104, 0.72);
}

.mascot-smile {
  width: 24rpx;
  height: 13rpx;
  margin: 10rpx auto 0;
  border-bottom: 5rpx solid rgba(247, 208, 104, 0.92);
  border-radius: 0 0 999rpx 999rpx;
}

.mascot-blush {
  position: absolute;
  top: 152rpx;
  width: 26rpx;
  height: 10rpx;
  background: rgba(255, 181, 167, 0.58);
  border-radius: 999rpx;
  filter: blur(1rpx);
}

.mascot-blush.left {
  left: 42rpx;
}

.mascot-blush.right {
  right: 42rpx;
}

.spark {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
}

.spark::before,
.spark::after {
  content: "";
  position: absolute;
  background: currentColor;
  border-radius: 999rpx;
}

.spark::before {
  left: 12rpx;
  top: 0;
  width: 4rpx;
  height: 28rpx;
}

.spark::after {
  left: 0;
  top: 12rpx;
  width: 28rpx;
  height: 4rpx;
}

.spark-left {
  top: 36rpx;
  left: 58rpx;
  color: #f7d068;
  transform: rotate(28deg);
}

.spark-right {
  right: 68rpx;
  bottom: 58rpx;
  color: rgba(26, 83, 54, 0.42);
  transform: rotate(45deg) scale(0.76);
}

.hero-copy {
  margin-top: 4rpx;
  text-align: center;
}

.hero-title {
  color: #1a211d;
  font-size: 52rpx;
  font-weight: 1000;
  line-height: 1.1;
  letter-spacing: 0;
}

.middle-guide {
  position: relative;
  z-index: 2;
  margin: 14rpx 38rpx 0;
  padding: 20rpx 22rpx 20rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(240, 237, 229, 0.92);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 34rpx rgba(42, 33, 20, 0.045);
  backdrop-filter: blur(18rpx);
}

.guide-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.guide-kicker {
  min-width: 0;
  color: #8a8377;
  font-size: 20rpx;
  font-weight: 780;
  line-height: 1.25;
  text-align: right;
}

.guide-title {
  min-width: 0;
  color: #1a5336;
  font-size: 23rpx;
  font-weight: 950;
  line-height: 1.2;
  white-space: nowrap;
}

.guide-steps {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.guide-step {
  display: flex;
  min-width: 0;
  min-height: 56rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 6rpx;
  color: #3d4742;
  background: #f7f5ef;
  border-radius: 18rpx;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 1;
}

.guide-step text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guide-num {
  display: flex;
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #fffdf8;
  background: #1a5336;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 950;
}

.hero-line {
  position: relative;
  display: inline-flex;
  margin-top: 18rpx;
  color: #5c6661;
  font-size: 25rpx;
  font-weight: 720;
  line-height: 1.45;
}

.hero-line text {
  position: relative;
  z-index: 1;
}

.hero-marker {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 4rpx;
  height: 14rpx;
  background: rgba(247, 208, 104, 0.34);
  border-radius: 999rpx;
}

.share-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
  margin: 26rpx 34rpx 0;
  padding: 22rpx;
  background: #fff6cf;
  border: 1rpx solid rgba(154, 115, 0, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(154, 115, 0, 0.08);
}

.share-kicker {
  color: #9a7300;
  font-size: 20rpx;
  font-weight: 950;
}

.share-title {
  margin-top: 5rpx;
  color: #11231c;
  font-size: 28rpx;
  font-weight: 1000;
}

.share-body {
  margin-top: 7rpx;
  color: #6a5c35;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.38;
}

.share-button {
  min-height: 64rpx;
  padding: 0 22rpx;
  color: #fffdf8;
  background: #1b4332;
  border-radius: 22rpx;
  font-size: 23rpx;
  font-weight: 950;
}

.example-nudge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin: 18rpx 46rpx 0;
  color: #837b6f;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.25;
}

.example-nudge view {
  max-width: 310rpx;
  color: #1a5336;
  overflow: hidden;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.starter-bubble {
  display: grid;
  grid-template-columns: 54rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  margin: 18rpx 60rpx 0;
  padding: 16rpx 18rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(240, 237, 229, 0.86);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(42, 33, 20, 0.035);
}

.starter-avatar {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  background: #1a5336;
  border-radius: 18rpx;
}

.starter-avatar view {
  width: 26rpx;
  height: 16rpx;
  background: #f7d068;
  border-radius: 999rpx;
}

.starter-copy {
  min-width: 0;
}

.starter-name {
  color: #8a8377;
  font-size: 19rpx;
  font-weight: 850;
  line-height: 1.2;
}

.starter-text {
  margin-top: 5rpx;
  overflow: hidden;
  color: #1a211d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.weak-verdict-card {
  position: relative;
  margin: 22rpx 34rpx 0;
  padding: 22rpx;
  color: #1a211d;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid #ece8dd;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 36rpx rgba(42, 33, 20, 0.04);
}

.weak-verdict-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.weak-verdict-kicker {
  color: #8a8377;
  font-size: 21rpx;
  font-weight: 850;
}

.weak-verdict-title {
  margin-top: 6rpx;
  color: #1a5336;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1.18;
}

.weak-verdict-score {
  flex: 0 0 auto;
  min-height: 50rpx;
  padding: 0 18rpx;
  color: #1a5336;
  background: #f7d068;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 50rpx;
}

.weak-verdict-row {
  margin-top: 12rpx;
  padding: 14rpx 0 0;
  background: transparent;
  border-top: 1rpx solid #f0ede5;
  border-radius: 0;
}

.weak-verdict-row:nth-of-type(n + 4) {
  display: none;
}

.weak-verdict-label {
  color: #8a8377;
  font-size: 20rpx;
  font-weight: 950;
}

.weak-verdict-text {
  margin-top: 6rpx;
  color: #3d4742;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.38;
}

.weak-verdict-actions {
  display: none;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.weak-verdict-primary,
.weak-verdict-secondary {
  display: flex;
  min-height: 68rpx;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 23rpx;
  font-weight: 950;
}

.weak-verdict-primary {
  color: #1a5336;
  background: #f7d068;
}

.weak-verdict-secondary {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.home-spacer {
  height: 300rpx;
}

.composer-shell {
  position: relative;
  z-index: 30;
  display: block;
  margin: 8rpx 16rpx 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 0 2rpx;
}

.quick-action {
  display: flex;
  min-width: 0;
  flex: 0 1 auto;
  min-height: 44rpx;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 0 10rpx;
  color: rgba(26, 83, 54, 0.82);
  background: transparent;
  border: 0;
  border-radius: 999rpx;
  box-shadow: none;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
}

.quick-action.warm {
  color: #8b5b11;
  background: transparent;
}

.quick-action text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  flex: 0 0 auto;
  background: transparent;
  border-radius: 50%;
}

.warm .quick-icon {
  background: transparent;
}

.quick-icon.camera::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 7rpx;
  width: 18rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 4rpx;
}

.quick-icon.camera::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 11rpx;
  width: 4rpx;
  height: 4rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.quick-icon.stuck::before,
.quick-icon.stuck::after {
  content: "";
  position: absolute;
  background: currentColor;
  border-radius: 999rpx;
}

.quick-icon.stuck::before {
  left: 10rpx;
  top: 2rpx;
  width: 5rpx;
  height: 13rpx;
}

.quick-icon.stuck::after {
  left: 10rpx;
  bottom: 2rpx;
  width: 5rpx;
  height: 5rpx;
}

.quick-icon.review::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 3rpx;
  width: 17rpx;
  height: 17rpx;
  border: 3rpx solid currentColor;
  border-left-color: transparent;
  border-radius: 50%;
}

.quick-icon.review::after {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 4rpx;
  width: 7rpx;
  height: 7rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(45deg);
}

.composer-card {
  margin-top: 0;
  padding: 18rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #eeeeee;
  border-radius: 42rpx;
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.065), 0 4rpx 16rpx rgba(0, 0, 0, 0.025);
}

.composer-chat-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 8rpx 14rpx;
}

.composer-chat-copy {
  min-width: 0;
  flex: 1;
}

.composer-avatar {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f7d068;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(247, 208, 104, 0.18);
}

.composer-avatar view {
  width: 7rpx;
  height: 7rpx;
  background: #1a211d;
  border-radius: 999rpx;
}

.composer-chat-title {
  overflow: hidden;
  color: #1a211d;
  font-size: 28rpx;
  font-weight: 1000;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.composer-chat-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #7b756b;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.composer-open-arrow {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #1a5336;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 1000;
  line-height: 1;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 102rpx;
  padding: 4rpx 6rpx 16rpx;
  background: #f7f5ef;
  border: 1rpx solid #ece8dd;
  border-radius: 34rpx;
}

.mic-button,
.send-button {
  position: relative;
  display: flex;
  width: 82rpx;
  height: 82rpx;
  min-width: 82rpx;
  max-width: 82rpx;
  min-height: 82rpx;
  max-height: 82rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  line-height: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.mic-button {
  background: #f5f5f5;
}

.send-button {
  background: #1a5336;
  box-shadow: 0 4rpx 16rpx rgba(26, 83, 54, 0.25);
}

.mic-icon {
  position: relative;
  width: 16rpx;
  height: 24rpx;
  border: 3rpx solid #8b8b8b;
  border-radius: 999rpx;
}

.mic-icon::before {
  content: "";
  position: absolute;
  left: -9rpx;
  bottom: -9rpx;
  width: 28rpx;
  height: 14rpx;
  border-right: 3rpx solid #8b8b8b;
  border-bottom: 3rpx solid #8b8b8b;
  border-left: 3rpx solid #8b8b8b;
  border-radius: 0 0 999rpx 999rpx;
}

.mic-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -17rpx;
  width: 3rpx;
  height: 8rpx;
  background: #8b8b8b;
  border-radius: 999rpx;
  transform: translateX(-50%);
}

.thought-input {
  min-width: 0;
  height: 82rpx;
  flex: 1;
  color: #1a211d;
  font-size: 31rpx;
  font-weight: 720;
  line-height: 82rpx;
}

.thought-input::placeholder {
  color: #a3a3a3;
}

.send-icon {
  position: relative;
  width: 30rpx;
  height: 22rpx;
}

.send-icon::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 9rpx;
  width: 19rpx;
  height: 4rpx;
  background: #ffffff;
  border-radius: 999rpx;
