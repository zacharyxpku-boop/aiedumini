<view class="home-page">
  <view class="home-bg home-bg-dots"></view>
  <view class="home-glow gold"></view>
  <view class="home-glow green"></view>

  <view class="first-run-overlay" wx:if="{{showFirstRunOverlay}}" catchtap="closeFirstRunOverlay">
    <view class="first-run-card">
      <view>咕点不直接给结果</view>
      <text>陪你先看清今晚第一步。</text>
      <text>点一下继续，或等 3 秒自动收起。</text>
    </view>
  </view>

  <view class="home-header">
    <view class="home-brand">
      <image class="home-brand-icon" mode="aspectFit" src="/assets/reference/brand-house.png" />
      <view>
        <view class="home-title">原点智学</view>
        <view class="home-subtitle">今晚先迈出第一步</view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="home-scroll">
    <view class="mini-home-shell ux-kit-screen ux-kit-home">
      <view class="mini-topline">
        <view class="mini-brand">
          <image class="mini-brand-mark" mode="aspectFit" src="/assets/reference/brand-house.png" />
          <view>
            <text>原点智学</text>
            <text>小明（四年级）</text>
          </view>
        </view>
        <view class="mini-family-pill" bindtap="goProfile">小明家</view>
      </view>

      <view class="mini-hero-card">
        <view class="mini-hero-copy">
          <view class="mini-streak-pill"><text class="mini-streak-dot"></text><text>{{homeViewModel.routePill}}</text></view>
          <view class="mini-title">{{homeViewModel.title}}</view>
          <view class="mini-subtitle">{{homeViewModel.subtitle}}</view>
          <view class="mini-subtitle companion-route-strip">{{homeViewModel.companionStrip}}</view>
          <view class="mini-subtitle">{{homeViewModel.teacherPickerLabel}} · {{homeViewModel.teacherPickerHint}}</view>
          <view class="mini-streak-pill"><text class="mini-streak-dot"></text><text>连续学习</text><text>7</text><text>天</text></view>
        </view>
        <image class="mini-hero-mascot" mode="aspectFit" src="/assets/reference/hero-mascot.png" />
      </view>

      <view class="mini-report-card" bindtap="goReportPreview">
        <view class="mini-report-head">
          <text>个性化报告预览</text>
          <text>查看 →</text>
        </view>
        <view class="mini-report-body">
          <view class="mini-signal-chart"><view></view></view>
          <view class="mini-report-tags">
            <text class="ok">逻辑思维强</text>
            <text class="ok">阅读理解好</text>
            <text class="warn">计算准确率待提升</text>
            <text class="warn">审题习惯待稳定</text>
          </view>
        </view>
      </view>

      <view class="mini-report-card" wx:if="{{incomingShareRelay}}">
        <view class="mini-report-head">
          <text>同伴接力</text>
          <text bindtap="continueShareRelay">继续</text>
        </view>
        <view wx:for="{{incomingShareRelay.relayPackCards}}" wx:key="id">{{item.title}} {{item.line}}</view>
        <view>{{incomingShareRelay.receiverOwnMaterialChallengeLine}}</view>
        <view>{{incomingShareRelay.firstStepLine}}</view>
      </view>

      <view class="mini-entry-grid ux-kit-jump-grid">
        <view class="mini-entry-card ux-kit-jump-card green" data-scene="upload" bindtap="openEntryDetail">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-upload.png" />
          <text>上传资料</text>
          <text>文档、试卷、错题</text>
          <view class="mini-entry-arrow">›</view>
        </view>
        <view class="mini-entry-card blue" bindtap="goReportPreview">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-report.png" />
          <text>个性化报告</text>
          <text>待提升点与建议</text>
          <view class="mini-entry-arrow blue">›</view>
        </view>
        <view class="mini-entry-card ux-kit-jump-card green" data-scene="tutor" bindtap="openEntryDetail">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-tutor.png" />
          <text>原小点</text>
          <text>智能答疑与讲解</text>
          <view class="mini-entry-arrow">›</view>
        </view>
        <view class="mini-entry-card ux-kit-jump-card yellow" data-scene="review" bindtap="openEntryDetail">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-review.png" />
          <text>复习游戏</text>
          <text>趣味挑战练习</text>
          <view class="mini-entry-arrow orange">›</view>
        </view>
        <view class="mini-entry-card orange" bindtap="goProfile">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-parent.png" />
          <text>家长中心</text>
          <text>一起见证成长</text>
          <view class="mini-entry-arrow orange">›</view>
        </view>
        <view class="mini-entry-card map" bindtap="goLearningMap">
          <image class="mini-entry-visual" mode="aspectFill" src="/assets/reference/entry-map.png" />
          <text>学习地图</text>
          <text>任务进度与目标</text>
          <view class="mini-entry-arrow">›</view>
        </view>
      </view>
      <view class="mini-route-card">
        <view class="mini-section-head"><text>{{homeViewModel.inputCard.title}}</text><text>预计 15-20 分钟</text></view>
        <view class="mini-subtitle" wx:if="{{homeViewModel.miniLessonResume}}">{{homeViewModel.miniLessonResume.title}}</view>
        <view class="mini-subtitle" wx:if="{{homeViewModel.reportServiceResume}}">{{homeViewModel.reportServiceResume.title}}</view>
        <textarea class="mini-route-input" value="{{thoughtInput}}" placeholder="{{homeViewModel.inputCard.placeholder}}" maxlength="500" auto-height bindinput="onThoughtInput" />
        <view class="mini-route-line">
          <view class="mini-route-node done">
            <image class="mini-route-icon" mode="aspectFill" src="/assets/reference/entry-upload.png" />
            <text>上传资料</text>
            <text>材料进来</text>
          </view>
          <view class="mini-route-node done">
            <image class="mini-route-icon" mode="aspectFill" src="/assets/reference/entry-report.png" />
            <text>生成报告</text>
            <text>依据清楚</text>
          </view>
          <view class="mini-route-node active">
            <image class="mini-route-icon" mode="aspectFill" src="/assets/reference/entry-tutor.png" />
            <text>说第一步</text>
            <text>原小点点拨</text>
          </view>
          <view class="mini-route-node">
            <image class="mini-route-icon" mode="aspectFill" src="/assets/reference/entry-review.png" />
            <text>回访</text>
            <text>验证迁移</text>
          </view>
          <view class="mini-route-node final">
            <image class="mini-route-icon" mode="aspectFill" src="/assets/reference/entry-parent.png" />
            <text>家长看</text>
            <text>只看下一步</text>
          </view>
        </view>
        <view class="mini-subtitle" wx:if="{{homeViewModel.emptyState}}">{{homeViewModel.emptyState}}</view>
        <view class="mini-subtitle" wx:if="{{homeViewModel.teacherPickerHint}}">{{homeViewModel.teacherPickerHint}}</view>
        <view class="mini-subtitle route-next-lite" wx:if="{{homeViewModel.nextStep}}" catchtap="runHomeNextStep">{{homeViewModel.nextStep.text}} · {{homeViewModel.nextStep.cta}}</view>
        <view class="mini-main-cta" catchtap="planTonight">{{homeViewModel.primaryCta}}</view>
        <view class="mini-subtitle" bindtap="submitAiDraft">{{homeViewModel.secondaryAction}}</view>
      </view>

      <view class="mini-bottom-grid">
        <view class="mini-progress-card">
          <view class="mini-section-head"><text>今日进度</text><text bindtap="goReview">去学习 ›</text></view>
          <view class="mini-progress-body">
            <view class="mini-progress-ring"><text>60%</text></view>
            <view>
              <text>今日目标</text>
              <text>3 / 5 步</text>
              <text>连续学习 7 天</text>
            </view>
          </view>
        </view>
        <view class="mini-sticker-card" bindtap="goProfile">
          <view class="mini-section-head"><text>咕点小贴士</text></view>
          <text>完成今天的学习目标，咕点会给你一枚成长星星哦！</text>
          <image mode="aspectFit" src="/assets/reference/gudian-sticker.png" />
        </view>
      </view>
    </view>
  </scroll-view>
</view>
