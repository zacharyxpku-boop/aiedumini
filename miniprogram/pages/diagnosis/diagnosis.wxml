<view class="page diagnosis-page safe-bottom">
  <view class="yd-page yd-shell">
    <view class="app-subpage-topbar">
      <view class="app-subpage-brand">
        <view class="app-subpage-logo"><view class="app-subpage-logo-core"></view></view>
        <view class="app-subpage-brand-copy">
          <view class="app-subpage-brand-name">原点智学</view>
          <view class="app-subpage-brand-sub">3 个问题先看今晚第一步</view>
        </view>
      </view>
      <view class="app-subpage-pill">先定位</view>
      <button class="subpage-home" bindtap="goHome">首页</button>
    </view>

    <view class="diagnosis-hero">
      <view class="diagnosis-hero-copy">
        <view class="diagnosis-hero-badge">3 个问题先定位</view>
        <view class="diagnosis-title">先看看卡在哪里</view>
        <view class="diagnosis-subtitle">先看 3 个小问题，再补成绩和作业，我会先猜今晚最该修的点。</view>
      </view>
      <view class="diagnosis-hero-art">
        <view class="diagnosis-plant-stem"></view>
        <view class="diagnosis-plant-leaf one"></view>
        <view class="diagnosis-plant-leaf two"></view>
        <view class="diagnosis-plant-pot"></view>
      </view>
    </view>

    <view class="diagnosis-card" wx:if="{{quickSnap}}">
      <view class="diagnosis-card-head">
        <view>
          <view class="diagnosis-card-title">现在最像卡在这里</view>
          <view class="diagnosis-card-desc">{{quickSnap.axisName}}</view>
        </view>
        <view class="diagnosis-score">{{quickSnap.score}}</view>
      </view>
      <view class="diagnosis-card-body">{{quickSnap.nextMove}}</view>
      <view class="diagnosis-quick-verdict">先修这个卡点</view>
    </view>


    <view class="global-depth-card" wx:if="{{surfaceDepthPack}}">
      <view class="global-depth-head">
        <view>
          <view class="global-depth-title">{{surfaceDepthPack.title}}</view>
          <view class="global-depth-summary">{{surfaceDepthPack.summary}}</view>
        </view>
        <view class="global-depth-score">{{surfaceDepthPack.readyCount}}/{{surfaceDepthPack.totalCount}}</view>
      </view>
      <view class="global-depth-next" data-route="{{surfaceDepthPack.primaryRoute}}" bindtap="runSurfaceDepthAction">{{surfaceDepthPack.nextAction}}</view>
      <view class="global-depth-grid">
        <view class="global-depth-chip {{item.ready ? 'ready' : ''}}" wx:for="{{surfaceDepthPack.cards}}" wx:key="id" data-route="{{item.route}}" data-dimension-id="{{item.id}}" data-label="{{item.displayLabel}}" bindtap="runSurfaceDepthAction">
          <text class="global-depth-chip-title">{{item.displayLabel}}</text>
          <text class="global-depth-chip-line">{{item.ready ? item.evidenceLine : item.gapLine}}</text>
        </view>
      </view>
      <view class="global-depth-note">{{surfaceDepthPack.familyLine}}</view>
    </view>

    <view class="diagnosis-panel">
      <view class="diagnosis-section-title">三个小问题</view>

      <view class="field">
        <view class="label">1. 这类题先要用到什么旧知识？</view>
        <textarea class="textarea diagnosis-textarea" value="{{form.snapPrerequisite}}" data-field="snapPrerequisite" bindinput="onInput" placeholder="比如：先要知道等量关系、单位统一，或先回忆哪个公式。" />
      </view>

      <view class="field">
        <view class="label">2. 如果现在开始做，第一步会先做什么？</view>
        <textarea class="textarea diagnosis-textarea" value="{{form.snapMethod}}" data-field="snapMethod" bindinput="onInput" placeholder="比如：先圈已知和未知，再写关系；不要直接算到底。" />
      </view>

      <view class="field">
        <view class="label">3. 如果我换一个条件，你还会做吗？</view>
        <textarea class="textarea diagnosis-textarea" value="{{form.snapTransfer}}" data-field="snapTransfer" bindinput="onInput" placeholder="比如：一变式就不会，或者还能说出应该先检查什么。" />
      </view>
    </view>

    <view class="diagnosis-detail-toggle">
      <view>
        <view class="diagnosis-detail-title">补充今晚情况</view>
        <view class="diagnosis-detail-subtitle">有成绩、作业或错题时再填</view>
      </view>
      <button class="diagnosis-detail-button" bindtap="toggleDiagnosisDetails">{{showDiagnosisDetails ? '收起' : '展开'}}</button>
    </view>

    <view class="diagnosis-panel quiet" wx:if="{{showDiagnosisDetails}}">
      <view class="diagnosis-section-title">补充今晚情况</view>

      <view class="diagnosis-grid">
        <view class="field">
          <view class="label">年级</view>
          <picker range="{{gradeOptions}}" bindchange="onGradeChange">
            <view class="picker-box">{{form.grade}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="label">学科</view>
          <picker range="{{subjectOptions}}" bindchange="onSubjectChange">
            <view class="picker-box">{{form.subject}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="label">最近一次成绩</view>
        <view class="score-row">
          <input class="input" type="number" value="{{form.score}}" data-field="score" bindinput="onInput" />
          <view class="score-sep">/</view>
          <input class="input" type="number" value="{{form.totalScore}}" data-field="totalScore" bindinput="onInput" />
        </view>
      </view>

      <view class="field">
        <view class="label">今晚可用时间</view>
        <input class="input" type="number" value="{{form.minutes}}" data-field="minutes" bindinput="onInput" />
      </view>

      <view class="field">
        <view class="label">错题或试卷情况</view>
        <textarea class="textarea diagnosis-textarea" value="{{form.examText}}" data-field="examText" bindinput="onInput" placeholder="比如：应用题读题慢，方程移项经常变号，压轴题一看到就乱。" />
      </view>

      <view class="field">
        <view class="label">今晚作业清单</view>
        <textarea class="textarea diagnosis-textarea" value="{{form.homeworkText}}" data-field="homeworkText" bindinput="onInput" placeholder="每行一项：数学方程基础题 8 道；应用题 4 道；整理错题。" />
      </view>
    </view>

    <button class="diagnosis-primary" bindtap="submit">生成今晚第一步安排</button>
  </view>
</view>
