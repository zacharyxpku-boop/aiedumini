.score-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.score-row .input {
  flex: 1;
}

.score-sep {
  color: #8A8377;
  font-size: 36rpx;
  font-weight: 800;
}

.diagnosis-page {
  min-height: 100vh;
  padding: 20rpx 28rpx 140rpx;
  background: transparent;
}

.diagnosis-page .yd-brand-sub {
  max-width: 260rpx;
}

.subpage-home {
  display: flex;
  min-width: 92rpx;
  min-height: 48rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #10372d;
  background: #fffdf8;
  border: 1rpx solid #eadbc3;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(54, 42, 24, 0.045);
  font-size: 22rpx;
  font-weight: 950;
  line-height: 48rpx;
}

.diagnosis-hero {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 18rpx;
  align-items: center;
  margin-top: 28rpx;
  padding: 30rpx 28rpx;
  overflow: hidden;
  color: #10231c;
  background: linear-gradient(180deg, #fffdf8 0%, #f7fbf5 100%);
  border: 1rpx solid #eadfce;
  border-radius: 34rpx;
  box-shadow: 0 22rpx 42rpx rgba(65, 48, 28, 0.08);
}

.diagnosis-hero-copy {
  min-width: 0;
}

.diagnosis-hero-badge {
  display: inline-flex;
  min-height: 44rpx;
  align-items: center;
  padding: 0 18rpx;
  color: #0f4f3d;
  background: #eaf5ee;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.diagnosis-title {
  margin-top: 16rpx;
  color: #101915;
  font-size: 52rpx;
  font-weight: 1000;
  line-height: 1.06;
}

.diagnosis-subtitle {
  margin-top: 12rpx;
  color: #665e53;
  font-size: 24rpx;
  font-weight: 780;
  line-height: 1.5;
}

.diagnosis-hero-art {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 28rpx;
}

.diagnosis-plant-stem {
  position: absolute;
  left: 72rpx;
  top: 24rpx;
  width: 8rpx;
  height: 90rpx;
  background: #8EB962;
  border-radius: 999rpx;
}

.diagnosis-plant-leaf {
  position: absolute;
  width: 48rpx;
  height: 30rpx;
  background: #9CCB75;
  border-radius: 50% 50% 50% 0;
}

.diagnosis-plant-leaf.one {
  left: 24rpx;
  top: 48rpx;
  transform: rotate(-30deg);
}

.diagnosis-plant-leaf.two {
  right: 18rpx;
  top: 30rpx;
  transform: scaleX(-1) rotate(-22deg);
}

.diagnosis-plant-pot {
  position: absolute;
  left: 46rpx;
  bottom: 12rpx;
  width: 64rpx;
  height: 34rpx;
  background: #E2C297;
  border-radius: 8rpx 8rpx 22rpx 22rpx;
}

.diagnosis-card,
.diagnosis-panel {
  margin-top: 16rpx;
  padding: 22rpx;
  background: #FFFDF8;
  border: 1rpx solid #E8DED0;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(54, 42, 24, 0.055);
}

.diagnosis-panel.quiet {
  background: #FBF6EC;
}

.diagnosis-detail-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  background: #FFFDF8;
  border: 1rpx solid #E8DED0;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(54, 42, 24, 0.04);
}

.diagnosis-detail-title {
  color: #101915;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1.2;
}

.diagnosis-detail-subtitle {
  margin-top: 6rpx;
  color: #665E53;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 1.35;
}

.diagnosis-detail-button {
  display: flex;
  min-width: 104rpx;
  min-height: 54rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  color: #10372D;
  background: #FFE08A;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 54rpx;
}

.diagnosis-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.diagnosis-card-title,
.diagnosis-section-title {
  color: #101915;
  font-size: 28rpx;
  font-weight: 950;
}

.diagnosis-card-desc,
.diagnosis-card-body {
  margin-top: 8rpx;
  color: #665E53;
  font-size: 23rpx;
  font-weight: 760;
  line-height: 1.48;
}

.diagnosis-quick-verdict {
  margin-top: 12rpx;
  color: #0F4F3D;
  font-size: 20rpx;
  font-weight: 900;
  opacity: 0.62;
}

.diagnosis-score {
  flex: 0 0 auto;
  min-width: 74rpx;
  height: 74rpx;
  padding: 0 12rpx;
  color: #10372D;
  background: #FFE08A;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 1000;
  line-height: 74rpx;
  text-align: center;
}

.diagnosis-panel .field {
  margin-top: 18rpx;
}

.diagnosis-textarea {
  min-height: 140rpx;
  background: #FFFDF8;
}

.diagnosis-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.diagnosis-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  color: #FFFDF8;
  background: #0C4A3B;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 950;
  box-shadow: 0 16rpx 34rpx rgba(15, 79, 61, 0.18);
}
