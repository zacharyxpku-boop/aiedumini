page {
  background: #F8F9F7;
}

.radar-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #1A202C;
  background: #F8F9F7;
}

.radar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 42vh;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(226, 235, 230, 0.92) 0%, rgba(248, 249, 247, 0) 100%);
}

.radar-bg::after {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  filter: blur(34rpx);
}

.radar-header {
  position: relative;
  z-index: 5;
  display: flex;
  min-height: calc(104rpx + env(safe-area-inset-top));
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: calc(18rpx + env(safe-area-inset-top)) 38rpx 14rpx;
}

.radar-header-left {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  align-items: center;
  gap: 18rpx;
}

.radar-back {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #1A202C;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(30, 74, 56, 0.06);
}

.radar-back-icon {
  margin-top: -4rpx;
  font-size: 58rpx;
  line-height: 1;
}

.radar-heading {
  min-width: 0;
}

.radar-kicker {
  color: #8A948E;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.radar-heading-title {
  margin-top: 4rpx;
  overflow: hidden;
  color: #1E4A38;
  font-size: 32rpx;
  font-weight: 1000;
  line-height: 1.1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.radar-mode {
  display: flex;
  min-height: 62rpx;
  flex: 0 0 auto;
  align-items: center;
  gap: 10rpx;
  padding: 0 18rpx;
  color: #1E4A38;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 22rpx rgba(30, 74, 56, 0.055);
  font-size: 22rpx;
  font-weight: 950;
}

.radar-header-actions {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 10rpx;
}

.radar-home {
  display: flex;
  min-width: 86rpx;
  min-height: 62rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #1E4A38;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 22rpx rgba(30, 74, 56, 0.055);
  font-size: 22rpx;
  font-weight: 950;
  line-height: 62rpx;
}

.mode-dot {
  width: 12rpx;
  height: 12rpx;
  background: #1E4A38;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(30, 74, 56, 0.10);
}

.radar-scroll {
  position: relative;
  z-index: 1;
  height: calc(100vh - 104rpx - env(safe-area-inset-top));
}

.radar-content {
  padding: 8rpx 40rpx 156rpx;
}

.report-dashboard {
  position: relative;
  margin-bottom: 30rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.94);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 8% 4%, rgba(34, 185, 92, 0.13), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(76, 159, 255, 0.12), transparent 22%),
    linear-gradient(180deg, #fffef9 0%, #f7fbf3 100%);
  box-shadow: 0 22rpx 60rpx rgba(38, 58, 43, 0.08);
  overflow: hidden;
}

.report-dash-top,
.report-dash-brand,
.report-dash-hero,
.report-chip-row,
.report-evidence-grid,
.report-section-head,
.report-action-row {
  box-sizing: border-box;
}

.report-dash-top,
.report-dash-brand,
.report-section-head,
.report-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.report-dash-brand {
  min-width: 0;
  justify-content: flex-start;
}

.report-dash-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
  box-sizing: border-box;
  padding: 6rpx;
  border-radius: 18rpx;
  background: #eef7ff;
  box-shadow: 0 14rpx 26rpx rgba(76, 159, 255, 0.12);
}

.report-dash-brand text {
  display: block;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-dash-brand text:first-child {
  color: #18211d;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.report-dash-brand text:last-child {
  margin-top: 3rpx;
  color: #6a766f;
  font-size: 21rpx;
  font-weight: 760;
}

.report-dash-pill {
  flex: 0 0 auto;
  padding: 13rpx 18rpx;
  color: #14854a;
  background: #ebf9ed;
  border: 1rpx solid rgba(34, 185, 92, 0.16);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.report-dash-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 178rpx;
  gap: 20rpx;
  align-items: center;
  margin-top: 30rpx;
}

.report-dash-title {
  color: #101a16;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1.08;
}

.report-dash-sub {
  margin-top: 12rpx;
  color: #64706a;
  font-size: 24rpx;
  line-height: 1.55;
}

.report-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.report-chip-row text {
  padding: 8rpx 14rpx;
  color: #26754c;
  background: #f0fbf0;
  border: 1rpx solid rgba(34, 185, 92, 0.14);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 820;
  white-space: nowrap;
}

.report-radar-art {
  width: 190rpx;
  height: 174rpx;
  border-radius: 34rpx;
  background: #eef7ff;
}

.report-evidence-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 22rpx;
}

.report-evidence-grid view {
  min-width: 0;
  min-height: 116rpx;
  padding: 14rpx 8rpx;
  display: grid;
  align-content: center;
  justify-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
}

.report-evidence-grid text:first-child {
  color: #17211d;
  font-size: 21rpx;
  font-weight: 900;
  text-align: center;
}

.report-evidence-grid text:last-child {
  color: #66746d;
  font-size: 19rpx;
  font-weight: 760;
}

.report-method-card {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(232, 238, 230, 0.95);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
}

.report-section-head text:first-child {
  color: #18211d;
  font-size: 27rpx;
  font-weight: 950;
}

.report-section-head text:last-child {
  color: #738077;
  font-size: 20rpx;
  font-weight: 780;
}

.report-method-list {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
}

.report-method-list view {
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f8faf5;
}

.report-method-list text {
  display: block;
}

.report-method-list text:first-child {
  color: #14854a;
  font-size: 24rpx;
  font-weight: 950;
}

.report-method-list text:last-child {
  margin-top: 6rpx;
  color: #66746d;
  font-size: 21rpx;
  line-height: 1.45;
}

.report-action-row {
  margin-top: 20rpx;
}

.report-primary,
.report-secondary {
  flex: 1 1 0;
  height: 76rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 76rpx;
  text-align: center;
}

.report-primary {
  color: #1d261f;
  background: linear-gradient(180deg, #ffd84f 0%, #f5b300 100%);
}

.report-secondary {
  color: #14854a;
  background: #ebf9ed;
}

.radar-hero {
  padding-bottom: 28rpx;
}

.radar-signal {
  display: inline-flex;
  min-height: 48rpx;
  align-items: center;
  gap: 12rpx;
  padding: 0 18rpx;
  color: #1E4A38;
  background: rgba(226, 235, 230, 0.64);
  border: 1rpx solid rgba(30, 74, 56, 0.10);
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 950;
}

.signal-pulse {
  width: 14rpx;
  height: 14rpx;
  background: #1E4A38;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx rgba(30, 74, 56, 0.13);
}

.radar-hero-title {
  margin-top: 24rpx;
  color: #1A202C;
  font-size: 54rpx;
  font-weight: 1000;
  line-height: 1.12;
  letter-spacing: 0;
}

.radar-hero-copy {
  max-width: 650rpx;
  margin-top: 16rpx;
  color: #5D6670;
  font-size: 27rpx;
  font-weight: 720;
  line-height: 1.58;
}

.radar-metric-scroll {
  width: 100%;
  margin-top: 30rpx;
}

.radar-metric-row {
  display: inline-flex;
  gap: 18rpx;
  min-width: 100%;
  padding: 0 0 10rpx;
}

.radar-metric-card {
  display: flex;
  width: 218rpx;
  min-height: 184rpx;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #ECEFEB;
  border-radius: 34rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.035);
}

.radar-metric-card.focus {
  color: #FFFFFF;
  background: #1E4A38;
  border-color: rgba(30, 74, 56, 0.32);
  box-shadow: 0 20rpx 42rpx rgba(30, 74, 56, 0.13);
}

.radar-metric-card.save {
  background: rgba(226, 235, 230, 0.46);
  border-color: rgba(30, 74, 56, 0.10);
}

.metric-icon {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  color: #D95B50;
  background: #FFF0EF;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 1000;
}

.focus .metric-icon {
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.18);
}

.save .metric-icon {
  color: #1E4A38;
  background: rgba(30, 74, 56, 0.10);
}

.metric-label {
  margin-top: 18rpx;
  color: #9AA3AA;
  font-size: 21rpx;
  font-weight: 780;
  line-height: 1.25;
}

.focus .metric-label {
  color: rgba(255, 255, 255, 0.72);
}

.metric-value {
  margin-top: 6rpx;
  overflow: hidden;
  color: #1A202C;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.focus .metric-value,
.focus .metric-value text {
  color: #FFFFFF;
}

.metric-value text {
  margin-left: 2rpx;
  color: inherit;
  font-size: 22rpx;
  font-weight: 800;
}

.radar-primary {
  display: flex;
  width: 100%;
  min-height: 104rpx;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #FFFFFF;
  background: #1E4A38;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 42rpx rgba(30, 74, 56, 0.16);
  font-size: 31rpx;
  font-weight: 1000;
}

.primary-arrow {
  font-size: 32rpx;
}

.radar-glass-panel {
  display: flex;
  align-items: center;
  gap: 26rpx;
  margin: 6rpx 0 42rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  box-shadow: 0 18rpx 36rpx rgba(30, 74, 56, 0.055);
  backdrop-filter: blur(20rpx);
}

.radar-mini-chart {
  width: 166rpx;
  height: 166rpx;
  flex: 0 0 auto;
  padding: 8rpx;
  background: #FFFFFF;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.045);
}

.radar-canvas {
  display: block;
  width: 150rpx;
  height: 150rpx;
}

.radar-glass-copy {
  min-width: 0;
}

.glass-title {
  color: #1A202C;
  font-size: 28rpx;
  font-weight: 1000;
  line-height: 1.2;
}

.glass-body {
  margin-top: 8rpx;
  color: #68727A;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.42;
}

.radar-section {
  margin-top: 34rpx;
}

.radar-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.radar-section-title {
  color: #1A202C;
  font-size: 38rpx;
  font-weight: 1000;
  line-height: 1.15;
}

.radar-section-pill {
  min-height: 44rpx;
  padding: 0 18rpx;
  color: #1E4A38;
  background: #E2EBE6;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 44rpx;
}

.radar-timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.timeline-line {
  position: absolute;
  left: 37rpx;
  top: 54rpx;
  bottom: 54rpx;
  width: 3rpx;
  background: #DEE3DD;
}

.timeline-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.timeline-index {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  color: #9AA3AA;
  background: #FFFFFF;
  border: 4rpx solid #DEE3DD;
  border-radius: 999rpx;
  box-shadow: 0 0 0 8rpx #F8F9F7;
  font-size: 30rpx;
  font-weight: 1000;
}

.timeline-index.active {
  color: #FFFFFF;
  background: #1E4A38;
  border-color: #1E4A38;
  box-shadow: 0 0 0 8rpx #F8F9F7, 0 12rpx 24rpx rgba(30, 74, 56, 0.18);
}

.timeline-card {
  flex: 1;
  min-width: 0;
  padding: 26rpx;
  background: #FFFFFF;
  border: 1rpx solid #EDF0EC;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.035);
}

.timeline-card.active {
  border-color: rgba(30, 74, 56, 0.16);
  box-shadow: 0 18rpx 32rpx rgba(30, 74, 56, 0.07);
}

.timeline-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.timeline-title {
  min-width: 0;
  color: #1A202C;
  font-size: 30rpx;
  font-weight: 1000;
  line-height: 1.22;
}

.timeline-meta {
  min-height: 38rpx;
  flex: 0 0 auto;
  padding: 0 14rpx;
  color: #C3483F;
  background: #FFF0EF;
  border-radius: 10rpx;
  font-size: 21rpx;
  font-weight: 950;
  line-height: 38rpx;
}

.timeline-body {
  margin-top: 12rpx;
  color: #68727A;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.5;
}

.timeline-action {
  display: inline-flex;
  min-height: 58rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 0 22rpx;
  color: #1E4A38;
  background: #E2EBE6;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 950;
}

.radar-feedback-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 34rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #EDF0EC;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.035);
}

.feedback-title {
  color: #1A202C;
  font-size: 28rpx;
  font-weight: 1000;
}

.feedback-body,
.feedback-status {
  margin-top: 8rpx;
  color: #68727A;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.42;
}

.feedback-status {
  color: #1E4A38;
  font-weight: 900;
}

.feedback-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 12rpx;
}

.feedback-btn {
  min-width: 76rpx;
  min-height: 62rpx;
  color: #FFFFFF;
  background: #1E4A38;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 950;
}

.feedback-btn.ghost {
  color: #1E4A38;
  background: #F2F7F4;
  border: 1rpx solid #DDE9E2;
}

.growth {
  padding-bottom: 6rpx;
}

.growth-scroll {
  width: 100%;
  margin-top: 24rpx;
}

.growth-row {
  display: inline-flex;
  gap: 22rpx;
  min-width: 100%;
  padding: 0 0 10rpx;
}

.growth-card {
  width: 500rpx;
  min-height: 260rpx;
  padding: 30rpx;
  color: #1A202C;
  background: #FFFFFF;
  border: 1rpx solid #E5E9E4;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.035);
}

.growth-card.active {
  color: #FFFFFF;
  background: #1E4A38;
  border-color: #1E4A38;
  box-shadow: 0 22rpx 46rpx rgba(30, 74, 56, 0.14);
}

.growth-tag {
  display: inline-flex;
  min-height: 42rpx;
  align-items: center;
  padding: 0 16rpx;
  color: #707A83;
  background: #F1F3F1;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 950;
}

.active .growth-tag {
  color: #1E4A38;
  background: #FFFFFF;
}

.growth-title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 1000;
  line-height: 1.22;
}

.growth-body,
.growth-proof {
  margin-top: 12rpx;
  color: #68727A;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.48;
}

.active .growth-body {
  color: rgba(255, 255, 255, 0.78);
}

.growth-proof {
  color: #1E4A38;
  font-weight: 950;
}

.active .growth-proof {
  color: #FFFFFF;
}

.parent-question,
.radar-axis-card {
  margin-top: 24rpx;
  padding: 24rpx;
  color: #1E4A38;
  background: #E2EBE6;
  border: 1rpx solid rgba(30, 74, 56, 0.10);
  border-radius: 28rpx;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1.5;
}

.radar-axis-card {
  color: #1A202C;
  background: #FFFFFF;
  border-color: #EDF0EC;
  box-shadow: 0 12rpx 24rpx rgba(26, 32, 44, 0.035);
}

.axis-title {
  color: #1A202C;
  font-size: 28rpx;
  font-weight: 1000;
}

.axis-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.axis-item {
  color: #4E5962;
  font-size: 24rpx;
  font-weight: 800;
}

.axis-between {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.axis-bar {
  height: 10rpx;
  margin-top: 10rpx;
  overflow: hidden;
  background: #EDF0EC;
  border-radius: 999rpx;
}

.axis-bar-fill {
  height: 100%;
  background: #1E4A38;
  border-radius: 999rpx;
}
